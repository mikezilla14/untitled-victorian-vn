# Compiled scripts
**/*.rpyc
**/*.rpymc

# Automatic backups
**/*.rpyb

# Archive files
**/*.rpa

# Build output / Distribution files
**/*-source/
**/*-dists/
**/*-market/
**/*.exe
**/*.zip
**/*.tar.bz2
**/*.app/
**/*.apk
**/*.ipa
**/*.aab

# Save games
**/saves/*
!**/saves/.keep

# Ren'Py Logs and state
**/log.txt
**/errors.txt
**/traceback.txt
**/renpy_dev.log.*

# Python caches
**/*.pyc
**/*.pyo
__pycache__/

# OS generated files
.DS_Store
.DS_Store?
._*
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
