    {
      "id": "label-8067e527-8427-421c-944b-d6acfb934581",
      "name": "stern_chain_1",
      "x": 100,
      "y": 12275,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "fade",
          "id": "item-fbf1996b-9b9e-4261-8635-09bb2975f246",
          "backgroundId": "bg_savoy_corridor_morning"
        },
        {
          "id": "item-2483a6e2-4e33-4acc-a767-359f58455146",
          "type": "show",
          "characterId": "stern_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "stern_sprite neutral"
        },
        {
          "id": "item-8eaae369-13df-41ac-b4d7-e0252ef203da",
          "type": "dialogue",
          "characterId": null,
          "text": "The west wing linen closet is narrower than a confessional and smells of starch and cold lye."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "7822e9a0-b199-40cc-aafc-fbba11f32695",
              "type": "if",
              "conditionRaw": "time_manager.time_of_day == \"Morning\"",
              "dialogue": [
                {
                  "id": "item-09a96113-60d9-4034-b3f0-2988df18742b",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Outside, the busy morning rush of the second-floor shift carries a muffled, mechanical hum."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "time_manager.time_of_day == \"Morning\""
            },
            {
              "id": "a3bed323-68df-4c34-85c7-5b9ad4d29771",
              "type": "elif",
              "conditionRaw": "time_manager.time_of_day == \"Evening\"",
              "dialogue": [
                {
                  "id": "item-261cb6eb-da48-4000-9bdc-06bae0de52b5",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The gas wall-sconces outside are already unlit, casting long, dim shadows across the threshold."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "time_manager.time_of_day == \"Evening\""
            },
            {
              "id": "9e2ffee9-80a8-44a8-8b5b-d58a3e7e12bb",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-9f93febe-9de1-4d54-8ee4-5fbec0b9304f",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The quiet of the late-night corridor is absolute, making every rustle of cotton sound like a warning."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-178bb2b8-0cde-49c5-99f1-ee0dfec31908"
        },
        {
          "id": "item-a396f529-3d49-4ae6-a78e-5e886536801b",
          "type": "dialogue",
          "characterId": null,
          "text": "Miss Stern stands inside, her keys clutched in her hand like a small iron crop."
        },
        {
          "id": "item-ad90c735-a06e-4823-ba8a-59b7ead5d084",
          "type": "dialogue",
          "characterId": null,
          "text": "Her eyes move from my collar to the folded sheets, measuring the precision of my service."
        },
        {
          "id": "item-15c07709-a290-4d9a-8018-e508d450ddd9",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "Cora. The sheets for suite 402. Did you fold them with the lock-stitch hem outward, or did you simply tumble them in the country fashion?"
        },
        {
          "type": "choice",
          "options": [
            {
              "id": "996d4875-fb4e-42a2-bc5d-71ec158b7766",
              "text": "Lower my head and act like a simple, stupid country girl. [[Shed Suspicion / Break Chain]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"creative\", intensity=\"standard\")",
                  "id": "item-982faa82-c35f-434e-b1c4-9b48cf3e4331"
                },
                {
                  "type": "python_script",
                  "code": "apply_effects(stern_susp=-10)",
                  "id": "item-636ea526-c2cc-477a-96d7-55faf8cd3a2f"
                },
                {
                  "type": "python_script",
                  "code": "story.complete_chain_beat(\"stern\")",
                  "id": "item-20692250-dfd5-47b4-b2ae-67dbfa7f8591"
                },
                {
                  "id": "item-1593f12f-d65a-4735-843b-6281da685d2c",
                  "type": "show",
                  "characterId": "cora_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "None",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "cora_sprite base"
                },
                {
                  "id": "item-8cb5d5c1-330a-4974-8836-43de34eb07cf",
                  "type": "show",
                  "characterId": "stern_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "move",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "stern_sprite neutral"
                },
                {
                  "id": "item-e7720ae1-c9b7-4a48-99a7-ea619b0ea3cb",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "Outward, Ma'am. Missy showed me, and I made sure to repeat it exactly so as not to offend."
                },
                {
                  "id": "item-9f2c2a9d-88b7-49ff-9945-04d86c52b098",
                  "type": "dialogue",
                  "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
                  "text": "Exactly is a large word for a small mind. Keep to that simple standard, Cora, and the Strand will remain a distant worry."
                },
                {
                  "id": "item-59091821-3d67-404e-9cac-46c888819d46",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She dismisses me with a slight twitch of her chin."
                },
                {
                  "id": "item-213a4dc0-9062-49dd-ac42-4ebfa1d720be",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "My safety costs nothing but my pride. The door to her private ledger is shut."
                }
              ]
            },
            {
              "id": "572a602c-46ec-4f4c-9359-f1607c49c571",
              "text": "Explain the geometry of the fold, meeting her gaze. [[Lean Into Tension / Progress Chain]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"curious\", intensity=\"standard\", witness=\"stern\")",
                  "id": "item-3df841cf-1e1b-4e48-81c4-1c1ab2870bda"
                },
                {
                  "type": "python_script",
                  "code": "story.complete_chain_beat(\"stern\")",
                  "id": "item-969ed1dc-31bd-4731-9b90-ea3b5f63f60b"
                },
                {
                  "id": "item-401752c7-5a16-425d-8eb3-fed2b0cd5bd5",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "The outward stitch preserves the line of the silk, Ma'am. It prevents friction against the mahogany frame, keeping the fabric warm to the touch."
                },
                {
                  "id": "item-bb8faa8d-9cdb-43f6-97b7-6e0d7e70af51",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Miss Stern goes still."
                },
                {
                  "id": "item-2e8ab864-9d37-4967-99f4-0785e1a7a7d2",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Her chest rises once, her keys clicking softly in the quiet cupboard."
                },
                {
                  "id": "item-0a3d39cd-c998-4107-a97e-e63a962d239f",
                  "type": "dialogue",
                  "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
                  "text": "Touch? A girl who knows the grain of the guest's bed is a girl who spends too much time looking at what does not belong to her."
                },
                {
                  "id": "item-ecdea6cc-96c2-449d-8bcc-d10faa84e278",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She steps closer. The heavy, warm scent of wool and lavender soap surrounds me."
                },
                {
                  "id": "item-8f77a46f-947b-43d4-beed-a1264ea00492",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Slowly, she raises the cold iron ring of her keys, placing the flat metal against the side of my neck to correct my posture, forcing my chin upward."
                },
                {
                  "id": "item-a326b844-eab1-43aa-b788-485190e64d9b",
                  "type": "dialogue",
                  "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
                  "text": "Keep that chin high, Cora Vale. But do not let me find you looking down at the silk again."
                },
                {
                  "id": "item-7a56aa76-7df1-42e4-9ec2-e62678b2103b",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Her touch is brief, cold, and utterly improper."
                },
                {
                  "id": "item-57f66d76-f71a-41ba-89ac-3e6e59f1697e",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I have shown too much edge, and she has marked the place where it sits."
                }
              ]
            }
          ],
          "id": "item-016f382f-1a77-4c83-9268-8f4c26dd1b55"
        },
        {
          "type": "hide",
          "layer": null,
          "id": "item-0a6448db-1b46-4296-b563-80bb3dcbbac3",
          "characterId": "stern_sprite"
        }
      ]
    },
    {
      "id": "label-46b7e8c9-812c-4dd3-bbef-c29990ef4345",
      "name": "stern_chain_2",
      "x": 100,
      "y": 12405,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "fade",
          "id": "item-85af7c76-6b09-42a2-9605-d352060cb94d",
          "backgroundId": "bg_servants_quarters_dusk"
        },
        {
          "id": "item-fcc0a998-9fb8-47d4-b9c6-afe09f6c18b4",
          "type": "show",
          "characterId": "stern_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "stern_sprite neutral"
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "0bf35dd2-a18b-4a14-b121-74a7b7b60744",
              "type": "if",
              "conditionRaw": "time_manager.time_of_day == \"Evening\"",
              "dialogue": [
                {
                  "id": "item-abad329f-52f9-4b5f-a881-792853792417",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The servants' quarters are thick with the grey London twilight, the copper steam pipes muttering behind the wall."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "time_manager.time_of_day == \"Evening\""
            },
            {
              "id": "4ac81cc9-c20f-4455-a136-798d6349c35b",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-22bc7205-5ee1-4752-a57a-f3d6b34111dc",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "A cold late-night draft rattles the small windowpane, casting flickering candle-shadows across the narrow floor."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-15fd82fd-d897-498c-9dae-bf41c08129b8"
        },
        {
          "id": "item-ccac74a2-7c61-4d2c-99b0-5810fb54f4ac",
          "type": "dialogue",
          "characterId": null,
          "text": "I am resting on the edge of the narrow bed when the door handles jiggles. Miss Stern enters before the latch can sound."
        },
        {
          "id": "item-bf6df98b-c098-413f-ab7f-3311609553da",
          "type": "dialogue",
          "characterId": null,
          "text": "I scramble to slide the cheap notebook under my uniform apron, but her hand descends."
        },
        {
          "id": "item-ee425de4-d998-45f7-987a-0269faf3a265",
          "type": "dialogue",
          "characterId": null,
          "text": "She does not snatch it. She merely presses her thumb onto the leather cover, keeping it pinned against my lap."
        },
        {
          "id": "item-cd168862-38ff-44e3-9924-c7566d602129",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "A ledger of kitchen weights, Cora? Or does a chambermaid believe she has thoughts worth preserving in ink?"
        },
        {
          "type": "choice",
          "options": [
            {
              "id": "24f67bcb-0e4c-4082-b5cf-cdc5f297faed",
              "text": "Apologize and call it a spelling exercise. [[Shed Suspicion / Break Chain]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"creative\", intensity=\"standard\")",
                  "id": "item-02be5ef5-6567-40c7-87ab-42c7819dc513"
                },
                {
                  "type": "python_script",
                  "code": "apply_effects(stern_susp=-10)",
                  "id": "item-b786b972-16f2-41de-afa8-62d4e00d80b0"
                },
                {
                  "type": "python_script",
                  "code": "story.complete_chain_beat(\"stern\")",
                  "id": "item-532a5a69-fe48-4844-b1bc-fa315c5a5ba0"
                },
                {
                  "id": "item-ddead406-7bc9-46b1-99d5-7afe7adfe39a",
                  "type": "show",
                  "characterId": "cora_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "None",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "cora_sprite base"
                },
                {
                  "id": "item-8b056196-0c61-43e6-b5f2-94027c9b8987",
                  "type": "show",
                  "characterId": "stern_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "move",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "stern_sprite neutral"
                },
                {
                  "id": "item-5172c78c-c2d4-4ba5-b33a-6ea84481678b",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "Only my letters, Ma'am. My mother said a maid who cannot spell the inventory is of no use to a fine house."
                },
                {
                  "id": "item-05909903-28c0-4923-b3a5-ef97151ad3e8",
                  "type": "dialogue",
                  "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
                  "text": "Your mother was sensible. Keep to spelling 'apron' and 'lye', Cora. Leave the long words to those who do not have to wash them."
                },
                {
                  "id": "item-d0b39c35-5f9d-4b2d-a0c8-1ed4e37beaf8",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She draws her hand back and leaves. The notebook is safe, but the ink in my veins feels cold."
                }
              ]
            },
            {
              "id": "227ee5d8-7b99-4a0e-a2cf-0460aacedb2d",
              "text": "Hold the notebook tight. Read her a scandalous anonymous passage. [[Progress Chain]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"curious\", intensity=\"standard\", witness=\"stern\")",
                  "id": "item-d714794d-91ce-4bfc-9dbc-e41206711396"
                },
                {
                  "type": "python_script",
                  "code": "story.complete_chain_beat(\"stern\")",
                  "id": "item-74254c83-5765-4c8a-b467-f97fddd1d012"
                },
                {
                  "id": "item-45859d15-4f45-47ee-b483-595b6e24c783",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "I was writing about the west corridor, Ma'am."
                },
                {
                  "id": "item-a9e9c20a-877b-4734-b9d9-97106d38c743",
                  "type": "dialogue",
                  "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
                  "text": "Speak plainly, girl."
                },
                {
                  "id": "item-d252509d-1e69-47da-98c9-2a252387b273",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "I wrote: 'The warden of the floor has a voice like iron, but her keys shake when she touches the maid's collar. She has a secret appetite for the dust she pretends to clean.'"
                },
                {
                  "id": "item-e183d879-fa04-482d-89cb-450866f08844",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Miss Stern's keys slip from her fingers, striking the floor with a bright, silver clatter."
                },
                {
                  "id": "item-c385ed01-28d9-4d4a-82f0-862846982637",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She does not bend to retrieve them."
                },
                {
                  "id": "item-4d6f28f0-0bd0-49c5-bdcc-cbb7e8345cb8",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Instead, she steps forward, pinning me flat against the small wooden desk."
                },
                {
                  "id": "item-d06bf8cb-5ba7-4a7a-bb8e-bfd8b999aeda",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Her breathing is ragged, her face inches from mine, her fingers sliding beneath my coarse uniform apron to press directly against my corset, checking my pulse."
                },
                {
                  "id": "item-355cb417-27e1-4ed3-b096-42a74204821a",
                  "type": "dialogue",
                  "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
                  "text": "You are a monstrous creature, Cora Vale. A thief who steals the thoughts of her betters."
                },
                {
                  "id": "item-4794dd6f-0257-4055-8373-32a705aba4f0",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "Is it theft if it is true, Ma'am?"
                },
                {
                  "id": "item-a966ca4a-68e9-4f19-a253-8d7c89a09391",
                  "type": "dialogue",
                  "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
                  "text": "If I find this notebook again... I will burn it. And then I will write a reference for you that will make the Strand look inviting."
                },
                {
                  "id": "item-ac119a9c-02c2-4dd3-8e72-c23efdd9daa6",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Her hand remains pressed against my chest for one second longer than warning requires."
                },
                {
                  "id": "item-28006692-f8b8-4999-bb4f-0c2df656a960",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Her touch is hot, trembling, and full of dread."
                },
                {
                  "id": "item-740769ef-5cfa-4ce0-8f87-75b2ecd929c2",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She leaves me with a threat that reads exactly like an invitation."
                }
              ]
            }
          ],
          "id": "item-e9dd1a9d-e1c3-4989-b733-beb80c2ce0aa"
        },
        {
          "type": "hide",
          "layer": null,
          "id": "item-43382871-866e-4473-9b51-8f5ca43a1633",
          "characterId": "stern_sprite"
        }
      ]
    },
    {
      "id": "label-fc4759d5-7b9d-4633-9c1d-b9329af91a0d",
      "name": "stern_chain_3",
      "x": 100,
      "y": 12535,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "fade",
          "id": "item-0a094ff1-026d-4762-b2dd-426447f10d0e",
          "backgroundId": "bg_master_suite_day"
        },
        {
          "id": "item-6b38185c-d6e0-48a5-86ce-0dbff62f14d4",
          "type": "show",
          "characterId": "stern_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "stern_sprite neutral"
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "1b6e8d5b-23a1-4e78-be16-a0f5f2e4d3e4",
              "type": "if",
              "conditionRaw": "time_manager.time_of_day == \"Afternoon\"",
              "dialogue": [
                {
                  "id": "item-59e14c50-8af0-4a04-b47d-2e12b56bcef2",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The afternoon sun filters through the velvet drapes of the vacant Master Suite, casting a dusty, golden glare across the carpet."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "time_manager.time_of_day == \"Afternoon\""
            },
            {
              "id": "69cad65f-ec47-4e8a-ba92-acfa50bbe797",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-1e65a071-c40f-4a22-a1d5-9e14c4466320",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The evening drapes are drawn tight, the electric wall-sconces deactivated; only a single wax candle burns on the dressing table."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-1f508639-5f5b-4380-8f62-b949e4adafa9"
        },
        {
          "id": "item-b76d6234-cb16-40cc-9d80-d576eb4d8308",
          "type": "dialogue",
          "characterId": null,
          "text": "Miss Stern stands beside the vanity. She has pulled out a drawer and dumped its contents onto the floor: a dry rose, banker's stubs, and three scraps of paper."
        },
        {
          "id": "item-2411ca89-32f2-4861-9347-83941b78d2ea",
          "type": "dialogue",
          "characterId": null,
          "text": "Her keys hang from her belt, clicking as she turns her head to study me."
        },
        {
          "id": "item-a4bebab7-4e5d-4e54-984e-7e1251790678",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "A guest leaves many things. The young maid sees them as souvenirs. I see them as evidence of character."
        },
        {
          "id": "item-72bf6dba-d76a-48b9-bf07-6f9c32210661",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "Tell me, Cora. What do you see?"
        },
        {
          "type": "choice",
          "options": [
            {
              "id": "9b330f58-8a56-40f3-84a5-7e5fe26bdc4c",
              "text": "Play the blind servant, turning away from her gaze. [[Shed Suspicion / Lost Opportunity: Safe option, but you lose this climax forever.]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"creative\", intensity=\"standard\")",
                  "id": "item-981dc9f9-efb2-4adc-a058-cd020562a18b"
                },
                {
                  "type": "python_script",
                  "code": "apply_effects(stern_susp=-15)",
                  "id": "item-f53cf43c-10bd-4a7c-8943-00a1b5892483"
                },
                {
                  "type": "python_script",
                  "code": "story.complete_chain_beat(\"stern\")",
                  "id": "item-eac246be-1ae5-4ebb-994e-5d08d7256d69"
                },
                {
                  "id": "item-624efd5a-d01c-48c8-b0ff-01d895c72aae",
                  "type": "show",
                  "characterId": "cora_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "None",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "cora_sprite base"
                },
                {
                  "id": "item-3b12e4e5-d75c-4f01-9b33-78b304621781",
                  "type": "show",
                  "characterId": "stern_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "move",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "stern_sprite neutral"
                },
                {
                  "id": "item-888bb798-bdeb-44d1-b408-a7ae0c553286",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "Dust, Ma'am. And scraps that should have been swept before the second floor shift."
                },
                {
                  "id": "item-4398baa2-4d11-4684-83aa-9980dc97c06a",
                  "type": "dialogue",
                  "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
                  "text": "Correct. A drawer is a box for linens, not a confessional."
                },
                {
                  "id": "item-1a026df7-b816-48de-8b7b-d877a3d2d3aa",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She nods, satisfied with my simple maid's mask."
                },
                {
                  "id": "item-6c763cff-f469-4336-acac-330c32f87df6",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I remain a ghost in her hotel, safe but starved for the book's ending. The fire between us is extinguished, never to be rekindled."
                }
              ]
            },
            {
              "id": "fde5e84d-286d-4b4c-a732-14883de76028",
              "text": "Seize the one-time opportunity: Step into her space and audit the stubs. [[Climax: 2.2 Spice. Spikes Suspicion (+25) and Corruption (+20), raising Anxiety. Requires: Anxiety < 75 and Stern Suspicion < 80]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"transgressive\", intensity=\"standard\", witness=\"stern\")",
                  "id": "item-841cddc8-569d-4e37-97a1-5a97582fb35f"
                },
                {
                  "type": "python_script",
                  "code": "story.complete_chain_beat(\"stern\")",
                  "id": "item-ad0da443-584f-4acd-8d44-6e68d44c71de"
                },
                {
                  "id": "item-3f38e857-20b9-407b-ae6b-32ef71ee25d2",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "I see a banker's draft stub, Ma'am. And a dry rose from a florist on the Strand that closed last month."
                },
                {
                  "id": "item-b81ca074-64d8-4efb-86d0-ed2cee0c2c15",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "The guest was spending money he did not yet have, on a woman who did not want to wait for it."
                },
                {
                  "id": "item-76a27198-e9ef-46e9-969a-043d3ddcc9b3",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Miss Stern turns on me so quickly the hem of her heavy black wool dress brushes my boots."
                },
                {
                  "id": "item-af02e59a-8a9f-4ae2-937b-154e9eba2efa",
                  "type": "dialogue",
                  "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
                  "text": "Enough!"
                },
                {
                  "id": "item-f36e0168-fd73-4b13-88e0-74f7d77b447c",
                  "type": "dialogue",
                  "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
                  "text": "Your cleverness is a disease, Cora. You look through the guests' pockets with your eyes."
                },
                {
                  "id": "item-9dc6a90a-e9aa-423d-93bc-e8e10eb56fed",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She grabs me by the wrists. Her grip is iron-tight, pulling my arms behind my back and forcing me down onto my knees on the thick pile of the Savoy carpet before the vanity."
                },
                {
                  "id": "item-d48d3112-1e24-4fdc-81d7-1d94b9223f2d",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Her face is flushed, her neat lace cap slipping slightly askew from the sudden exertion. Her breath comes hot against my face as she leans down, her chest pressing against my shoulder."
                },
                {
                  "id": "item-e1537636-30a9-48e6-a518-270cdff98d27",
                  "type": "dialogue",
                  "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
                  "text": "Since you are so fond of this floor, you will remain here. On your knees. I will inspect your uniform's inner seams to ensure you have stolen nothing else."
                },
                {
                  "id": "item-e8aea5fd-9f3d-477c-b116-a762c98407cb",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She bends over me, her hands tracing the coarse cotton of my skirt. Slowly, her fingers slide beneath the heavy apron, reaching the rear laces of my corset and unhooking the hem to check the hidden linings."
                },
                {
                  "id": "item-ef4f0870-7bb4-46bd-9cf1-a89ab8d48fdf",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Her fingers are warm, lingering against my bare thighs above my stockings under the guise of an audit. The heat of her hand makes my skin shiver, every brush of her fingertips sending a sharp, sweet jolt of dread and desire through my spine."
                },
                {
                  "id": "item-abd0dc86-0b57-45fb-8164-fdb89dd9e0bf",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I tremble, my chest pressing hard against the vanity drawer, the scent of lavender and starch thick in my throat."
                },
                {
                  "id": "item-07dfbdf3-9d89-40eb-b424-1f269861d68d",
                  "type": "dialogue",
                  "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
                  "text": "A maid who cannot be trusted must be thoroughly occupied, Cora Vale."
                },
                {
                  "id": "item-298cc0d5-741b-448d-afcd-846fc284504f",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Her fingers slide higher, tracing the curve of my hip with a slow, deliberate pressure that has nothing to do with housekeeping."
                },
                {
                  "id": "item-106aa1ad-4d10-432e-b19c-bf1375426fa2",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I let out a soft gasp, my head falling back against her shoulder, feeling the rapid beat of her heart behind her starch collar."
                },
                {
                  "id": "item-b1287c7c-f231-4d7d-914b-d80407c93731",
                  "type": "dialogue",
                  "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
                  "text": "Do not move, Cora. If you speak a word of this... if you breathe..."
                },
                {
                  "id": "item-75ba22d7-86f1-4df0-8fe4-c3351d22eed2",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She leaves me flushed, breathing heavily, and ruined on the floor."
                },
                {
                  "id": "item-5c5105a2-5b95-4b2d-83ce-7c48919e007c",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The raw material I have gathered is pure fire, but my name is now safely written in her private book."
                }
              ]
            },
            {
              "id": "ab33819f-66db-41c0-a8a0-8dae1e73c825",
              "text": "Seize the one-time opportunity... [[Locked: Anxiety too high (>= 75) or Suspicion too high (>= 80). Choosing this would trigger an immediate breakdown or public dismissal.]]",
              "dialogue": [
                {
                  "id": "item-fb7e45b5-2d53-442f-8b43-351bed9ac914",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "You cannot press further. Your hands shake too violently from your frayed nerves (Anxiety: [player.anxiety]/75), and the dread of Miss Stern's iron keys is a physical barrier. To push her now, when she already watches your every step with deep mistrust (Stern Suspicion: [player.stern_suspicion]/80), would invite an immediate breakdown or public dismissal."
                }
              ]
            }
          ],
          "id": "item-2168a695-605a-4bad-afbb-96c262c26f5d"
        },
        {
          "type": "hide",
          "layer": null,
          "id": "item-423cc362-0f53-4c67-ac70-666d2667b821",
          "characterId": "stern_sprite"
        }
      ]
    },
    {
      "id": "label-3e8a4ec8-6a13-4f31-8268-e1521f435ebf",
      "name": "missy_chain_1",
      "x": 100,
      "y": 12665,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "fade",
          "id": "item-48637dc6-addc-4d1b-a015-7af022f882c3",
          "backgroundId": "bg_laundry_room_day"
        },
        {
          "id": "item-c984f720-cc95-41dc-add6-a958dd394d06",
          "type": "show",
          "characterId": "missy_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "missy_sprite smiling"
        },
        {
          "id": "item-68928fa8-f85f-466c-8b52-96741f90564e",
          "type": "dialogue",
          "characterId": null,
          "text": "The laundry room is a thick, humid fog of lye and boiling starch."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "a6dceec4-525c-4e98-93c0-f55a3d47ca4e",
              "type": "if",
              "conditionRaw": "time_manager.time_of_day == \"Morning\"",
              "dialogue": [
                {
                  "id": "item-3071bc30-ea59-4b46-b166-2d9713701a54",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The copper boilers are shrieking under full morning pressure, turning every face soft at the edges."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "time_manager.time_of_day == \"Morning\""
            },
            {
              "id": "a8d34498-1530-4e9f-b318-0083db52cfea",
              "type": "elif",
              "conditionRaw": "time_manager.time_of_day == \"Afternoon\"",
              "dialogue": [
                {
                  "id": "item-af352a1f-5a09-45f7-b8c3-9d37d36b250e",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The afternoon heat is suffocating, steam dripping down the grey slate walls like grease."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "time_manager.time_of_day == \"Afternoon\""
            },
            {
              "id": "fce7c3ff-03d2-42e7-8c9a-9e8b6e66353f",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-077e7940-a200-4f88-b984-5e714b488656",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The late-night tubs are cooling, the quiet hum of the boilers sounding like a sleeping beast."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-bad7a4ef-d1e3-493c-9ec1-c39ef7b9e28c"
        },
        {
          "id": "item-8fb9d26d-8b2a-4e7a-9d8c-3fbf9fbc719c",
          "type": "dialogue",
          "characterId": null,
          "text": "Missy is sitting on a wicker laundry hamper, her fingers red and raw from the coarse soap."
        },
        {
          "id": "item-246db37b-22a2-4dcf-9efa-4af6a75b4fb2",
          "type": "dialogue",
          "characterId": null,
          "text": "A torn lace collar lies in her lap, and she is trying to sew it with trembling hands."
        },
        {
          "id": "item-a42e6435-317b-4c80-8783-69e51cb2b8f9",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "If Miss Stern sees this tear, she'll dock my pay three shillings. It was that gentleman in room 301. He threw his boots at the door while I was changing the wash-water. He has no right, Cora. None at all."
        },
        {
          "type": "choice",
          "options": [
            {
              "id": "8a663bca-d612-4de3-8b86-06fe18d644d9",
              "text": "Help her stitch it silently. Comfort her. [[Shed Suspicion / Break Chain]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"creative\", intensity=\"standard\")",
                  "id": "item-e7d93942-9cba-4e0e-a960-733684ae70eb"
                },
                {
                  "type": "python_script",
                  "code": "apply_effects(missy_susp=-10)",
                  "id": "item-86943672-8762-4bda-b20b-1c1e0a88c888"
                },
                {
                  "type": "python_script",
                  "code": "story.complete_chain_beat(\"missy\")",
                  "id": "item-ae747067-292e-463a-ac50-84ef6b79714b"
                },
                {
                  "id": "item-87ce308c-e5e1-41ca-b597-82bedd891eed",
                  "type": "show",
                  "characterId": "cora_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "None",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "cora_sprite base"
                },
                {
                  "id": "item-bcf9c2a5-de3c-4f04-9c3c-37c49512275e",
                  "type": "show",
                  "characterId": "missy_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "move",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "missy_sprite smiling"
                },
                {
                  "id": "item-63dcade2-23ac-4325-b530-ae9436b490e4",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "Give it here. My mother taught me the French seam. It hides the raw edge completely, so even Stern's glass won't find it."
                },
                {
                  "id": "item-2d037391-e856-4a8b-9008-bd3577d6a6b3",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I take the needle. We sit together on the wicker hamper, our shoulders touching in the warm steam."
                },
                {
                  "id": "item-fa4f347e-43e8-48f7-98a2-10bee79003fc",
                  "type": "dialogue",
                  "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
                  "text": "You're a good friend, Cora. Most girls here would have carried the tale to Miss Stern to get the credit."
                },
                {
                  "id": "item-cdad8a3c-f1d8-4cce-9c11-64b4cd92e6cd",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Her trust feels heavy. But it keeps my cover secure."
                }
              ]
            },
            {
              "id": "8c33c7fb-532e-417e-8f72-8de4ba0fa028",
              "text": "Stroke her cheek, questioning her with tender, quiet romance. [[Progress Chain]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"curious\", intensity=\"standard\", witness=\"missy\")",
                  "id": "item-74158ecc-488b-4914-b853-34d15dd888ed"
                },
                {
                  "type": "python_script",
                  "code": "story.complete_chain_beat(\"missy\")",
                  "id": "item-33e225d0-5232-41db-a8ca-c4ccb20a1f2d"
                },
                {
                  "id": "item-8c0e9a5d-8e2c-4dcc-b258-2d4f110691a8",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "You shouldn't have to bear his cruelty, Missy. Was it the wine, or is he always that monstrous when the door is closed?"
                },
                {
                  "id": "item-1802286a-2bb6-43ef-a656-c38dceb7f4d4",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I reach out, my fingers tracing the damp, flushed skin of her cheek, brushing a wet curl of hair behind her ear with lingering, safe tenderness."
                },
                {
                  "id": "item-d3fb8bf5-6e85-4289-ab27-48e25960cf33",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Missy flinches, her breath catching, but she does not retreat. Her defensive moral shield falters under the unexpected warmth."
                },
                {
                  "id": "item-0f1bb1c1-f31a-44d2-99c7-60784af0f488",
                  "type": "dialogue",
                  "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
                  "text": "Cora... your hands are so soft. Not like mine. You don't belong over the lye-tubs."
                },
                {
                  "id": "item-80a9e609-be69-4bec-b190-8a36c8cf4d58",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "We belong where we can protect each other, Missy."
                },
                {
                  "id": "item-6defd28c-3c2f-4a6f-bdd5-a74b4281ff3f",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She looks up, her eyes wide, quiet, and exceptionally focused in the steam."
                },
                {
                  "id": "item-968d32f9-aa30-462c-84b2-7729da4a5b9a",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I have treated her pain with tenderness, and the physical heat between us has become real, rooted in the beginning of trust."
                }
              ]
            }
          ],
          "id": "item-fe08e535-6c72-4db6-bf3f-e7ae5eee1325"
        },
        {
          "type": "hide",
          "layer": null,
          "id": "item-07120d24-0776-4133-a2b9-f26b0fe5f52d",
          "characterId": "missy_sprite"
        }
      ]
    },
    {
      "id": "label-c13386bb-2763-418b-9420-2dcddaf91e39",
      "name": "missy_chain_2",
      "x": 100,
      "y": 12795,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "fade",
          "id": "item-e4b1e927-a5a2-44fb-adc1-b0fecbc8b69e",
          "backgroundId": "bg_servants_corridor_dim"
        },
        {
          "id": "item-7e674aeb-737e-49d2-b2f7-992d3e404625",
          "type": "show",
          "characterId": "missy_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "missy_sprite neutral"
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "806a6602-ee68-40bd-bc60-a1857179dd84",
              "type": "if",
              "conditionRaw": "time_manager.time_of_day == \"Evening\"",
              "dialogue": [
                {
                  "id": "item-562a1587-5ece-423c-83b3-b38a6495dcb8",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The corridor gas jets are turned low, casting long, dark shadows along the service lift."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "time_manager.time_of_day == \"Evening\""
            },
            {
              "id": "e5413ed5-81eb-4bd9-9cc1-d492a828aaee",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-146f9a41-4a1f-47a6-889a-31f5bb92fab2",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The late-night quarters are silent, the faint sound of footsteps echoing on the stairs above."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-394a4374-0214-460a-836c-c4ec6cbf842e"
        },
        {
          "id": "item-ff4089a7-bbe6-4f22-bdd9-ee59eddce697",
          "type": "dialogue",
          "characterId": null,
          "text": "Missy leans in close, her breath smelling faintly of lye and the peppermint she keeps to mask it."
        },
        {
          "id": "item-27191e6b-a08b-4016-b280-dd3c0f852e93",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "I saw Mr. Locke's valet carrying a leather case down the back stairs. It had brass hinges and a double lock."
        },
        {
          "id": "item-b4084dfd-a051-4780-8f3f-69736ff1af15",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "He looked at me like he wanted to choke me for being there. They hide things, Cora. Terrible things."
        },
        {
          "id": "item-cc8c65ea-4dc5-4b18-983b-272cf587e64d",
          "type": "dialogue",
          "characterId": null,
          "text": "Suddenly, heavy footsteps echo at the end of the hall. The shadow of Miss Stern's keys appears on the wall."
        },
        {
          "id": "item-ae3d252b-f454-4640-821c-64b85961b714",
          "type": "dialogue",
          "characterId": null,
          "text": "Before I can think, I grab Missy by the wrist and drag her into the narrow cedar broom closet, closing the door behind us into pitch blackness."
        },
        {
          "type": "choice",
          "options": [
            {
              "id": "e4eafdc3-5f5c-44b7-815c-f1a7dbf3e310",
              "text": "Tell her to keep quiet for her own safety. [[Shed Suspicion / Break Chain]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"creative\", intensity=\"standard\")",
                  "id": "item-0ba6950c-826f-48bb-ae34-d7eb871de1e5"
                },
                {
                  "type": "python_script",
                  "code": "apply_effects(missy_susp=-15)",
                  "id": "item-0c8aef50-690c-4baf-b34b-10dfbd0cd2c8"
                },
                {
                  "type": "python_script",
                  "code": "story.complete_chain_beat(\"missy\")",
                  "id": "item-65e6d9b3-f2c0-4f67-8158-c1e0e2d95d4e"
                },
                {
                  "id": "item-7c6855bd-eae0-446a-8a3f-c10266a14e35",
                  "type": "show",
                  "characterId": "cora_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "None",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "cora_sprite base"
                },
                {
                  "id": "item-d5828893-33f1-4e0f-ab43-8b2046bbd437",
                  "type": "show",
                  "characterId": "missy_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "move",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "missy_sprite neutral"
                },
                {
                  "id": "item-09eedc46-bf16-4e91-82b4-ec1e3a23ab4c",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "Don't look at it again, Missy. Valets keep secrets because they are paid to. We are paid only to wash the sheets."
                },
                {
                  "id": "item-0536e93e-e4a7-49e3-931b-38f33a590218",
                  "type": "dialogue",
                  "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
                  "text": "You're right. I'll forget I ever saw it. God keep us quiet."
                },
                {
                  "id": "item-bd7ec89c-7932-4cbc-92a4-ab7161992693",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She smiles, relieved by my caution. The secret stays safe."
                }
              ]
            },
            {
              "id": "eae02786-5b2a-49c3-9f33-41434d49b0be",
              "text": "Press her chest-to-chest in the dark, whispering with sensual agency. [[Progress Chain]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"curious\", intensity=\"standard\", witness=\"missy\")",
                  "id": "item-4ba461d3-45cc-4861-97a2-4660ff6f91c9"
                },
                {
                  "type": "python_script",
                  "code": "story.complete_chain_beat(\"missy\")",
                  "id": "item-dcb51d18-f962-46fe-b302-2cc0286d427e"
                },
                {
                  "id": "item-77999466-a910-401f-889c-b7e409d9012f",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The broom closet is tiny, smelling of cedar oil and damp aprons."
                },
                {
                  "id": "item-612c5192-e655-43ee-8e96-194802e02bb4",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "We are pressed chest-to-chest, our breathing echoing in the small enclosure."
                },
                {
                  "id": "item-c930e60d-9d4e-4a13-b351-7791d45d4831",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I slide my hand over Missy's narrow waist to steady her, my fingers sinking into the soft cloth of her corset."
                },
                {
                  "id": "item-0bdd3061-4cc1-4d3c-9816-69294550464d",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Missy does not pull away. In the dark, her face is inches from mine, her lips parted, her eyes reflecting the sliver of gas-lamp light under the door."
                },
                {
                  "id": "item-232dda7b-dde3-442b-9a59-a4101dd8e725",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "Double locks? Was it a Chubb patent?"
                },
                {
                  "id": "item-2da90941-5b6a-4007-b57d-33f87db23896",
                  "type": "dialogue",
                  "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
                  "text": "Cora... please. We are too close. If Miss Stern opens this door..."
                },
                {
                  "id": "item-f6e7cccf-6b41-48c2-98a0-fdd813d90c8b",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "Then let her find us. Your skin is too warm for locks, Missy."
                },
                {
                  "id": "item-c624bf51-e328-460a-9d07-57087afbfc7b",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Missy gasps softly, her hands clutching my shoulders, her chest rising against mine as she actively chooses to lean into the touch."
                },
                {
                  "id": "item-827eb868-bda6-4a03-88e8-0ff463b3f427",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The social danger of Miss Stern's keys outside becomes the structural frame that heightens our physical proximity."
                },
                {
                  "id": "item-fbc29ca9-960b-425f-94e4-dc8c3e0f1c9c",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "We are not prying; we are catching fire in the dark, and her yield is a conscious, sovereign choice."
                }
              ]
            }
          ],
          "id": "item-cd312181-3c3f-46c5-9224-292741258184"
        },
        {
          "type": "hide",
          "layer": null,
          "id": "item-b8eb36d7-e296-4784-9006-246532ebbdd2",
          "characterId": "missy_sprite"
        }
      ]
    },
    {
      "id": "label-640d76db-3f05-45f7-9d73-394853354c27",
      "name": "missy_chain_3",
      "x": 100,
      "y": 12925,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "fade",
          "id": "item-b101d56a-3e1a-4a48-8432-0d539c21ab65",
          "backgroundId": "bg_laundry_room_day"
        },
        {
          "id": "item-df49b171-b5c8-492e-aca4-dd5c61f08155",
          "type": "show",
          "characterId": "missy_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "missy_sprite shocked"
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "34b59ad2-254b-4774-a23a-8b976100e05f",
              "type": "if",
              "conditionRaw": "time_manager.time_of_day == \"Afternoon\"",
              "dialogue": [
                {
                  "id": "item-8e541692-dad6-46ff-8748-69d2f0db826d",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The laundry boilers are silent, the late-afternoon steam settling in damp layers over the floor."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "time_manager.time_of_day == \"Afternoon\""
            },
            {
              "id": "80399b72-7f46-4a21-8504-6fb22bccde49",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-076b472f-5cac-4521-809c-3902e6ff3654",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The late-night laundry is completely vacant, the only light coming from the red embers of the boiler furnace."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-cf62b5fa-be81-4cd1-8c5b-57590aee0de8"
        },
        {
          "id": "item-3494f7eb-6c8a-468e-9d95-96f16b3b5051",
          "type": "dialogue",
          "characterId": null,
          "text": "Missy stops me near the wash-tubs, holding a discarded scrap of my manuscript."
        },
        {
          "id": "item-502c37cd-ddd9-4e1c-9519-3d4eafad97dd",
          "type": "dialogue",
          "characterId": null,
          "text": "Her face is pale under the electric light, her fingers shaking."
        },
        {
          "id": "item-739cf38b-b780-4cfa-abae-9c9266a1564a",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "Is this... me, Cora? 'The laundry girl with raw fingers who believed every promise she found in a pocket'?"
        },
        {
          "id": "item-bb02ade9-2c99-4a1f-af73-d5c838ebac6b",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "Did you write this? Have you been prying into my soul to make a story?"
        },
        {
          "type": "choice",
          "options": [
            {
              "id": "251fde44-3078-42f0-9522-d32616c48e23",
              "text": "Tear the page and beg her forgiveness. [[Shed Suspicion / Lost Opportunity: Safe option, but you lose this climax forever.]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"creative\", intensity=\"standard\")",
                  "id": "item-8868e726-7b7c-4703-bca8-24af55c770cf"
                },
                {
                  "type": "python_script",
                  "code": "apply_effects(missy_susp=-20)",
                  "id": "item-d5521ec3-572e-4ac8-8205-df4e8490c887"
                },
                {
                  "type": "python_script",
                  "code": "story.complete_chain_beat(\"missy\")",
                  "id": "item-d65f0299-b19d-4cae-ae04-8d261e19419c"
                },
                {
                  "id": "item-26443182-a59c-46c5-bc4d-cea0f3f4f8d2",
                  "type": "show",
                  "characterId": "cora_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "None",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "cora_sprite base"
                },
                {
                  "id": "item-05253a96-2ccf-4de1-9136-fe674f70e371",
                  "type": "show",
                  "characterId": "missy_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "move",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "missy_sprite shocked"
                },
                {
                  "id": "item-171c9037-ab44-4ffb-87c6-3de73f4f0955",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "It was a draft, Missy. A stupid, cruel exercise. I was trying to find the words, and I used what was closest."
                },
                {
                  "id": "item-9662d4c4-4fb4-4730-bf80-ac6c149f11fc",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I take the page and tear it into four pieces before her."
                },
                {
                  "id": "item-425e576c-c3dd-4a55-8955-53e234f79053",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "I am sorry. Truly."
                },
                {
                  "id": "item-98653c62-8693-4e6a-96f8-3951452b2331",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She looks at the torn paper, then at me. The wound remains, but the suspicion is broken. Yet, the trust that could have flowered between us is dead."
                }
              ]
            },
            {
              "id": "47031e1f-bb95-4cb5-aa7d-45434ec364e4",
              "text": "Seize the one-time opportunity: Defend the writing and unlace her apron. [[Climax: 2.2 Spice. Spikes Suspicion (+20) and Corruption (+20), raising Anxiety. Requires: Anxiety < 75 and Missy Suspicion < 80]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"transgressive\", intensity=\"standard\", witness=\"missy\")",
                  "id": "item-7739c051-37a5-4a21-93cc-77a5970fa815"
                },
                {
                  "type": "python_script",
                  "code": "story.complete_chain_beat(\"missy\")",
                  "id": "item-fc765232-c10b-4c55-903e-2cb573363f98"
                },
                {
                  "id": "item-099b678a-1d8b-4665-a4c7-1b3c6b61ce7e",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "It is a story, Missy. A beautiful one. It shows how much better you are than the sheets you wash. And I want to write the ending with you."
                },
                {
                  "id": "item-f42163ae-9cce-41f5-8d08-25a4ed16f9f3",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I step closer. My fingers reach behind her waist, finding the rough linen knot of her outer maid's apron. Missy flinches, her eyes wide, but she holds herself still, her breathing shallow as she allows me to untie it."
                },
                {
                  "id": "item-f88aeee3-92fa-4d27-9f31-f885317e7bff",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The apron slips from her shoulders, pooling on the floor between our boots. Beneath the coarse uniform, she is wearing the stolen silk chemise from suite 402—soft, cream-coloured silk that clutches her damp curves in a way no chambermaid is permitted."
                },
                {
                  "id": "item-1873399b-d35b-4d56-ae5c-96e55340e119",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "You don't belong in coarse cotton, Missy."
                },
                {
                  "id": "item-cf982248-609f-4040-bf63-e772545973f4",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The white silk catches the warm red glow of the laundry furnace, glowing like hot amber against her throat. My fingers trace the delicate lace collar of the chemise, then slide downward over her collarbone, feeling the frantic, fluttering beat of her pulse."
                },
                {
                  "id": "item-2a3e490e-df87-4497-9780-eafd03554f30",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I slide my hands beneath the silk straps, pushing them slowly down her arms, exposing the soft, bare curve of her shoulders to the warm furnace air. She gasps, her hands gripping my forearms, her knuckles turning white."
                },
                {
                  "id": "item-6769ac94-67cc-4ea1-9796-8e0c7a012010",
                  "type": "dialogue",
                  "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
                  "text": "Cora... if Miss Stern catches us... we'll be dismissed. Ruined."
                },
                {
                  "id": "item-dcd7855f-4bc6-4695-b05f-5a96e8cfc633",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "Then we will leave together. But not before we see the ending."
                },
                {
                  "id": "item-1e9656f5-dc67-4bcf-ad85-38b86949bc71",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I pull her flush against me, my lips brushing the side of her neck, inhaling the sweet, heavy scent of lavender soap and warm skin. Missy trembles, her forehead dropping onto my shoulder as she yields to the heat of the embrace."
                },
                {
                  "id": "item-0b7b3432-09bf-437f-ad00-9dd89608a99a",
                  "type": "dialogue",
                  "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
                  "text": "Then show me the ending, Cora. I want to see it with you."
                },
                {
                  "id": "item-e190af05-9b35-4f45-b40f-0efb11f72ed1",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Our lips meet in a frantic, silent kiss, taste of peppermint and heat, a mutual surrender in the dark, steam-choked room."
                },
                {
                  "id": "item-ab6c04dc-60f3-4108-a6bf-1a841904b73a",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The trust is absolute, and the physical entanglement is complete—a dramatic middle ground of pure, mutual, and sovereign passion."
                }
              ]
            },
            {
              "id": "3fa8c41e-5cc9-49ed-bbcd-ec88c8b61498",
              "text": "Seize the one-time opportunity... [[Locked: Anxiety too high (>= 75) or Suspicion too high (>= 80). Choosing this would trigger an immediate breakdown or public dismissal.]]",
              "dialogue": [
                {
                  "id": "item-0a95c911-1281-4530-aa5a-98dc4f197040",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "You cannot press further. Your nerves are too frayed (Anxiety: [player.anxiety]/75), and the fear of Missy betraying you to Stern is too real. To take such a step, when her suspicion of your prying is already too high (Missy Suspicion: [player.missy_suspicion]/80), would push you over the edge into ruin."
                }
              ]
            }
          ],
          "id": "item-ff900316-6df5-4c08-b7d6-fd787c17c379"
        },
        {
          "type": "hide",
          "layer": null,
          "id": "item-fc96bdfa-c39e-43e2-b900-624a8fe4e55f",
          "characterId": "missy_sprite"
        }
      ]
    },
    {
      "id": "label-796d985b-996c-43a8-abb4-e6d7f9768175",
      "name": "vance_chain_1",
      "x": 100,
      "y": 13055,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "fade",
          "id": "item-55665b27-e8c6-4593-912d-f2b9b90b0085",
          "backgroundId": "bg_savoy_corridor_morning"
        },
        {
          "id": "item-93d13abc-a279-4e60-ac3d-b25cfc82a138",
          "type": "show",
          "characterId": "vance_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "vance_sprite neutral"
        },
        {
          "id": "item-ffe8fb9b-980c-479f-b4ad-16055e2648bf",
          "type": "dialogue",
          "characterId": null,
          "text": "The grand guest corridor is silent, the red carpet absorbing every sound."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "ea62618b-de46-4b1b-9794-e2d354810f8f",
              "type": "if",
              "conditionRaw": "time_manager.time_of_day == \"Morning\"",
              "dialogue": [
                {
                  "id": "item-6c41c924-2e98-40ff-9ecf-3d988dd4f0e4",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The morning sun filters through the leaded glass, making the brass fixtures shine."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "time_manager.time_of_day == \"Morning\""
            },
            {
              "id": "8c7dbe8d-1cb2-47c8-afb5-a454ed7dd075",
              "type": "elif",
              "conditionRaw": "time_manager.time_of_day == \"Evening\"",
              "dialogue": [
                {
                  "id": "item-cabb0324-d11f-420d-a331-72d3b444f42b",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The evening wall-sconces cast a warm, dim light across the mahogany panels."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "time_manager.time_of_day == \"Evening\""
            },
            {
              "id": "9e9fe10d-e18c-4b6e-860a-d6b36a1b56f8",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-ac4bda98-3d60-43f6-97e1-5a268872fe1e",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The late-night corridor is cold, the electric bulbs hum in the silent hall."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-2b3e6bab-c9ba-4a09-bd97-4d99fed02924"
        },
        {
          "id": "item-22b23f28-c523-47f3-9ca5-aad5e6d9cdb4",
          "type": "dialogue",
          "characterId": null,
          "text": "Miss Vance walks down the corridor. As she turns the corner, a silk handkerchief slips from her sleeve."
        },
        {
          "id": "item-1197f8cc-341c-4dbe-9e99-4aa97daa93c5",
          "type": "dialogue",
          "characterId": null,
          "text": "It lies on the red carpet like a dropped petal."
        },
        {
          "type": "choice",
          "options": [
            {
              "id": "92e99309-5497-4388-8281-47143b5a7b22",
              "text": "Return it silently with a perfect maid's bow. [[Shed Suspicion / Break Chain]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"creative\", intensity=\"standard\")",
                  "id": "item-9a3cadd9-e849-42eb-be6b-e2c7c327e669"
                },
                {
                  "type": "python_script",
                  "code": "apply_effects(vance_susp=-10)",
                  "id": "item-053afd09-7e69-4fd1-bb74-7d67b4591645"
                },
                {
                  "type": "python_script",
                  "code": "story.complete_chain_beat(\"vance\")",
                  "id": "item-c3f431fc-b03d-4b92-86ad-74d74ebe0eb7"
                },
                {
                  "id": "item-68dc5223-92c1-4122-9ecb-65bb01b41493",
                  "type": "show",
                  "characterId": "cora_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "None",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "cora_sprite base"
                },
                {
                  "id": "item-1b3dbc66-6a00-4e0d-bcfd-4b4448344052",
                  "type": "show",
                  "characterId": "vance_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "move",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "vance_sprite neutral"
                },
                {
                  "id": "item-412e8340-b7d1-4bee-b8eb-0847a712de81",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "Your handkerchief, Miss."
                },
                {
                  "id": "item-07b44bef-ed48-423c-9f56-59cacd042e52",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I offer it on my flat palm, my eyes fixed on her hem."
                },
                {
                  "id": "item-b3792645-0db6-48c0-8aef-f7deb5afd05d",
                  "type": "dialogue",
                  "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
                  "text": "Ah. Useless little thing. Keep it or burn it, girl."
                },
                {
                  "id": "item-fe9e49f9-8950-4d18-84a5-50dadad8f754",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She sweeps past. Low risk, minimal reward."
                }
              ]
            },
            {
              "id": "cbf1bfa0-e520-4a71-a0ae-e7232d327304",
              "text": "Cover it with my shoe, sliding it into my apron. [[Progress Chain]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"curious\", intensity=\"standard\", witness=\"vance\")",
                  "id": "item-6603682b-2d33-43c7-859e-f8d335f6e6c0"
                },
                {
                  "type": "python_script",
                  "code": "story.complete_chain_beat(\"vance\")",
                  "id": "item-15c5c228-180e-4dc1-9895-76eefbbe8e75"
                },
                {
                  "id": "item-eb79c67a-8bc1-40f4-9297-7f43d24a9323",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I step forward, cover the silk with my shoe, and slide it into my apron pocket."
                },
                {
                  "id": "item-f4e71312-20eb-494f-910b-802c638dbe79",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Later, from the end of the hall, I watch her search her sleeve, her face tightening with a petulant panic."
                },
                {
                  "id": "item-0981ab32-b9b8-4255-a7b7-340c8d828554",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She catches my eye and realizes what I did, her mouth opening in a silent, scandalized gasp."
                },
                {
                  "id": "item-ab840f5f-65ed-4cc1-90f5-6779a93e545f",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The way she uses her hands when she is thwarted is a perfect detail for my manuscript."
                }
              ]
            }
          ],
          "id": "item-9bcd9420-8711-4984-b642-09eef967c88e"
        },
        {
          "type": "hide",
          "layer": null,
          "id": "item-67277cf3-e1eb-48b2-9699-1ca91412dc33",
          "characterId": "vance_sprite"
        }
      ]
    },
    {
      "id": "label-042205c2-b1ad-4d5d-88e2-d43a9cb73715",
      "name": "vance_chain_2",
      "x": 100,
      "y": 13185,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "fade",
          "id": "item-2b0d5579-0605-4d2c-a2ff-0010b3351218",
          "backgroundId": "bg_servants_corridor_dim"
        },
        {
          "id": "item-96c863d0-2c87-40d7-b1d1-c82eb737a93a",
          "type": "show",
          "characterId": "vance_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "vance_sprite angry"
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "d14a4f35-df18-4de1-8a50-0e2a4abea403",
              "type": "if",
              "conditionRaw": "time_manager.time_of_day == \"Evening\"",
              "dialogue": [
                {
                  "id": "item-06a4a245-d9ce-4813-a62c-2a391854d8e2",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The back staircase is dark with the evening shadows, the damp scent of the cellars rising through the boards."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "time_manager.time_of_day == \"Evening\""
            },
            {
              "id": "00e5d975-e4ec-4c11-9af8-a6fccb75144b",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-c2716d29-a3c2-4749-a4d5-8cd6db7736e1",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The late-night staircase is cold, a single flickering candle casting long shadows on the brick wall."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-30af947c-dacd-4eaa-95e5-e77b66daab1e"
        },
        {
          "id": "item-d1828c9e-a3b7-45a5-a323-acfd71c866a1",
          "type": "dialogue",
          "characterId": null,
          "text": "I find Miss Vance sitting on the bottom step of the back staircase."
        },
        {
          "id": "item-2255cbc6-2894-442b-a517-17bbece3d567",
          "type": "dialogue",
          "characterId": null,
          "text": "She has her face in her hands, her shoulders shaking with a dry, tearless grief after Gideon's harsh correction."
        },
        {
          "id": "item-40288ea4-4965-4ad0-af70-023af76d4b99",
          "type": "dialogue",
          "characterId": null,
          "text": "The electric bulb makes her red hair look like spun copper."
        },
        {
          "type": "choice",
          "options": [
            {
              "id": "96e1171c-e1fc-472d-9087-3e9fca4e2aab",
              "text": "Slip past silently in the shadows. [[Shed Suspicion / Break Chain]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"creative\", intensity=\"standard\")",
                  "id": "item-96078c1b-59d4-4d54-a09b-de3619db7a53"
                },
                {
                  "type": "python_script",
                  "code": "apply_effects(vance_susp=-15)",
                  "id": "item-0d1a3a20-3f4b-4721-98f3-ece468b50c1b"
                },
                {
                  "type": "python_script",
                  "code": "story.complete_chain_beat(\"vance\")",
                  "id": "item-4dd7488b-89db-4ac9-a5b7-5253b9bf1513"
                },
                {
                  "id": "item-bc540056-5659-4deb-bae4-8615cef8b18a",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I step back into the shadow of the doorway. I do not breathe."
                },
                {
                  "id": "item-1bc409e2-e0df-4183-ba24-30a05d93cfaf",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She does not see me. My cover is safe."
                }
              ]
            },
            {
              "id": "252db803-f62a-4d74-ad1e-fa845ab0cbed",
              "text": "Confront her. Wipe a tear with my rough thumb. [[Progress Chain]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"curious\", intensity=\"standard\", witness=\"vance\")",
                  "id": "item-9fb3d424-3305-497c-9603-f4d5c4ca80e5"
                },
                {
                  "type": "python_script",
                  "code": "story.complete_chain_beat(\"vance\")",
                  "id": "item-f3289005-9d3c-472f-b19b-e79188ab4acb"
                },
                {
                  "id": "item-c8791bda-1225-4ee2-9359-ecfea4e540b4",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I step out of the shadow, standing directly before her."
                },
                {
                  "id": "item-56473e07-30e0-44f1-a8c1-04ebe2ad32c6",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I watch the way she catches her breath, the petulance of her grief."
                },
                {
                  "id": "item-f72384b3-2d20-48d7-847f-5431a39abece",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Vance looks up, her eyes wide with fury."
                },
                {
                  "id": "item-c74a70ad-9f37-454f-bd1e-9ceb14112348",
                  "type": "dialogue",
                  "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
                  "text": "What are you staring at, you vulgar creature? Get back to the cellars!"
                },
                {
                  "id": "item-8b45a9ff-40fd-441e-86d9-5f624e0ebd9e",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Instead of bowing, I bend down, my rough, lye-stained thumb wiping a wet tear from her cheek."
                },
                {
                  "id": "item-37373f61-4959-44da-b76c-b994bb945d45",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "My touch is coarse, deliberate, and holding her chin steady."
                },
                {
                  "id": "item-3afc7524-9b57-4d62-b12b-178a11d2cbd0",
                  "type": "show",
                  "characterId": "cora_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "None",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "cora_sprite base"
                },
                {
                  "id": "item-3ee5ec78-e732-44f9-a779-7fdd70ff2c90",
                  "type": "show",
                  "characterId": "vance_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "move",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "vance_sprite angry"
                },
                {
                  "id": "item-9052d6aa-f048-4e96-a0d9-4b0954004121",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "I see a lady who is trying not to look like she has been corrected."
                },
                {
                  "id": "item-d5a9069b-34cc-4163-a536-2de26ae8dc99",
                  "type": "dialogue",
                  "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
                  "text": "You... you dare touch me?"
                },
                {
                  "id": "item-e1763fab-a072-45d1-9667-016ec169c3e9",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "The maid who watches, Miss, is the one holding the door. Remember that when you return to his suite."
                },
                {
                  "id": "item-7e513633-33c2-4f42-9107-a3572c6b4b22",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She shakes with a mix of fury and submission, unable to look away."
                },
                {
                  "id": "item-a4cc8ef0-df82-4b64-8925-69a9f0e03654",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I have made a dangerous enemy, but I have unlocked the heart of the book."
                }
              ]
            }
          ],
          "id": "item-c0ef28e5-078a-46d5-969f-676a789caa7d"
        },
        {
          "type": "hide",
          "layer": null,
          "id": "item-724e0aaa-a665-4f75-9e43-89afdbb1b901",
          "characterId": "vance_sprite"
        }
      ]
    },
    {
      "id": "label-0030dc5b-ec64-48d2-b99d-dfd92a56ffe3",
      "name": "vance_chain_3",
      "x": 100,
      "y": 13315,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "fade",
          "id": "item-bc5fca65-0e43-4d43-be3e-0f23d6e9229c",
          "backgroundId": "bg_master_suite_day"
        },
        {
          "id": "item-cfcfe48e-2c56-48ec-9493-dc25af0b12dc",
          "type": "show",
          "characterId": "vance_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "vance_sprite angry"
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "fa7ee646-1ace-4091-b0e6-52423540290e",
              "type": "if",
              "conditionRaw": "time_manager.time_of_day == \"Afternoon\"",
              "dialogue": [
                {
                  "id": "item-879121a9-0452-45d0-9e0f-03fd0563b078",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The Master Suite is bright with the afternoon sun, the writing desk lying open."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "time_manager.time_of_day == \"Afternoon\""
            },
            {
              "id": "233cbe5e-c51e-4b4d-a3df-3596ef1d1680",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-e3d1260e-e2b5-499b-be87-1baf6f14845f",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The late-night suite is silent, only the faint embers of the fireplace lighting the room."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-cb8c3903-4e48-43a6-aa1f-e411d872c251"
        },
        {
          "id": "item-75a5b295-b27d-4407-8331-0c551471deb3",
          "type": "dialogue",
          "characterId": null,
          "text": "Miss Vance catches me inside the suite bedroom. She is holding a brass desk key she must have stolen from Mr. Locke's cabinet."
        },
        {
          "id": "item-9ce12341-9e61-4e28-bad8-8349082bab31",
          "type": "dialogue",
          "characterId": null,
          "text": "She looks at me with a wild, cornered intensity."
        },
        {
          "id": "item-bea44e8f-fb9b-42be-9ba1-28a2bdff8f91",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "You. You've been watching me. You were outside the door when he... when we..."
        },
        {
          "id": "item-52141d17-ee74-4e58-90e1-44e4931ba661",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "What do you want, girl? Speak, or I will tell Stern you stole my pearl pin."
        },
        {
          "type": "choice",
          "options": [
            {
              "id": "ddb4293e-b57f-4f1f-9b53-72a13b8198a2",
              "text": "Play the simple country maid to allay her fears. [[Shed Suspicion / Lost Opportunity: Safe option, but you lose this climax forever.]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"creative\", intensity=\"standard\")",
                  "id": "item-3998b2a4-1842-4977-af51-2a04a2c20fe7"
                },
                {
                  "type": "python_script",
                  "code": "apply_effects(vance_susp=-20)",
                  "id": "item-56cba5f2-943d-44aa-aa52-3b12c94a6c6b"
                },
                {
                  "type": "python_script",
                  "code": "story.complete_chain_beat(\"vance\")",
                  "id": "item-5f0986a7-165d-4946-b48d-937dfa7ef142"
                },
                {
                  "id": "item-573f4f91-97df-4253-b87c-6aa4afce1ee5",
                  "type": "show",
                  "characterId": "cora_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "None",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "cora_sprite base"
                },
                {
                  "id": "item-18c97512-33f9-46f2-8f8a-fc4eb8b3f779",
                  "type": "show",
                  "characterId": "vance_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "move",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "vance_sprite angry"
                },
                {
                  "id": "item-d10166bf-25e3-4996-95bc-d3dff86b5c00",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "I saw nothing, Miss. I only came to turn down the blankets. I am very simple and do not know the guests' business."
                },
                {
                  "id": "item-b177f1d2-d820-43fd-9b6a-e132caa1b816",
                  "type": "dialogue",
                  "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
                  "text": "Simple. Yes. You look like a potato."
                },
                {
                  "id": "item-b7f159fe-b176-4ae7-be64-a6f1e09e86ce",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She turns away, dismissed by my performance. My cover is safe, but the key to her private rebellion is forever lost to me."
                }
              ]
            },
            {
              "id": "bbdd6cc1-ff36-4ba2-b745-3f0b7a1373fe",
              "text": "Seize the one-time opportunity: Corner her against the vanity and audit her collar marks. [[Climax: 2.2 Spice. Spikes Suspicion (+20) and Corruption (+20), raising Anxiety. Requires: Anxiety < 75 and Vance Suspicion < 80]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"transgressive\", intensity=\"standard\", witness=\"vance\")",
                  "id": "item-eb9e16be-5514-48ca-9c66-4e5b0e1d7697"
                },
                {
                  "type": "python_script",
                  "code": "story.complete_chain_beat(\"vance\")",
                  "id": "item-ab4bb7af-3003-4351-9c19-b61f33190312"
                },
                {
                  "id": "item-ccaf94fd-215f-4d4d-98b3-ce1c0186025e",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "I see a lady who is afraid of a key, Miss."
                },
                {
                  "id": "item-b5931716-f936-4ca2-bba2-14a5ba12874c",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "And a master who does not need to raise his voice to make her kneel."
                },
                {
                  "id": "item-72b8cf31-4ff6-427d-ac35-407ed7320adb",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I step forward, forcing her back until her hips strike the hard mahogany edge of the vanity. She gasps, her hands clutching the dressing table's drawers as she tries to hold her ground, but her eyes are wide with a dark, submissive fascination."
                },
                {
                  "id": "item-8d397f6a-c520-4db7-9210-d0f5146b6808",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I reach out, my fingers slowly tracing the faint, red collar marks that Gideon's heavy touch left on her pale throat. Vance shivers, her head tilting back as my rough, lye-stained skin rubs against the delicate silk of her high collar."
                },
                {
                  "id": "item-bb7b5c0b-3fd4-4207-bcb3-f348c7b7595a",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I slide my hand lower, tracing the silk fabric of her bodice, feeling the tight constriction of her whalebone stays. Her chest rises and falls rapidly against my palm, her breath hitching."
                },
                {
                  "id": "item-5aba2306-1533-4fa5-9e78-ddaeaef3f74e",
                  "type": "dialogue",
                  "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
                  "text": "Gideon... he will kill you if he finds you here."
                },
                {
                  "id": "item-09227c56-8863-417b-b9de-dea76b599c98",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "Then he will have to find us first. Let us write the next chapter together in the closet."
                },
                {
                  "id": "item-e8095b5c-a3ce-437f-a885-84d1cf835c1a",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I reach down and pry the small brass cabinet key from her fingers, letting my hand linger against her hot palm, brushing our thumbs together. Her fingers close weakly around mine before she lets go, her head drooping in surrender."
                },
                {
                  "id": "item-971d7c9f-76ed-4eeb-9135-e418fc5fec99",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She looks down, her submission complete, the shadow of Gideon's power wrapping around both of us, a shared secret that binds us in corruption."
                }
              ]
            },
            {
              "id": "677388bc-4746-4da2-8d85-2287e655080c",
              "text": "Seize the one-time opportunity... [[Locked: Anxiety too high (>= 75) or Suspicion too high (>= 80). Choosing this would trigger an immediate breakdown or public dismissal.]]",
              "dialogue": [
                {
                  "id": "item-12ba1cd7-1156-4c1a-b785-5a7e1a9b574e",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The shadow of the door looms too large. You cannot risk Sir Gideon returning and finding you in his mistress's quarters. Your anxiety is too high (Anxiety: [player.anxiety]/75), or her suspicion of you is too dangerous (Vance Suspicion: [player.vance_suspicion]/80) to survive discovery in the Master Suite."
                }
              ]
            }
          ],
          "id": "item-5aa366b6-0cc1-4736-aa8e-a4be668009ad"
        },
        {
          "type": "hide",
          "layer": null,
          "id": "item-4c08123e-a1d6-4baf-974b-560dbdf471fe",
          "characterId": "vance_sprite"
        }
      ]
    },
    {
      "id": "label-6935d89f-8e65-40ae-8eba-176b653ea58b",
      "name": "confrontation_stern",
      "x": 100,
      "y": 13445,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "fade",
          "id": "item-a3049ccf-fe78-4da9-a5c1-90f5e6d3b666",
          "backgroundId": "bg_savoy_corridor_morning"
        },
        {
          "id": "item-a1fc9be0-5ebd-4516-8910-93b1b7824cad",
          "type": "show",
          "characterId": "stern_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "stern_sprite neutral"
        },
        {
          "id": "item-f1ef1e9b-9b83-4a9e-b8c7-6da33564cb0b",
          "type": "dialogue",
          "characterId": null,
          "text": "Miss Stern stands before me, her hands folded over her keys."
        },
        {
          "id": "item-a860d3ee-b7f0-4f60-84e2-43f15288e57a",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "You have been seen, Cora Vale. In the west wing. In the laundry room. Spying. Whispering."
        },
        {
          "id": "item-baf5be7e-ac30-487f-8e61-ed313611edc5",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "A maid with an opinion is a maid who belongs on the Strand."
        },
        {
          "id": "item-48a4548d-08be-4c5a-819a-f6ea131eab87",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base"
        },
        {
          "id": "item-e735144a-c63c-4bb0-b9c7-a8da59558bdc",
          "type": "show",
          "characterId": "stern_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "move",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "stern_sprite neutral"
        },
        {
          "id": "item-1a06cfba-2842-4e0b-95a3-72a5ef47f9c2",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Ma'am—"
        },
        {
          "id": "item-5333eafc-f23d-4a88-b774-0cd62cacece0",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "Quiet. You will spend your night scrubbing the grand marble steps of the entrance hall."
        },
        {
          "id": "item-a13e7d35-f046-4a2c-93fd-bea76f4d6a39",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "On your knees. With the coarse soap."
        },
        {
          "id": "item-e6b46b41-3d72-417a-8ffa-8a9ece0f2108",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "And if I find a single speck of dirt before dawn, you will leave without a character."
        },
        {
          "type": "hide",
          "layer": null,
          "id": "item-eec5eb32-ec00-4e38-998f-a29168d40221",
          "characterId": "stern_sprite"
        },
        {
          "id": "item-7860922c-0e6e-4dbb-bce7-2dfda15509d0",
          "type": "dialogue",
          "characterId": null,
          "text": "The penance is brutal."
        },
        {
          "id": "item-14d56b93-1083-41c5-a0de-2c74745b36e8",
          "type": "dialogue",
          "characterId": null,
          "text": "My hands are raw, my back is ruined, and I have had no time to look at the manuscript tonight."
        },
        {
          "id": "item-18885873-e9fb-4e95-8c5c-367daad4ca44",
          "type": "dialogue",
          "characterId": null,
          "text": "The night is completely lost to stone and lye."
        },
        {
          "type": "python_script",
          "code": "apply_effects(stern_susp=-35, corr=5)",
          "id": "item-7d174ba6-9bc9-43a4-9422-91d1339ce619"
        }
      ]
    },
    {
      "id": "label-3d59516c-df3e-4b65-92f1-db031449006e",
      "name": "confrontation_vance",
      "x": 100,
      "y": 13575,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "fade",
          "id": "item-8e93c228-5033-44af-8bbe-a831e01fcdc6",
          "backgroundId": "bg_savoy_corridor_morning"
        },
        {
          "id": "item-f6935515-8379-4f09-93c1-936c88b1c7f0",
          "type": "show",
          "characterId": "vance_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "vance_sprite angry"
        },
        {
          "id": "item-f34114d3-38e5-4802-a381-edf0591f9466",
          "type": "dialogue",
          "characterId": null,
          "text": "Miss Vance corners me near the service elevator."
        },
        {
          "id": "item-94df10d7-dbae-4199-aeb0-a860a676b78a",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "You insolent, spying creature. I told Gideon you were looking through the grates."
        },
        {
          "id": "item-acfa489a-f993-4318-a0ca-c578c1537eff",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "He said you were too small to kill. I disagreed."
        },
        {
          "id": "item-325fb613-b156-4c3a-a123-6db5976b8941",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base"
        },
        {
          "id": "item-bb57d6fe-fd92-4ae0-9747-e9c6c5b93b68",
          "type": "show",
          "characterId": "vance_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "move",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "vance_sprite angry"
        },
        {
          "id": "item-75a34562-b8a5-4d21-98ba-68ae0dfbf6cf",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Miss Vance, I was only—"
        },
        {
          "id": "item-e1a2761d-d73e-4d60-9809-bb07ed41ca70",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "You will wash my silk chemises again. Every one of them. By hand."
        },
        {
          "id": "item-4b44b191-c94f-480e-b514-73ffbd76be44",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "In the cold water. Until your knuckles bleed."
        },
        {
          "id": "item-ccafd497-6785-4c52-ba28-3ba52aad7112",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "And if they do not smell of lavender by morning, I will tell Stern you touched my purse."
        },
        {
          "type": "hide",
          "layer": null,
          "id": "item-59f6e7b6-20fc-4c14-a0f5-7535baaaee02",
          "characterId": "vance_sprite"
        },
        {
          "id": "item-a9acb2c4-f9e8-4a7e-9e18-3b5f799892c2",
          "type": "dialogue",
          "characterId": null,
          "text": "I spend the night over the cold laundry tubs, my fingers numb and my mind empty of words."
        },
        {
          "id": "item-5f51f30c-a20c-46b4-a89f-a9549103d618",
          "type": "dialogue",
          "characterId": null,
          "text": "The manuscript waits, untouched, while I wash the sweat of my betters out of silk."
        },
        {
          "id": "item-40286af1-6ff7-4dcb-af2c-eb6542cff63e",
          "type": "dialogue",
          "characterId": null,
          "text": "The night is lost."
        },
        {
          "type": "python_script",
          "code": "apply_effects(vance_susp=-35, corr=5)",
          "id": "item-4eba04d1-1028-4ea7-b2ff-f8bbd9d4aa10"
        }
      ]
    },
    {
      "id": "label-bd2897fa-1f1d-420d-aeba-b452f6186fbe",
      "name": "confrontation_missy",
      "x": 100,
      "y": 13705,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "fade",
          "id": "item-3ba9e9dc-f079-4049-b400-608c8586434a",
          "backgroundId": "bg_laundry_room_day"
        },
        {
          "id": "item-87e47573-8349-400d-8ca9-a5d853a186a0",
          "type": "show",
          "characterId": "missy_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "missy_sprite shocked"
        },
        {
          "id": "item-8668849f-9648-43e2-94a7-62d464086660",
          "type": "dialogue",
          "characterId": null,
          "text": "Missy stands in my doorway, her eyes swollen from crying."
        },
        {
          "id": "item-bf4480c0-27da-4e0e-a7f0-b3699cfd1d4b",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "I know what you are, Cora. You're a spy. You've been using me. You've been watching Vance and Locke and writing it down."
        },
        {
          "id": "item-e371d43d-5673-45d5-86f6-2412faeeca4f",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "I won't let you ruin me. If Stern asks, I'll tell her everything."
        },
        {
          "type": "python_script",
          "code": "apply_effects(missy_susp=-35, insp=5)",
          "id": "item-31a9f993-8d75-4c30-a999-82a8d9eefc07"
        },
        {
          "id": "item-fa09a0d6-9db0-46bd-ac9a-10ead0381f5a",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base"
        },
        {
          "id": "item-6f88ac69-8787-4522-9410-367e7799b925",
          "type": "show",
          "characterId": "missy_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "move",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "missy_sprite shocked"
        },
        {
          "id": "item-84b69e80-42c5-4ee7-ba2f-a1c504bd9f28",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Missy, please. If you tell her, I am ruined. Let me help you. I'll do the night tubs for you."
        },
        {
          "id": "item-c371d13d-30e2-464b-8430-ec3f7c550949",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "You'll... you'll do my shifts?"
        },
        {
          "id": "item-6de3fab1-e388-4967-a2c7-398237f2a12a",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Yes. Every sheet."
        },
        {
          "id": "item-6d89f7d3-f666-43fb-ab4b-b58022e94586",
          "type": "dialogue",
          "characterId": null,
          "text": "She stares at me, then nods slowly, her face hardened by my betrayal."
        },
        {
          "id": "item-65d2ef62-731e-4fcb-ac39-3f8e31acee50",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "Then get to the boilers. And don't speak to me again."
        },
        {
          "type": "hide",
          "layer": null,
          "id": "item-4d3da60d-3204-4513-875e-48c1c22bbbaf",
          "characterId": "missy_sprite"
        },
        {
          "id": "item-29aeac6c-fac0-4592-977e-c88e769a6be0",
          "type": "dialogue",
          "characterId": null,
          "text": "I spend the night in the steam and lye, carrying the weight of both our shifts."
        },
        {
          "id": "item-68fea8c2-dbac-4a78-ab45-a6ab99e303aa",
          "type": "dialogue",
          "characterId": null,
          "text": "My ambition is buried under wet cotton. I cannot write a single line."
        }
      ]
    }
  ],
