        {
          "type": "if_block",
          "branches": [
            {
              "id": "67163c66-aaad-4547-b66b-5c900331ba0a",
              "type": "if",
              "conditionRaw": "chapter_key == \"day1_chapter\" or chapter_key == \"day1_slop_chapter\"",
              "dialogue": [
