    {
      "id": "label-f548b7b5-c87e-43ec-9f41-b89048c97033",
      "name": "day100_2_parlour_branch",
      "x": 2500,
      "y": 11755,
      "dialogue": [
        {
          "id": "item-99b2df70-373a-432b-9007-07f904640fe8",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite flushed"
        },
        {
          "id": "item-50486564-3bcb-427b-a046-e9967bee614f",
          "type": "dialogue",
          "characterId": null,
          "text": "I press my forehead to the cold paneling, my eye aligned with the keyhole's narrow slit."
        },
        {
          "id": "item-1a96c0cc-ebf5-4806-a429-4bddc06152e7",
          "type": "dialogue",
          "characterId": null,
          "text": "The air through the wood is hot — damp skin, crushed violets, the iron sweetness of fear."
        },
        {
          "id": "item-b22aea09-22b4-4d7f-a46e-5ad25ccd7b3f",
          "type": "dialogue",
          "characterId": null,
          "text": "Lady Eleanor's silk dinner dress is piled at her waist like discarded skin."
        },
        {
          "id": "item-b09d6499-f6f5-4fca-8809-b237e6981125",
          "type": "dialogue",
          "characterId": null,
          "text": "Margaret, the under-housemaid, kneels between her thighs. Her rough hands grip Eleanor's pinned hair."
        },
        {
          "id": "item-1cb04baf-fffd-49d5-8899-235b4b93bce3",
          "type": "dialogue",
          "characterId": null,
          "text": "The Lady of the house arches against the settee, her white throat straining, her mouth open on a breathless sob."
        },
        {
          "id": "item-07c7ebf0-9111-448c-b640-e7e7de8ba92e",
          "type": "dialogue",
          "characterId": null,
          "text": "Hush, Margaret... if Sir John should wake..."
        },
        {
          "id": "item-de365ff2-ec28-4b08-ae84-78640181a9ff",
          "type": "dialogue",
          "characterId": null,
          "text": "Then let him wake, my Lady. You asked me to stay."
        },
        {
          "id": "item-910d24fe-74f5-4f37-9647-6e1222962b52",
          "type": "dialogue",
          "characterId": null,
          "text": "The sound of fabric tearing softly. A harsh, filthy whisper. Eleanor does not push her away."
        },
        {
          "id": "item-e83f91da-1aeb-477d-9e99-5efd5c4fba56",
          "type": "dialogue",
          "characterId": null,
          "text": "She clings to the girl's coarse sleeves, her fine rings catching on plain linen."
        },
        {
          "id": "item-e2b73033-6c52-4c9e-a880-2405fdaede7f",
          "type": "dialogue",
          "characterId": null,
          "text": "My thighs press together under rough wool. The absolute hypocrisy of it."
        },
        {
          "id": "item-c49cf9e7-a52b-45f7-aac5-ddcaf826af74",
          "type": "dialogue",
          "characterId": null,
          "text": "This is the woman who lectures the village girls on modesty and chastity."
        },
        {
          "id": "item-fc69656c-c77d-4653-9140-20c163091466",
          "type": "dialogue",
          "characterId": null,
          "text": "So the saint of Wiltshire opens in the dark for a maid's rough hands."
        },
        {
          "id": "item-e14c9178-158f-473c-8fec-5ba154fd74f5",
          "type": "dialogue",
          "characterId": null,
          "text": "Blood hums between my legs — not shame, but a sudden, blinding tally of power."
        },
        {
          "id": "item-98b23708-3e92-401d-81cd-6c7cc071ccc8",
          "type": "dialogue",
          "characterId": null,
          "text": "A Lady's ruin is total. I file that away like ink."
        },
        {
          "id": "item-c2403afa-88dc-41ea-9d6e-d9d1c4176e27",
          "type": "jump",
          "destinationLabelId": "label-c708bd7d-7047-4a2a-aae6-ad112f5eda95"
        }
      ]
    },
    {
      "id": "label-451cee3f-9b83-40c7-bb5d-f042fa4d9908",
      "name": "day100_2_desk_branch",
      "x": 2500,
      "y": 11885,
      "dialogue": [
        {
          "id": "item-72e62cb8-84c0-4074-9efb-7ca8bef4e92f",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite focused"
        },
        {
          "id": "item-601514f6-90d5-4f58-a1bc-78d2790b2899",
          "type": "dialogue",
          "characterId": null,
          "text": "My fingers slide through the drawers like a thief in the night, paper rustling under my nails."
        },
        {
          "id": "item-4239c1aa-59db-4f2f-bdc3-5d40e036562e",
          "type": "dialogue",
          "characterId": null,
          "text": "Deep beneath charity ledgers, wrapped in soiled ribbon, I find a packet in Lady Eleanor's elegant sloped hand."
        },
        {
          "id": "item-eef22b09-94bb-41af-8efd-8494cd54c8df",
          "type": "dialogue",
          "characterId": null,
          "text": "'...when you pinned me against the laundry press, with your mouth at my throat... I have never felt such low, delicious agony. To have my wrists held in your plain, strong hands...'"
        },
        {
          "id": "item-ddfb413c-23cf-40a8-aad7-5bbb92ca7231",
          "type": "dialogue",
          "characterId": null,
          "text": "'...if Sir John should suspect, I am ruined — my name, my children, everything. But my body is no longer mine when you enter the room...'"
        },
        {
          "id": "item-0808dfbc-2535-49df-832e-b512b31420a1",
          "type": "dialogue",
          "characterId": null,
          "text": "Under the ribbon packet, a single sheet in a man's wild hand — Sir John's, unmistakable."
        },
        {
          "id": "item-4f4e0346-5a92-439e-9ee0-eacd0db49642",
          "type": "dialogue",
          "characterId": null,
          "text": "'...the locked box of photographic plates remains at the Savoy, the key secured with the solicitor on the Strand...'"
        },
        {
          "id": "item-90b4696b-beed-4f4d-b744-e044d594affc",
          "type": "dialogue",
          "characterId": null,
          "text": "Ink has weight. It pulls heat into the body — a pulse between the legs that reading ought not to teach."
        },
        {
          "id": "item-239f51bf-3f05-490c-8cbc-d196f83bac0a",
          "type": "dialogue",
          "characterId": null,
          "text": "She preaches temperance downward while drowning in a maid's plain sleeves."
        },
        {
          "id": "item-043a7f94-f058-475c-8068-b8e5b735e414",
          "type": "dialogue",
          "characterId": null,
          "text": "And he writes of London, of a secret box. I have read their blood in the ink."
        },
        {
          "id": "item-b94840a3-1b3c-4870-b9be-107e865edd0d",
          "type": "jump",
          "destinationLabelId": "label-c708bd7d-7047-4a2a-aae6-ad112f5eda95"
        }
      ]
    },
    {
      "id": "label-c708bd7d-7047-4a2a-aae6-ad112f5eda95",
      "name": "day100_2_reconvergence",
      "x": 2900,
      "y": 11885,
      "dialogue": [
        {
          "id": "item-22ee29fd-ec61-49d8-a2be-12eb9c8338a1",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite guarded_travel"
        },
        {
          "id": "item-5fce562d-c57b-4997-bbcd-15de8b7ef450",
          "type": "dialogue",
          "characterId": null,
          "text": "A sharp rustle behind me. The door swings wide."
        },
        {
          "id": "item-d4a9a100-cde5-44e5-89b0-5b2ada669010",
          "type": "dialogue",
          "characterId": null,
          "text": "Lady Eleanor stands in the threshold. Her hair is wild, her collar crooked, her eyes wide with manic terror."
        },
        {
          "id": "item-71984341-0268-467d-926d-e9484e3dc412",
          "type": "dialogue",
          "characterId": null,
          "text": "She has my three missing manuscript pages clutched in her hand. She knows what I have seen."
        },
        {
          "id": "item-7004b49d-913c-456f-95ee-ddb8e5afdba8",
          "type": "show",
          "characterId": "lady_eleanor_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "moveinright",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "lady_eleanor_sprite panicked"
        },
        {
          "id": "item-356ed0a1-14ec-49b3-8f2a-0859e6f668f8",
          "type": "dialogue",
          "characterId": "char-9f5f293b-0552-4d66-97a6-a127db5cd5e2",
          "text": "You... you Irish guttersnipe."
        },
        {
          "id": "item-77f4bd83-38eb-490d-b58f-3b2e6bb2a78b",
          "type": "dialogue",
          "characterId": "char-9f5f293b-0552-4d66-97a6-a127db5cd5e2",
          "text": "You dare search my rooms? You dare write this filth about flesh and touch?"
        },
        {
          "id": "item-b80b2cbc-1c6d-4aed-b1e2-15da9219cbbd",
          "type": "dialogue",
          "characterId": null,
          "text": "Careful. My head screams in my mother's soft, looping lilt. Swallow it. Choke it down."
        },
        {
          "id": "item-d825840e-8274-40d7-97a7-9b4d1f1f0723",
          "type": "dialogue",
          "characterId": null,
          "text": "Flat tongue. English country girl. She must not hear the Cork in my throat."
        },
        {
          "id": "item-d5432fc6-3570-464f-b351-cc690119ae7e",
          "type": "dialogue",
          "characterId": "char-9f5f293b-0552-4d66-97a6-a127db5cd5e2",
          "text": "I will not have your eyes in this house another hour. Sir John! Sir John!"
        },
        {
          "id": "item-f7df2142-15dd-436c-86dd-61968ad289a3",
          "type": "dialogue",
          "characterId": null,
          "text": "Footsteps in the hall. Sir John enters — collar straight, face grey, authority intact."
        },
        {
          "id": "item-522929e2-3c4c-4ccf-b6c4-5aaf422c1559",
          "type": "dialogue",
          "characterId": null,
          "text": "He takes the manuscript pages from his wife's shaking hand. His gaze finds me."
        },
        {
          "id": "item-85c16dac-aa1a-465b-b2d4-2d9308e20bd7",
          "type": "show",
          "characterId": "lady_eleanor_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "lady_eleanor_sprite panicked"
        },
        {
          "id": "item-74161654-6219-4407-a7f7-063d18f946fd",
          "type": "show",
          "characterId": "sir_john_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "moveinright",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "sir_john_sprite cold"
        },
        {
          "id": "item-3a71d947-6f8a-41ef-8cca-481b246d0992",
          "type": "dialogue",
          "characterId": "char-1706738f-dbb1-43dc-9c9e-b69e090ee2a9",
          "text": "Come out, Vale."
        },
        {
          "id": "item-3dd1d046-f3f4-4a85-80d5-6c2e15cd105b",
          "type": "dialogue",
          "characterId": null,
          "text": "The quietness of his voice is worse than a shout. It is the absolute authority of the house."
        },
        {
          "id": "item-b7a916c6-a4ea-4896-bc8e-7824cb9c2b1c",
          "type": "dialogue",
          "characterId": null,
          "text": "I step out from beside the bureau."
        },
        {
          "type": "choice",
          "options": [
            {
              "id": "95de9363-9cbe-4bf0-9601-4b376c6da50c",
              "text": "Lie — I was seeking a draft in the study. [[Careful posture]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "story.set_prologue_holywell_posture(\"careful\")",
                  "id": "item-0308e9e0-94ac-40ce-9d4a-f5b416421e43"
                },
                {
                  "id": "item-09d23cd5-09e7-4bc7-9d88-a9a1fb4285d2",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "There was a draft, sir."
                },
                {
                  "id": "item-b1045e2d-4b86-4241-9d30-ab279035eca8",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "My voice is level, country-flat. Let him hear a simpleton."
                },
                {
                  "id": "item-e8f62438-b0d7-452c-80f0-705d4e1ab2d1",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I must protect my secrets. A careful posture is the safest mask."
                }
              ]
            },
            {
              "id": "8b07315f-52e9-4457-8728-94010865e680",
              "text": "Deflect — they are my pages. [[Eager posture]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"observant\", intensity=\"standard\")",
                  "id": "item-c5d09666-2745-4d29-8b11-a7dcdca152b1"
                },
                {
                  "type": "python_script",
                  "code": "story.set_prologue_holywell_posture(\"eager\")",
                  "id": "item-33dd8f07-ccc0-43ed-ac88-87f97a8a9f42"
                },
                {
                  "id": "item-c993a3eb-8379-4c29-955a-7cfae6185956",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "They are my pages, sir."
                },
                {
                  "id": "item-9e8e6422-1354-48a5-aa84-008cc4b796d2",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "A dangerous word from a maid in a borrowed apron. I will not cower."
                },
                {
                  "id": "item-21dec47d-de87-455b-aef2-fc941a647004",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "My writing is mine. I want a publisher before my courage fails."
                }
              ]
            },
            {
              "id": "e5128f94-6d61-402d-a7fa-ba112b848e67",
              "text": "Submit — throw myself on his mercy. [[Desperate posture]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"observant\", intensity=\"standard\")",
                  "id": "item-de67c255-ac24-40bf-9fc7-d16a4766ee9e"
                },
                {
                  "type": "python_script",
                  "code": "story.set_prologue_holywell_posture(\"desperate\")",
                  "id": "item-76412c4e-8e9b-487e-bf6f-e0909f49381a"
                },
                {
                  "id": "item-6d5f681b-6324-4033-8b73-414ff81e1e00",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "Forgive me, sir."
                },
                {
                  "id": "item-b3d8eb72-d67b-42f7-92a0-49ca0f65f607",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I bend my neck. Let him believe the submission is real."
                },
                {
                  "id": "item-f6a379bf-0c33-4661-8e9b-e2d0ec13d551",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I am desperate. I will pay whatever price London demands."
                }
              ]
            }
          ],
          "id": "item-f436b4a0-426a-4a8a-ab4a-70c423cd8097"
        },
        {
          "id": "item-02d82d62-10ae-4886-9339-52804dfde278",
          "type": "dialogue",
          "characterId": "char-9f5f293b-0552-4d66-97a6-a127db5cd5e2",
          "text": "Send her away. Tonight. Before she breathes a word in the village."
        },
        {
          "id": "item-94d3f323-a8e6-4450-9b36-100cacd9821f",
          "type": "dialogue",
          "characterId": null,
          "text": "Sir John looks at the pages. His chest rises once — controlled, cold."
        },
        {
          "id": "item-d90a04e4-9148-4301-aeab-ecdc22980dc5",
          "type": "dialogue",
          "characterId": "char-1706738f-dbb1-43dc-9c9e-b69e090ee2a9",
          "text": "You write of skin. Of touch. Of things a decent housemaid should not name."
        },
        {
          "id": "item-4d953ae9-af99-4824-b083-dd4b3b94a547",
          "type": "dialogue",
          "characterId": "char-1706738f-dbb1-43dc-9c9e-b69e090ee2a9",
          "text": "You observed too clearly, Vale. And you wrote too well."
        },
        {
          "id": "item-d28d59b2-ed66-4b64-ab70-f9cd718081c1",
          "type": "dialogue",
          "characterId": "char-1706738f-dbb1-43dc-9c9e-b69e090ee2a9",
          "text": "Why did you write this filth?"
        },
        {
          "type": "choice",
          "options": [
            {
              "id": "57e0c75b-c55f-4e78-94b6-625aa68c262f",
              "text": "For the shillings home. [[Practical ambition]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"observant\", intensity=\"standard\")",
                  "id": "item-c9dc1adb-2aec-412e-9329-5da9b89ca594"
                },
                {
                  "type": "python_script",
                  "code": "story.set_prologue_why_write(\"money_home\")",
                  "id": "item-4fec9ddb-b824-450f-824b-c0a8765cd3c0"
                },
                {
                  "id": "item-452fb6f5-5a56-4e7d-9b7f-0ab14f3a0c2e",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Mother's cough. Father's pride. Shillings are the only language they understand."
                },
                {
                  "id": "item-05c868c0-1ce7-4364-ae28-b11f0af76f70",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Sentiment is a luxury. Rent is not."
                }
              ]
            },
            {
              "id": "065bdb43-66e8-48c3-805a-de0d3e5714ac",
              "text": "To catalogue what power hides. [[Curious, corrupting]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"creative\", intensity=\"standard\")",
                  "id": "item-0867bdad-aac7-44a6-9e57-778e4b4d1081"
                },
                {
                  "type": "python_script",
                  "code": "story.set_prologue_why_write(\"cataloguer\")",
                  "id": "item-f44fb5a4-16b3-438e-9346-a7e7b87f2c6f"
                },
                {
                  "id": "item-d3ec9d04-5a53-401e-a7ee-005148728ae3",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I want the machine on paper — who kneels, who commands, who pretends."
                },
                {
                  "id": "item-45bc8168-0b29-4af3-8092-a7de676e06bf",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Truth is a weapon even when I am too small to swing it."
                }
              ]
            },
            {
              "id": "1cded313-7687-4051-90a1-88d3a1467d17",
              "text": "Because scandal tastes better than porridge. [[Transgressive]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"creative\", intensity=\"standard\")",
                  "id": "item-60c9fc9d-a40f-4cfb-8b8d-191926a3592e"
                },
                {
                  "type": "python_script",
                  "code": "story.set_prologue_why_write(\"scandal_hungry\")",
                  "id": "item-df0906c3-9e82-4a73-8362-f07656c9958e"
                },
                {
                  "id": "item-7c56e2fe-84fc-4666-b7b2-70c92f5bb193",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I will not pretend innocence is a meal."
                },
                {
                  "id": "item-586fcfc6-616e-498b-88e4-d59009856033",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Wiltshire taught me appetite. London will teach me price."
                }
              ]
            }
          ],
          "id": "item-fdbfb1ef-b98b-49f8-a732-8dadc462bad7"
        },
        {
          "id": "item-3e7ad164-1c1d-43c4-ae2c-b85c149ed2ae",
          "type": "dialogue",
          "characterId": null,
          "text": "Sir John crumples the three pages into his pocket. Lady Eleanor watches, white as flour."
        },
        {
          "id": "item-8cc8f75e-fc01-451b-ab06-d9464b0dfff3",
          "type": "dialogue",
          "characterId": "char-1706738f-dbb1-43dc-9c9e-b69e090ee2a9",
          "text": "My wife is correct. Pack your trunk. You leave on the morning train."
        },
        {
          "id": "item-f7aa3a9c-c07c-4ec5-aa47-8923d9838e69",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "I understand, sir."
        },
        {
          "id": "item-c99941ee-630d-4dd0-898a-3aa5e7b81dde",
          "type": "dialogue",
          "characterId": "char-1706738f-dbb1-43dc-9c9e-b69e090ee2a9",
          "text": "I will give you a reference for the Savoy, Vale. But if a word of what you have seen — or written — leaves your mouth, no decent house in England will have you."
        },
        {
          "id": "item-01f37b68-ea33-4725-a37b-3a49e23f5a57",
          "type": "dialogue",
          "characterId": "char-1706738f-dbb1-43dc-9c9e-b69e090ee2a9",
          "text": "Your name will be blackened. You will be in the gutter."
        },
        {
          "id": "item-e5e117cc-8928-467d-b2a4-b72ab6cccc2f",
          "type": "dialogue",
          "characterId": null,
          "text": "Threat and thrill share a pulse. A Lady's ruin is absolute; a Lord's is negotiable."
        },
        {
          "id": "item-fc909f03-d631-4e37-a3e1-1c775200fd0b",
          "type": "dialogue",
          "characterId": null,
          "text": "If their secrets have weight, perhaps mine will too — one day. Not tonight."
        },
        {
          "id": "item-bd3d7504-fd0f-44c8-a101-b0bae1701798",
          "type": "dialogue",
          "characterId": null,
          "text": "Wiltshire ends here."
        },
        {
          "type": "python_script",
          "code": "renpy.block_rollback()",
          "id": "item-c5735825-0a72-4e4d-92da-6978bc1ea777"
        },
        {
          "id": "item-ff99d6aa-2678-4f14-9d4b-9e16c8c7db28",
          "type": "jump",
          "destinationLabelId": "label-19598315-05b1-4e3e-8b26-1663ac7a6141"
        }
      ]
    },
    {
      "id": "label-19598315-05b1-4e3e-8b26-1663ac7a6141",
      "name": "day100_3_night_daydream",
      "x": 3300,
      "y": 11885,
      "dialogue": [
        {
          "type": "python_script",
          "code": "set_time_period(\"Night\")",
          "id": "item-148f5c40-40aa-4049-8fcd-1842a68f7626"
        },
        {
          "type": "scene",
          "layer": null,
          "transition": "None",
          "id": "item-bf17b47f-93c1-4586-9322-40cfe5be6439",
          "backgroundId": "bg_train_carriage_day"
        },
        {
          "id": "item-1cee21fa-3e69-4a21-bc13-6b4a11fb75ad",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "moveinright",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base"
        },
        {
          "id": "item-9b75c809-4ad9-40d9-a3c0-8c05cf3d417a",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base_travel"
        },
        {
          "id": "item-086380a5-6d0e-40b0-8c5a-add4b3187587",
          "type": "dialogue",
          "characterId": null,
          "text": "The train pulls east. Iron joints click like latches closing behind me."
        },
        {
          "id": "item-5c8873a0-f600-4158-87af-6c09f9585836",
          "type": "dialogue",
          "characterId": null,
          "text": "Coal smoke, damp wool, rain on glass. The third-class bench is hard."
        },
        {
          "id": "item-47ce0177-3ed2-4b9b-af91-4b27550e8284",
          "type": "dialogue",
          "characterId": null,
          "text": "London is not a destination. It is an escape with teeth."
        },
        {
          "id": "item-65f1016d-6c31-48bc-b0ed-1e248f8326c8",
          "type": "dialogue",
          "characterId": null,
          "text": "Wiltshire recedes into the smog. My satchel is at my feet, my manuscript hidden inside."
        },
        {
          "id": "item-15f0ee77-5de1-4f96-81ab-7d0ea8676a3a",
          "type": "dialogue",
          "characterId": null,
          "text": "They will think me an English country girl. They must never hear the Cork in my throat."
        },
        {
          "id": "item-8f60cd71-1601-48e7-a5d4-1df41e2aca7f",
          "type": "dialogue",
          "characterId": null,
          "text": "To survive there, I must decide what shape I will take. How will I move through the Savoy?"
        },
        {
          "type": "choice",
          "options": [
            {
              "id": "f7d04f7d-70ba-4cdc-b1f8-1090c9ba6483",
              "text": "By becoming unseen, listening, and moving through the gaps. [[Ghost Focus: +1 Ghost]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "story.set_run_archetype_seed(\"ghost\")",
                  "id": "item-32345337-f0cb-49c7-bcc4-d4c25d40b2da"
                },
                {
                  "type": "python_script",
                  "code": "apply_archetype_edge(\"ghost\", 1)",
                  "id": "item-c392e468-94c0-41bd-bfff-1397ed8ac7ec"
                },
                {
                  "id": "item-9a6396dd-0f4a-4fc5-8705-d3d63b607c75",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Yes. Let them look past me. I will be the shadow that hears everything and says nothing."
                },
                {
                  "id": "item-2ebf157a-fc6b-46cd-8884-5797397eb001",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "A ghost is never trapped. A ghost has already escaped."
                }
              ]
            },
            {
              "id": "192c43aa-9820-4432-9465-5b3d131806c4",
              "text": "By reading the threat, appeasing them, and redirecting the danger. [[Prey Focus: +1 Prey]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "story.set_run_archetype_seed(\"prey\")",
                  "id": "item-e43b7802-d575-41dd-9417-e0b3b172b1cd"
                },
                {
                  "type": "python_script",
                  "code": "apply_archetype_edge(\"prey\", 1)",
                  "id": "item-73824646-40be-4e44-895a-ba14c65d9f4f"
                },
                {
                  "id": "item-7914e732-eb8a-4e0a-8ce2-54f83adbdb1a",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Yes. I will know their weight before they swing it. I will bend so I do not break."
                },
                {
                  "id": "item-62905778-bbe5-4077-a9ec-8afa393d5b17",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The prey knows the forest better than the hunter ever will."
                }
              ]
            },
            {
              "id": "a48a9976-4136-4353-ad58-0705b16e1a36",
              "text": "By testing their boundaries, baiting them, and beginning to use them as material. [[Predator Focus: +1 Predator]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "story.set_run_archetype_seed(\"predator\")",
                  "id": "item-db630f5a-b826-4ca8-984d-146b850fbeb1"
                },
                {
                  "type": "python_script",
                  "code": "apply_archetype_edge(\"predator\", 1)",
                  "id": "item-449cd350-998f-44a5-868c-d7e4f357db22"
                },
                {
                  "id": "item-3d3487db-a166-4ee8-be33-38ca1138d8c5",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Yes. I will find where they are soft. I will provoke them until they show their teeth, and then I will write it."
                },
                {
                  "id": "item-9ba3828e-c09c-4d81-9d9a-6ad55462a551",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Let them hunt. I will be the one who feeds on the aftermath."
                }
              ]
            }
          ],
          "id": "item-e97df478-4825-47b5-898e-58d77643c166"
        },
        {
          "id": "item-659536d1-219d-4ce3-98c5-e98436d5c64e",
          "type": "dialogue",
          "characterId": null,
          "text": "If I close my eyes, the coal grease smells of the withdrawing room's velvet heat."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "0087df92-fcac-4a10-add0-13b8403b3e76",
              "type": "if",
              "conditionRaw": "story.prologue_found == \"overheard\"",
              "dialogue": [
                {
                  "id": "item-5b101071-b67d-4789-ade9-d2e6eba1afb1",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I replay the parlour's breath until the carriage rocks in time with it."
                },
                {
                  "id": "item-e96ee46d-82ae-417e-a504-75524ca65ab4",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Margaret's rough hands in Eleanor's pinned hair. The Lady's helpless, gasping surrender."
                },
                {
                  "id": "item-84e90604-a1f4-4d0d-823d-a994b7bccc4e",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The raw reality of mistress opened where no vicar could see."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.prologue_found == \"overheard\""
            },
            {
              "id": "0eed94d2-b32c-45ca-ae25-40961bf5e4eb",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-30535bc5-0f4a-4437-be0f-7ef0c7c720f4",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I replay the letters' ink until the words move on my skin like Margaret's plain sleeves."
                },
                {
                  "id": "item-8d58814f-d0ed-4600-a0c2-0bbffffdc42e",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Wrists held at the laundry press. Mouth at the throat. Eleanor's ink-wet confession."
                },
                {
                  "id": "item-d0aa0624-2beb-4c79-991d-5885d784b356",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Desire written in black ink, transferring heat to my thighs."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-b23eba19-05e3-4092-9e5c-6904ccd98445"
        },
        {
          "id": "item-4fb0ebeb-6eca-4639-a6ff-9c356263868d",
          "type": "dialogue",
          "characterId": null,
          "text": "In the daydream I am not the maid at the door. I am the author who opened it."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "250549f0-2f21-4fb3-8788-99bdda40ca15",
              "type": "if",
              "conditionRaw": "story.prologue_holywell_posture == \"careful\"",
              "dialogue": [
                {
                  "id": "item-fdc38ef4-6578-4c0e-8ae2-2d88e13ec250",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I write the undoing slowly — a button, a breath — enough to sell, not enough to hang me."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.prologue_holywell_posture == \"careful\""
            },
            {
              "id": "cf07ca81-ad6d-43a3-b9ae-c0cd69ef5b2d",
              "type": "elif",
              "conditionRaw": "story.prologue_holywell_posture == \"eager\"",
              "dialogue": [
                {
                  "id": "item-63185990-4ff6-4441-ad2a-a3bd6ca44255",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I write faster than shame can catch me. Slide the coins across before the ink dries."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.prologue_holywell_posture == \"eager\""
            },
            {
              "id": "911d604d-257a-44fe-9517-4801d721d335",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-aa2c8274-a067-4e68-907c-d87c9a4b61a3",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I write until the reader looks away, flushed. Desperation makes good spice."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-73cdcb0a-20ba-4b80-b3b7-ab5d1bc9237f"
        },
        {
          "id": "item-ba60ebbc-0f33-4bd3-b533-04da07834e87",
          "type": "dialogue",
          "characterId": null,
          "text": "The fantasy is mine, and the hunger travels with me to London."
        },
        {
          "id": "item-aa3d6f39-7c2d-48c9-84e8-76f75dd8a504",
          "type": "jump",
          "destinationLabelId": "label-61d2c344-a4f2-4dc0-b8dc-eb30b2a59983"
        }
      ]
    },
    {
      "id": "label-61d2c344-a4f2-4dc0-b8dc-eb30b2a59983",
      "name": "day100_3_arrival",
      "x": 3700,
      "y": 11885,
      "dialogue": [
        {
          "id": "item-8808fb52-b1b5-42e4-8c2c-f69c31b656c6",
          "type": "dialogue",
          "characterId": null,
          "text": "The train whistle screams. A metal throat tearing through the smog."
        },
        {
          "id": "item-a5f50701-e110-46da-9bf4-40698d0a325b",
          "type": "dialogue",
          "characterId": null,
          "text": "The carriage lurches as we hit the Waterloo points. My satchel slips."
        },
        {
          "id": "item-3cf5cfde-769d-4c59-a246-52ee8e8fd5bf",
          "type": "dialogue",
          "characterId": null,
          "text": "Pages scatter across the dirty floorboards — my manuscript, bold where it should be chaste."
        },
        {
          "id": "item-382a0404-d557-475e-a1f0-9c946af0495a",
          "type": "dialogue",
          "characterId": null,
          "text": "The gentleman opposite lowers his newspaper. His gaze drifts toward the floor."
        },
        {
          "id": "item-032b2d98-7162-470d-a200-6625a39dc967",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Forgive me, sir."
        },
        {
          "id": "item-5ea8433a-6477-4f70-943c-1a82a995ea8a",
          "type": "dialogue",
          "characterId": null,
          "text": "Three words. Flat. Safe. English as a parson's daughter."
        },
        {
          "id": "item-412121db-1750-4fe8-a81d-beb5e4297d74",
          "type": "dialogue",
          "characterId": null,
          "text": "I sweep the sheets under my skirt before he can read a single line."
        },
        {
          "id": "item-22785f9d-b3aa-4a45-af4c-6c240c9c9f82",
          "type": "dialogue",
          "characterId": null,
          "text": "He clears his throat and raises the paper — politeness as a wall."
        },
        {
          "id": "item-20563a5c-6d58-482e-a3a5-7d9adb4ea68f",
          "type": "dialogue",
          "characterId": null,
          "text": "I buckle the satchel. My fingers tremble."
        },
        {
          "id": "item-16aab5f6-9126-4dd6-b74c-8d0642addb3b",
          "type": "dialogue",
          "characterId": null,
          "text": "Outside, Waterloo's iron ribs rise through the soot."
        },
        {
          "id": "item-0b51f5d4-4bb2-4cfc-8bc5-b3c5bbe22f5b",
          "type": "dialogue",
          "characterId": null,
          "text": "The Savoy waits — employment, mask, material."
        },
        {
          "id": "item-547239a4-fcbc-45fb-abd8-be737167e022",
          "type": "dialogue",
          "characterId": null,
          "text": "Holywell waits — payment, risk, the author I pretend I am destined to become."
        },
        {
          "id": "item-7a9225c2-7902-45c3-90b8-5c3c60718b6a",
          "type": "dialogue",
          "characterId": null,
          "text": "Very well. Let it try."
        },
        {
          "type": "python_script",
          "code": "time_manager.set_current_day(1)",
          "id": "item-20eac108-b355-43bf-8c49-e0427e11deb4"
        },
        {
          "type": "python_script",
          "code": "set_time_period(\"Morning\")",
          "id": "item-355aca5a-f8d8-4a4c-be2e-a32dc95d205f"
        },
        {
          "id": "item-8bf846cc-9862-4a45-9fe8-cdad9aa5e999",
          "type": "jump",
          "destinationLabelId": "label-b9a3a3d9-b027-4724-b94f-2f1f9f83efe2"
        }
      ]
    },
    {
      "id": "label-b9a3a3d9-b027-4724-b94f-2f1f9f83efe2",
      "name": "day101_main",
      "x": 4100,
      "y": 11885,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "fade",
          "id": "item-ef6c483b-1fc5-4919-9cb6-148331946bfb",
          "backgroundId": "bg_savoy_corridor_morning"
        },
        {
          "id": "item-23704cc4-56eb-4140-93b4-4ef46fd02695",
          "type": "dialogue",
          "characterId": null,
          "text": "The Savoy does not merely employ girls like me. It strips them of their names, swallows them down, and polishes the brass with whatever is left."
        },
        {
          "id": "item-b6a1071b-9fff-44e2-95d2-870b51ef36e9",
          "type": "dialogue",
          "characterId": null,
          "text": "I hold my breath against the heavy, suffocating scent of expensive coal smoke, gas lamps, and the wet lavender water used to mask the smell of London's rot."
        },
        {
          "id": "item-33577b20-5238-444b-ac91-e4af1a8ee36b",
          "type": "dialogue",
          "characterId": null,
          "text": "Behind my teeth, my mother's soft, looping Cork lilt scrambles to escape. I force it down. Deep. Below the floorboards."
        },
        {
          "id": "item-433c335e-f758-4350-9448-2e2c2ca2f28a",
          "type": "dialogue",
          "characterId": null,
          "text": "Here, I must speak with the rounded, flat, hollow vowels of a Wiltshire parson's daughter. A single slip—one wild, soft Irish consonant—and my papers will be matches for the grate."
        },
        {
          "id": "item-3888c5cb-6e5a-4b1d-80c1-cb775b1d0769",
          "type": "dialogue",
          "characterId": null,
          "text": "And after the grate? The workhouse. Or the damp, gas-lit alleys of Holywell Street, selling my skin where I once hoped to sell my words."
        },
        {
          "id": "item-07c0680b-699a-4626-9adf-4f050d1dbf3d",
          "type": "jump",
          "destinationLabelId": "label-280b569a-562e-4c58-9009-61dbe5a7fba6"
        }
      ]
    },
    {
      "id": "label-280b569a-562e-4c58-9009-61dbe5a7fba6",
      "name": "day101_1_cora_waiting",
      "x": 4500,
      "y": 11885,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-82337260-6728-4c7b-8d39-a9bb644a8fe1",
          "backgroundId": "bg_savoy_corridor_morning"
        },
        {
          "id": "item-be1ef69d-5d6b-490f-86b2-3e0f2996ec25",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.1,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "dissolve",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite guarded_travel"
        },
        {
          "id": "item-8912851b-2233-43b0-bdbb-245e54ff976c",
          "type": "dialogue",
          "characterId": null,
          "text": "I stand outside Miss Stern's door, my traveling dress damp at the hem, my palms sweating against my small valise."
        },
        {
          "id": "item-6efc6a31-e765-443d-997b-609d821c75ed",
          "type": "dialogue",
          "characterId": null,
          "text": "Sir John's reference sits in my pocket like a blade with his name on the handle. He gave it cold, conditional, already regretted. If Stern smells the ink of my lies, the trap slams shut before I begin."
        },
        {
          "id": "item-b4bb66c9-534a-44ea-979a-84bffc65015b",
          "type": "dialogue",
          "characterId": null,
          "text": "From behind the heavy mahogany door, a clock ticks with a heavy, metallic precision—the heartbeat of a house that owns every second of my day."
        },
        {
          "id": "item-a75d4fc0-59a7-4840-abc5-3e58b493f61c",
          "type": "dialogue",
          "characterId": null,
          "text": "A maid passes carrying towels white enough to blind. A footman steps past with a silver tray."
        },
        {
          "id": "item-ecf9686a-14f2-4605-ac70-563ea3904916",
          "type": "dialogue",
          "characterId": null,
          "text": "No one asks who I am."
        },
        {
          "id": "item-1acdfcae-3a84-49ce-97bb-28e994a1e17c",
          "type": "dialogue",
          "characterId": null,
          "text": "That is the first rule of this place. Be useful enough to ignore."
        },
        {
          "id": "item-69702cb2-2418-4b4d-af9a-4f3694c0456b",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "Enter."
        },
        {
          "id": "item-dec08823-99c4-4b91-b90e-9fe04a2792f6",
          "type": "jump",
          "destinationLabelId": "label-66136659-6ab9-48a8-b64a-efa9d6a6e1bf"
        }
      ]
    },
    {
      "id": "label-66136659-6ab9-48a8-b64a-efa9d6a6e1bf",
      "name": "day101_1_morning_interview",
      "x": 4900,
      "y": 11885,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-1076122e-59d8-46a9-b4b4-a386b0b17109",
          "backgroundId": "bg_stern_office_entrance"
        },
        {
          "id": "item-76526a3a-a5d6-4246-99a0-75a4229256bc",
          "type": "show",
          "characterId": "stern_sprite",
          "isFlipped": false,
          "xpos": 0.9,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "stern_sprite neutral"
        },
        {
          "id": "item-1bfafde8-6e18-498f-aa9c-22630e27337d",
          "type": "dialogue",
          "characterId": null,
          "text": "Miss Stern stands rather than sits."
        },
        {
          "id": "item-1a3b1c53-3327-4a1f-b3fb-58e5c9e1e723",
          "type": "dialogue",
          "characterId": null,
          "text": "It is not courtesy. It is measurement."
        },
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-fdfee065-ff83-43df-a589-48889e4a5047",
          "backgroundId": "bg_stern_office_reverse"
        },
        {
          "type": "hide",
          "layer": null,
          "id": "item-7a4fb1fe-2074-4a65-87b5-f2b104d99603",
          "characterId": "bg_stern_office_entrance"
        },
        {
          "type": "hide",
          "layer": null,
          "id": "item-4aa140ab-6313-49af-947e-00747345c779",
          "characterId": "stern_sprite neutral"
        },
        {
          "id": "item-fea27da0-4e15-4af6-9906-6cc18e0cdcd5",
          "type": "show",
          "characterId": "stern_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "stern_sprite neutral"
        },
        {
          "id": "item-e5b4ab4d-3602-46a3-af5d-df8f01eb1315",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "dissolve",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base_travel"
        },
        {
          "id": "item-22737cc7-6e87-47af-b6fe-9a6f56b65acb",
          "type": "dialogue",
          "characterId": null,
          "text": "Her eyes move from my cap to my boots."
        },
        {
          "id": "item-d0d6c905-2a72-4622-970e-6683fb8af368",
          "type": "dialogue",
          "characterId": null,
          "text": "Weighing every inch for disobedience."
        },
        {
          "id": "item-42699b42-5cb2-47a9-b271-76f4c528fc50",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "Cora Vale."
        },
        {
          "id": "item-6936549e-cf1d-4bfa-a301-94dfb151cf50",
          "type": "show",
          "characterId": "stern_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "stern_sprite neutral"
        },
        {
          "id": "item-9fb9f3b4-435b-4119-9884-5b031cc0787e",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "moveinleft",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base_travel"
        },
        {
          "id": "item-bd724201-b690-43ca-bc90-4a4f7ce1d41b",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Yes, Ma'am."
        },
        {
          "id": "item-e6c40fa0-a241-48c8-a088-955d5cda62a7",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "Sir John's reference speaks to your quiet nature. Your lack of curiosity."
        },
        {
          "id": "item-25fb04cb-214f-4238-8b14-4fd308d5924a",
          "type": "dialogue",
          "characterId": null,
          "text": "The paper is his leash. Wiltshire ended in dismissal at his wife's behest—not in my triumph."
        },
        {
          "id": "item-1f59f2e1-0512-4876-ad47-31f580314d13",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "I keep my eyes on my work, Ma'am."
        },
        {
          "id": "item-63014425-968a-45dd-bbb0-0059f11291ed",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "You have worked in service before."
        },
        {
          "id": "item-64afafff-6144-4ef0-bcc7-bb29c97dbfa4",
          "type": "dialogue",
          "characterId": null,
          "text": "The lie is waiting for me, neat as a folded sheet."
        },
        {
          "id": "item-91892697-6cdf-4875-b1a8-0fb54b7f8818",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Yes, Ma'am. In the country."
        },
        {
          "id": "item-32c49c2c-2d24-4152-8f73-bcb9d4f5bc22",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "The country forgives slowness. The Savoy does not."
        },
        {
          "id": "item-e5655da3-f187-40fd-8a1e-1a9f2c5cd2c8",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "A maid in this house is hands without noise, feet without weight, and memory without a tongue."
        },
        {
          "id": "item-bd2c32f9-9947-4194-bf31-5467d9ef99e8",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "Can you be that?"
        },
        {
          "type": "choice",
          "options": [
            {
              "id": "c97e085f-32c0-4996-894b-3ce180ab8543",
              "text": "Lower my eyes. Let her mistake fear for obedience.",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"observant\", intensity=\"standard\")",
                  "id": "item-f1fe9a84-ae5d-486b-abaa-95748b014b25"
                },
                {
                  "type": "python_script",
                  "code": "story.set_day1_interview_state(\"meek\")",
                  "id": "item-1d87648b-9993-4c7b-93a7-97a60ee7d997"
                },
                {
                  "type": "python_script",
                  "code": "apply_archetype_edge(\"prey\", 1)",
                  "id": "item-6191ebcb-6d25-4c36-9d0d-e06f17e41e9d"
                },
                {
                  "id": "item-d7ee73f9-f68a-4043-a1a1-d4ea392b3edc",
                  "type": "show",
                  "characterId": "cora_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "cora_sprite guarded_travel"
                },
                {
                  "id": "item-cd0f3512-079c-4c89-a532-c1bdb52d83c1",
                  "type": "show",
                  "characterId": "stern_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "dissolve",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "stern_sprite neutral"
                },
                {
                  "id": "item-04052f6a-453f-444e-8311-85b46ab06633",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "I can, Ma'am. I only wish to work hard."
                },
                {
                  "id": "item-174582e8-a698-4421-a422-76e0531f1f55",
                  "type": "dialogue",
                  "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
                  "text": "Wishing is for girls with leisure. You will work because you are told."
                },
                {
                  "id": "item-a7a2c33f-1248-40e8-aad1-4638713e8402",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "Yes, Ma'am."
                },
                {
                  "id": "item-d5562632-5b3b-42e6-9886-d9e7cb2684c3",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She hears a dull country girl."
                },
                {
                  "id": "item-4d32f16e-32ad-425d-aae4-b686c5b88534",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Good. Let the woman keep that version of me."
                }
              ]
            },
            {
              "id": "0e5fc279-a14a-4cbe-addc-7c521763af83",
              "text": "Answer cleanly. Let competence do what meekness cannot.",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"transgressive\", intensity=\"standard\", witness=\"stern\")",
                  "id": "item-de022474-b61f-4686-be69-caaa53bedfe4"
                },
                {
                  "type": "python_script",
                  "code": "story.set_day1_interview_state(\"competent\")",
                  "id": "item-085039ea-2cda-4e2c-a872-b873bd5380d4"
                },
                {
                  "type": "python_script",
                  "code": "apply_archetype_edge(\"ghost\", 1)",
                  "id": "item-bbc3e8de-3d79-4c61-bfe1-52af9fbb5571"
                },
                {
                  "id": "item-e1feb8f6-355b-41f6-9344-315962b489e3",
                  "type": "show",
                  "characterId": "cora_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "cora_sprite base_travel"
                },
                {
                  "id": "item-c31d29e8-a071-493b-be06-f350370c2f60",
                  "type": "show",
                  "characterId": "stern_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "dissolve",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "stern_sprite neutral"
                },
                {
                  "id": "item-fed9722c-a553-4764-b858-44e7915ee5ca",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "I can be quiet, quick, and exact. If I err, it will not be from carelessness."
                },
                {
                  "id": "item-bfb2909d-bcbf-4913-9410-4fa0c01fc021",
                  "type": "dialogue",
                  "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
                  "text": "Exact?"
                },
                {
                  "id": "item-a80d3b62-0a35-454a-a90b-8e6ef7827c32",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "Yes, Ma'am."
                },
                {
                  "id": "item-d6e42624-60cf-4ccb-9a3a-276c4aa4650b",
                  "type": "dialogue",
                  "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
                  "text": "A dangerous word from a girl in a borrowed apron."
                },
                {
                  "id": "item-bf06ef3d-9d25-4499-8dc1-d96c2e3f43ed",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "There."
                },
                {
                  "id": "item-5b022360-76d5-442e-9e4a-1720c6ef3481",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She sees it. Not all of it, but enough to dislike me."
                }
              ]
            }
          ],
          "id": "item-dbfaf310-6bb0-46ec-b5b5-b7c697809485"
        },
        {
          "id": "item-46ea69e0-f9b9-41ac-8598-bf833c2e073c",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "You speak with some polish, Vale. But polish can hide a great deal of dust."
        },
        {
          "id": "item-0dd86c07-1238-4b8c-8286-1c3f228d1c11",
          "type": "dialogue",
          "characterId": null,
          "text": "Miss Stern steps from behind her desk. Her leather boots click with slow, deliberate pacing."
        },
        {
          "id": "item-51615546-085c-4d89-8af1-ae41b44811ef",
          "type": "dialogue",
          "characterId": null,
          "text": "The scent of starch, vinegar, and cold lavender presses into my space. She stops inches from me, her height casting a long shadow over my face."
        },
        {
          "id": "item-10108cc1-7769-4ea7-ae04-d058077c58af",
          "type": "dialogue",
          "characterId": null,
          "text": "With a slow, clinical movement, she reaches out. Her fingers—dry, firm, and smelling faintly of carbolic soap—brush the collar of my traveling dress, tracing the line of my throat with a lingering, diagnostic pressure."
        },
        {
          "type": "choice",
          "options": [
            {
              "id": "3b7451f6-6789-450c-b687-546bdc514d64",
              "text": "Lower my chin, allowing her fingers to adjust the fabric, matching her slow rhythm.",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"observant\", intensity=\"standard\")",
                  "id": "item-02e4cff3-6a16-4405-9669-7aa58608b8b9"
                },
                {
                  "type": "python_script",
                  "code": "story.set_day1_stern_relation(\"subservient\")",
                  "id": "item-e83e3159-1d96-49d3-9a77-ebc69cbea3d7"
                },
                {
                  "type": "python_script",
                  "code": "apply_archetype_edge(\"prey\", 1)",
                  "id": "item-5caeeaec-df17-4dcf-9040-e01eed41b82a"
                },
                {
                  "id": "item-635bc52e-7bf8-46ad-8781-bef192be0f91",
                  "type": "show",
                  "characterId": "cora_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "dissolve",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "cora_sprite guarded_travel"
                },
                {
                  "id": "item-42df4d57-c422-4297-85eb-4db3f93389d4",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "I... I only wish to give satisfaction, Ma'am."
                },
                {
                  "id": "item-f0005bb6-6c07-474d-affe-053c5b98b6cc",
                  "type": "dialogue",
                  "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
                  "text": "Satisfaction is a transaction, Vale. I buy your silence and your labor. See that you do not default on either."
                },
                {
                  "id": "item-b02f08a7-7e06-4ef6-90f5-d7e63da435ce",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Her fingers are cold against my neck, a physical threat dressed as administrative care. I keep my breathing shallow, letting her feel the tremor she expects."
                }
              ]
            },
            {
              "id": "3f252883-4c25-4d7a-8f4a-32def338bb26",
              "text": "Stand perfectly rigid, holding my breath to mask my pulse, letting her treat me like a mannequin.",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"transgressive\", intensity=\"standard\", witness=\"stern\")",
                  "id": "item-42bfb9b1-d629-40d9-af4e-68c25148c714"
                },
                {
                  "type": "python_script",
                  "code": "story.set_day1_stern_relation(\"resistant\")",
                  "id": "item-bcd727ed-3df5-45de-af81-2e31ff82aa71"
                },
                {
                  "type": "python_script",
                  "code": "apply_archetype_edge(\"ghost\", 1)",
                  "id": "item-ed6ed271-9d39-4ca0-86f4-4da7979cb33b"
                },
                {
                  "id": "item-5cb3a53c-1eca-4aea-b0ef-7f05ab2d46da",
                  "type": "show",
                  "characterId": "cora_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "dissolve",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "cora_sprite base_travel"
                },
                {
                  "id": "item-ec0af8be-d0f3-4303-ba0f-741b733eae41",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "Yes, Ma'am."
                },
                {
                  "id": "item-76b40789-e0d9-4d08-b873-ce9d2f2faec1",
                  "type": "dialogue",
                  "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
                  "text": "A stone does not flinch when it is touched, Vale. But stones have no thoughts of their own. Can you be a stone?"
                },
                {
                  "id": "item-1c60e0e8-9f66-4a07-acc1-f56f3db50f1e",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "I can, Ma'am."
                },
                {
                  "id": "item-e8428096-eae1-4b04-8f6c-682a7535a243",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I turn my gaze to the brass buttons of her jacket, letting my eyes glaze. My body is a weight she may arrange as she pleases, but my mind is somewhere else entirely."
                },
                {
                  "id": "item-65c54d14-1cc0-424f-9f94-27aba569ef9f",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Unseen, untouched. A ghost in her own skin."
                }
              ]
            },
            {
              "id": "7474bfc9-9294-480a-bfce-3b606fbeb6b9",
              "text": "Meet her gaze directly through the closeness, accepting the intrusion with a steady pulse.",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"transgressive\", intensity=\"standard\", witness=\"stern\")",
                  "id": "item-94c11f30-c88f-4dad-ba6d-6ef22c4fb008"
                },
                {
                  "type": "python_script",
                  "code": "story.set_day1_stern_relation(\"complicit\")",
                  "id": "item-5c8702a2-a76a-4821-b913-718a473692a3"
                },
                {
                  "type": "python_script",
                  "code": "apply_archetype_edge(\"predator\", 1)",
                  "id": "item-967ae2a4-abbd-46b1-8500-26698ce5232d"
                },
                {
                  "id": "item-5145d8af-0c8a-4b30-a315-4ab072468565",
                  "type": "show",
                  "characterId": "cora_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "dissolve",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "cora_sprite base_travel"
                },
                {
                  "id": "item-a7e0f0de-4ebf-4081-8b19-da909ea3f287",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "I understand the value of a proper fit, Ma'am."
                },
                {
                  "id": "item-5a4cecd3-45b3-4af1-8774-ba3ebbc5b985",
                  "type": "dialogue",
                  "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
                  "text": "Do you?"
                },
                {
                  "id": "item-f6a9eff3-fd93-45fb-a73d-62ba774511cd",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Miss Stern's thumb presses hard against the hollow above my collarbone, a brief, sharp warning before she slowly slides her hand down to lift my chin."
                },
                {
                  "id": "item-469f6728-eb5e-4ce9-b1e1-4ee78d1feba7",
                  "type": "dialogue",
                  "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
                  "text": "A maid who looks back is a maid who wants to be noticed, Vale. And noticed maids in the Savoy do not last long enough to collect their first quarter's wages."
                },
                {
                  "id": "item-19b4585f-624e-4e1e-ba2e-218b064ab7b6",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Her touch is hot, deliberate. It is not morality that guides her hand—it is the sheer, intoxicating pleasure of absolute control."
                },
                {
                  "id": "item-44d5700d-5f7c-47f6-acb1-d3b1aa7ce2b0",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I did not look away. She knows now I am measuring her, too."
                }
              ]
            }
          ],
          "id": "item-e2b8ea7b-e560-4804-a104-8e0f0676bf8e"
        },
        {
          "id": "item-8b6b3b30-4ec4-4235-9726-ce1e3b0d544d",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "The guests here are... particular, Vale. They have expensive tastes and very short memories. Some maids think they can trade their secrets for silk, or their bodies for a gentleman's favor."
        },
        {
          "id": "item-7c8a0a67-625a-45c4-bb3d-20585057c69a",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "They always end up on the street, or worse."
        },
        {
          "id": "item-14119397-dd70-4813-9e9f-539b98a74059",
          "type": "dialogue",
          "characterId": null,
          "text": "She paces behind her desk, her gaze remaining on my lips."
        },
        {
          "id": "item-fe489798-c398-46b7-a442-08b8a52fc6ac",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "If a gentleman offers you a trinket, or asks you to enter his room when his wife is out... do you understand what happens to girls who lose their tongue, or keep it for the wrong price?"
        },
        {
          "type": "choice",
          "options": [
            {
              "id": "011f8374-a360-4dc9-b280-effefdf684c1",
              "text": "Lower my head, speaking with flat utility: 'I will keep my head down, Ma'am.'",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"observant\", intensity=\"standard\")",
                  "id": "item-07dbc8b6-b4d1-445c-acef-37fc7e36d672"
                },
                {
                  "type": "python_script",
                  "code": "story.set_day1_stern_secret_bound(\"fearful\")",
                  "id": "item-b97032e6-83f3-4b7d-9823-25f6652bd9bb"
                },
                {
                  "type": "python_script",
                  "code": "apply_archetype_edge(\"prey\", 1)",
                  "id": "item-05836e56-90f4-4f14-bea7-a7220bc7a182"
                },
                {
                  "id": "item-9acce99a-5580-4664-95d3-c896022874cb",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "I will keep my head down, Ma'am. I have no interest in the guests."
                },
                {
                  "id": "item-6ce4c941-f607-43da-933b-5e4253011854",
                  "type": "dialogue",
                  "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
                  "text": "Interest is a luxury. Avoidance is a chore. See that you do it."
                },
                {
                  "id": "item-6d41eba5-3595-4ad4-8ecd-bcccb7247141",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The warning works. She sees a frightened country girl who knows her place is a narrow ledge."
                }
              ]
            },
            {
              "id": "643358c9-e3cc-476b-853a-51d7267f43a9",
              "text": "Keep my tone even, professional, and empty: 'I only see the work, Ma'am.'",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"observant\", intensity=\"standard\")",
                  "id": "item-428cfecc-3558-4455-b681-944eb68ce188"
                },
                {
                  "type": "python_script",
                  "code": "story.set_day1_stern_secret_bound(\"loyal\")",
                  "id": "item-00a717d1-62dc-4b6f-9f93-aa237597350e"
                },
                {
                  "type": "python_script",
                  "code": "apply_archetype_edge(\"ghost\", 1)",
                  "id": "item-4d21aa8d-b123-4a27-8f61-e2b8fb478250"
                },
                {
                  "id": "item-07321fee-d3e9-4a71-9a7f-1cb53b32a454",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "I only see the work, Ma'am. The rooms are empty to me until they are cleaned."
                },
                {
                  "id": "item-56408d0c-9a39-4f31-a4d4-7a545849db7d",
                  "type": "dialogue",
                  "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
                  "text": "An excellent answer. Keep it true, and we shall have no difficulties."
                },
                {
                  "id": "item-8ece6af6-b428-48a5-9013-91f25fb5af9c",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Empty rooms, empty faces. I will be the draft that blows through them, leaving no trace."
                }
              ]
            },
            {
              "id": "958716a4-0d0d-46fc-94a7-c76eeae3ef27",
              "text": "Meet her eyes with quiet audacity: 'I know how to keep secrets, Ma'am—and those of the house.'",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"transgressive\", intensity=\"standard\", witness=\"stern\")",
                  "id": "item-aa61d0cf-0c91-4aca-a3e3-07757e5e25a7"
                },
                {
                  "type": "python_script",
                  "code": "story.set_day1_stern_secret_bound(\"exploitative\")",
                  "id": "item-e4a0e14c-9477-4481-8e02-1ccdf0cb197c"
                },
                {
                  "type": "python_script",
                  "code": "apply_archetype_edge(\"predator\", 1)",
                  "id": "item-d984ce8c-8e62-4f70-a0d0-fb75109e4228"
                },
                {
                  "id": "item-6ef4d57f-b4fc-434a-a7a5-d09bdce02209",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "I know how to keep secrets, Ma'am—and those of the house."
                },
                {
                  "id": "item-51f6c0bf-4fbf-4eb7-910d-b2b9c18bc342",
                  "type": "dialogue",
                  "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
                  "text": "Secrets? A maid has no secrets, Vale. She only has duties. Remember that, or I will ensure your references become as blank as your future."
                },
                {
                  "id": "item-1c782ec6-46e3-46c8-acdf-84efd42fa71b",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "A slip. I let her see the ink beneath the starch."
                },
                {
                  "id": "item-7699c4d9-ad7e-4846-aa80-cb257fca42ab",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "But her eyes flared. She knows now that I am not just a maid; I am a witness. And witnesses can be bought, or they can be feared."
                }
              ]
            }
          ],
          "id": "item-31f9750a-0dce-478e-b992-f03a02c2838a"
        },
        {
          "id": "item-f74b50fd-a896-4a2e-b0c9-47b5785f6b74",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "You will report to the laundry first. Missy will show you the necessary route."
        },
        {
          "id": "item-deae1dec-47f5-4e95-95ae-4f33cc81c753",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "You will not wander. You will not question guests. You will not cultivate opinions."
        },
        {
          "id": "item-011223d4-6bb3-4863-b310-4a27f48d6be5",
          "type": "dialogue",
          "characterId": null,
          "text": "Too late for that."
        },
        {
          "id": "item-cb213db9-6062-42d8-a680-bb9a3b57c178",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "And if a guest drops something, breaks something, or throws something, you will retrieve it without expression."
        },
        {
          "type": "hide",
          "layer": null,
          "id": "item-dc10a73d-bdc5-498b-a05a-dff40a9dec3d",
          "characterId": "stern_sprite"
        },
        {
          "id": "item-6e42ffc4-3a9d-46ef-bdf0-dfdca62e8d80",
          "type": "jump",
          "destinationLabelId": "label-37b418f0-1c56-4fe0-b029-a1b1b477b768"
        }
      ]
    },
    {
      "id": "label-37b418f0-1c56-4fe0-b029-a1b1b477b768",
      "name": "day101_1_vance_throws_toy",
      "x": 5300,
      "y": 11885,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-a0235ace-8572-4229-8569-62aaccae5b87",
          "backgroundId": "bg_savoy_corridor_morning"
        },
        {
          "id": "item-b38d8dc5-6549-4049-b288-70e02d6827b5",
          "type": "dialogue",
          "characterId": null,
          "text": "The guest wing corridor gleams—mahogany, gloss, and velvet restraint."
        },
        {
          "id": "item-11027a6d-0374-43ec-9e54-56bc90765ce8",
          "type": "dialogue",
          "characterId": null,
          "text": "I halt at the threshold between office and stairs, arms laden with clean linen."
        },
        {
          "id": "item-ab985688-958f-41fc-8d5a-48ef497ed8ba",
          "type": "dialogue",
          "characterId": null,
          "text": "A sharp clatter cracks against the wainscoting. A silver-gilt crystal scent-bottle spins across the carpet, spilling amber jasmine oil."
        },
        {
          "id": "item-c7b4c6d5-5008-4b79-ade3-6e652c42ca3e",
          "type": "show",
          "characterId": "vance_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "vance_sprite angry"
        },
        {
          "id": "item-d52e390c-66e3-4711-91f5-291ca8844ce5",
          "type": "dialogue",
          "characterId": null,
          "text": "A footman retreats, eyes lowered, as if escaping a blow."
        },
        {
          "id": "item-910522f5-d106-44fc-9c7b-ce3256d8d71a",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "Stupid, useless boy! I said the lavender toilet-water, not this vulgar, suffocating grease!"
        },
        {
          "id": "item-b73beaf4-384e-42d3-bc72-a33979e85c74",
          "type": "dialogue",
          "characterId": null,
          "text": "She paces, breath shallow, cheeks flushed high under lacquered hair. The spilled scent hangs thick and hot, filling the narrow space with floral pressure."
        },
        {
          "id": "item-e9d8b94a-3bf2-4d94-9361-82d167920f05",
          "type": "dialogue",
          "characterId": null,
          "text": "Her gaze swings wildly, landing on me. Her chest rises and falls against stiff silk."
        },
        {
          "id": "item-a44cdfa8-77bb-49d4-93d3-ae04483b79cd",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "You. Girl. Do not stand there like a post. Pick it up before it stains the master's carpet."
        },
        {
          "id": "item-d53e8b50-d5e0-43c6-bde0-a770a88e952e",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "moveinleft",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base_travel"
        },
        {
          "id": "item-29d8333b-6056-4ff4-ae95-0731cddf027b",
          "type": "dialogue",
          "characterId": null,
          "text": "Her voice is velvet and grit—authority arranged, but trembling with petulant irritation."
        },
        {
          "id": "item-4a0eae4a-d329-4897-b4b8-fcb0baa8bae3",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Yes, Miss."
        },
        {
          "id": "item-c766fe73-e274-43c0-80fc-7a902a0036eb",
          "type": "dialogue",
          "characterId": null,
          "text": "I pause. The jasmine oil has pooled on the red wool. I step forward, bending low, my fingers finding the cold, heavy silver."
        },
        {
          "id": "item-8d20e888-83a1-455b-a00c-045efc2649fa",
          "type": "dialogue",
          "characterId": null,
          "text": "From this proximity, the hem of her violet gown hovers inches from my hands. I hear the sharp drag of her breath, the nervous tap of her boot."
        },
        {
          "id": "item-6da28457-6300-4edd-a7bd-643a37d5b221",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "Careful, you clumsy creature! If you chip the crystal, Miss Stern will hear of it."
        },
        {
          "id": "item-a395cea6-99e3-445b-a47f-91c7892de0ff",
          "type": "dialogue",
          "characterId": null,
          "text": "I have handled worse than broken glass. Debt. Lies. Men who mistook my silence for consent."
        },
        {
          "id": "item-c152a6e1-2c52-44f9-a844-42e5e0c14458",
          "type": "dialogue",
          "characterId": null,
          "text": "I lift the bottle, feeling the warmth of her nearness. I choose not to enumerate them."
        },
        {
          "type": "choice",
          "options": [
            {
              "id": "e310b283-9664-4042-b4d6-340b4e5cd3ac",
              "text": "Lower my chin, offering the bottle with a humble, trembling maid's hand. [[Subservient posture]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"observant\", intensity=\"standard\")",
                  "id": "item-bf7749ce-161b-4e26-90f5-73ccf52f9c24"
                },
                {
                  "type": "python_script",
                  "code": "story.set_day1_vance_relation(\"subservient\")",
                  "id": "item-ae39b037-25d8-46d0-9209-2d385f1d25dc"
                },
                {
                  "id": "item-27ac418a-23e7-4d0c-bb9f-cba3726da584",
                  "type": "show",
                  "characterId": "cora_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "dissolve",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "cora_sprite guarded_travel"
                },
                {
                  "id": "item-bdd1a811-cf9d-4760-b9cf-ac4d0ea056d3",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "My apologies, Miss. I wish to serve."
                },
                {
                  "id": "item-574a3796-c2e9-4983-9529-24b21803f034",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Vance takes the bottle, her fingers brushing mine with a brief, cold swipe. She lifts her chin, her face smoothing as she absorbs my submission."
                },
                {
                  "id": "item-63695a80-9c43-4505-be03-011fd71ee626",
                  "type": "dialogue",
                  "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
                  "text": "At least one of you has some sense of place. Go clean your hands, girl. You smell of the laundry."
                },
                {
                  "id": "item-414ae60b-a9a4-4cb8-8a49-55e9c8cebbc4",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She sees a stupid country maid. I let her keep that version."
                }
              ]
            },
            {
              "id": "89dbcd00-88b7-4260-82b1-d8268f8d8306",
              "text": "Stand straight and meet her gaze directly, holding the bottle between us. [[Defiant posture]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"transgressive\", intensity=\"standard\", witness=\"vance\")",
                  "id": "item-68cd0f36-49ba-43c3-83b3-ff6c5e38504f"
                },
                {
                  "type": "python_script",
                  "code": "story.set_day1_vance_relation(\"defiant\")",
                  "id": "item-924b21fc-c057-4896-a275-2f115aa6769e"
                },
                {
                  "id": "item-ec601ac6-beb4-4241-9454-0a1d082b79b8",
                  "type": "show",
                  "characterId": "cora_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "dissolve",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "cora_sprite base_travel"
                },
                {
                  "id": "item-fdc25f07-2716-4639-9336-6d101862e2e5",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "It is not chipped, Miss. It is sound."
                },
                {
                  "id": "item-81030fcd-746f-4ee1-8bca-e12d9bea9781",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Vance goes still. Her eyes widen, traveling from my cap to my lips, startled by the directness of my tone."
                },
                {
                  "id": "item-ee8b3588-504d-4d23-a719-4c6a0e32ab24",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She steps closer—jasmine and warm skin pressing into my face. Her breathing is loud in the quiet hall."
                },
                {
                  "id": "item-0e0155f1-c7c7-43bd-b38c-fdc5c768b6a6",
                  "type": "dialogue",
                  "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
                  "text": "You speak with a great deal of confidence for a girl in a borrowed apron."
                },
                {
                  "id": "item-f22354a5-e207-4fea-b3cf-56425cacc221",
                  "type": "dialogue",
                  "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
                  "text": "Do you want me to tell Miss Stern how you look at guests?"
                },
                {
                  "id": "item-a7c86334-3d50-4308-a696-1e06d50afd0e",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She threatens me, but her hand shakes as she reaches for the bottle."
                },
                {
                  "id": "item-a903e0fa-dece-4649-be27-5867e1803b4f",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She is not angry. She is exposed."
                }
              ]
            },
            {
              "id": "c231d308-4583-4b88-9f0a-3770753339db",
              "text": "Offer it on my flat palm with a cold, blank face. [[Ghostly posture]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"observant\", intensity=\"standard\")",
                  "id": "item-24f6cbe3-4d79-41a0-92bc-82e52e02c0ff"
                },
                {
                  "type": "python_script",
                  "code": "story.set_day1_vance_relation(\"ghostly\")",
                  "id": "item-7d65a7e9-f8ce-4df6-b4b7-bab041f3976d"
                },
                {
                  "id": "item-d74d2226-b335-40fd-b053-bf307262de25",
                  "type": "show",
                  "characterId": "cora_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "dissolve",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "cora_sprite base_travel"
                },
                {
                  "id": "item-76902262-a54a-4881-980f-f6f0f397a85a",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "The scent-bottle, Miss."
                },
                {
                  "id": "item-d65af756-55d0-4e6f-90db-20f466c45b25",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Vance snatches it, her expression twisting into a scowl of irritation. My complete lack of reaction is a wall she cannot scale."
                },
                {
                  "id": "item-e71a93e0-7127-4324-943c-16495ec37d24",
                  "type": "dialogue",
                  "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
                  "text": "Useless post. You are like a piece of furniture that has learned to walk."
                },
                {
                  "id": "item-6395f72d-c96f-48b7-ae3b-d3c52742cf51",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "A mirror does not apologize for showing dust. It only holds the shape."
                }
              ]
            }
          ],
          "id": "item-e4f00f46-00b7-480e-894f-93628cb8dc60"
        },
        {
          "id": "item-9a578761-a4fa-4dec-9023-df7a60a908f3",
          "type": "show",
          "characterId": "gideon_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "gideon_sprite cold"
        },
        {
          "id": "item-d261d5d6-991f-4509-8f67-fd6cea0abbff",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Vance."
        },
        {
          "type": "hide",
          "layer": null,
          "id": "item-e4537363-bb50-4fed-a7e9-e8f8fe47ab08",
          "characterId": "vance_sprite"
        },
        {
          "type": "hide",
          "layer": null,
          "id": "item-b4eaa672-6184-4f5b-b21f-9c93fb35c2be",
          "characterId": "cora_sprite"
        },
        {
          "id": "item-74092092-92ef-4dff-8397-b9d3c77b609b",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base_travel"
        },
        {
          "id": "item-955ced9a-c34b-4ad4-9661-f708eb529a11",
          "type": "show",
          "characterId": "vance_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "vance_sprite submissive"
        },
        {
          "id": "item-2010dd64-b257-4476-8f8d-2fc45b62f856",
          "type": "show",
          "characterId": "gideon_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "dissolve",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "gideon_sprite cold"
        },
        {
          "id": "item-bbc72920-a08a-490d-9952-04739e6d67a0",
          "type": "dialogue",
          "characterId": null,
          "text": "One word. The corridor temperature drops."
        },
        {
          "id": "item-5bfdb906-bbf5-4d33-967a-edee18d52dea",
          "type": "dialogue",
          "characterId": null,
          "text": "Vance's shoulders fall. Her lips part in a swallowed gasp—petulant fury folding into practiced, submissive compliance."
        },
        {
          "id": "item-2906f5c4-f5d8-448d-a0a0-b9fdbec74ccd",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "Gideon. I... I was only correcting the maid. She was careless with the linen."
        },
        {
          "id": "item-566247af-e122-41d4-9664-339cdc2b7082",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "You were making yourself visible."
        },
        {
          "id": "item-549d72ef-5fef-42b6-b999-b7e0f81e74b8",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "The hallway is for passage, Vance, not for theatre. Do not teach the servants bad habits before luncheon."
        },
        {
          "id": "item-7558f1d3-1074-43bc-81ee-e6ed5905ffd4",
          "type": "dialogue",
          "characterId": null,
          "text": "Vance's mouth closes tightly. She nods once, her eyes fixed on the silver buttons of his vest."
        },
        {
          "id": "item-a2a2f74b-fa2d-4a51-a42d-fd23f3e272b4",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "Of course, Sir."
        },
        {
          "id": "item-73fe4ab1-e22c-4e61-ba13-e7b08171414f",
          "type": "dialogue",
          "characterId": null,
          "text": "Of course. Not yes. Not sorry. Of course."
        },
        {
          "id": "item-af32b729-1912-4b8c-b7a9-79770f6be930",
          "type": "dialogue",
          "characterId": null,
          "text": "As if obedience were a ceremony, and surrender her only dress."
        },
        {
          "id": "item-a90b4bee-db2e-465f-9b25-d35423e0d2d5",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Your name, girl?"
        },
        {
          "id": "item-81eca1fa-25e3-4af1-a141-c940b1a4e624",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Cora, Sir."
        },
        {
          "id": "item-e68f19b1-1419-49ab-b496-d174694b2d16",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Then learn quickly, Cora. This house rewards discretion. If Ms. Vance cannot manage her temper, I expect you to manage your tongue."
        },
        {
          "id": "item-7d825949-ca61-465d-a814-3fdc81620298",
          "type": "dialogue",
          "characterId": null,
          "text": "He does not threaten with his voice. That is why it feels like an iron collar."
        },
        {
          "type": "hide",
          "layer": null,
          "transition": "dissolve",
          "id": "item-8a24269c-14fe-4607-9c5e-14c664a2dec2",
          "characterId": "gideon_sprite"
        },
        {
          "id": "item-d6e5d03e-fdb8-436a-85ff-0da3d4dc5f84",
          "type": "dialogue",
          "characterId": null,
          "text": "Mr. Locke turns and walks back toward the Master Suite, his boots striking the floor with quiet, absolute authority."
        },
        {
          "id": "item-78c31746-30db-4422-bcb1-2f724e4ae477",
          "type": "dialogue",
          "characterId": null,
          "text": "Vance remains behind a moment, her hands clutching the silver scent-bottle until her knuckles whiten."
        },
        {
          "id": "item-52465ef9-72c6-4c8c-b907-f85a43bb4e15",
          "type": "dialogue",
          "characterId": null,
          "text": "She turns to me, her voice a low, burning hiss."
        },
        {
          "id": "item-89519574-064f-477c-a444-4f14a0598e23",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "You. Do not think this is finished. Take my lace wrap and bring it to the dressing room. Now."
        },
        {
          "type": "hide",
          "layer": null,
          "id": "item-0a92113b-10a9-42b3-a984-a4c8b7625ffa",
          "characterId": "vance_sprite"
        },
        {
          "type": "hide",
          "layer": null,
          "transition": "dissolve",
          "id": "item-2ba133cf-072b-479a-9f8e-c55f23a15821",
          "characterId": "cora_sprite"
        },
        {
          "id": "item-38883323-8edd-447c-8d32-7ccd541ee74b",
          "type": "jump",
          "destinationLabelId": "label-085cfa22-164b-46b1-8d60-bc3204562a64"
        }
      ]
    },
    {
      "id": "label-085cfa22-164b-46b1-8d60-bc3204562a64",
      "name": "day101_1_vance_dressing_room",
      "x": 5700,
      "y": 11885,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-3d170499-bce2-407d-b159-bb3250f3f0b0",
          "backgroundId": "bg_master_suite_day"
        },
        {
          "id": "item-aebad34f-4759-4b54-9fee-f2e0cbb94672",
          "type": "dialogue",
          "characterId": null,
          "text": "The private vestibule of the Master Suite is warm, quiet, and smelling of French powder and the heavy spilled jasmine."
        },
        {
          "id": "item-a4d97710-fc2c-4fef-b414-9bbe5a915d3e",
          "type": "dialogue",
          "characterId": null,
          "text": "Gideon has gone into the inner study, the heavy mahogany door shut behind him."
        },
        {
          "id": "item-009f713f-6c04-499d-90b6-d745e52e0633",
          "type": "dialogue",
          "characterId": null,
          "text": "Miss Vance stands by the vanity, her back to me. She has unpinned her heavy hat, her hair falling in loose red coils over her shoulders."
        },
        {
          "id": "item-8f89b4b4-f693-4914-839b-7bfec52852fd",
          "type": "show",
          "characterId": "vance_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "vance_sprite angry_dressing_gown"
        },
        {
          "id": "item-e6fd14d2-d881-4a19-926b-14ecfff9c7ee",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "Close the door."
        },
        {
          "id": "item-1ea452de-a155-4834-bcbd-680bc816cd60",
          "type": "dialogue",
          "characterId": null,
          "text": "I step inside, the door latch clicking shut behind me. I set her lace wrap on the velvet bench."
        },
        {
          "id": "item-4c58248d-60fb-49e0-a096-c7065eb5310d",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "dissolve",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base_travel"
        },
        {
          "id": "item-10b70f79-ea34-44af-aa5c-1eb2268d0281",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "The wrap is here, Miss."
        },
        {
          "id": "item-c73a7586-4b26-454c-931e-8ddc68d031cc",
          "type": "dialogue",
          "characterId": null,
          "text": "She turns on me, her eyes bright with a mixture of shame and fury. She is breathing heavily, the laces of her corset visible where her collar has been loosened."
        },
        {
          "id": "item-ad0809eb-924d-4045-a1f7-d4fc00144261",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "You saw that. You saw him correct me like a child."
        },
        {
          "id": "item-f545db41-0be4-4d10-be06-1c73f6686af3",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "Do you think it's amusing? A maid watching from the shadow, counting the master's words?"
        },
        {
          "id": "item-b7f3b404-be50-46b3-a002-0e49292e1150",
          "type": "dialogue",
          "characterId": null,
          "text": "She steps closer, cornering me against the wardrobe. Our breath mingles, the heat of her skin radiating through the silk dress. She reaches out, her hand catching the strap of my apron, her fingers pressing into my shoulder."
        },
        {
          "id": "item-bc4a16da-5372-414b-8423-d8acae955bb0",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "Help me unpin the collar. My fingers are shaking. {w}Well? Move!"
        },
        {
          "id": "item-6399b88b-b60a-4866-bd60-35296ad62594",
          "type": "dialogue",
          "characterId": null,
          "text": "I step behind her. My fingers touch the warm, smooth skin of her neck as I reach for the silver pins of her lace collar."
        },
        {
          "id": "item-2e4b67b7-eca8-42b5-b8a4-4c200e0378fe",
          "type": "dialogue",
          "characterId": null,
          "text": "Her pulse is a frantic, fluttering bird beneath my thumb. I can feel the shiver that runs through her spine as my rough, lye-stained skin rubs against her delicate throat."
        },
        {
          "type": "choice",
          "options": [
            {
              "id": "4fc212c2-af0b-40fb-bc13-a66c74b59816",
              "text": "Handle the lace with gentle, soothing fingers, easing the pressure. [[Protected posture]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"observant\", intensity=\"standard\")",
                  "id": "item-7faec27a-273b-4db3-b02a-e202f33f73d1"
                },
                {
                  "type": "python_script",
                  "code": "story.set_day1_vance_relation(\"protected\")",
                  "id": "item-b390e238-f3ed-4b90-9a09-59ecae9f0bdd"
                },
                {
                  "id": "item-9c146938-be2d-488d-a1c2-18456cb15212",
                  "type": "show",
                  "characterId": "cora_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "dissolve",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "cora_sprite flushed"
                },
                {
                  "id": "item-6597beb2-6917-442f-bcdc-96e0460ea45a",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I adjust the lace slowly, my touch light and reassuring against her hot skin."
                },
                {
                  "id": "item-e80f5569-22ba-43d9-b291-3fa3f27124c0",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "He was harsh, Miss. But the wainscoting carries no tales. I have already forgotten his words."
                },
                {
                  "id": "item-d818799e-7908-4743-8d60-3b97f64927d9",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Vance lets out a long, trembling sigh, her shoulders dropping. For a fraction of a second, her head tilts back, her soft hair brushing against my apron."
                },
                {
                  "id": "item-6b040150-b00a-46d9-80a1-90891ff5eb38",
                  "type": "dialogue",
                  "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
                  "text": "He... he only wishes me to be perfect. But it is... suffocating."
                },
                {
                  "id": "item-5b2acd0f-0066-4c7c-9b3f-c44a405cd979",
                  "type": "dialogue",
                  "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
                  "text": "You are surprisingly gentle for a laundry girl."
                },
                {
                  "id": "item-cb8c8685-5174-45f6-afb7-06f89e894e26",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She wants shelter. Let me build a small, dark wall around her."
                }
              ]
            },
            {
              "id": "d7c6859d-f180-4518-8b43-958adcc0e09a",
              "text": "Touch the red pressure mark left on her collarbone by Gideon. [[Intimate posture]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"transgressive\", intensity=\"standard\", witness=\"vance\")",
                  "id": "item-86a2e7b5-68fd-4c42-8ffe-764640d835eb"
                },
                {
                  "type": "python_script",
                  "code": "story.set_day1_vance_relation(\"intimate\")",
                  "id": "item-07e71afd-631d-47d4-a6e1-be0090da9c91"
                },
                {
                  "id": "item-883f1981-6bdf-4514-ba1a-09b3857e074a",
                  "type": "show",
                  "characterId": "cora_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "dissolve",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "cora_sprite flushed"
                },
                {
                  "id": "item-89ebe7c7-ed4e-4806-96c3-720d0d66f3a3",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "My thumb slides down her neck, pressing lightly against the red, flushed mark on her skin."
                },
                {
                  "id": "item-a88040f6-d317-419e-919a-7dc681d46c12",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "The master has a heavy hand, Miss. It must be difficult to wear his marks in public."
                },
                {
                  "id": "item-340eb01e-accc-4320-a42f-becf3e9a6168",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Vance gasps, her back arching slightly. Her hands grip the vanity table behind her, her knuckles turning red."
                },
                {
                  "id": "item-772f4c23-0e49-4db2-8efc-9fa3dc181d59",
                  "type": "dialogue",
                  "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
                  "text": "You... you insolent wretch. How dare you touch me there..."
                },
                {
                  "id": "item-734a2e6d-0c18-4b82-9804-88402cd5aa21",
                  "type": "dialogue",
                  "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
                  "text": "Gideon would have you thrown to the streets if he knew you were speaking of his hand."
                },
                {
                  "id": "item-be6e2be2-541a-4a69-b075-af09de9a40b8",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "But he does not know, Miss. We are alone."
                },
                {
                  "id": "item-3e184822-0b2d-41c8-9cc8-b5365ff6a734",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She shivers, her eyes dark and wet in the mirror. The physical heat between us is thick, a shared secret of submission and command."
                }
              ]
            },
            {
              "id": "9d0dc6b7-1b18-4d65-9d29-032cd3aeca58",
              "text": "Perform the duty with cold, clinical precision. [[Observed posture]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"observant\", intensity=\"standard\")",
                  "id": "item-10b6c8e2-1af3-481b-addd-9cf5b252dd6c"
                },
                {
                  "type": "python_script",
                  "code": "story.set_day1_vance_relation(\"observed\")",
                  "id": "item-e02dfa9e-97fa-454c-8811-8018dd97cbed"
                },
                {
                  "id": "item-cc9130b2-0655-4b2c-9eca-d114b2106184",
                  "type": "show",
                  "characterId": "cora_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "dissolve",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "cora_sprite base_travel"
                },
                {
                  "id": "item-9f0670da-aa4c-4f1a-a019-f86645410871",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I unpin the collar cleanly, stepping back the moment the silk falls open."
                },
                {
                  "id": "item-0d116d1f-05a9-45ee-9850-1cd34fb88719",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "It is undone, Miss. You are free."
                },
                {
                  "id": "item-0e1fc9e5-2246-4309-80c2-bc1c265e0f42",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Vance turns, looking at me with a frustrated scowl. She feels the coldness of my gaze, the way I treat her distress like an entry in a ledger."
                },
                {
                  "id": "item-3b09adcd-8e1a-4b09-a12c-97c3e29e65a0",
                  "type": "dialogue",
                  "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
                  "text": "You are like a stone, Cora. Go. Before I find a reason to have Stern inspect your trunk."
                },
                {
                  "id": "item-f77b9c3d-c038-4f1b-87cc-a3dc9a1c2368",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "A stone sees the mark. It does not shiver."
                }
              ]
            }
          ],
          "id": "item-475320f2-aebf-4a44-b8f4-50dc50c69216"
        },
        {
          "type": "hide",
          "layer": null,
          "id": "item-be01dec8-9fa7-415a-8c3d-887c93d53bdf",
          "characterId": "vance_sprite"
        },
        {
          "type": "hide",
          "layer": null,
          "transition": "dissolve",
          "id": "item-85053dc1-96c2-4239-b226-c3f818fff5c9",
          "characterId": "cora_sprite"
        },
        {
          "id": "item-6ec82a88-9d91-48d2-a967-bc0efdbf3dbc",
          "type": "jump",
          "destinationLabelId": "label-e2cc7774-e3bc-4cd1-91f7-1dcd76e42c5d"
        }
      ]
    },
    {
      "id": "label-e2cc7774-e3bc-4cd1-91f7-1dcd76e42c5d",
      "name": "day101_1_vance_stairwell_encounter",
      "x": 6100,
      "y": 11885,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-50135fa3-3a5a-4717-b787-a1ac43cbdfee",
          "backgroundId": "bg_servants_corridor_dim"
        },
        {
          "id": "item-155031ba-1698-42f3-8455-236083ef7764",
          "type": "dialogue",
          "characterId": null,
          "text": "I slip out of the suite, my heart beating rapidly in the quiet corridor."
        },
        {
          "id": "item-28b44fbd-6a32-4810-a61c-5f28ad04abcb",
          "type": "dialogue",
          "characterId": null,
          "text": "I turn toward the narrow service stairwell that leads down to the laundry, the air growing colder and smelling of damp stone."
        },
        {
          "id": "item-0ca175b3-86ca-4f59-aa49-a115e418da89",
          "type": "dialogue",
          "characterId": null,
          "text": "Suddenly, the heavy door above creaks open. Footsteps hurry down the stone steps behind me."
        },
        {
          "id": "item-f5071cd8-1d73-4d2e-ba33-5ea1a6c5ecdc",
          "type": "show",
          "characterId": "vance_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "vance_sprite indignant"
        },
        {
          "id": "item-4bf4fc0f-755d-4e97-bc47-91c7ab622142",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "Wait. You."
        },
        {
          "id": "item-ec97300f-7e59-4bf0-ad03-abb3248d4e8f",
          "type": "dialogue",
          "characterId": null,
          "text": "I turn. Vance stands on the step above me. She has not re-laced her collar; the silk is open, exposing her pale neck and the rising flush of her skin."
        },
        {
          "id": "item-e72ec06f-98ba-44df-a05c-433d109eba92",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "dissolve",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base_travel"
        },
        {
          "id": "item-a9a87e1f-ea17-4264-b606-ee687379d9ea",
          "type": "dialogue",
          "characterId": null,
          "text": "Before I can bow, she steps down, her hand catching my sleeve and dragging me into the shadow beneath the landing."
        },
        {
          "id": "item-911c6996-f67c-4c96-89de-cddc3b529925",
          "type": "dialogue",
          "characterId": null,
          "text": "She presses me flat against the cold brick wall, her chest pressing against mine. The scent of jasmine is sharp and close, mixed with the sweat of her panic."
        },
        {
          "id": "item-c720b21d-51d6-4bab-b76b-73b047b6dfb1",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "Tell me. Are you going to tell that old crow Stern? Or Missy?"
        },
        {
          "id": "item-62ab9c34-af54-4ec3-91e9-c44e780cd1a2",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "If Gideon thinks I am... compromised. If he thinks the servants are whispering about us..."
        },
        {
          "id": "item-5e62e62f-187e-40d4-99cf-012935516503",
          "type": "dialogue",
          "characterId": null,
          "text": "Her fingers tighten on my arm. She is trying to look threatening, but her chest is heaving, and her lips are trembling."
        },
        {
          "type": "choice",
          "options": [
            {
              "id": "88a6fc19-c6a6-4e7a-9dfa-9d249d1924a3",
              "text": "Assure her of my absolute maid's silence. [[Loyal witness]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"observant\", intensity=\"standard\")",
                  "id": "item-e532f701-731a-474a-b0cc-fd4547765aa6"
                },
                {
                  "type": "python_script",
                  "code": "story.set_day1_vance_relation(\"loyal_witness\")",
                  "id": "item-6d9b85e1-e9dd-4124-9e22-ef731a9e0cea"
                },
                {
                  "id": "item-b3931cee-9342-4d24-a475-4943426e3912",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "I only see the sheets and the carpets, Miss. I have no time for gossip."
                },
                {
                  "id": "item-ea31f7fe-f6c6-4760-a19c-995e3ca3ee5b",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Vance studies my face, searchingly. Her breathing slows, her grip on my sleeve loosening."
                },
                {
                  "id": "item-802572b6-5bf4-462e-9ba7-c810765e00c3",
                  "type": "dialogue",
                  "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
                  "text": "Good. Keep it that way. If I hear a single whisper... I will know it was you."
                },
                {
                  "id": "item-f64197bb-9a27-4447-9fd1-3f2226ec1a65",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She is relieved, but the suspicion remains. I am still a witness she must watch."
                }
              ]
            },
            {
              "id": "93359c3b-489b-4296-b2de-ecc6176fa418",
              "text": "Feed her anxiety, turning the power dynamics. [[Accomplice posture]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"transgressive\", intensity=\"standard\", witness=\"vance\")",
                  "id": "item-8bf0a74d-64be-4516-b138-927b8f24104f"
                },
                {
                  "type": "python_script",
                  "code": "story.set_day1_vance_relation(\"accomplice\")",
                  "id": "item-3ab163de-0cb6-4f4e-ba46-b21f89855aa1"
                },
                {
                  "id": "item-c6922ac8-227a-442e-89b3-e4ec4fa1b281",
                  "type": "show",
                  "characterId": "cora_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "dissolve",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "cora_sprite flushed"
                },
                {
                  "id": "item-78c1a5fb-ab1c-49e2-876b-276d42b3e517",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I lean in close, my lips brushing her ear in the cold stairwell."
                },
                {
                  "id": "item-6a9db46a-16ad-46ba-96d4-4f0630ba82c7",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "I saw how you looked at him, Miss. I know what it is to want a hand that commands you."
                },
                {
                  "id": "item-ee7c6352-2090-4df3-a884-40fdbbf65327",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "I won't tell Stern. But we both know the weight of his shoe."
                },
                {
                  "id": "item-e9eedfc1-4f03-4a98-a654-eb669cef9d13",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Vance lets out a sharp, wet gasp. Her eyes flare with terror and a sudden, dark arousal. Her head falls back against the brick, her chest pressing hard against my hands."
                },
                {
                  "id": "item-d7155adc-fc11-430c-bc75-07d8e2e951d3",
                  "type": "dialogue",
                  "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
                  "text": "You... you are a wicked girl, Cora. A dangerous, wicked girl."
                },
                {
                  "id": "item-61dc7da7-e8ae-47a7-860d-1bddb16c701d",
                  "type": "dialogue",
                  "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
                  "text": "If Gideon found you speaking to me like this..."
                },
                {
                  "id": "item-5213cf72-c3d1-4b04-8ae0-3e9bd9449980",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "But he is in his study, Miss. And you are here. With me."
                },
                {
                  "id": "item-9c8a1e51-a366-41fc-b707-9d160e087eba",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Our skin shivers in the cold draft. She does not pull away. The collusion between us is sealed in the dark stairwell."
                }
              ]
            },
            {
              "id": "d6e3ea1a-07c8-433d-b4c6-68987fdc2322",
              "text": "Detach myself and push past her. [[Silent observer]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"observant\", intensity=\"standard\")",
                  "id": "item-cdc2747d-513a-4f62-9842-c6dc401c343e"
                },
                {
                  "type": "python_script",
                  "code": "story.set_day1_vance_relation(\"silent_observer\")",
                  "id": "item-5e11dc8b-019f-4106-9b62-0c02d790ff05"
                },
                {
                  "id": "item-c6d4aa93-f4a3-466d-9cbf-77ebe59a1cb3",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "Miss Stern is waiting for me in the laundry, Miss. If I am late, she will ask why I was delayed in the guest corridor."
                },
                {
                  "id": "item-a47c279d-bf02-41fd-88bd-48e001347093",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "That silences her. She pulls her hand back as if burned, her face hardening into her lady's mask."
                },
                {
                  "id": "item-9aa8e51e-631d-4ada-940d-1440cc99e27d",
                  "type": "dialogue",
                  "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
                  "text": "Then go. Before I have you dismissed myself."
                },
                {
                  "id": "item-a24adf22-5bf9-441e-86b0-35439dc0ca8b",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I have the shape of her fear. That is all the material I need."
                }
              ]
            }
          ],
          "id": "item-f86aab10-6b5d-43f5-9907-ae63fb6b4b84"
        },
        {
          "type": "hide",
          "layer": null,
          "id": "item-f4badf72-c5f2-4d30-b0cd-476ad0966d5d",
          "characterId": "vance_sprite"
        },
        {
          "type": "hide",
          "layer": null,
          "transition": "dissolve",
          "id": "item-1fc0db10-59ac-4260-bea8-6975382a9aab",
          "characterId": "cora_sprite"
        },
        {
          "id": "item-25a63352-ac57-4f25-99cb-005e502b922b",
          "type": "dialogue",
          "characterId": null,
          "text": "She retreats up the stairs, her silk skirt rustling in the dark."
        },
        {
          "id": "item-1c70ec64-fbec-469b-96d2-12560ce2282c",
          "type": "dialogue",
          "characterId": null,
          "text": "I watch her go. A lady of the Savoy, bound in silk and swallowed terror."
        },
        {
          "id": "item-f160b98f-8ea9-4acf-908a-82628ad797bb",
          "type": "dialogue",
          "characterId": null,
          "text": "There is a chapter in that. A very long one."
        },
        {
          "id": "item-d8ebb550-4ab5-4a99-8a42-a8fccf3996f2",
          "type": "jump",
          "destinationLabelId": "label-1a9c337a-5871-4b78-8fcd-ddf50b377506"
        }
      ]
    },
    {
      "id": "label-1a9c337a-5871-4b78-8fcd-ddf50b377506",
      "name": "day101_2_missy_meets_cora",
      "x": 6500,
      "y": 11885,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "fade",
          "id": "item-3948f263-3f29-428d-a15e-aa5cc8d5ff0b",
          "backgroundId": "bg_laundry_room_day"
        },
        {
          "id": "item-bc5bad8c-f45a-4678-a954-5fc2e0750945",
          "type": "dialogue",
          "characterId": null,
          "text": "The laundry room is heat, lye, damp cotton, and women trying not to cough."
        },
        {
          "id": "item-f7909193-b02f-4ff6-b483-ca543173fc39",
          "type": "dialogue",
          "characterId": null,
          "text": "Steam beads on the walls. It turns every face soft at the edges."
        },
        {
          "id": "item-b1d89048-6ff3-465e-8f15-88496ac1f453",
          "type": "show",
          "characterId": "missy_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "missy_sprite smiling"
        },
        {
          "id": "item-a28ba338-e6e5-471d-b428-b27d49cdde7d",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "You must be Cora. The new girl Miss Stern was sorting out."
        },
        {
          "id": "item-c45deadd-80ae-4e36-a493-b1a2ecbd99bf",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "moveinleft",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base_travel"
        },
        {
          "id": "item-67d43992-8551-4549-9c19-fe68ce79a1c6",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "I must be. Cora Vale."
        },
        {
          "id": "item-0fc8a1e0-33ca-4066-8d3c-7aa10ef38893",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "I'm Missy. Miss Stern said I'm to show you where things go. {w}Not everything, mind."
        },
        {
          "id": "item-7d8aa773-88ae-4d17-bba3-2e0c7595e9ce",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "If I showed you everything we'd both be dismissed and out on the Strand before tea. This place has more rules than the Bible, and twice as many ways to fall."
        },
        {
          "id": "item-bc234c61-b523-42f8-8949-50c4009c498d",
          "type": "dialogue",
          "characterId": null,
          "text": "She says it brightly, but there is a sharp, quiet calculation in the way she eyes the door."
        },
        {
          "id": "item-6eb5267e-8624-4a43-8c05-2f94cd4429f4",
          "type": "dialogue",
          "characterId": null,
          "text": "Not simple chatter. A junior maid who has calculated the cost of a single slip."
        },
        {
          "id": "item-d31e8057-c0c6-4972-994a-35b2d209dbf2",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Is the work always this warm?"
        },
        {
          "id": "item-a60a76e1-d5df-4132-a65c-2b7bf2e770e1",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "dissolve",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite collar_travel"
        },
        {
          "id": "item-f3d09663-b6db-4ea5-9b02-b57da678accf",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "Oh, this is a pleasant day. Wait until the boilers sulk and the head laundress starts counting the soap-bars like they're gold sovereigns."
        },
        {
          "id": "item-c91f5a39-1770-4b0a-98b2-627f56e78a69",
          "type": "dialogue",
          "characterId": null,
          "text": "Missy laughs at her own warning, though her eyes remain alert, and she presses a folded stack of garments into my arms."
        },
        {
          "id": "item-400b4b74-5afc-4633-92cc-8a4074633641",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "These go up by the guest corridor. Not the grand staircase, obviously. Servants' passage only. We're to be like ghosts, Cora. Hands without noise."
        },
        {
          "id": "item-a384f71b-9ed3-47b6-990c-fd2acaad8fb2",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "And don't look too closely at anything left outside a door. Guests hate being known. And what they hate, they punish."
        },
        {
          "id": "item-53525800-8701-41d6-b3e7-207d0c5b6fdc",
          "type": "dialogue",
          "characterId": null,
          "text": "Guests hate being known."
        },
        {
          "id": "item-82710a58-db3b-48ce-815a-1868a394d9af",
          "type": "dialogue",
          "characterId": null,
          "text": "A remarkably sharp decoding of the hotel's lethal hierarchy."
        },
        {
          "id": "item-2294d944-3cae-4312-9856-5e7fe368991e",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "I'll remember. Discretion first."
        },
        {
          "id": "item-add036d5-c5b1-414b-9d46-8c8582e03b73",
          "type": "dialogue",
          "characterId": null,
          "text": "Missy studies me for a second longer than comfort allows, her gaze parsing my apron, my cap, and the country stiffness I haven't quite washed off."
        },
        {
          "id": "item-7d8d66be-f4c1-4c73-be67-6e9f7cbde400",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "You looked pale out there. Miss Stern does that to a girl. She makes everyone feel as if they've violated the commandments just by breathing the air."
        },
        {
          "id": "item-32b8ecfe-911d-4cfd-9584-90f6e9d3404a",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Have you?"
        },
        {
          "id": "item-39814413-6e07-4403-a080-b7caaef546d0",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "What?"
        },
        {
          "id": "item-11248d79-81fe-473f-ab2f-ea4915d2fbab",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Violated the commandments. Or stolen spoons."
        },
        {
          "id": "item-65ce07cd-5df8-44a9-b376-c8b2cf4a7c6f",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "Certainly not. A girl's virtue and her honesty are the only shields she has in London. Lose either, and you're under the carriage wheels."
        },
        {
          "id": "item-370ecd0b-6b76-4ae3-bdd3-b2855912b9e7",
          "type": "dialogue",
          "characterId": null,
          "text": "She hesitates, a small, knowing crease appearing between her brows."
        },
        {
          "id": "item-e8d044d3-5b8e-48fe-8566-179d906af494",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "Well. There was a silver spoon Miss Stern threw out because the silver-plate was peeling and it looked improper for the suites. I kept it to stir my tea. But that's salvage, not sin."
        },
        {
          "id": "item-933ae79d-73db-4d35-ac8b-ca037a357fe8",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "And where are you from, Cora? Your papers say Wiltshire."
        },
        {
          "id": "item-44053c95-c1b2-451c-8ed4-882285d0e0df",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "A small village. Near Fovant."
        },
        {
          "id": "item-f230e7f1-2eb5-4da4-979c-3fabd1804e6a",
          "type": "dialogue",
          "characterId": null,
          "text": "Missy's eyes light up with sudden, beautiful, and terrifying recognition."
        },
        {
          "id": "item-ab9db516-deae-4141-976b-67471c3a99ee",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "Wiltshire! Oh, bless you, I'm from Hindon myself! Just three miles down the road!"
        },
        {
          "id": "item-9705914a-6131-4cbd-9968-288d83f14e96",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "You must know the old oak by the mill? And the curate, Mr. Harrison? He has the most wonderful, proper sermons on Sundays."
        },
        {
          "id": "item-24043522-29f1-417f-ad3b-0db9a8ff599c",
          "type": "dialogue",
          "characterId": null,
          "text": "My heart stops. A physical blow to my chest."
        },
        {
          "id": "item-04f6573d-767d-4615-b08a-748e86178030",
          "type": "dialogue",
          "characterId": null,
          "text": "She is the real thing—the innocent, pious English country girl I am pretending to be."
        },
        {
          "id": "item-5d07760f-6329-4559-81ac-fb5a8b3cee57",
          "type": "dialogue",
          "characterId": null,
          "text": "If I slip now, if I name the wrong lane or mispronounce the local grange, she will know. And her concern will destroy me."
        },
        {
          "id": "item-2a335f36-500c-4345-88a4-81dc0460ae4b",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "The old mill is quite beautiful in spring, Missy."
        },
        {
          "id": "item-c3f21792-f7e5-4a1f-bdad-56579e1e3aa3",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "We lived closer to the parish line."
        },
        {
          "id": "item-43eaae4b-5452-40b8-bc8b-e8cd23808c62",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "We did not often travel to Hindon."
        },
        {
          "id": "item-75a345da-87f8-4485-a9e9-a310819faf0f",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "Ah, that's a pity. The curate's wife was always so good to the girls in service. Such a righteous place."
        },
        {
          "id": "item-c07c4d98-1bab-4076-aab2-42ce66584e8c",
          "type": "dialogue",
          "characterId": null,
          "text": "The irony is a cold weight. Missy is the very life I claimed to have lived, purely to get this position."
        },
        {
          "id": "item-c59ac1e9-ed61-4e86-913c-da805bed0fca",
          "type": "dialogue",
          "characterId": null,
          "text": "We are two halves of a lie, and she has no idea she is holding the knife."
        },
        {
          "id": "item-3c1eac10-8ddc-474e-9975-0e29683ab833",
          "type": "dialogue",
          "characterId": null,
          "text": "I almost like her immediately. Her country armor is thicker than mine, but she knows exactly where the joints are."
        },
        {
          "id": "item-ef4cd302-6de4-43f0-81e2-ca234665227e",
          "type": "jump",
          "destinationLabelId": "label-09c03112-023e-45c3-9630-b0d167d2ebf1"
        }
      ]
    },
    {
      "id": "label-09c03112-023e-45c3-9630-b0d167d2ebf1",
      "name": "day101_2_coras_path_choice",
      "x": 6900,
      "y": 11885,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "fade",
          "id": "item-e2842930-823d-4e60-906d-29c68f9a1f1c",
          "backgroundId": "bg_servants_corridor_dim"
        },
        {
          "id": "item-4ddffd0d-657d-4560-8d8f-ec8eff8b9569",
          "type": "dialogue",
          "characterId": null,
          "text": "The servants' corridor behind the guest wing is narrower than it should be."
        },
        {
          "id": "item-45251a4f-2125-4a56-a8e2-ab6a5b55f5d4",
          "type": "dialogue",
          "characterId": null,
          "text": "The walls carry sound the way a body carries fever."
        },
        {
          "id": "item-831e0113-c174-4638-bd1a-ec743114b111",
          "type": "show",
          "characterId": "missy_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "missy_sprite smiling"
        },
        {
          "id": "item-dbcc8340-956b-4dd0-b4f0-b69f9ad9cbaa",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "This way. Mind the third board. It complains, and Miss Stern hears every creak."
        },
        {
          "id": "item-bf6ddee4-265b-4d76-becb-f593b10136e4",
          "type": "dialogue",
          "characterId": null,
          "text": "We pass a service door near the Master Suite."
        },
        {
          "id": "item-e43c6b3f-bd88-47ba-bb6c-2d4a2e6d686f",
          "type": "dialogue",
          "characterId": null,
          "text": "Beyond it: a sharp sound."
        },
        {
          "id": "item-25c07443-b983-43a9-9ede-8a1474aeec27",
          "type": "dialogue",
          "characterId": null,
          "text": "Not a dropped tray."
        },
        {
          "id": "item-1b2b7a16-a2ca-4a95-8060-d8bcde5907b2",
          "type": "dialogue",
          "characterId": null,
          "text": "Not a broken glass."
        },
        {
          "id": "item-328e8df2-ab42-463e-8837-21781b5e37ac",
          "type": "dialogue",
          "characterId": null,
          "text": "A voice pressed low, carrying a rhythmic, trembling weight."
        },
        {
          "id": "item-5c00158f-9670-4c0e-82a2-5c4a660a5d20",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "Please. I understand. I do."
        },
        {
          "id": "item-412124b9-f271-4d08-b0d3-3fcb96703b94",
          "type": "show",
          "characterId": "missy_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "missy_sprite shocked"
        },
        {
          "id": "item-faf3a2e9-7267-4b84-963d-8098980bdbc7",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "Was that Miss Vance? She sounds... she doesn't sound proper."
        },
        {
          "id": "item-ff4c1371-fb74-441f-b673-442d9e3106f3",
          "type": "dialogue",
          "characterId": null,
          "text": "Another sound follows. Smaller. A wet gasp."
        },
        {
          "id": "item-f4435da4-47e1-4143-a2d8-66d24e34b0d3",
          "type": "dialogue",
          "characterId": null,
          "text": "Missy goes absolutely still, her fingers tightening around the wicker hamper."
        },
        {
          "id": "item-6e9131fb-2aa4-4241-bf8c-b235555e21a5",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "If she's in distress... we ought to fetch Miss Stern. Or is it improper for us to interfere?"
        },
        {
          "id": "item-fa356fa0-8afd-4da8-bc41-45154121e7b5",
          "type": "dialogue",
          "characterId": null,
          "text": "This is the moment."
        },
        {
          "id": "item-e8f79040-5883-4475-856b-8849ab13514a",
          "type": "dialogue",
          "characterId": null,
          "text": "Not the sound. Not Vance's voice. Not Mr. Locke's hand, if it was his hand."
        },
        {
          "id": "item-17ce2077-bafe-408f-b09f-c597195f9010",
          "type": "dialogue",
          "characterId": null,
          "text": "The moment is the choice of what I become in order to use it."
        },
        {
          "type": "choice",
          "options": [
            {
              "id": "0556a292-9312-494f-b61a-dd6ad3e3ea52",
              "text": "Let Missy's concern open the door. [[Predator path]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"transgressive\", intensity=\"standard\", witness=\"vance\")",
                  "id": "item-5011c952-a4b5-43fb-ad95-98075f01697c"
                },
                {
                  "type": "python_script",
                  "code": "story.set_corridor_state(\"predator\")",
                  "id": "item-ae0cc1f4-cc24-4aae-ae37-339feacffcd1"
                },
                {
                  "type": "python_script",
                  "code": "apply_archetype_edge(\"predator\", 1)",
                  "id": "item-51860088-3f6b-4ef3-ba76-f33d6fa4ade0"
                },
                {
                  "id": "item-52e4d377-5107-4703-8ea0-a33f74fa42ed",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "You may be right. If she's hurt, someone should check. But you know the house, Missy—if I open the wrong door on my first day, Miss Stern will have my references."
                },
                {
                  "id": "item-849312d2-f8e9-4838-87d9-835ff1f5bba0",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I use her genuine moral concern as a shield."
                },
                {
                  "id": "item-75304506-6d09-405d-92e1-18615f2843cf",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "It is a calculated argument, and her sharp, protective instinct for other maids makes her accept the risk."
                },
                {
                  "id": "item-80092902-f039-4031-94d5-8413648b1d63",
                  "type": "dialogue",
                  "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
                  "text": "Only a little look, then. Only to ensure she isn't in peril."
                },
                {
                  "id": "item-e0ce53d0-ee61-4ccd-9510-739d695fcc49",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She steps toward the service door, her posture cautious, her movements deliberate."
                },
                {
                  "id": "item-f517f899-080a-4a3a-97ba-5ab1453143b4",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I step back into the shadow."
                },
                {
                  "id": "item-7a823bf9-c39e-4722-846d-53883978b633",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Missy's hand reaches the latch. Her decency does the work my hunger asks of it."
                },
                {
                  "id": "item-20fdb6fe-71e9-4697-b6b0-e673cfb6a388",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Through the narrow opening, the room is revealed in fragments: Vance's white hand on dark carpet; the master's polished shoe; the silver head of his walking stick resting against his knee."
                },
                {
                  "id": "item-a8d3ee59-6971-4145-8c95-2b5a2113ad92",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Missy gasps, her observant eyes taking in the transgressive tableau before her."
                },
                {
                  "id": "item-15772759-23cd-4a0f-9060-650ff2790312",
                  "type": "dialogue",
                  "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
                  "text": "The door."
                },
                {
                  "id": "item-dccc445d-8bfc-40d7-96c6-95104c1825e3",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Missy pulls it shut so fast the latch bites, her face white with immediate self-defense."
                },
                {
                  "id": "item-11a1037d-b292-48ee-90ec-53358974e3f5",
                  "type": "dialogue",
                  "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
                  "text": "Oh. Oh, Cora. That was... he was holding her. Like she was a dog."
                },
                {
                  "id": "item-7d32d2ee-b2c8-4d08-be39-1e9afae473fd",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "We saw nothing."
                },
                {
                  "id": "item-54ec0df8-7191-41fa-9e9d-22f2d2e2e3c8",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I say it to soothe her, but she is already retreating, her defensive propriety locking down like iron."
                },
                {
                  "id": "item-e9bc7237-1631-48b9-86fe-061a5ab1eb2b",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I have seen enough. And I have used her to get it."
                },
                {
                  "type": "python_script",
                  "code": "story.set_missy_day1_trust_state(\"unsettled\")",
                  "id": "item-9f53d136-0d91-48fb-a4a5-f71b9b87591a"
                }
              ]
            },
            {
              "id": "f8d18e3b-b84e-446b-9153-8f1d53e625e8",
              "text": "Look for myself. [[Prey path]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"transgressive\", intensity=\"standard\", witness=\"vance\")",
                  "id": "item-c23eb53a-0c07-49d4-8a7f-7a52374ac3ca"
                },
                {
                  "type": "python_script",
                  "code": "story.set_corridor_state(\"prey\")",
                  "id": "item-2323e601-7c90-4660-a43c-fb94ee4923d3"
                },
                {
                  "type": "python_script",
                  "code": "apply_archetype_edge(\"prey\", 1)",
                  "id": "item-7df1a0b0-a198-4ba0-8458-5a6d75b3f5cd"
                },
                {
                  "id": "item-63a1ac60-e8c6-4a4f-9697-df54652a31e4",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "Stay there. Let me see."
                },
                {
                  "id": "item-29cb8321-873e-453e-9449-3591031f1686",
                  "type": "dialogue",
                  "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
                  "text": "Cora, no—it's sin to pry into the suites."
                },
                {
                  "id": "item-78dc3dab-f82e-48ee-aff1-cd915ec9b3c1",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "Quiet."
                },
                {
                  "id": "item-c25c6225-64f8-44ca-afcd-c7c4d4cb399a",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I move before caution can catch me."
                },
                {
                  "id": "item-d35627dd-d437-4a70-925a-a9777113775b",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The third board complains exactly as promised."
                },
                {
                  "id": "item-ae4aa42d-3c61-457e-a958-fa0029de237d",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Through the crack I see Vance kneeling, face lifted in a desperate mix of fury and submission."
                },
                {
                  "id": "item-8131cdf8-5476-4773-b94b-70ae141cc6f1",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Mr. Locke holds her chin between two fingers, his grip light but absolute."
                },
                {
                  "id": "item-29ed9133-893e-4cc3-86bb-83290ace47cb",
                  "type": "dialogue",
                  "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
                  "text": "Again."
                },
                {
                  "id": "item-d838ae1c-0ebd-498d-a98e-dfff83af38aa",
                  "type": "dialogue",
                  "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
                  "text": "I forgot myself, Sir."
                },
                {
                  "id": "item-9bb7c2aa-9ee0-4484-a499-5b000afd1065",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "My breath catches."
                },
                {
                  "id": "item-0f7ea3d8-2268-4811-8f49-3f9f2cef3400",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "His eyes move toward the door with terrifying speed."
                },
                {
                  "id": "item-2fb8746f-43fe-467f-b3f8-0fd03a2fd7af",
                  "type": "dialogue",
                  "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
                  "text": "Do we have an audience?"
                },
                {
                  "id": "item-99700c37-3f8a-40ad-bd4f-79aa472f7030",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I stumble back, my pulse hammering."
                },
                {
                  "id": "item-ec172381-9edb-4427-89ae-f4821cc42b41",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Missy's hand is already on my sleeve, her sharp instincts dragging me into the bend of the corridor before the latch can turn."
                },
                {
                  "id": "item-0519677c-7a31-4b50-a95e-9a4d2a9d1f7b",
                  "type": "dialogue",
                  "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
                  "text": "Have you lost your senses? If Mr. Locke sees us prying, we'll be ruined!"
                },
                {
                  "id": "item-52da6919-a737-4a89-9174-e0a16fd77480",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She is terrified, but her rescue was swift and observant."
                },
                {
                  "id": "item-10219baf-3572-4ecf-a336-62b3658f5720",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I have the image. The terrible, beautiful image."
                },
                {
                  "type": "python_script",
                  "code": "story.set_missy_day1_trust_state(\"shared_caution\")",
                  "id": "item-60cc606d-8ac2-4b55-848d-c5d0af208b76"
                }
              ]
            },
            {
              "id": "574a9fa7-3924-4fed-a59b-8f2ca4815eba",
              "text": "Pull Missy away. [[Ghost path]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"creative\", intensity=\"standard\")",
                  "id": "item-9f13e31a-e093-4f09-b451-570493aa5e7f"
                },
                {
                  "type": "python_script",
                  "code": "apply_effects(stern_susp=-5, vance_susp=-5, missy_susp=-5)",
                  "id": "item-938510ae-dfe2-4c1d-8829-eab38584ddcd"
                },
                {
                  "type": "python_script",
                  "code": "story.set_corridor_state(\"ghost\")",
                  "id": "item-07a21d67-336b-4926-9d0f-b5758b0fb82d"
                },
                {
                  "type": "python_script",
                  "code": "apply_archetype_edge(\"ghost\", 1)",
                  "id": "item-5f16d6bd-ba3d-448a-8825-5d8bb625ca05"
                },
                {
                  "id": "item-5cf98c02-da6c-4f22-8562-a48109150056",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "No. We walk on."
                },
                {
                  "id": "item-ba9b7490-4b3d-4ad5-836f-15e17f5c3fca",
                  "type": "dialogue",
                  "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
                  "text": "But if she's in peril—"
                },
                {
                  "id": "item-887f9d00-b925-438a-b691-304a65ca446a",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "If she is, Miss Stern already knows, or she has chosen to look away. Either way, simple maids are not the cure. We only get crushed in the door."
                },
                {
                  "id": "item-b2416025-e909-4426-a6ba-04a73c43bee5",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "That silences her. Her sharp intellect recognizes the brutal logic."
                },
                {
                  "id": "item-6bc51211-28d1-4e6e-b564-83933d4d4abd",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I take her by the wrist and keep walking, our pace quick and quiet."
                },
                {
                  "id": "item-7a67213c-dd63-4be7-9a92-3cd76d31b8b6",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Behind us, Vance says something too low to catch. Mr. Locke answers with a quietness worse than anger."
                },
                {
                  "id": "item-1d3f9de8-fff4-4b18-b432-362976f5c7a8",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I collect the rhythm. The pause. The absolute yielding."
                },
                {
                  "id": "item-206f02c9-a90c-4c3a-955e-a399a97c3fd9",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "A writer does not always need the picture."
                },
                {
                  "id": "item-e1470bac-b88a-47e9-9531-4b139297cc2a",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Sometimes the wall tells the truer story."
                },
                {
                  "type": "python_script",
                  "code": "story.set_missy_day1_trust_state(\"soothed\")",
                  "id": "item-e7f2b443-7adc-4107-8fe4-d3dcb06cd719"
                }
              ]
            }
          ],
          "id": "item-e35e327d-45de-4cb1-9da4-3e4b169d302e"
        },
        {
          "type": "hide",
          "layer": null,
          "id": "item-3617d1d9-dd57-473c-9655-bb888edf9610",
          "characterId": "missy_sprite"
        },
        {
          "id": "item-c3ecc982-a3ab-45f0-b650-b35db4a4fa32",
          "type": "jump",
          "destinationLabelId": "label-47e30168-dfe8-404d-945e-b74c0c9bcd27"
        }
      ]
    },
    {
      "id": "label-47e30168-dfe8-404d-945e-b74c0c9bcd27",
      "name": "day101_3_taking_stock_day1",
      "x": 7300,
      "y": 11885,
      "dialogue": [
        {
          "type": "python_script",
          "code": "set_time_period(\"Evening\")",
          "id": "item-00974ab9-8630-4dc7-9cad-e034fe35a154"
        },
        {
          "id": "item-6f82ab0f-235b-41a9-be95-cf30b0f30b62",
          "type": "call",
          "destinationLabelId": "label-2e4ded4a-66fe-4af1-bc74-b2be000272cc"
        },
        {
          "type": "scene",
          "layer": null,
          "transition": "fade",
          "id": "item-a16e0c32-738d-4229-84ae-6de9c2e5c67c",
          "backgroundId": "bg_servants_quarters_dusk"
        },
        {
          "id": "item-acaa43ab-9a21-4a21-a326-a1625c8bfc48",
          "type": "dialogue",
          "characterId": null,
          "text": "By twilight my room has become mine in the meanest possible sense."
        },
        {
          "id": "item-502bb156-2afa-46bc-91e8-4c980919c9e6",
          "type": "dialogue",
          "characterId": null,
          "text": "A narrow bed. A washbasin. A peg for the uniform. A desk too small for ambition."
        },
        {
          "id": "item-be77e202-ef60-40cc-94d4-979a8aee4151",
          "type": "dialogue",
          "characterId": null,
          "text": "Still, there is a door."
        },
        {
          "id": "item-3a564671-d42c-4322-9aa5-011ae382ba34",
          "type": "dialogue",
          "characterId": null,
          "text": "There is a candle."
        },
        {
          "id": "item-6f8b16a8-bd9d-4bad-82b8-de73aa903c7e",
          "type": "dialogue",
          "characterId": null,
          "text": "There is paper."
        },
        {
          "type": "python_script",
          "code": "show_ledger_ui()",
          "id": "item-3329134c-0368-4873-b385-c113eee45aec"
        },
        {
          "id": "item-20bf4152-c17e-4705-86eb-d9a091e7702b",
          "type": "dialogue",
          "characterId": null,
          "text": "I open my ledger, the ink wet, and record the day's useful damages."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "1c7e6624-cdce-4ac1-8205-a8f067a4c736",
              "type": "if",
              "conditionRaw": "story.day1_corridor_state == \"predator\"",
              "dialogue": [
                {
                  "id": "item-8e7bd01b-812d-4efb-853d-cbe14960a751",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Missy's shocked, wounded face returns first. I used her decency as a blunt instrument."
                },
                {
                  "id": "item-00b878b4-2329-48b6-9ab3-584db2799955",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Then Vance's hand on the carpet. Mr. Locke's shoe. The walking stick."
                },
                {
                  "id": "item-b0c61ec3-82af-4708-9d27-58bee7ce4d96",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The sentence looks uglier once written down, but it is real."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day1_corridor_state == \"predator\""
            },
            {
              "id": "61029381-e070-4caa-9be5-e47abb0ea426",
              "type": "elif",
              "conditionRaw": "story.day1_corridor_state == \"prey\"",
              "dialogue": [
                {
                  "id": "item-3651112b-6923-4a6b-969d-08af3ba9b9cc",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I can still feel the corridor board shift beneath my shoe."
                },
                {
                  "id": "item-ca2eb6bd-1035-4151-a14b-008e843b0a20",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Mr. Locke had almost seen me."
                },
                {
                  "id": "item-920d6d81-712d-48fb-94be-9a42aa0b7a09",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "No. Not almost."
                },
                {
                  "id": "item-ab4e763d-f548-4b46-8049-d00fbc304d23",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "He saw enough to wonder."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day1_corridor_state == \"prey\""
            },
            {
              "id": "194ffba5-84fe-41be-b6cf-9d4888c2baf6",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-f3c42d6c-8328-4a7f-b52a-6b1382586d10",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The wall gave me less than my hunger wanted and more than my safety deserved."
                },
                {
                  "id": "item-16f5ff1b-76ba-4f6e-b0b9-c16fa3a7aae6",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "A voice can kneel."
                },
                {
                  "id": "item-c10a60d9-ad82-4d94-8a46-2634f606fdda",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I had not known that before today."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-8bf657fd-d7d9-4fdb-894d-f934613d3431"
        },
        {
          "type": "python_script",
          "code": "_dominant = get_dominant_archetype()",
          "id": "item-23c654dc-8025-440b-970d-a19edb71cbd9"
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "d539019e-8952-4359-b903-34ab2b81a39b",
              "type": "if",
              "conditionRaw": "_dominant == \"ghost\"",
              "dialogue": [
                {
                  "id": "item-aaecb58f-1056-4237-b7ba-d1cd6cb8f20e",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "My style is emerging as that of the unseen observer. A ghost, moving through the Savoy's gaps."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "_dominant == \"ghost\""
            },
            {
              "id": "0fb9adb7-88de-47b9-97cb-91a31a5d9568",
              "type": "elif",
              "conditionRaw": "_dominant == \"prey\"",
              "dialogue": [
                {
                  "id": "item-5824b99f-7d04-4ad1-a02b-d05b663d36af",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I survive here by reading threat and adapting. Tactically yielding, like prey that lives to run."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "_dominant == \"prey\""
            },
            {
              "id": "f58d7fe3-640d-42a6-8094-eb616503d64e",
              "type": "elif",
              "conditionRaw": "_dominant == \"predator\"",
              "dialogue": [
                {
                  "id": "item-58584d72-7a1a-4947-9816-06e258a519e3",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I find myself looking for leverage. I will bait them, test their lines, and feed on their secrets."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "_dominant == \"predator\""
            }
          ],
          "id": "item-514e4f45-964a-45b8-8449-6da185855320"
        },
        {
          "id": "item-0b2eb7bf-448e-49a8-9fa3-fbd33f8d2554",
          "type": "call",
          "destinationLabelId": "label-8a4adb67-c46f-47a7-b4cc-ff7e6e84b591"
        },
        {
          "id": "item-67e727d2-8308-449f-b84b-f09226ebdc82",
          "type": "jump",
          "destinationLabelId": "label-2af61494-a97f-453b-80c6-a38d3c0d3dbf"
        }
      ]
    },
    {
      "id": "label-8a4adb67-c46f-47a7-b4cc-ff7e6e84b591",
      "name": "day101_night_story_window",
      "x": 13700,
      "y": 12757.5,
      "dialogue": [
        {
          "type": "python_script",
          "code": "set_time_period(\"Night\")",
          "id": "item-127fe3a7-1bec-47e7-9f47-0dff09f89c37"
        },
        {
          "id": "item-fb389bc0-316a-429b-8554-d330d30a2629",
          "type": "call",
          "destinationLabelId": "label-46e3ecc2-06e8-4066-9581-1bc3e9af5358"
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "11613dc5-c705-4728-9ad0-1c8529c5a848",
              "type": "if",
              "conditionRaw": "_penance_consumed",
              "dialogue": [],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "_penance_consumed"
            }
          ],
          "id": "item-19dfd5da-7af1-44fa-9e79-59003dc79adc"
        },
        {
          "type": "choice",
          "options": [
            {
              "id": "e3cf00ff-7871-4ff4-ab77-3e333d449f8e",
              "text": "Write the first chapter of my manuscript. [[Progress manuscript]]",
              "dialogue": [
                {
                  "id": "item-6a6bae2c-32e2-4b36-9349-e3e754ce2a43",
                  "type": "call",
                  "destinationLabelId": "label-fd289fa9-ab46-4802-91ef-a72ab6e54e06"
                }
              ]
            },
            {
              "id": "ed966825-847c-4d04-a35d-51c63048d06c",
              "text": "Listen for Miss Stern's keys in the west corridor.",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "_chain_label = story.resolve_chain_label(\"stern\")",
                  "id": "item-fd200401-43a4-407a-b335-a02c914afb92"
                },
                {
                  "id": "item-2038bcc1-3180-40b2-9c54-724b6ced5fbc",
                  "type": "call",
                  "destinationLabelId": ""
                }
              ]
            },
            {
              "id": "c85243a5-6766-4ade-83cb-b889b5df2b21",
              "text": "Find Missy before the laundry goes cold.",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "_chain_label = story.resolve_chain_label(\"missy\")",
                  "id": "item-230c2da4-a9cf-456d-9040-b9a1e3353832"
                },
                {
                  "id": "item-8d51ce6e-2941-4059-acf9-0dd1ee27e527",
                  "type": "call",
                  "destinationLabelId": ""
                }
              ]
            },
            {
              "id": "1fcd8f9a-588d-4c98-945e-a2b5e6cce5b4",
              "text": "Walk the guest wing where Mr. Locke's shoe still has authority.",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "_chain_label = story.resolve_chain_label(\"vance\")",
                  "id": "item-6c5dd9ce-6b8f-403a-b1dd-5950d710b87c"
                },
                {
                  "id": "item-42ffb8fd-a05e-4825-b455-18d2afbd67fd",
                  "type": "call",
                  "destinationLabelId": ""
                }
              ]
            },
            {
              "id": "5e097930-cf38-49d2-90c1-4a722304fead",
              "text": "Stay at the desk and let the ink dry. [[Rest and reflect]]",
              "dialogue": [
                {
                  "type": "choice",
                  "options": [
                    {
                      "id": "64e4ca4e-259b-4c72-9343-824b0d5cdc30",
                      "text": "Order. Safety in structure. [[Creative discipline]]",
                      "dialogue": [
                        {
                          "type": "python_script",
                          "code": "apply_balanced_effect(\"creative\", intensity=\"standard\")",
                          "id": "item-199c6a65-59b3-412c-a07b-60c00f205cb7"
                        },
                        {
                          "type": "python_script",
                          "code": "story.set_day1_ledger_focus(\"inspiration\")",
                          "id": "item-6174dbef-a7aa-4880-ae84-e3f73495df4a"
                        },
                        {
                          "id": "item-492a28d0-3f29-4cd1-b9cf-9649ce8d823a",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "I draw three columns in the ledger."
                        },
                        {
                          "id": "item-2f72d9d0-9a93-4242-97f9-51f11d8e258b",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "Command. Witness. Consequence."
                        },
                        {
                          "id": "item-6feb97e4-ac41-40c2-8581-06694f7b8cf6",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "The shape of the scene matters more than the appetite of it."
                        },
                        {
                          "id": "item-7aed76f2-5c24-4d87-b29d-97013a462b60",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "A woman attacks downward because she cannot attack upward. A man corrects her, not from kindness, but ownership. A servant sees and becomes dangerous."
                        },
                        {
                          "id": "item-4bdc0f22-a8af-49dd-a88b-b121f346f9ae",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "That is a story."
                        },
                        {
                          "id": "item-d059ebfa-e991-440f-ac62-b9d212c1debb",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "Not a confession."
                        },
                        {
                          "id": "item-4f91f44e-3d3e-4af6-8e05-a8c32fa6e691",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "Not yet."
                        }
                      ]
                    },
                    {
                      "id": "be143b93-9f35-4455-9c3b-de05f2150279",
                      "text": "Exposure. Safety in knowing the threat. [[Transgressive discipline]]",
                      "dialogue": [
                        {
                          "type": "python_script",
                          "code": "apply_balanced_effect(\"transgressive\", intensity=\"standard\", witness=\"vance\")",
                          "id": "item-0db749a8-cb59-4903-850a-d6d6d318cda2"
                        },
                        {
                          "type": "python_script",
                          "code": "story.set_day1_ledger_focus(\"corruption\")",
                          "id": "item-6316f73c-b594-4972-bae7-cb74a090722b"
                        },
                        {
                          "id": "item-bf096faa-d47f-4a9e-9cd4-adb82c57c8e2",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "I try to write command, witness, consequence."
                        },
                        {
                          "id": "item-7662e8e1-2b05-4468-bdee-a4ae88d5a36d",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "My hand writes want."
                        },
                        {
                          "id": "item-bcbe7c86-d8fb-43ac-a25a-d31ae15203ef",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "Not simply Vance's."
                        },
                        {
                          "id": "item-6f6d1e9d-83b6-4210-a8f1-47832b763285",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "That would be easier. Cleaner."
                        },
                        {
                          "id": "item-a14302f2-1767-49da-87e7-5cd819984437",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "I think of the way she yielded and hated him for making her yield."
                        },
                        {
                          "id": "item-e1ed75bb-e1a5-4e5f-baaa-4239957c26b5",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "I think of Missy reaching for the latch because I placed fear in her hand and called it concern."
                        },
                        {
                          "id": "item-76357b41-1320-45db-b99b-ac9ac5f66c7f",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "I think of myself outside the door, starved for the next sound."
                        },
                        {
                          "id": "item-22fe8165-5cf7-4de8-859c-a15ddd21e87b",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "The ledger does not forgive me."
                        },
                        {
                          "id": "item-c75514a2-1c52-4316-9370-d8dd47a290b5",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "It records beautifully."
                        }
                      ]
                    }
                  ],
                  "id": "item-c1709563-1a18-4699-a32e-97818e2318e1"
                },
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"observant\", intensity=\"standard\")",
                  "id": "item-3bc0df88-997a-474d-a4be-dbfac159ad2d"
                }
              ]
            }
          ],
          "id": "item-b52ce539-a5a5-4c56-b9b6-1c57d79455f6"
        }
      ]
    },
    {
      "id": "label-2e4ded4a-66fe-4af1-bc74-b2be000272cc",
      "name": "day101_evening_consequence_window",
      "x": 22100,
      "y": 12832.5,
      "dialogue": [
        {
          "id": "item-e7552146-60c4-425d-8f6c-afae5798fefa",
          "type": "call",
          "destinationLabelId": "label-5f635f30-8ef3-4f17-80e7-4e5cde552ded"
        }
      ]
    },
    {
      "id": "label-fd289fa9-ab46-4802-91ef-a72ab6e54e06",
      "name": "day101_4_write_the_chapter",
      "x": 14100,
      "y": 12730,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-45606f0e-6891-41df-86db-84071c27d76a",
          "backgroundId": "bg_cora_desk_night"
        },
        {
          "type": "python_script",
          "code": "story.set_day1_night_action(\"write\")",
          "id": "item-61203657-9fb4-4621-8065-592f23793239"
        },
        {
          "type": "choice",
          "options": [
            {
              "id": "608d92ed-6f0d-43c3-9e6f-67f7f5ad1ef6",
              "text": "Frame it with order and structure. I must write what is safe. [[Creative framing]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"creative\", intensity=\"standard\")",
                  "id": "item-49c24df3-807e-491b-8d1c-8ee312321dc3"
                },
                {
                  "type": "python_script",
                  "code": "story.set_day1_ledger_focus(\"inspiration\")",
                  "id": "item-01987856-011e-4db4-b539-ff9188f5d7e6"
                },
                {
                  "id": "item-42a2d3e6-12dd-4dd9-b2bd-6ab582821eae",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I draw three columns in the ledger and let the structure guide my hand."
                },
                {
                  "id": "item-a5f754b6-83d6-4632-970d-04532db660be",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The shape of the scene matters more than the appetite of it."
                },
                {
                  "id": "item-89b7ca5a-09e9-4c40-9bfa-6b1d470d38f4",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "A woman attacks downward because she cannot attack upward. A man corrects her, not from kindness, but ownership."
                }
              ]
            },
            {
              "id": "929fc954-e9f6-42f4-9db7-df005ad04e0a",
              "text": "Frame it with exposure and appetite. I must write the truth. [[Transgressive framing]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"transgressive\", intensity=\"standard\", witness=\"vance\")",
                  "id": "item-2d992f53-bbde-4963-b699-26072804b7e7"
                },
                {
                  "type": "python_script",
                  "code": "story.set_day1_ledger_focus(\"corruption\")",
                  "id": "item-7195bcd2-61ca-4e97-9379-9c895dc55cac"
                },
                {
                  "id": "item-64a2f8e1-994f-4da8-8678-547ae1558b2c",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I try to write command, witness, consequence, but my hand writes want."
                },
                {
                  "id": "item-626d85cb-23d9-406c-93d3-bc2103792e3b",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I think of the way she yielded and hated him for making her yield."
                },
                {
                  "id": "item-07045d70-2767-4635-b8f0-67bc376a5f89",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I think of Missy reaching for the latch because I placed fear in her hand."
                }
              ]
            }
          ],
          "id": "item-8c61b285-d038-494e-b99d-4bd3c6e54768"
        },
        {
          "id": "item-44cba472-3bd1-4794-9ba4-85b496e959c2",
          "type": "dialogue",
          "characterId": null,
          "text": "The first sentence arrives like a servant entering the wrong room: terrified, many-layered, and unable to retreat."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "0488dfd6-73e3-4b07-9aa9-c0fcd487e639",
              "type": "if",
              "conditionRaw": "story.day1_corridor_state == \"predator\"",
              "dialogue": [
                {
                  "id": "item-d6633db5-304d-4e36-925c-f27b1757e21d",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I write a maid who learns that innocence is not a virtue."
                },
                {
                  "id": "item-c2e99e8d-666c-4f07-92be-ff8383793880",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "It is a tool left unattended."
                },
                {
                  "id": "item-efb9a5ae-a7ac-465f-bac9-d158afb2d81c",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She places a sweeter girl before a dangerous door and discovers that guilt has a taste."
                },
                {
                  "type": "if_block",
                  "branches": [
                    {
                      "id": "0ded6502-fab9-44c8-a028-6722a500fcdb",
                      "type": "if",
                      "conditionRaw": "story.day1_ledger_focus == \"corruption\"",
                      "dialogue": [
                        {
                          "id": "item-b444e232-621e-4225-b833-cb264c9c4cd7",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "In the chapter, the maid does not apologise."
                        },
                        {
                          "id": "item-37df0a0d-02d0-4cfc-9ef1-d37d5d6256fb",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "She improves."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      },
                      "rawCondition": "story.day1_ledger_focus == \"corruption\""
                    },
                    {
                      "id": "90075a00-48a6-4698-8840-229a67a60942",
                      "type": "else",
                      "conditionRaw": null,
                      "dialogue": [
                        {
                          "id": "item-840b13ee-8c60-4d7b-ad9b-ea847a2309be",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "In the chapter, the maid understands the cost and writes it down anyway."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      }
                    }
                  ],
                  "id": "item-d461e1d1-959c-458d-83b1-619f266aa43a"
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day1_corridor_state == \"predator\""
            },
            {
              "id": "3d31a1f6-9bfd-42af-98ec-6a76da0bc280",
              "type": "elif",
              "conditionRaw": "story.day1_corridor_state == \"prey\"",
              "dialogue": [
                {
                  "id": "item-2f473d07-120a-4b02-9f53-c517b8283b3b",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I write a maid who looks through a forbidden crack and is seen looking."
                },
                {
                  "id": "item-ba860c43-155b-4b6b-aba6-59762ae07ca4",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The gentleman does not shout. He invites her closer."
                },
                {
                  "id": "item-ea4e7273-23bf-4a9b-838b-505b83c4bdf5",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "That is worse."
                },
                {
                  "type": "if_block",
                  "branches": [
                    {
                      "id": "3cca4f1e-1fc9-4daa-a8dc-6df853f574af",
                      "type": "if",
                      "conditionRaw": "story.day1_ledger_focus == \"corruption\"",
                      "dialogue": [
                        {
                          "id": "item-61ec7957-8454-4448-b55d-b0085419940d",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "On the page, fear and invitation become difficult to separate."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      },
                      "rawCondition": "story.day1_ledger_focus == \"corruption\""
                    },
                    {
                      "id": "85fd0ab2-2ae6-43b8-942d-fae1eb985692",
                      "type": "else",
                      "conditionRaw": null,
                      "dialogue": [
                        {
                          "id": "item-5c402547-7397-4cc3-a609-d764e6770f56",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "On the page, the danger remains danger. The heat is only evidence."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      }
                    }
                  ],
                  "id": "item-e6b58cd8-c2b5-4988-9e0a-0267cf8cd688"
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day1_corridor_state == \"prey\""
            },
            {
              "id": "85c208d1-e70b-4438-980a-d32c85754f23",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-2f3ddab7-8ce7-4d34-807a-abff0b64af18",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I write a maid who never sees the room."
                },
                {
                  "id": "item-75d21032-aaec-424c-bab5-a8e454a40c5b",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Only the wall. Only the voice. Only the terrible grammar of command and reply."
                },
                {
                  "id": "item-f1f43886-ecaa-4c9e-9944-08c5c8b15095",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Her ignorance becomes precision."
                },
                {
                  "type": "if_block",
                  "branches": [
                    {
                      "id": "42e78246-7eb9-4b86-8a5e-3420728cfbe4",
                      "type": "if",
                      "conditionRaw": "story.day1_ledger_focus == \"corruption\"",
                      "dialogue": [
                        {
                          "id": "item-50487513-bd61-4e4f-a936-c8694b906883",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "She imagines too much and tells herself imagination is not participation."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      },
                      "rawCondition": "story.day1_ledger_focus == \"corruption\""
                    },
                    {
                      "id": "1495a111-b819-4848-b17c-29c691dda3ba",
                      "type": "else",
                      "conditionRaw": null,
                      "dialogue": [
                        {
                          "id": "item-555041f6-310d-408b-8563-8b49cee32fd1",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "She understands that distance can sharpen a knife."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      }
                    }
                  ],
                  "id": "item-15e84775-6cc7-4e80-b27f-844b8c575b6f"
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-4466df92-8eb7-4907-9441-bdcdd672c70f"
        },
        {
          "id": "item-7ce6e796-7b30-477e-bd5c-49606e85469f",
          "type": "dialogue",
          "characterId": null,
          "text": "By the time the candle gutters, there are pages."
        },
        {
          "id": "item-cf8613ef-bdd7-4926-b1a1-20a082dfe115",
          "type": "dialogue",
          "characterId": null,
          "text": "Not a chapter. Not a wound. Not even a proper lie."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "d0c9a176-fdf5-47db-b5c4-ac702a932280",
              "type": "if",
              "conditionRaw": "player.corruption_level <= WRITE_SLOP_MAX_CORRUPTION_LEVEL",
              "dialogue": [
                {
                  "id": "item-9ddfd14c-7d8c-497f-b751-eb16906d5e8e",
                  "type": "call",
                  "destinationLabelId": "label-50c93452-a12f-49cf-9982-b6cc72b97648"
                },
                {
                  "id": "item-703cbe6a-3e1d-4cda-a43a-380cad4b2baf",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Flavorless slop."
                },
                {
                  "id": "item-3a14063a-8084-4974-ab02-e97f9400f979",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Unsellable, bloodless, afraid of its own pulse."
                },
                {
                  "id": "item-c27ffa6e-475b-4f34-accf-0d6c2ae9a13f",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I had inspiration, but no appetite, and the page told on me."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "player.corruption_level <= WRITE_SLOP_MAX_CORRUPTION_LEVEL"
            },
            {
              "id": "55180cb4-1c21-4ee0-8fef-f81ccb574f18",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "story.complete_manuscript_chapter(\"day1_chapter\")",
                  "id": "item-48f70422-194a-4e07-9caf-dcd12e43edd2"
                },
                {
                  "id": "item-aa10e60b-994f-41ca-a7f3-fd02888387c6",
                  "type": "call",
                  "destinationLabelId": "label-50c93452-a12f-49cf-9982-b6cc72b97648"
                },
                {
                  "id": "item-8549e200-6b4c-45ac-b214-6c63213abc07",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "There is a shape worth keeping, but it still feels premature."
                },
                {
                  "id": "item-18d1f118-af45-44e1-9631-63185deca2b6",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Tomorrow's material will decide whether this becomes a chapter or kindling."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-09b21c2e-6527-4736-888f-42c6f187b2db"
        },
        {
          "type": "python_script",
          "code": "apply_effects(insp=-10)",
          "id": "item-bd13c16d-6c1d-4ca8-9e7f-5ec4f07633c9"
        },
        {
          "id": "item-dfc49499-9c89-4c2e-a227-e6a32e25ad3c",
          "type": "dialogue",
          "characterId": null,
          "text": "I press the pages flat beneath the ledger."
        },
        {
          "id": "item-545be4f6-077f-4c36-9d96-329b7ff4e90d",
          "type": "dialogue",
          "characterId": null,
          "text": "Tomorrow the house will expect a maid."
        },
        {
          "id": "item-615cbaea-ecf7-4c50-9d22-6d8b36dd257d",
          "type": "dialogue",
          "characterId": null,
          "text": "Tonight it acquired a failed first draft."
        }
      ]
    },
    {
      "id": "label-2af61494-a97f-453b-80c6-a38d3c0d3dbf",
      "name": "day102_1_cora_missy_first_shift",
      "x": 7700,
      "y": 11632.5,
      "dialogue": [
        {
          "type": "python_script",
          "code": "time_manager.set_current_day(2)",
          "id": "item-df8090a4-0560-4eea-9264-a68371be9ef1"
        },
        {
          "type": "python_script",
          "code": "set_time_period(\"Morning\")",
          "id": "item-551f412f-a3b2-4ccb-83a1-3f427345169e"
        },
        {
          "type": "scene",
          "layer": null,
          "transition": "fade",
          "id": "item-3bfd9bdd-118c-42f2-88d9-4253aaeea35a",
          "backgroundId": "bg_master_suite_day"
        },
        {
          "id": "item-87dece62-ff38-4057-a28d-86baf2b11324",
          "type": "dialogue",
          "characterId": null,
          "text": "The Master Suite is larger in daylight and less honest for it."
        },
        {
          "id": "item-5c2f13c6-9046-4959-89a0-76a1628080a6",
          "type": "dialogue",
          "characterId": null,
          "text": "Breakfast has emptied the room of its occupants, but not of them."
        },
        {
          "id": "item-b1e37257-e259-450c-ae22-cb72f3d8286d",
          "type": "dialogue",
          "characterId": null,
          "text": "Vance is in the perfume lingering over the dressing table. Mr. Locke is in the chair angled toward the hearth, as if the room itself has learned to obey him."
        },
        {
          "id": "item-958daa96-fdce-464c-b153-e9ee568600a7",
          "type": "dialogue",
          "characterId": null,
          "text": "The rich do not only leave crumbs."
        },
        {
          "id": "item-b2e71dc0-241b-4371-9336-dd9a6730861e",
          "type": "dialogue",
          "characterId": null,
          "text": "They leave proof that someone lived loudly while pretending not to."
        },
        {
          "id": "item-2e1303b9-2c7e-45f1-9fc0-4c830255feec",
          "type": "show",
          "characterId": "missy_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "missy_sprite smiling"
        },
        {
          "id": "item-ad05e71b-a678-4f82-b84a-5b02f632f4a6",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "Best room in the hotel, this one. Best view, best rugs, best chance of being shouted at by Miss Stern for breathing the air wrong."
        },
        {
          "id": "item-43b82522-8e76-4afc-a9e8-6dff6ceda2ec",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base"
        },
        {
          "id": "item-40a8d246-8e7e-461c-b448-2d30ee27a6d3",
          "type": "show",
          "characterId": "missy_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "move",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "missy_sprite smiling"
        },
        {
          "id": "item-2ae10b8e-b0ee-4e2f-a924-3db67d648f04",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "You make it sound almost desirable."
        },
        {
          "id": "item-00db46cf-2d05-4b37-951a-32801448e987",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "Oh, it is, in a terrible sort of way. You should see the breakfast trays they carry up. Kippers. Proper marmalade. Soft eggs with little hats on. It's like a different country, Cora. But if you linger too long looking at the drapes, they'll have you out on the street without a character."
        },
        {
          "id": "item-f88cd48a-7e39-4364-826b-1c849be1e659",
          "type": "dialogue",
          "characterId": null,
          "text": "She says this while hauling a damp sheet into a basket twice her width, her face flushed but her hands exact."
        },
        {
          "id": "item-c39dfede-6e8b-40d9-b667-8f7a775def53",
          "type": "dialogue",
          "characterId": null,
          "text": "An intelligent country girl who has decoded the Savoy's math: luxury is paid for by the invisibility of those who clean it."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "4418919b-b498-4792-9121-f7847bef5645",
              "type": "if",
              "conditionRaw": "story.day1_night_action == \"visit_missy\"",
              "dialogue": [
                {
                  "id": "item-09e30e48-693f-400f-bd37-482b5dc11086",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Missy glances at me more softly than she did yesterday."
                },
                {
                  "id": "item-c0d50350-986b-4253-ac0a-c3056c7c7f3d",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Last night's kindness—a quiet conversation in the steam, a shared warning—still has a little weight between us."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day1_night_action == \"visit_missy\""
            },
            {
              "id": "6bb644e6-ed34-45e8-bb0d-dd18f9fde292",
              "type": "elif",
              "conditionRaw": "story.day1_corridor_state == \"predator\"",
              "dialogue": [
                {
                  "id": "item-92db5184-de7f-40b8-a320-eefd6582bb65",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Missy is bright with me, but her shoulders carry a subtle stiffness."
                },
                {
                  "id": "item-9f1ac0cd-eec5-474e-accd-70f5510c2c67",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Her sharp memory hasn't forgotten the service door, even if she has decided her defensive moral shield requires her to remain silent about it."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day1_corridor_state == \"predator\""
            },
            {
              "id": "d5e6fe5f-b8b1-4018-b951-d5bed139bce3",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-3457f046-e67f-435e-8ded-22372ee0a5cf",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Missy moves as if yesterday can be folded away with the linen."
                },
                {
                  "id": "item-4ede58da-f3e0-4a77-adc0-640671a25385",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I envy the trick. I do not share it."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-9b1502db-7c56-4f40-b679-da84967676ed"
        },
        {
          "id": "item-4079e2a7-ee2e-45ac-812d-358a4395da1d",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "You take the hearth. I'll see to the armoire. If anything bites, shout. Miss Stern says a quiet maid is a safe maid, but I say a loud maid at least gets to keep her fingers."
        },
        {
          "id": "item-b7d0b57e-16ca-4695-9750-8778a38e7ca1",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Does anything bite?"
        },
        {
          "id": "item-eb536c8e-86d3-4585-b49d-9040561c8cbf",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "In a suite like this? Only the pride of the people who pay for it."
        },
        {
          "id": "item-7687c69c-5bc8-4adf-ad80-63e4d9c20cec",
          "type": "dialogue",
          "characterId": null,
          "text": "I kneel at the hearth and brush yesterday's ash into a pan."
        },
        {
          "id": "item-a79db4df-4da2-44ff-a7bd-996bcf61ec8f",
          "type": "dialogue",
          "characterId": null,
          "text": "The work should empty the mind."
        },
        {
          "id": "item-ed37f2a5-9caa-4268-8976-453833bfbd2b",
          "type": "dialogue",
          "characterId": null,
          "text": "It does not."
        },
        {
          "id": "item-81243da8-9bf3-4d4e-bad7-7612e833fa6e",
          "type": "jump",
          "destinationLabelId": "label-4c3a8dda-5f59-4ffc-8fbf-072f94e637e4"
        }
      ]
    },
    {
      "id": "label-4c3a8dda-5f59-4ffc-8fbf-072f94e637e4",
      "name": "day102_1_missy_finds_a_thing",
      "x": 8100,
      "y": 11632.5,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-1d811d9a-98f4-442b-bbc4-da10ab4b9388",
          "backgroundId": "bg_master_suite_day"
        },
        {
          "id": "item-b0ac269e-5bd4-40e2-97fe-e12abc4e0bf8",
          "type": "show",
          "characterId": "missy_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "missy_sprite smiling"
        },
        {
          "id": "item-89530ddc-78a8-4ac5-881f-b7d357171fef",
          "type": "dialogue",
          "characterId": null,
          "text": "There is a soft clatter behind me."
        },
        {
          "id": "item-1584af37-538f-4ba9-80b5-43535461f664",
          "type": "dialogue",
          "characterId": null,
          "text": "Not porcelain. Not metal. Something lighter. A hatbox giving up its secret."
        },
        {
          "id": "item-a6289b28-57c4-4841-b9b2-0887aa415b9e",
          "type": "show",
          "characterId": "missy_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "missy_sprite confused"
        },
        {
          "id": "item-023523ec-ca87-4c8b-9c06-a8a75fa7f62c",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "Cora?"
        },
        {
          "id": "item-1aafcb12-378a-44ed-afbd-0d5b8ad74a42",
          "type": "dialogue",
          "characterId": null,
          "text": "Missy's voice has lost its bright shine. It has become quiet, exceptionally focused, and deliberate."
        },
        {
          "id": "item-31b919f1-7a15-436f-a316-31e9e9a68c21",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base"
        },
        {
          "id": "item-9df5e8f2-33a1-4e02-969c-d3119b90406f",
          "type": "show",
          "characterId": "missy_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "move",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "missy_sprite confused"
        },
        {
          "id": "item-a3d182d1-a8de-4f8e-8fcd-b5bec412c98f",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "What is it?"
        },
        {
          "id": "item-6bff33fe-0e9c-48b0-810c-bf0d92a1da97",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "I... I don't know. It was tucked behind the vanity hatbox. It isn't proper, Cora. It isn't proper at all."
        },
        {
          "id": "item-b32e3209-6882-4fe7-ad65-1426a88f03b0",
          "type": "dialogue",
          "characterId": null,
          "text": "She holds it up with two fingers, her touch cautious, her face flushed with a mix of moral alarm and highly focused interest."
        },
        {
          "id": "item-d47e98b2-0316-4112-bd2b-407f302e9208",
          "type": "dialogue",
          "characterId": null,
          "text": "Sheer silk lace. Expensive, transgressive, and designed with no interest whatsoever in modesty."
        },
        {
          "id": "item-350ff04e-db6a-46f5-aba6-53e0cef9cdf1",
          "type": "dialogue",
          "characterId": null,
          "text": "The white silk catches the daylight, lighter than it has any right to be."
        },
        {
          "id": "item-3d17af6d-cf77-467a-8dc8-5bead0f93a7e",
          "type": "dialogue",
          "characterId": null,
          "text": "The room seems to narrow around the thing."
        },
        {
          "id": "item-05023d73-6f15-4b0b-9d18-5a49489f2a1f",
          "type": "dialogue",
          "characterId": null,
          "text": "Vance's fury from yesterday. Gideon's quiet command. The service door. The sound through plaster."
        },
        {
          "id": "item-fa7d071f-0de2-40d3-80d3-a03afa8074e5",
          "type": "dialogue",
          "characterId": null,
          "text": "All of it becomes touchable."
        },
        {
          "id": "item-adba7378-ab6d-4c84-8787-e2a1fbf0a782",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "What sort of lady owns something like this? It's like... like a sin you can wear."
        },
        {
          "id": "item-2e95a858-01a5-40aa-9922-f2ce3cea91c9",
          "type": "dialogue",
          "characterId": null,
          "text": "Her religious register is active, a protective social shield drawn instantly to draw a line in the sand."
        },
        {
          "id": "item-f2fae801-69b9-4f77-a06e-a6c5cad24592",
          "type": "dialogue",
          "characterId": null,
          "text": "But her questions show a sharp, decoding intellect trying to comprehend the private transgressions of the suites."
        },
        {
          "id": "item-bf602f7d-2a47-4063-8875-736511ba4130",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "The sort who does not expect a maid to find it before luncheon."
        },
        {
          "id": "item-068b2482-31a1-4e81-8ec8-78df2175a913",
          "type": "dialogue",
          "characterId": null,
          "text": "Missy considers this, her gaze fixed on the sheer lace, her breathing turning slightly shallow."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "b91adc31-71c4-4ef1-a608-cc429b3781ec",
              "type": "if",
              "conditionRaw": "story.day1_corridor_state == \"predator\"",
              "dialogue": [
                {
                  "id": "item-689cc5b3-fbcb-4291-858f-84116f4616ce",
                  "type": "jump",
                  "destinationLabelId": "label-719ede4a-493a-4400-9429-1fe017106e72"
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day1_corridor_state == \"predator\""
            },
            {
              "id": "fd2a3636-79b6-49ca-bd4a-e19eb1b9f74c",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-b27e2015-d2dc-4e11-a6cd-000549162fbc",
                  "type": "jump",
                  "destinationLabelId": "label-21c39789-baac-4853-a989-ca5e2893ad91"
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-3eb6d08a-06a3-4a2f-ace0-85f1577d4fe7"
        },
        {
          "id": "item-77023b89-4a3b-40a3-96ba-be31f847b23d",
          "type": "jump",
          "destinationLabelId": "label-719ede4a-493a-4400-9429-1fe017106e72"
        }
      ]
    },
    {
      "id": "label-719ede4a-493a-4400-9429-1fe017106e72",
      "name": "day102_1_cora_takes_the_thing",
      "x": 8500,
      "y": 12607.5,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-9253cab0-0922-44bb-a42d-023b17bcf62b",
          "backgroundId": "bg_master_suite_day"
        },
        {
          "id": "item-7eb89d20-afdd-4fbc-b3a6-3a853f7be322",
          "type": "show",
          "characterId": "missy_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "missy_sprite confused"
        },
        {
          "type": "python_script",
          "code": "story.set_day2_contraband_state(\"stolen_wearing\")",
          "id": "item-e8fe64ce-1f6f-4b68-a4a6-e660041454d4"
        },
        {
          "type": "python_script",
          "code": "apply_balanced_effect(\"transgressive\", intensity=\"standard\", witness=\"vance\")",
          "id": "item-5d018733-23a5-4993-8f9b-875e612365c5"
        },
        {
          "id": "item-1ec87c22-8282-460e-995f-0214f8fffd18",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base"
        },
        {
          "id": "item-861528a9-9d5a-469b-a435-55a6ad768236",
          "type": "show",
          "characterId": "missy_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "move",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "missy_sprite confused"
        },
        {
          "id": "item-abaf5f73-2977-4cfe-9759-3da99dc2f7cf",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Give it here."
        },
        {
          "id": "item-ab439eff-7327-4424-989e-fa685ba40efe",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "Shouldn't we put it back? If they discover it's gone..."
        },
        {
          "id": "item-3229aa61-fe20-46f0-bca9-60c7de5a6f39",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "We should not stand in the middle of Mr. Locke's suite holding it like a banner. If Stern walks in now, we're both ruined."
        },
        {
          "id": "item-7b471e2c-28d1-4944-b0cc-74fd7ea7c43e",
          "type": "dialogue",
          "characterId": null,
          "text": "Missy flinches, the practical danger silencing her."
        },
        {
          "id": "item-7749f44b-4d26-48d4-a578-a0896a0144c7",
          "type": "dialogue",
          "characterId": null,
          "text": "She hands it over, her eyes lingering on my fingers."
        },
        {
          "id": "item-dc21a400-43cb-4018-afbb-6745c475c14a",
          "type": "dialogue",
          "characterId": null,
          "text": "The lace is lighter than guilt should be."
        },
        {
          "id": "item-cb6f115b-3866-4bdf-b405-ae59b75fadca",
          "type": "dialogue",
          "characterId": null,
          "text": "I cross into the washroom before Missy can form another question."
        },
        {
          "id": "item-2dbc0ee9-f70a-408e-acbb-1b15f9c69fde",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "Cora? What are you doing in there?"
        },
        {
          "id": "item-2c1dd597-3d37-4835-b1ed-4321b0759182",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Keep folding, Missy. Don't look toward the door."
        },
        {
          "id": "item-56326b5a-b7bd-4ad2-88d2-ec3218f4d389",
          "type": "dialogue",
          "characterId": null,
          "text": "Behind the half-closed door, I remove my plain, coarse cotton uniform and step into the stolen silk."
        },
        {
          "id": "item-1f9788a7-ecf3-4cef-8b1e-d4cf935abf83",
          "type": "dialogue",
          "characterId": null,
          "text": "Every breath is a wager against the fabric."
        },
        {
          "id": "item-9d545b68-3fb9-40a3-b47d-94959585b7dc",
          "type": "dialogue",
          "characterId": null,
          "text": "It sits beneath the uniform like a secret, transgressive sentence."
        },
        {
          "id": "item-22e12ddb-48d5-43ad-87a1-6616b128f628",
          "type": "dialogue",
          "characterId": null,
          "text": "The maid above. The sovereign desire below."
        },
        {
          "id": "item-5c2f2e87-451b-4937-b89a-69bdcdfe8ba1",
          "type": "dialogue",
          "characterId": null,
          "text": "When I return, Missy looks at my empty hands, her sharp eyes immediately cataloging the slight shift in my posture, the way the cotton uniform sits differently."
        },
        {
          "id": "item-434e89e4-d639-4375-93e3-e3cb7d33352e",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "Where is it? You didn't..."
        },
        {
          "id": "item-93c1dc92-7fc1-46c4-b30e-5dad61176f4f",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "It is safe, Missy."
        },
        {
          "id": "item-e297e6e0-e2d9-411d-a970-582c917fc4d7",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "Safe is not the same as proper, Cora. There's a wicked draft in this room, and you look... different."
        },
        {
          "id": "item-923458c6-5c1c-4026-ade5-af31269b90f5",
          "type": "dialogue",
          "characterId": null,
          "text": "She knows. Or her sharp, sheltered observancy warns her that a boundary has been crossed."
        },
        {
          "id": "item-d5198709-9ca7-4337-a715-caab2d4687f7",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "In this house, proper is only what survives being noticed. We do what we must to keep our heads."
        },
        {
          "id": "item-dc4cf31d-d360-4eae-a0fe-60ada9d0d01e",
          "type": "dialogue",
          "characterId": null,
          "text": "She doesn't like that. Her protective moral shield is bruised, her trust unsettled."
        },
        {
          "type": "python_script",
          "code": "story.set_missy_day2_suspicion_state(\"uneasy\")",
          "id": "item-9c76d173-137b-4520-b735-a2b4f27aa3a6"
        },
        {
          "id": "item-8dd8ddda-9b61-4ea6-b2e3-71324891e548",
          "type": "jump",
          "destinationLabelId": "label-4fbb4754-2803-4ae6-b108-5f63eb81d2d2"
        }
      ]
    },
    {
      "id": "label-21c39789-baac-4853-a989-ca5e2893ad91",
      "name": "day102_1_cora_deceives_missy",
      "x": 8500,
      "y": 11502.5,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-7cf69e98-764d-48d7-97c8-a6dea3d73fba",
          "backgroundId": "bg_master_suite_day"
        },
        {
          "id": "item-5ffa9919-b0ef-48cc-8077-3166523a6b3c",
          "type": "show",
          "characterId": "missy_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "missy_sprite confused"
        },
        {
          "type": "python_script",
          "code": "story.set_day2_contraband_state(\"planted_in_trunk\")",
          "id": "item-18c40766-9fe1-4b44-8c74-30a27f68cf08"
        },
        {
          "type": "python_script",
          "code": "apply_balanced_effect(\"curious\", intensity=\"standard\", witness=\"missy\")",
          "id": "item-0f2d7a1e-d9f2-4448-a466-15a0651d06c7"
        },
        {
          "id": "item-707a0410-d9fa-4364-b3fe-3928584f9bda",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base"
        },
        {
          "id": "item-ef655470-c7af-4e8a-ab3f-cd823ae4b93d",
          "type": "show",
          "characterId": "missy_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "move",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "missy_sprite confused"
        },
        {
          "id": "item-39cb6ffc-38c3-4ad7-8584-3ec90963a934",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Put it away. Quickly."
        },
        {
          "id": "item-9ba1164b-c133-4a75-b080-f560a09ab18d",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "Back in the hatbox?"
        },
        {
          "id": "item-f33fed6f-864d-4aa1-a8e1-0e656ddfc2f5",
          "type": "dialogue",
          "characterId": null,
          "text": "The hatbox is the obvious place."
        },
        {
          "id": "item-dd88b937-504d-4702-b1e1-ddbe5d7a6a30",
          "type": "dialogue",
          "characterId": null,
          "text": "Obvious things are where Miss Stern's blame waits."
        },
        {
          "id": "item-f932d23b-294d-4f8f-92eb-b94f2a17a2d5",
          "type": "dialogue",
          "characterId": null,
          "text": "A trunk is not a hiding place."
        },
        {
          "id": "item-33b463a8-a6ee-4add-a3a5-9e8cfbb166b6",
          "type": "dialogue",
          "characterId": null,
          "text": "It is a question addressed to the gentleman who owns it."
        },
        {
          "id": "item-9fe2d81c-24c6-4d61-bd20-465ef563dbc4",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "No. In Mr. Locke's travel trunk. Folded deep beneath his shirts. If Miss Stern finds it loose, she'll ask why we were careless."
        },
        {
          "id": "item-d6330c16-9a6d-4963-b50d-379598f2720c",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "Mr. Locke's trunk? But... Cora, that's prying into a gentleman's private property. If he catches us..."
        },
        {
          "id": "item-f5f01a6f-5f37-4484-8545-dce7a757c426",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "He won't. Not if you fold it cleanly and slide it in. If it's found loose in the open vanity, Stern will have us both on the street. It's safety, Missy. For both of us."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "4791d569-0dcd-4855-af71-9a68f69574b1",
              "type": "if",
              "conditionRaw": "story.day1_corridor_state == \"prey\"",
              "dialogue": [
                {
                  "id": "item-61c5e399-2e06-43b5-bd67-8b1782da0165",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I hear how desperate the logic sounds only after I have said it."
                },
                {
                  "id": "item-55ca9648-9dcd-462f-9ec1-814d3e3bcf42",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Yesterday he almost saw me at the door. Today I cannot afford another visible mistake."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day1_corridor_state == \"prey\""
            },
            {
              "id": "86d128f0-bd82-46d6-abe2-a6b16215063b",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-a66876e7-7222-42e9-beb6-40d1a59ece63",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The logic is clean, and Missy's sharp mind parses the risk."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-177140f9-de82-44ed-b7d1-1178561217ce"
        },
        {
          "id": "item-fa480388-1881-4594-95ba-ab95727dd3fd",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "I suppose. It's better than Stern finding it."
        },
        {
          "id": "item-aea01219-a9cd-4bae-a2ec-ecbee1c9fe20",
          "type": "dialogue",
          "characterId": null,
          "text": "She crosses to the trunk, her hands performing the risk, folding the lace carefully beneath a layer of his shirts."
        },
        {
          "id": "item-e0a7b199-4917-4808-a811-f5fea0f0dec5",
          "type": "dialogue",
          "characterId": null,
          "text": "Her hands carry the precarity; mine remain clean."
        },
        {
          "id": "item-e3369600-28ea-4472-8c16-9dd5c4c5d380",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "There. Folded away. God forgive me if it's sin."
        },
        {
          "id": "item-7d8541ad-23f1-40cf-82cc-316e58178b52",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "You did well. It's protection, not sin."
        },
        {
          "id": "item-f4190399-9097-4853-872b-ca003c5b049c",
          "type": "dialogue",
          "characterId": null,
          "text": "She looks relieved, her trust intact, believing we have navigated a trap together."
        },
        {
          "id": "item-1d91fff3-8d6c-4bce-9c0f-3bdbf6eb11db",
          "type": "dialogue",
          "characterId": null,
          "text": "I look useful."
        },
        {
          "type": "python_script",
          "code": "story.set_missy_day2_suspicion_state(\"trusting\")",
          "id": "item-2c0d151f-28ab-4c84-93cf-72afb94b0c72"
        },
        {
          "id": "item-e4d500b0-4351-4138-b9eb-480ddb03b859",
          "type": "jump",
          "destinationLabelId": "label-4fbb4754-2803-4ae6-b108-5f63eb81d2d2"
        }
      ]
    },
    {
      "id": "label-4fbb4754-2803-4ae6-b108-5f63eb81d2d2",
      "name": "day102_2_day2_chore_time",
      "x": 8900,
      "y": 11632.5,
      "dialogue": [
        {
          "type": "python_script",
          "code": "set_time_period(\"Afternoon\")",
          "id": "item-fe42e624-02be-4cba-8e47-c56d52f85668"
        },
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-404a9185-0f49-4c85-b866-944c976a703e",
          "backgroundId": "bg_servants_corridor_morning"
        },
        {
          "id": "item-8aa76525-b73d-41f2-aa27-1ade91aa29c1",
          "type": "dialogue",
          "characterId": null,
          "text": "We escape the suite with the linen cart and the sort of silence that pretends nothing has happened."
        },
        {
          "id": "item-d071801d-6d11-4282-a8c3-bd5f6850df42",
          "type": "dialogue",
          "characterId": null,
          "text": "The corridor is narrower than it was yesterday."
        },
        {
          "id": "item-5264b84c-7732-40e7-9e3d-cb23aa76bf0e",
          "type": "show",
          "characterId": "missy_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "missy_sprite smiling"
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "b19c3f1d-4a72-4257-a088-361634bd83b3",
              "type": "if",
              "conditionRaw": "story.day2_contraband_state == \"stolen_wearing\"",
              "dialogue": [
                {
                  "id": "item-52859575-7d60-4805-b3ca-f1c829bc1b90",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The lace moves beneath my uniform with each step."
                },
                {
                  "id": "item-8c0b0db6-b41f-45cf-8558-de26f354b381",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Heat and fear share the same pulse."
                },
                {
                  "id": "item-c0e5a412-87c2-4e2d-a47c-dfad1c765713",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Every stair, every turn, every nod to passing staff becomes a private dare."
                },
                {
                  "id": "item-d33ba375-2d36-4a89-9e72-e6e4f5f67c4d",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "No one knows what I am carrying because I am carrying it as myself."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day2_contraband_state == \"stolen_wearing\""
            },
            {
              "id": "d187a1f3-a212-4aa3-b0f2-1ee799cdb142",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-d643e49d-ad59-4f68-8638-7311cadb244b",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The lace remains upstairs, hidden in Gideon's trunk by Missy's hands and my instruction."
                },
                {
                  "id": "item-8b1acaa3-33e2-4ef3-bfed-78c1fb0dc1ad",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "A fact placed in the wrong drawer is not a fact anymore. It is a trap with upholstery."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-b89d7d5a-9a6e-407c-bce2-bc2a3cee2230"
        },
        {
          "id": "item-13281ac7-6489-4c75-84f6-7f12757bb3fd",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "You are quiet."
        },
        {
          "id": "item-4e041239-12e3-4127-8f37-46160e8d1989",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base"
        },
        {
          "id": "item-0b695d75-7164-4cea-82bb-b3423f2b529b",
          "type": "show",
          "characterId": "missy_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "move",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "missy_sprite smiling"
        },
        {
          "id": "item-c01a2b43-523c-4e1b-b39b-fa91368421e9",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "I am working."
        },
        {
          "id": "item-c378e45b-4854-4466-befd-d3658ce11860",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "That's never stopped anyone from talking before."
        },
        {
          "id": "item-4fa2c784-dbe0-4a51-88cb-e6f8920cfcc5",
          "type": "dialogue",
          "characterId": null,
          "text": "She tries to smile."
        },
        {
          "id": "item-63cf5ef7-900a-4a99-806f-63c2105c6332",
          "type": "dialogue",
          "characterId": null,
          "text": "It does not quite settle."
        },
        {
          "type": "python_script",
          "code": "show_ledger_ui()",
          "id": "item-496a8324-c3cd-4328-b729-2240635c3a34"
        },
        {
          "type": "choice",
          "options": [
            {
              "id": "e346ef07-9cff-43c0-bcf5-6b2c7d85b0e7",
              "text": "Work fast. Catalogue the room, the people, the risk. [[Observant focus]]",
              "dialogue": [
                {
                  "id": "item-53421ae2-4298-4da1-ac3e-64a88704cea6",
                  "type": "jump",
                  "destinationLabelId": "label-5a076f09-b29a-4820-9280-d0e3f3ba063d"
                }
              ]
            },
            {
              "id": "ab624ad0-44d6-47b2-a47a-dee390b28b86",
              "text": "Linger near the danger. Let the secret sharpen itself. [[Reckless linger]]",
              "dialogue": [
                {
                  "id": "item-74e5fd50-c225-4bc5-b6b0-a1d3d92b7ef0",
                  "type": "jump",
                  "destinationLabelId": "label-ae709a96-7511-43ab-ad7e-2307547f3cc3"
                }
              ]
            }
          ],
          "id": "item-83d3087d-2fcf-4e1b-ae84-67cb34268d54"
        },
        {
          "id": "item-fe00f06c-12b1-4812-b5be-c48c014e9045",
          "type": "jump",
          "destinationLabelId": "label-5a076f09-b29a-4820-9280-d0e3f3ba063d"
        }
      ]
    },
    {
      "id": "label-5a076f09-b29a-4820-9280-d0e3f3ba063d",
      "name": "day102_2_day2_insp_choice",
      "x": 9300,
      "y": 12542.5,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-936a39bf-06a3-4747-a497-eb3a3d3ab611",
          "backgroundId": "bg_servants_corridor_morning"
        },
        {
          "id": "item-1e05e600-2c85-40f7-8f17-079a247fbd6b",
          "type": "show",
          "characterId": "missy_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "missy_sprite smiling"
        },
        {
          "type": "python_script",
          "code": "story.set_day2_chore_focus(\"inspiration\")",
          "id": "item-e46776ac-4204-4351-af33-530d7596c10c"
        },
        {
          "type": "python_script",
          "code": "apply_balanced_effect(\"creative\", intensity=\"standard\")",
          "id": "item-57c83e2c-6658-4fd8-8346-a9210ac4232b"
        },
        {
          "type": "python_script",
          "code": "apply_effects(stern_susp=-5)",
          "id": "item-163b237c-4a8a-4279-a657-55fdc9ac2eb9"
        },
        {
          "id": "item-65eed6d0-40b0-4650-8d59-2bc15655d8dc",
          "type": "dialogue",
          "characterId": null,
          "text": "I make the morning into inventory."
        },
        {
          "id": "item-5de8199a-fc1c-484f-8f8b-b0d7ffa1c5e6",
          "type": "dialogue",
          "characterId": null,
          "text": "The direction of the light in the suite. The scent of Vance's powder. The exact stiffness in Missy's shoulders when she lies badly to herself."
        },
        {
          "id": "item-185bacee-cb37-4228-97e9-d7d4bacfe327",
          "type": "dialogue",
          "characterId": null,
          "text": "A story cannot live on heat alone."
        },
        {
          "id": "item-b20ecc6e-1779-4d9c-b462-a72f9bd38c34",
          "type": "dialogue",
          "characterId": null,
          "text": "It needs furniture. It needs weather. It needs a servant who knows which board complains beneath a careless foot."
        },
        {
          "id": "item-20c37cce-f477-4edd-b462-e0431b42e1b9",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "You look like you're counting things."
        },
        {
          "id": "item-67a02fb7-e606-4ac7-accb-2b4ed9e28ec9",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base"
        },
        {
          "id": "item-7a70992c-d98d-4868-a6b3-0d9537d105c4",
          "type": "show",
          "characterId": "missy_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "move",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "missy_sprite smiling"
        },
        {
          "id": "item-8eae3cc8-8281-40f6-a7fc-44d7f1d754dc",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "I am."
        },
        {
          "id": "item-3f69a3f7-1492-452a-8c2f-0c3b7af52d8d",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "What things?"
        },
        {
          "id": "item-8d9dbc68-fca8-4b76-869b-14b0bc324d91",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Ways not to be dismissed before luncheon."
        },
        {
          "id": "item-fa48a843-ec1e-4cee-9bc6-339d1e7a561a",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "Oh. You'll need more fingers."
        },
        {
          "id": "item-b113a51d-e469-48be-ba72-1e1bd7fbf442",
          "type": "dialogue",
          "characterId": null,
          "text": "That gets a laugh out of me before I can stop it."
        },
        {
          "id": "item-47884da3-7385-4c80-b613-ac6dd5e873df",
          "type": "dialogue",
          "characterId": null,
          "text": "Missy notices."
        },
        {
          "id": "item-bba73cca-b788-48b3-aad8-a4d6092e26c5",
          "type": "dialogue",
          "characterId": null,
          "text": "For one small second, the house loses."
        },
        {
          "id": "item-e2b1a4f0-ff42-4c76-aeb6-30ad727fe3a0",
          "type": "call",
          "destinationLabelId": "label-2fe1e95e-072d-4ad0-9326-f3c097d038da"
        },
        {
          "id": "item-751d5f2a-c196-44e0-9a71-ceffcdc091b9",
          "type": "call",
          "destinationLabelId": "label-b067d0bd-1955-4dfd-92c1-287c4e1e8053"
        },
        {
          "id": "item-4eb00661-d4ce-479f-b0fd-1e898ddde183",
          "type": "jump",
          "destinationLabelId": "label-67bb536e-782a-4f1b-817f-2db666861794"
        }
      ]
    },
    {
      "id": "label-ae709a96-7511-43ab-ad7e-2307547f3cc3",
      "name": "day102_2_day2_corr_choice",
      "x": 9300,
      "y": 11305,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-4ec77334-3b85-4f7c-89cd-a3aa52256997",
          "backgroundId": "bg_servants_corridor_morning"
        },
        {
          "id": "item-8d09334e-9ab6-4d4a-9cfa-1e96edd107c8",
          "type": "show",
          "characterId": "missy_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "missy_sprite smiling"
        },
        {
          "type": "python_script",
          "code": "story.set_day2_chore_focus(\"corruption\")",
          "id": "item-92761498-a8f2-43ae-8de1-8dc29337dc5a"
        },
        {
          "type": "python_script",
          "code": "apply_balanced_effect(\"transgressive\", intensity=\"standard\", witness=\"vance\")",
          "id": "item-20b3bad2-8052-4ead-bf79-8a204ef3f232"
        },
        {
          "id": "item-efaafa3a-a542-4321-b0df-d317b2789281",
          "type": "dialogue",
          "characterId": null,
          "text": "I slow the cart near the guest wing."
        },
        {
          "id": "item-4ba634a6-ede6-4215-b986-b4a22bdc8663",
          "type": "dialogue",
          "characterId": null,
          "text": "There are always reasons. A folded towel not square enough. A dropped pin. A scuff on polished wood that may or may not exist."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "a67062c9-99a6-4089-8aca-e4c2be03f16e",
              "type": "if",
              "conditionRaw": "story.day2_contraband_state == \"stolen_wearing\"",
              "dialogue": [
                {
                  "id": "item-18ce4cdf-9756-4fc5-bda0-bfdba44d0d5e",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The stolen lace answers every step."
                },
                {
                  "id": "item-3ec64c6d-3661-4a63-ab59-833d341efecc",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "One wrong glance and the day becomes a different kind of day."
                },
                {
                  "id": "item-7f8774b0-db99-482b-9dc7-3eabc93cc13b",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I should feel foolish. Instead, the uniform feels less like a prison and more like a disguise I have finally learned to use."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day2_contraband_state == \"stolen_wearing\""
            },
            {
              "id": "d23ce41a-e0ab-42e6-80c8-50b4bf1d1e8a",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-d0c2cd90-06e2-407f-ac95-24dcdd48cc5d",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Upstairs, the lace waits where it should not be."
                },
                {
                  "id": "item-7a72ca9e-fd9d-4585-8be6-d91f39ecd942",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I imagine the trunk opened. The pause. The recalculation. Mr. Locke seeing the lie not as panic, but as intention."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-d6a9862a-5a32-4942-9e4a-bde5a33121d6"
        },
        {
          "id": "item-d74d0390-731a-4fe2-8114-1c34f14e163b",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "Cora, we'll be missed."
        },
        {
          "id": "item-36f62273-b23e-4cdd-86da-af757fcaee5c",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base"
        },
        {
          "id": "item-047bf864-06c0-4dbc-9514-4d20b53e5840",
          "type": "show",
          "characterId": "missy_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "move",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "missy_sprite smiling"
        },
        {
          "id": "item-ee6c106f-026d-452e-931a-78ca518d7ef3",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Then push faster."
        },
        {
          "id": "item-80c08ef7-43c9-4f87-b655-f080973c1a86",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "You were the one who slowed down."
        },
        {
          "id": "item-d7bea1e7-738d-4622-8863-800a80e18c70",
          "type": "dialogue",
          "characterId": null,
          "text": "There is a little steel in her now."
        },
        {
          "id": "item-363130d3-641c-40eb-8187-bf024af3b391",
          "type": "dialogue",
          "characterId": null,
          "text": "Good."
        },
        {
          "id": "item-5449738d-3bae-4d5e-ab02-05deb64327ac",
          "type": "dialogue",
          "characterId": null,
          "text": "Or not good."
        },
        {
          "id": "item-acb31820-cba1-4c97-9dc9-a0c9c5dc72c9",
          "type": "dialogue",
          "characterId": null,
          "text": "Useful, at least."
        },
        {
          "id": "item-e2dc1b8d-ca75-46a2-a16b-a5e8c0b7659d",
          "type": "call",
          "destinationLabelId": "label-2fe1e95e-072d-4ad0-9326-f3c097d038da"
        },
        {
          "id": "item-5cd71689-4481-4abf-b13a-cdefdf2c34ed",
          "type": "call",
          "destinationLabelId": "label-b067d0bd-1955-4dfd-92c1-287c4e1e8053"
        },
        {
          "id": "item-bd97e853-23bf-44d9-9e6f-1c5bceb43339",
          "type": "jump",
          "destinationLabelId": "label-67bb536e-782a-4f1b-817f-2db666861794"
        }
      ]
    },
    {
      "id": "label-5eddca7e-f2d8-46a9-b1d1-52fb0dcbc8c2",
      "name": "day102_2_optional_character_chain",
      "x": 9300,
      "y": 12682.5,
      "dialogue": [
        {
          "id": "item-76f965cc-7268-4fd6-b1e4-c27e71b55bac",
          "type": "call",
          "destinationLabelId": "label-b067d0bd-1955-4dfd-92c1-287c4e1e8053"
        }
      ]
    },
    {
      "id": "label-b067d0bd-1955-4dfd-92c1-287c4e1e8053",
      "name": "day102_afternoon_story_window",
      "x": 9700,
      "y": 12662.5,
      "dialogue": [
        {
          "id": "item-dacba74d-5857-4618-92d3-11a611f94238",
          "type": "call",
          "destinationLabelId": "label-46e3ecc2-06e8-4066-9581-1bc3e9af5358"
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "5ccdf223-0118-49c9-a5e5-eeea7d1451c5",
              "type": "if",
              "conditionRaw": "_penance_consumed",
              "dialogue": [],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "_penance_consumed"
            }
          ],
          "id": "item-ada988ab-6f9c-45e0-9b81-a62227a20989"
        },
        {
          "type": "choice",
          "options": [
            {
              "id": "3330bcbd-d38b-4e4b-b052-43a0e736ed40",
              "text": "Let Miss Stern find me near the linen closet.",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "_chain_label = story.resolve_chain_label(\"stern\")",
                  "id": "item-bc8db4ce-acd1-4fbd-8a9c-3b30073e4933"
                },
                {
                  "id": "item-de8a81ae-3292-4429-bfea-c28e1ca9018e",
                  "type": "call",
                  "destinationLabelId": ""
                }
              ]
            },
            {
              "id": "9f799ea6-658c-4ea8-9224-65b02ffd9183",
              "text": "Steal an hour with Missy before Stern counts the sheets.",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "_chain_label = story.resolve_chain_label(\"missy\")",
                  "id": "item-47bf3c82-1871-445c-b0ff-ec3e589bed47"
                },
                {
                  "id": "item-d3d4304f-3689-4028-8487-d46727d3c203",
                  "type": "call",
                  "destinationLabelId": ""
                }
              ]
            },
            {
              "id": "9234d5a2-f984-4278-8fd5-e4a0bd32c43c",
              "text": "Drift toward the Locke Suite and watch who performs for whom.",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "_chain_label = story.resolve_chain_label(\"vance\")",
                  "id": "item-4a73a497-7716-4a7f-886a-e9142fe0a7b0"
                },
                {
                  "id": "item-bce753e2-f7d9-40c7-9751-e39c965aeb42",
                  "type": "call",
                  "destinationLabelId": ""
                }
              ]
            },
            {
              "id": "ed9d9fb4-2cbf-4d34-9a10-aa004be2de0b",
              "text": "Push the cart on and keep my hands honest.",
              "dialogue": [
                {
                  "type": "if_block",
                  "branches": [
                    {
                      "id": "06532b86-1db5-4612-afd9-00ad06a35182",
                      "type": "if",
                      "conditionRaw": "story.day2_chore_focus == \"corruption\"",
                      "dialogue": [
                        {
                          "id": "item-0d1c0023-a09e-4ae3-a2c1-5de894f81553",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "Honesty is a word for people who are not wearing stolen lace."
                        },
                        {
                          "id": "item-129154f0-5b18-4fed-8823-4fbd4f9c2362",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "I work in silence and call it restraint."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      },
                      "rawCondition": "story.day2_chore_focus == \"corruption\""
                    },
                    {
                      "id": "3b18bdc7-d253-48bf-94a2-6a3a2fe0fd49",
                      "type": "else",
                      "conditionRaw": null,
                      "dialogue": [
                        {
                          "id": "item-656f7b99-8853-417b-860b-297343a67dd4",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "I count boards, hinges, and the distance between stairs."
                        },
                        {
                          "id": "item-5f835a71-19d7-43bb-a65e-9c39483f5820",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "Craft is safer when it has no audience."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      }
                    }
                  ],
                  "id": "item-5325fb76-365f-4c6a-8f13-d3f40458e3d8"
                },
                {
                  "id": "item-be47fd4f-430e-44ab-8e7b-d1a456a89065",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The hallway outside the Master Suite is dim, the scent of lavender and expensive powder leaking beneath the heavy mahogany door."
                },
                {
                  "id": "item-b9b478a3-8db2-4a96-a071-a323fa74548b",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "As I push the cart past the threshold, a voice filters through the crack—Miss Vance's, carrying a raw, petulant heat."
                },
                {
                  "id": "item-d3fef740-7469-4cff-bd84-4c52d97f0641",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I stop. My hand stays on the wood of the cart. I lean close to the frame and listen."
                },
                {
                  "id": "item-6fde0a9f-0ab6-472b-8ed2-ced50413219b",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Beyond the door, Miss Vance is in a state of loose, disheveled vulnerability, her silk dressing gown half-unlaced at the shoulder as she holds a crystal glass of sherry."
                },
                {
                  "id": "item-2b98e8a7-b3c8-4810-b68f-1fad6b9812f6",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Missy stands near the vanity, folding a linen shift. Her hands are steady, but her flushed face catches the gas-lamp light."
                },
                {
                  "id": "item-34e7e53a-0507-4cef-9cf9-e16f37567592",
                  "type": "show",
                  "characterId": "missy_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "None",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "missy_sprite smiling"
                },
                {
                  "id": "item-83a4983f-df6b-4ecc-9bb2-8e704309d645",
                  "type": "show",
                  "characterId": "vance_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "moveinright",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "vance_sprite neutral"
                },
                {
                  "id": "item-cf4ad1d1-6f4b-4da7-a26a-843ef2aa1f6e",
                  "type": "dialogue",
                  "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
                  "text": "You're prying again, girl. I see your eyes moving over my perfumes. Do you want to touch them?"
                },
                {
                  "id": "item-47b306db-630e-49e1-9461-d7c61e90bbb3",
                  "type": "dialogue",
                  "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
                  "text": "No, Miss. I was only tidying the vanity as Miss Stern directed."
                },
                {
                  "id": "item-0302b061-340a-4b4c-b4f8-82d45cf5d4e1",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Vance rises, her movements slightly unsteady but deliberate, stepping directly into Missy's space until the silk of her dressing gown brushes the coarse cotton of Missy's apron."
                },
                {
                  "id": "item-fadc4866-d790-4eb6-a5e1-1c1b330ca1fe",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She reaches out, her manicured fingers trailing slowly, provocatively along the high white collar of Missy's uniform, her thumb brushing the skin of Missy's throat."
                },
                {
                  "id": "item-879a34ec-dc2f-4b47-9e2e-2fe8cea15ebc",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Missy flinches, her breath catching, but she stands her ground, her observant eyes locking onto Vance's lips."
                },
                {
                  "id": "item-34a602cb-1acc-48bf-a9b4-d476cdd5cde2",
                  "type": "dialogue",
                  "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
                  "text": "You think you're clean because you wash the soot, but the soot here gets under the skin eventually. It makes you want... things you shouldn't name."
                },
                {
                  "id": "item-c50ffd35-b512-4597-a837-5ced0928ed1d",
                  "type": "dialogue",
                  "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
                  "text": "Perhaps, Miss. But some of us have to wash the soot off. Others are permitted to wear it."
                },
                {
                  "id": "item-1054a733-1408-4806-b490-9b6efff9e3d8",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The physical tension between them is a sudden, breathtaking flash of forbidden desire—class captivity meeting physical curiosity."
                },
                {
                  "id": "item-86d36021-33bf-4773-a0e3-14dd50b90e50",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Vance draws her hand back with a quiet, sharp gasp, her face flushing, while Missy bows, her defensive propriety restoring itself like steel."
                },
                {
                  "id": "item-de1af20d-55cd-4c93-b695-5f74d53ac733",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I step back from the door, my pulse hammering against the stolen lace beneath my uniform."
                },
                {
                  "id": "item-8872dfd3-f9fc-407e-a417-7466778bdb57",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "There is a brilliant, dangerous chapter in that."
                },
                {
                  "id": "item-405c851d-0361-47fa-aa1b-b1d04444cada",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The house loses interest when I stop offering it a face."
                }
              ]
            }
          ],
          "id": "item-9e931037-4bb3-48e0-815c-f8a6525776e5"
        }
      ]
    },
    {
      "id": "label-2fe1e95e-072d-4ad0-9326-f3c097d038da",
      "name": "day102_afternoon_consequence_window",
      "x": 9700,
      "y": 12532.5,
      "dialogue": [
        {
          "id": "item-b68c717f-39b2-4bff-820e-ddfdbe286c14",
          "type": "call",
          "destinationLabelId": "label-5f635f30-8ef3-4f17-80e7-4e5cde552ded"
        }
      ]
    },
    {
      "id": "label-67bb536e-782a-4f1b-817f-2db666861794",
      "name": "day102_3_stern_fetches_cora",
      "x": 9700,
      "y": 11260,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-77c12927-9be8-4856-8d25-d377120f3d9b",
          "backgroundId": "bg_servants_corridor_day"
        },
        {
          "id": "item-92d06930-7a21-4df9-b132-ad4d60deb070",
          "type": "show",
          "characterId": "stern_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "stern_sprite stern"
        },
        {
          "id": "item-39ccfa65-0967-4dd5-9a1d-6bd7802cc19d",
          "type": "dialogue",
          "characterId": null,
          "text": "Stern finds me at the foot of the servants' stair."
        },
        {
          "id": "item-5f60113a-941b-46a6-b30f-cf6ee3d7bdd6",
          "type": "dialogue",
          "characterId": null,
          "text": "She does not raise her voice."
        },
        {
          "id": "item-da1ad3e8-527a-4b31-8aab-62b49f9eb035",
          "type": "dialogue",
          "characterId": null,
          "text": "That is how I know the matter is already dangerous."
        },
        {
          "id": "item-330d3905-6fc7-4b72-88ac-63cc7c852213",
          "type": "dialogue",
          "characterId": null,
          "text": "Somewhere above us, a clock marks the interval between discovery and punishment."
        },
        {
          "id": "item-7f13370d-c309-4323-a8d5-f2e0bdf39171",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "Cora. Upstairs."
        },
        {
          "id": "item-4392b057-a966-4333-ab55-38a3b65ff572",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base"
        },
        {
          "id": "item-7a1d4dad-27d3-47e7-97f4-dbb3eb1ee50f",
          "type": "show",
          "characterId": "stern_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "move",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "stern_sprite stern"
        },
        {
          "id": "item-97923fa9-f485-4c3c-a613-71ecde08131d",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Ma'am?"
        },
        {
          "id": "item-0e4f8814-fb80-4fac-a3f6-67cf8543113d",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "Do not make me repeat myself."
        },
        {
          "id": "item-75b11196-73c5-478e-a64f-09ffcde67b4a",
          "type": "dialogue",
          "characterId": null,
          "text": "Her eyes flick once toward my hands. Empty. Then my face. Too still."
        },
        {
          "id": "item-5a7b7806-430b-4d55-b084-28cd3d97a2de",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "There is a complaint from the Master Suite. You were assigned there this morning."
        },
        {
          "id": "item-67bc0962-4a62-473d-8c90-51f677efeb3e",
          "type": "dialogue",
          "characterId": null,
          "text": "Behind her, Missy has gone pale."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "0b7c7776-f7c9-4de1-b4c4-ee7adeef054b",
              "type": "if",
              "conditionRaw": "story.missy_day2_suspicion_state == \"uneasy\"",
              "dialogue": [
                {
                  "id": "item-c79cbddd-a6eb-4e9b-ae19-e316d50b721a",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She knows I took it. Or knows enough to fear knowing."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.missy_day2_suspicion_state == \"uneasy\""
            },
            {
              "id": "2f69fda1-bf4a-4717-9585-1131fa30a985",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-1f1549bb-c422-4c28-af54-0e8830efd283",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She trusts me enough to be frightened for both of us."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-5f46efb4-1f71-42c0-ad9f-ca530ec61a8e"
        },
        {
          "id": "item-1b587128-5cd6-4f0a-95cf-a1500452dfb1",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "Both of you. Move."
        },
        {
          "id": "item-fd03c835-9504-40f9-b305-9025b1d175f4",
          "type": "jump",
          "destinationLabelId": "label-45dbee30-3d83-4bd2-81eb-868fdc071f6c"
        }
      ]
    },
    {
      "id": "label-45dbee30-3d83-4bd2-81eb-868fdc071f6c",
      "name": "day102_3_vance_goes_incandescent",
      "x": 10100,
      "y": 11260,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "fade",
          "id": "item-60caf6cb-efb4-4cb6-94a3-a3aae7838f14",
          "backgroundId": "bg_master_suite_tea"
        },
        {
          "id": "item-15a64bb8-2c90-4b55-b349-fc330bb2c177",
          "type": "show",
          "characterId": "missy_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "missy_sprite shocked"
        },
        {
          "id": "item-315fc9c3-cabd-49a1-a3fa-299b9a0d17cb",
          "type": "show",
          "characterId": "stern_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "stern_sprite stern"
        },
        {
          "id": "item-f9cd6e91-34a5-44bf-8a94-2263e2034bfc",
          "type": "show",
          "characterId": "vance_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "vance_sprite angry"
        },
        {
          "id": "item-be8eea4b-636f-479d-a7ad-b57a5662132d",
          "type": "dialogue",
          "characterId": null,
          "text": "The Master Suite has become a courtroom without chairs."
        },
        {
          "id": "item-9628bf4f-b967-4c53-a222-30dc4a04bfcb",
          "type": "dialogue",
          "characterId": null,
          "text": "Vance stands by the armoire, one hand clenched around the edge of a hatbox."
        },
        {
          "id": "item-115fc2c0-9b32-4675-994d-14116ac3023c",
          "type": "dialogue",
          "characterId": null,
          "text": "Her face is controlled so tightly that the control itself has become indecent."
        },
        {
          "id": "item-0ee5c28b-2ea8-4123-ba1d-6477e24c8bb1",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "Something has been taken."
        },
        {
          "id": "item-ca649688-4838-45ba-a3ae-52392167f77e",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "Madam, I assure you—"
        },
        {
          "id": "item-89e9bb31-5cfc-4895-a6a3-894484c791f0",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "Do not assure me. Find it."
        },
        {
          "id": "item-e17a32c3-8847-472c-b4c2-9616034d947a",
          "type": "dialogue",
          "characterId": null,
          "text": "Missy inhales too sharply."
        },
        {
          "id": "item-cc811df5-5963-467c-81bf-766df5b21681",
          "type": "dialogue",
          "characterId": null,
          "text": "Vance hears it."
        },
        {
          "id": "item-eaaeebe1-ce23-461f-af30-e40acea5b764",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "You."
        },
        {
          "id": "item-c3e8d838-0fad-4ee8-92f0-5864a3445658",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "Madam?"
        },
        {
          "id": "item-9e5c1693-1d2c-4575-82af-2f5613b59b2c",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "You were here. Both of you were here."
        },
        {
          "id": "item-3209545b-be36-419b-abf6-251113c571c3",
          "type": "dialogue",
          "characterId": null,
          "text": "Her eyes move to me."
        },
        {
          "id": "item-b3dc3991-5756-4ed2-b10a-d0a02953f92d",
          "type": "dialogue",
          "characterId": null,
          "text": "Yesterday she saw a maid. Today she sees a possible thief."
        },
        {
          "id": "item-7036a6db-f1a1-49ab-9947-1e8ecd7a51f4",
          "type": "dialogue",
          "characterId": null,
          "text": "That is progress of a kind."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "f9688603-d944-492c-bf1f-60cfd5c4c3f7",
              "type": "if",
              "conditionRaw": "story.day2_contraband_state == \"stolen_wearing\"",
              "dialogue": [
                {
                  "id": "item-e11f62f0-cffe-4de0-a93f-71ff1b478cf3",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The missing object is under my skirt."
                },
                {
                  "id": "item-ef7305b0-3354-444c-8e1d-8156445622de",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The absurdity of it threatens to become laughter, which would be fatal."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day2_contraband_state == \"stolen_wearing\""
            },
            {
              "id": "b4b7948d-ea9a-49ce-a1d7-dae87826a45d",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-5d2f0ce9-b36f-4b2e-8ed9-fedfe6a6e595",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The missing object is hidden in a trunk a few feet away."
                },
                {
                  "id": "item-b2315e51-6861-42cb-b8de-0f98dde3ce53",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Missy placed it there. I made that true."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-06e644d6-cea3-45d8-9601-9aa6e85ba20b"
        },
        {
          "id": "item-7f00fbf9-fcf5-4eb7-8680-977ccc0079a2",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "I will not have servants pawing through my private things."
        },
        {
          "id": "item-334bfc9d-78a8-49df-8052-7bc9f39bb363",
          "type": "dialogue",
          "characterId": null,
          "text": "Private."
        },
        {
          "id": "item-3fd7d046-18a2-48ff-b3e8-916c6d66acc9",
          "type": "dialogue",
          "characterId": null,
          "text": "The word enters the room wearing gloves and entirely the wrong shoes."
        },
        {
          "id": "item-83a4929d-0db2-47d2-a564-369dd138b8fa",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "Cora. Missy. If either of you has any knowledge of this matter, speak now."
        },
        {
          "id": "item-1dc99318-55d6-44b7-b221-8fd36c73c657",
          "type": "dialogue",
          "characterId": null,
          "text": "Speak now."
        },
        {
          "id": "item-3208ccd5-4100-4f05-a0a7-d44f33bdd492",
          "type": "dialogue",
          "characterId": null,
          "text": "As if truth from below stairs were ever heard before the floor above it decided."
        },
        {
          "id": "item-26645f9f-3657-433d-9a0e-b9fb946dad87",
          "type": "jump",
          "destinationLabelId": "label-ccfa3326-b7f4-4dc5-8b9f-5907d4116661"
        }
      ]
    },
    {
      "id": "label-ccfa3326-b7f4-4dc5-8b9f-5907d4116661",
      "name": "day102_3_coras_choice",
      "x": 10500,
      "y": 11260,
      "dialogue": [
        {
          "type": "choice",
          "options": [
            {
              "id": "378afae4-ba96-4f79-9923-d664d64fc19a",
              "text": "Confess enough to control the damage. [[Prey: visible risk, cleanest conscience]]",
              "dialogue": [
                {
                  "id": "item-9b33bced-1fb6-405c-9939-cb9d7e4f77e2",
                  "type": "jump",
                  "destinationLabelId": "label-763f9781-b105-41cd-a6e6-467b7ab9cb50"
                }
              ]
            },
            {
              "id": "caab78dc-e52b-43ab-8d16-265d08fca8b7",
              "text": "Produce it as if discovering it now. [[Predator: controlled lie]]",
              "dialogue": [
                {
                  "id": "item-e83af46f-638c-4c76-935a-766a0b6ef898",
                  "type": "jump",
                  "destinationLabelId": "label-e280efec-f3f0-4a28-a9ef-c6b5899af573"
                }
              ]
            },
            {
              "id": "f195875f-4efb-4eb3-8818-9aa77c861dc2",
              "text": "Let Missy take the shape of the blame. [[Ghost: clean hands, dirty outcome]]",
              "dialogue": [
                {
                  "id": "item-15febc4d-e0cd-485f-bb9f-c9d63844f376",
                  "type": "jump",
                  "destinationLabelId": "label-01c05328-94de-4fc7-9830-83b7b743659d"
                }
              ]
            }
          ],
          "id": "item-a4b218b0-c9d9-4947-afe3-4bc8e2ac675e"
        },
        {
          "id": "item-694ba17b-8497-41b8-9ca1-82f43f1a8bc2",
          "type": "jump",
          "destinationLabelId": "label-763f9781-b105-41cd-a6e6-467b7ab9cb50"
        }
      ]
    },
    {
      "id": "label-763f9781-b105-41cd-a6e6-467b7ab9cb50",
      "name": "day102_3_cora_confesses",
      "x": 10900,
      "y": 12317.5,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-83ea4f06-c49f-40fa-8692-671e9e4aaac8",
          "backgroundId": "bg_master_suite_tea"
        },
        {
          "id": "item-76a8ab59-1b8b-48b6-b39d-f698784993c0",
          "type": "show",
          "characterId": "missy_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "missy_sprite shocked"
        },
        {
          "id": "item-99126692-300e-4c5e-9a3f-b7ff9ada249b",
          "type": "show",
          "characterId": "stern_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "stern_sprite stern"
        },
        {
          "id": "item-66704fba-a4b9-4f15-9ec8-0dd33679c762",
          "type": "show",
          "characterId": "vance_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "vance_sprite angry"
        },
        {
          "type": "python_script",
          "code": "story.set_day2_tea_choice(\"prey\")",
          "id": "item-45f15575-763a-4dc1-82b5-2e549d37234a"
        },
        {
          "type": "python_script",
          "code": "apply_archetype_edge(\"prey\", 1)",
          "id": "item-ea6d5e19-a6d6-4314-9ef2-e4f29561ae7e"
        },
        {
          "type": "python_script",
          "code": "apply_balanced_effect(\"transgressive\", intensity=\"standard\", witness=\"stern\")",
          "id": "item-62f95122-82a3-4da2-9d1a-2e559db3d21f"
        },
        {
          "id": "item-473b9c86-444e-428c-b3d0-2b4ca4e47d93",
          "type": "dialogue",
          "characterId": null,
          "text": "The truth is not safe."
        },
        {
          "id": "item-348932d0-5c63-4e8f-a252-815b875ff6f4",
          "type": "dialogue",
          "characterId": null,
          "text": "That does not make the lie safer."
        },
        {
          "id": "item-7895a81f-dbe5-4cce-ab7f-5cabe54ed80e",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base"
        },
        {
          "id": "item-42d8d81b-ea7a-4a81-8213-686ed83f434e",
          "type": "show",
          "characterId": "stern_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "stern_sprite stern"
        },
        {
          "id": "item-7f8059f4-406c-4ae4-b11c-578dbf39fc8f",
          "type": "show",
          "characterId": "missy_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "missy_sprite shocked"
        },
        {
          "id": "item-1d39c150-15f8-4ed8-b200-5269c8003b70",
          "type": "show",
          "characterId": "vance_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "move",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "vance_sprite angry"
        },
        {
          "id": "item-f1a7a8a7-1ef1-47a4-ac88-f0e807c54937",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Ma'am. I saw the item this morning."
        },
        {
          "id": "item-9854e7bf-0ace-4e7c-b05b-03af94af9bd1",
          "type": "dialogue",
          "characterId": null,
          "text": "Missy's head turns toward me."
        },
        {
          "id": "item-4770af9b-7855-42a2-a632-5eac5b47f7d4",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "You saw it."
        },
        {
          "id": "item-6922a5c6-37d0-49a8-95ab-0247cfa01bb9",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Yes, Ma'am. I did not understand whether it had been left aside for laundering or packed in error. I should have reported it to Miss Stern at once."
        },
        {
          "id": "item-7d9c63dc-7284-4a11-9151-c6c79845fba0",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "Yes. You should have."
        },
        {
          "id": "item-18d5bfc6-144e-476f-9adc-32a08986ec00",
          "type": "dialogue",
          "characterId": null,
          "text": "Stern's voice could cut thread."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "d9fefab1-7326-4881-a0de-958affdf7b94",
              "type": "if",
              "conditionRaw": "story.day2_contraband_state == \"stolen_wearing\"",
              "dialogue": [
                {
                  "id": "item-a9734ac5-1445-4b86-bc32-03565cc52ea0",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The lace remains beneath my uniform."
                },
                {
                  "id": "item-eabf7341-2713-411a-a0e3-d27984ab3e27",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "My confession is therefore not truth, but a smaller lie dressed as truth."
                },
                {
                  "id": "item-bdb12956-2757-414c-babd-294426ab970a",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Still, it stands closer to honesty than anything else I have available."
                },
                {
                  "id": "item-67ecb1c9-126f-4dfa-aaa3-86426a18a71b",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "My pulse does not agree with my mouth."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day2_contraband_state == \"stolen_wearing\""
            },
            {
              "id": "4b6a1ea5-f1a3-48d0-83c1-a02e84f5b37f",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-3adbf1fc-3cbb-48c2-bae2-1f1febe5a5cf",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I do not look at the trunk."
                },
                {
                  "id": "item-79824029-45f9-4a24-9996-b50842e894c2",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Looking would condemn Missy before I choose whether I mean to."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-5fcfc345-666d-4d06-b5e0-9da4e0c6ec05"
        },
        {
          "id": "item-b32ca357-ee11-40d0-8fd5-65b190797e46",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "Where is it?"
        },
        {
          "id": "item-006bc097-ff8f-4df3-ae61-973933370d43",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "I cannot say for certain, Ma'am. I only know I failed to report it."
        },
        {
          "id": "item-bd375d92-7b5f-4c14-87dc-6723eac6b01b",
          "type": "dialogue",
          "characterId": null,
          "text": "A bad answer."
        },
        {
          "id": "item-0527e2b2-9875-4e32-bce4-4c99f236600d",
          "type": "dialogue",
          "characterId": null,
          "text": "A brave answer."
        },
        {
          "id": "item-dded57e5-4199-4100-b483-fce56a7cb219",
          "type": "dialogue",
          "characterId": null,
          "text": "The two are cousins."
        },
        {
          "id": "item-69f35aaf-143b-4414-b20c-ebe7004549ae",
          "type": "jump",
          "destinationLabelId": "label-695bcc01-14cc-4876-b5a1-e8510fe3db06"
        }
      ]
    },
    {
      "id": "label-e280efec-f3f0-4a28-a9ef-c6b5899af573",
      "name": "day102_3_cora_pretends_to_find_it",
      "x": 10900,
      "y": 11195,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-e8b0c02e-d739-44b1-9397-26d31de0ee02",
          "backgroundId": "bg_master_suite_tea"
        },
        {
          "id": "item-fb580880-0add-48e1-a5d6-19a20a21e95a",
          "type": "show",
          "characterId": "missy_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "missy_sprite shocked"
        },
        {
          "id": "item-2a366d9f-55c6-4e50-b9a2-f91e1f1bd5d5",
          "type": "show",
          "characterId": "stern_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "stern_sprite stern"
        },
        {
          "id": "item-4a2e541f-f311-471c-9e5a-d745a61b58c2",
          "type": "show",
          "characterId": "vance_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "vance_sprite angry"
        },
        {
          "type": "python_script",
          "code": "story.set_day2_tea_choice(\"predator\")",
          "id": "item-0d65f42b-db19-4cae-b2f4-153322651045"
        },
        {
          "type": "python_script",
          "code": "apply_archetype_edge(\"predator\", 1)",
          "id": "item-c183a876-e5bd-43d8-8779-16872c818329"
        },
        {
          "type": "python_script",
          "code": "apply_balanced_effect(\"transgressive\", intensity=\"standard\", witness=\"stern\")",
          "id": "item-f6d4ee36-a4fa-40d8-8b28-6445f4eb5bf5"
        },
        {
          "id": "item-18bf4e7d-6ad4-4807-998e-ca64f9ad86f4",
          "type": "dialogue",
          "characterId": null,
          "text": "Helpful."
        },
        {
          "id": "item-8b6795e7-992e-485d-b3ba-5a9e7a54cd17",
          "type": "dialogue",
          "characterId": null,
          "text": "That is the mask."
        },
        {
          "id": "item-2104a99d-2b2f-4392-94c8-bc5e482b4d08",
          "type": "dialogue",
          "characterId": null,
          "text": "Helpful girls are allowed to cross rooms that guilty girls are not."
        },
        {
          "id": "item-00b31b71-242a-4440-9650-9230ca07a0fa",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base"
        },
        {
          "id": "item-c00d05fa-e68b-494f-b334-9b5fba79284b",
          "type": "show",
          "characterId": "stern_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "stern_sprite stern"
        },
        {
          "id": "item-31aa36e7-3ab0-408c-9ab5-f1a0d445ba97",
          "type": "show",
          "characterId": "missy_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "missy_sprite shocked"
        },
        {
          "id": "item-1c7db046-53c6-47dd-b1e0-8693480e4182",
          "type": "show",
          "characterId": "vance_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "move",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "vance_sprite angry"
        },
        {
          "id": "item-4abce66d-b86f-40ac-93bd-61fa085a3ade",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Pardon me, Madam. May I check where the morning things were placed?"
        },
        {
          "id": "item-88660a4c-b148-4be0-9245-2831134bd4a1",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "Do you imagine I have not looked?"
        },
        {
          "id": "item-c37f8e5c-d8f4-4397-b442-fd3910891124",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "No, Madam. Only that servants often look in servant ways."
        },
        {
          "id": "item-625bad4f-6d3a-440a-bc70-6d664eb4eae3",
          "type": "dialogue",
          "characterId": null,
          "text": "Stern's eyes sharpen."
        },
        {
          "id": "item-08554517-8e79-4703-847f-56926535dc4e",
          "type": "dialogue",
          "characterId": null,
          "text": "Stern's mouth tightens by a fraction."
        },
        {
          "id": "item-d129db21-0bf8-409e-8cd7-931d9c1cf66b",
          "type": "dialogue",
          "characterId": null,
          "text": "That is the Savoy equivalent of laughter."
        },
        {
          "id": "item-373b62ae-4cbe-497d-8304-73608e349d87",
          "type": "dialogue",
          "characterId": null,
          "text": "Too much intelligence. But the door is already open."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "5c365867-8927-4320-bf6e-8e80769b63e9",
              "type": "if",
              "conditionRaw": "story.day2_contraband_state == \"planted_in_trunk\"",
              "dialogue": [
                {
                  "id": "item-bbe09f63-e060-4683-a64f-b93fbb81bf65",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I cross to the travel trunk."
                },
                {
                  "id": "item-5f95ff35-28b1-4f01-b25b-7164a0940f5c",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Missy makes a tiny sound."
                },
                {
                  "id": "item-d646a3b6-b2de-4e93-b447-062a2a682be5",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I lift one folded shirt, then another, then pause as though surprised by what my hand has discovered."
                },
                {
                  "id": "item-aa1b20bd-729f-4ec2-95ee-692083230971",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "Is this the item, Madam?"
                },
                {
                  "id": "item-3f9cc979-7f2f-4c6c-b75e-22844cdd9aba",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I hold up the lace carefully."
                },
                {
                  "id": "item-d911449d-0e72-45cc-a740-ef8970f94ee3",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Missy looks as if I have pulled her own heart from the trunk."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day2_contraband_state == \"planted_in_trunk\""
            },
            {
              "id": "7407f750-630c-4d97-9d37-b21c737b50fc",
              "type": "elif",
              "conditionRaw": "story.day2_contraband_state == \"stolen_wearing\"",
              "dialogue": [
                {
                  "id": "item-a78af416-bc93-4bd3-be07-559f050edf10",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I cross to the armoire and open the hatbox."
                },
                {
                  "id": "item-880412af-01a1-470f-8eae-6d7d72126366",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "My body is a locked drawer. The room must not know it."
                },
                {
                  "id": "item-7879bb1c-ce7f-4904-a33b-7cd2c9439103",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "A second small lace ribbon lies caught under the hatbox lining."
                },
                {
                  "id": "item-6e075cf4-2aac-49a2-a097-570d8675ccbb",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Not the garment itself."
                },
                {
                  "id": "item-97db78b2-45a6-472a-9328-f74925760211",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Enough to teach the room the wrong lesson."
                },
                {
                  "id": "item-14a6b4e6-5943-4789-9461-57b627bf3f3e",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "There is a loose piece here, Madam. Perhaps the rest was misplaced while packing."
                },
                {
                  "id": "item-736fd57b-80b2-4a44-8af6-1801231861f2",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "It is not enough."
                },
                {
                  "id": "item-02fe2089-bac9-48b8-89a5-d5b27f142018",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "It is almost enough."
                },
                {
                  "id": "item-5c661df4-7487-41ad-aa15-ba270a4b4d1a",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "In a room this frightened, almost can work."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day2_contraband_state == \"stolen_wearing\""
            },
            {
              "id": "7b8d30ae-e77f-47a3-836e-26feac0c5b86",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-30bae59e-a050-49c4-bfed-bc4a4da89787",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I cross to the armoire and make a show of checking beneath the hatbox."
                },
                {
                  "id": "item-14af8e2d-bd88-4806-a888-7041c7d22eb9",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "Might this be it, Madam?"
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-4478be0b-2261-427e-9384-ba6f79d7509f"
        },
        {
          "id": "item-0a7e7a3b-666b-477e-91a5-ea30910655d3",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "Give it to me."
        },
        {
          "id": "item-af3646d1-fe41-401e-ab7c-11825f396614",
          "type": "dialogue",
          "characterId": null,
          "text": "I do."
        },
        {
          "id": "item-d7613a6e-b16f-4e70-8e5f-7ccbd4e166df",
          "type": "dialogue",
          "characterId": null,
          "text": "Our fingers do not touch."
        },
        {
          "id": "item-6d567147-a57e-48a8-a7b4-b69494984f24",
          "type": "jump",
          "destinationLabelId": "label-695bcc01-14cc-4876-b5a1-e8510fe3db06"
        }
      ]
    },
    {
      "id": "label-01c05328-94de-4fc7-9830-83b7b743659d",
      "name": "day102_3_cora_frames_missy",
      "x": 10900,
      "y": 11065,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-2a7f6cdc-70b4-4942-9a61-f767d4292c4d",
          "backgroundId": "bg_master_suite_tea"
        },
        {
          "id": "item-d94f1c66-4ff2-4fb3-8bc0-1c6cb67f60fd",
          "type": "show",
          "characterId": "missy_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "missy_sprite shocked"
        },
        {
          "id": "item-ea733bde-1869-495d-96b5-b9f0996e8481",
          "type": "show",
          "characterId": "stern_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "stern_sprite stern"
        },
        {
          "id": "item-f5cd6ea6-faeb-4801-bda7-a0f876cf4b81",
          "type": "show",
          "characterId": "vance_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "vance_sprite angry"
        },
        {
          "type": "python_script",
          "code": "story.set_day2_tea_choice(\"ghost\")",
          "id": "item-5aa124a5-713d-47fe-8d1e-6b250d037810"
        },
        {
          "type": "python_script",
          "code": "story.set_missy_day2_trust_break(True)",
          "id": "item-787812f9-a020-46aa-9808-1372402096f4"
        },
        {
          "type": "python_script",
          "code": "apply_archetype_edge(\"ghost\", 1)",
          "id": "item-366745f9-faaa-48ae-a02a-0355c72dcc28"
        },
        {
          "type": "python_script",
          "code": "apply_balanced_effect(\"transgressive\", intensity=\"standard\", witness=\"missy\")",
          "id": "item-cccd11c0-0591-4973-9069-ac2665e3928f"
        },
        {
          "id": "item-ad31ba53-3b5d-4810-89b8-3ae329fb9c95",
          "type": "dialogue",
          "characterId": null,
          "text": "There is a version of me that protects Missy."
        },
        {
          "id": "item-610155ea-5de4-448d-ac7e-4d49c84e2dc6",
          "type": "dialogue",
          "characterId": null,
          "text": "She exists."
        },
        {
          "id": "item-88b7d596-59ce-4dd9-9ba3-de0c8c436fe5",
          "type": "dialogue",
          "characterId": null,
          "text": "She is simply not the one who speaks first."
        },
        {
          "id": "item-a0ef35e7-cc86-453a-b91d-9e07b6fd9e9a",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base"
        },
        {
          "id": "item-a067dedf-2a8a-44b1-8b57-3c5c59e45a1b",
          "type": "show",
          "characterId": "stern_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "stern_sprite stern"
        },
        {
          "id": "item-9d158356-76a7-4d16-8350-94690f5fd04a",
          "type": "show",
          "characterId": "missy_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "missy_sprite shocked"
        },
        {
          "id": "item-1a8ceb61-86d3-46d9-b3b3-5cdcdca890e8",
          "type": "show",
          "characterId": "vance_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "move",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "vance_sprite angry"
        },
        {
          "id": "item-d516fb97-3c6d-4398-9648-91a4515060cb",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Missy handled it this morning, Ma'am."
        },
        {
          "id": "item-673e9e84-846c-4481-9e1c-2cea80752590",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "Cora—"
        },
        {
          "id": "item-a178862a-d610-4459-a89a-cc652e3bc69e",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "Quiet."
        },
        {
          "id": "item-a21e484a-6bf8-41bd-81a7-d6336a3a01c1",
          "type": "dialogue",
          "characterId": null,
          "text": "Missy's mouth closes."
        },
        {
          "id": "item-6b2528d0-9b46-4c73-a696-f0dd39fa168a",
          "type": "dialogue",
          "characterId": null,
          "text": "The betrayal arrives in her eyes before the fear does."
        },
        {
          "id": "item-ff93ffd5-2418-47eb-bfa5-cfbdabf2eb5b",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "I did not know whether she had been instructed to move it. It was not my place to question a senior maid's handling of the room."
        },
        {
          "id": "item-15159422-2e22-452a-a0ce-51f0f9b13051",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "I only did what you said."
        },
        {
          "id": "item-2f8d2b9c-7609-488d-a03c-fdda5050be46",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "What she said?"
        },
        {
          "id": "item-9bb4ed7e-97fd-408b-9a18-141753c1a884",
          "type": "dialogue",
          "characterId": null,
          "text": "The room turns toward me."
        },
        {
          "id": "item-f5199313-f9be-4d71-ba3d-bb9f115b7e07",
          "type": "dialogue",
          "characterId": null,
          "text": "I let confusion rise slowly, carefully, with no panic in it."
        },
        {
          "id": "item-ece0240e-a584-4d68-9af6-2836e41fecea",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "I told her not to leave private garments exposed, Madam. I did not instruct her to hide anything."
        },
        {
          "id": "item-4c52783f-c67d-441f-988d-3f71a3c40892",
          "type": "dialogue",
          "characterId": null,
          "text": "Every word is shaped to be defensible."
        },
        {
          "id": "item-cc2f25f2-887b-496c-9338-086daf1f064f",
          "type": "dialogue",
          "characterId": null,
          "text": "That is how cowards build knives with ivory handles."
        },
        {
          "id": "item-d9cccc13-32e0-4ce8-86aa-86f67da88c91",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "That's not—"
        },
        {
          "id": "item-3bc93ce3-02b8-4826-95da-ce54cea2ebf1",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "Enough."
        },
        {
          "id": "item-0b4b7154-2b51-455b-8e6a-959ee4335023",
          "type": "dialogue",
          "characterId": null,
          "text": "Missy stops."
        },
        {
          "id": "item-74cf9958-3baf-40d5-9da3-7b7e4e6ff9c0",
          "type": "dialogue",
          "characterId": null,
          "text": "She has already learned the house's first lesson: truth without rank is noise."
        },
        {
          "id": "item-52e4e98f-db39-4f72-81b7-abbcbe4cfa2d",
          "type": "jump",
          "destinationLabelId": "label-695bcc01-14cc-4876-b5a1-e8510fe3db06"
        }
      ]
    },
    {
      "id": "label-695bcc01-14cc-4876-b5a1-e8510fe3db06",
      "name": "day102_3_gideon_interrupts_controls_vance",
      "x": 11300,
      "y": 11260,
      "dialogue": [
        {
          "type": "python_script",
          "code": "set_time_period(\"Evening\")",
          "id": "item-7bb76ec6-becd-4654-9000-96f7a21638db"
        },
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-d7f6d385-bdd4-4784-87ae-b0ce74b0aaa9",
          "backgroundId": "bg_master_suite_tea"
        },
        {
          "id": "item-e5b2b66b-dfa6-4191-a321-12a401d693a3",
          "type": "show",
          "characterId": "gideon_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "gideon_sprite cold"
        },
        {
          "id": "item-f7283693-4077-4310-b033-6a7cfcdda05c",
          "type": "show",
          "characterId": "stern_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "stern_sprite stern"
        },
        {
          "id": "item-29b97d9f-7b97-4619-99f4-2ddfa45cbb6a",
          "type": "show",
          "characterId": "vance_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "vance_sprite angry"
        },
        {
          "id": "item-3a6978c7-fc0f-4fb4-ad5e-b4b46af1cdd8",
          "type": "dialogue",
          "characterId": null,
          "text": "The door opens without a knock."
        },
        {
          "id": "item-68a49071-4ca0-4515-a451-1ea569d7e713",
          "type": "dialogue",
          "characterId": null,
          "text": "Mr. Locke enters as if the argument has been waiting for his permission to exist."
        },
        {
          "id": "item-22ef33ca-9d57-42f2-a02a-8a30109221ef",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Vance."
        },
        {
          "id": "item-467a22ce-503f-47c0-91e6-ff169f8f0fff",
          "type": "dialogue",
          "characterId": null,
          "text": "That is all."
        },
        {
          "id": "item-ef90246f-d29e-4c16-b96b-7767ae7779cb",
          "type": "dialogue",
          "characterId": null,
          "text": "It is enough."
        },
        {
          "id": "item-fa1ff12b-205e-4569-8b77-71d9a4e9d518",
          "type": "show",
          "characterId": "vance_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "vance_sprite cowed"
        },
        {
          "id": "item-073c0276-045c-46c9-ae2d-ab30b7c13bb5",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "Something was taken from my things."
        },
        {
          "id": "item-92316101-3412-40c7-a91c-a3f1821cac55",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "So I gather. The corridor can hear you gathering it."
        },
        {
          "id": "item-19f06d9c-15d6-4e0f-8dad-c8a8ef822f79",
          "type": "dialogue",
          "characterId": null,
          "text": "Vance's colour changes."
        },
        {
          "id": "item-f3771048-55b5-4e30-900d-0acddf905c2e",
          "type": "dialogue",
          "characterId": null,
          "text": "Not shame, exactly. More intimate than that. A correction landing where others cannot see it."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "d734356c-bf35-44e1-8a5a-fc47f15cf500",
              "type": "if",
              "conditionRaw": "story.day2_tea_choice == \"prey\"",
              "dialogue": [
                {
                  "id": "item-7b6ed772-0354-4b03-b983-915ce876fb20",
                  "type": "dialogue",
                  "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
                  "text": "You."
                },
                {
                  "id": "item-cc656631-1d03-4520-bdce-bdce36082c12",
                  "type": "show",
                  "characterId": "cora_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "None",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "cora_sprite base"
                },
                {
                  "id": "item-49932ca7-cf25-4aa3-aa70-e4d8742abd60",
                  "type": "show",
                  "characterId": "stern_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "None",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "stern_sprite stern"
                },
                {
                  "id": "item-90237714-c1fe-4df2-99de-97c224b88ead",
                  "type": "show",
                  "characterId": "vance_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "None",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "vance_sprite cowed"
                },
                {
                  "id": "item-c08c4be0-182e-470e-85c8-1fdf00253b45",
                  "type": "show",
                  "characterId": "gideon_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "move",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "gideon_sprite cold"
                },
                {
                  "id": "item-45f787ee-1808-4b65-a84a-0bd421c2de22",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "Yes, Sir."
                },
                {
                  "id": "item-f3db1fec-9e47-47e7-a431-762cb7b41779",
                  "type": "dialogue",
                  "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
                  "text": "You saw the item and failed to report it."
                },
                {
                  "id": "item-14fda537-c7ac-42af-b0be-e203df4caa22",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "Yes, Sir."
                },
                {
                  "id": "item-e8a08580-0bf8-4f71-b88b-91cd8afc27f8",
                  "type": "dialogue",
                  "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
                  "text": "Yet you report your failure now."
                },
                {
                  "id": "item-051f643e-3410-4ba7-9aa5-579f7b6944f0",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "His attention is not warm."
                },
                {
                  "id": "item-c03e67ae-e248-43e7-afbe-73821e33dcba",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "It is worse. It is precise."
                },
                {
                  "id": "item-7c5b0fcc-1a1c-45d2-8ecf-0d4b5a714f59",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "That is correct, Sir."
                },
                {
                  "id": "item-a4e858dc-d3e8-4a2f-a0bf-b4af3ca1bd35",
                  "type": "dialogue",
                  "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
                  "text": "Interesting choice."
                },
                {
                  "id": "item-2133aa25-ba30-400f-bdb5-b8d33c2bca8d",
                  "type": "dialogue",
                  "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
                  "text": "Sir, I can have the girl dismissed—"
                },
                {
                  "id": "item-c5a483f5-b099-47c8-85be-4dadd607b60f",
                  "type": "dialogue",
                  "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
                  "text": "No."
                },
                {
                  "id": "item-9fe3e176-6a27-4ffa-b9f1-c02d2fe216e0",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Stern stops."
                },
                {
                  "id": "item-7b128473-6c65-4582-9648-43a3ef78c7d0",
                  "type": "dialogue",
                  "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
                  "text": "A dismissal makes noise. We are finished with noise for today."
                },
                {
                  "id": "item-ef479e7f-4952-43ba-8ef5-0f2ee28bd101",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "He does not spare me."
                },
                {
                  "id": "item-6981db83-2866-41a0-bd16-55cd37673472",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "He spares the hotel's reputation, which is the same thing with better upholstery."
                },
                {
                  "id": "item-04574b75-b114-4a0a-be35-1e73555e1208",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "His eyes remain on me one beat too long."
                },
                {
                  "id": "item-6d9a0423-7bba-4bd7-bf4f-780682306709",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I have not escaped notice."
                },
                {
                  "id": "item-69baf09a-e2d6-43e6-835c-ed97853ef97e",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I have been filed."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day2_tea_choice == \"prey\""
            },
            {
              "id": "c04e74a9-a21a-43d0-85c3-26a5510d77b8",
              "type": "elif",
              "conditionRaw": "story.day2_tea_choice == \"predator\"",
              "dialogue": [
                {
                  "type": "if_block",
                  "branches": [
                    {
                      "id": "ca9e079c-08fb-441c-878e-a9841c871921",
                      "type": "if",
                      "conditionRaw": "story.day2_contraband_state == \"planted_in_trunk\"",
                      "dialogue": [
                        {
                          "id": "item-10423d8f-f7d0-4e27-891e-d36c68502254",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "Mr. Locke looks at the lace, then at the trunk, then at me."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      },
                      "rawCondition": "story.day2_contraband_state == \"planted_in_trunk\""
                    },
                    {
                      "id": "d8824d88-b84f-469d-b418-949627512418",
                      "type": "else",
                      "conditionRaw": null,
                      "dialogue": [
                        {
                          "id": "item-e70511a6-15f4-43b3-90eb-5e5f37167819",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "Mr. Locke looks at the hatbox, then at my perfectly folded hands."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      }
                    }
                  ],
                  "id": "item-2d4675cc-323f-413b-b9c9-872346744fb6"
                },
                {
                  "id": "item-c39e82df-8214-4497-886f-c977a225ac44",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "He understands too quickly."
                },
                {
                  "id": "item-9e5869a1-da71-4abf-ab26-308026f4c514",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Men like him do not need proof when pattern will do."
                },
                {
                  "id": "item-f11abfb1-079b-4901-90a1-2b943e2d6902",
                  "type": "dialogue",
                  "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
                  "text": "Thank you. Leave it there."
                },
                {
                  "id": "item-1b28b4c7-e6db-41fb-b224-aa20f1496d7b",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "Yes, Sir."
                },
                {
                  "id": "item-c4b0cc48-d9cd-4f97-a2d2-34a8c178f33b",
                  "type": "dialogue",
                  "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
                  "text": "Thank her? She—"
                },
                {
                  "id": "item-9a4e100f-1e04-4009-950b-4bb4d243db05",
                  "type": "dialogue",
                  "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
                  "text": "Found what you misplaced."
                },
                {
                  "id": "item-e9ffd8b1-2c48-46c3-b7cc-e4a7d104677f",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "He has chosen which story the afternoon will believe."
                },
                {
                  "id": "item-2ecf0a21-2a94-419a-8e4f-5323a576195f",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Vance goes still."
                },
                {
                  "id": "item-d8966f8b-5360-47ae-b655-ee4b15bc9268",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The correction is mild enough to be polite and sharp enough to draw blood."
                },
                {
                  "id": "item-81df2541-d94f-4c63-b63c-d48cac9f43da",
                  "type": "dialogue",
                  "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
                  "text": "You will not punish the staff for your embarrassment."
                },
                {
                  "id": "item-a1aca3ef-b691-4146-82be-6e91b9895a5c",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "My gaze stays on the carpet."
                },
                {
                  "id": "item-4f57ce1e-e13f-463e-9ca6-20d806489132",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The carpet is expensive enough to hide several sins."
                },
                {
                  "id": "item-9985779c-1b8a-402a-92ee-fbfc8c3ce4a9",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "He knows I lied."
                },
                {
                  "id": "item-3cc63cb6-b61f-4b5a-836e-a6e526a1fc68",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "He has chosen to make the lie useful."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day2_tea_choice == \"predator\""
            },
            {
              "id": "cc97a113-916d-40ed-9d97-d7204c25674e",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-e047c8ff-47b4-4e54-8184-4c69a07d4743",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Mr. Locke's gaze passes over Missy first."
                },
                {
                  "id": "item-4c4ff37f-8b7b-4ff3-9928-9232d103dd6c",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She is pale. Terrified. Guilty-looking in the way frightened people always look guilty to those searching for a culprit."
                },
                {
                  "id": "item-6d5c3368-950a-45b2-9bf2-5a8ba69e09e9",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Then he looks at me."
                },
                {
                  "id": "item-70584247-db9b-44fe-99be-20d8ff1426d2",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I am calm."
                },
                {
                  "id": "item-c718fd88-16eb-43b8-8582-cc66d967a093",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Too calm, perhaps."
                },
                {
                  "id": "item-23b5281e-43d8-40fc-aa17-2381d62a7272",
                  "type": "dialogue",
                  "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
                  "text": "Miss Stern, you will not conduct an inquest in a guest room."
                },
                {
                  "id": "item-d3046fd8-091e-4314-8033-be79a4531aec",
                  "type": "dialogue",
                  "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
                  "text": "Sir."
                },
                {
                  "id": "item-45f362c4-2795-43c4-8f18-be00ba9ef5a7",
                  "type": "dialogue",
                  "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
                  "text": "But she—"
                },
                {
                  "id": "item-19c88eb7-764b-4568-ad11-40ca94b91800",
                  "type": "dialogue",
                  "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
                  "text": "Has been frightened enough to become useless for the afternoon. That is poor management, not justice."
                },
                {
                  "id": "item-8f3ba10e-9d11-4970-b350-f07a5c33bec0",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Missy's eyes fill."
                },
                {
                  "id": "item-b183ddc7-4bbc-4ae3-bb3b-ab41febca442",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She does not cry."
                },
                {
                  "id": "item-d90d47b8-1d16-451f-a4b4-e94713fbac64",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "That is the worst of it."
                },
                {
                  "id": "item-b4b26d9d-d478-4f6c-be7c-8e466bc2e402",
                  "type": "dialogue",
                  "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
                  "text": "Send the girl below. Send Cora back to work. I will discuss the rest with Miss Vance privately."
                },
                {
                  "id": "item-ac368f70-7efd-4559-8bdb-07d4265ac60e",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Privately."
                },
                {
                  "id": "item-23698385-0645-4d5e-b657-6700cbb99190",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Vance hears the word and obeys before any hand moves."
                },
                {
                  "id": "item-6aaabfc1-2f3e-409e-abe6-d0c6a11f8408",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "His eyes touch mine for the smallest fraction of time."
                },
                {
                  "id": "item-28f5c79e-fdf8-4b9c-8be5-bd588d2540c4",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "He has not believed me."
                },
                {
                  "id": "item-0d2b03e5-01a5-41f8-92fd-ee1330327a89",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "He has not exposed me."
                },
                {
                  "id": "item-d8e74ed8-219e-4c65-bacb-0030a1fb2dbf",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "He is keeping a note."
                },
                {
                  "id": "item-1ea36be3-5501-45d9-a7b7-05d52733e3b7",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "This is not mercy."
                },
                {
                  "id": "item-c4db0167-2dea-4497-ad97-ee9eadaf232e",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "It is investment."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-16e3fa12-e97f-4016-87d5-8cb6a85faaae"
        },
        {
          "id": "item-1c9c5df9-e19c-42b0-865e-503a2fa05731",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "That will be all."
        },
        {
          "type": "hide",
          "layer": null,
          "id": "item-1c58e52d-df23-41a4-9480-e809af4cb565",
          "characterId": "gideon_sprite"
        },
        {
          "type": "hide",
          "layer": null,
          "id": "item-d525cf80-7b7d-420d-9053-de160120a014",
          "characterId": "vance_sprite"
        },
        {
          "type": "hide",
          "layer": null,
          "id": "item-076f89c1-f22a-4c45-9812-c9d20b8a2767",
          "characterId": "stern_sprite"
        },
        {
          "type": "scene",
          "layer": null,
          "transition": "fade",
          "id": "item-039550da-c31c-43b6-a494-27fd6b0e9a77",
          "backgroundId": "bg_servants_corridor_day"
        },
        {
          "id": "item-ccc125c6-39f5-41d0-8b03-fe5a8037fe97",
          "type": "show",
          "characterId": "missy_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "missy_sprite shocked"
        },
        {
          "id": "item-fc46f304-7f73-46ff-a688-e30e60b8842f",
          "type": "dialogue",
          "characterId": null,
          "text": "The corridor receives us like a throat swallowing something sharp."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "8be2dd48-e8e0-4be2-b665-f3d94ff02234",
              "type": "if",
              "conditionRaw": "story.day2_tea_choice == \"ghost\"",
              "dialogue": [
                {
                  "id": "item-931b19bb-a045-443e-86f5-494ab5ccbc53",
                  "type": "dialogue",
                  "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
                  "text": "How could you?"
                },
                {
                  "id": "item-0a69a65b-9af0-40d2-88e0-e6a1a74e4ed0",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "There are many possible answers."
                },
                {
                  "id": "item-06411843-555f-4973-8396-2dcfc8dd8f9a",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "None are small enough to fit in the corridor."
                },
                {
                  "id": "item-a866eaf3-6f0e-48eb-9db9-7f9cf6215635",
                  "type": "show",
                  "characterId": "cora_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "None",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "cora_sprite base"
                },
                {
                  "id": "item-641f12b7-4ee6-47de-b2d2-eab8489c8e6d",
                  "type": "show",
                  "characterId": "missy_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "move",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "missy_sprite shocked"
                },
                {
                  "id": "item-9821f32c-7f7e-41a4-9e06-12edbe7a670e",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "Not here."
                },
                {
                  "id": "item-ed657ed8-8512-4cd9-be56-89653e1d17b4",
                  "type": "dialogue",
                  "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
                  "text": "No. Not anywhere."
                },
                {
                  "type": "hide",
                  "layer": null,
                  "id": "item-6a64f6a9-2986-4e08-adc9-14702e819037",
                  "characterId": "missy_sprite"
                },
                {
                  "id": "item-6c4166af-4d8e-4eea-9ce5-9262bda219e4",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She leaves me beside the cart."
                },
                {
                  "id": "item-d43835a4-fc4b-4435-97f7-b5b2be3c7f31",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "That, too, is material."
                },
                {
                  "id": "item-c8c67350-546a-473a-b3bb-c64e96d260b6",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I hate myself for knowing it."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day2_tea_choice == \"ghost\""
            },
            {
              "id": "abc48b64-271d-44c4-9097-553d1ef4b08b",
              "type": "elif",
              "conditionRaw": "story.day2_tea_choice == \"predator\"",
              "dialogue": [
                {
                  "id": "item-30df9c60-b376-437b-aa60-ec1b46e54184",
                  "type": "dialogue",
                  "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
                  "text": "You knew where it was."
                },
                {
                  "id": "item-bc447f69-2aa1-42ec-a0db-23cba99c66fc",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "I guessed."
                },
                {
                  "id": "item-41fc1c7e-9d0e-4ca4-a176-721a53b8d73e",
                  "type": "dialogue",
                  "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
                  "text": "No, you didn't."
                },
                {
                  "id": "item-d663defe-3d93-47e7-95de-82984d2a2ade",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "There is accusation in her voice now."
                },
                {
                  "id": "item-80c7a613-b7e1-49cd-86b3-6adf89733015",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Also awe."
                },
                {
                  "id": "item-227a57a2-1124-442c-ad36-1b97b5870feb",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I am not sure which is more dangerous."
                },
                {
                  "type": "hide",
                  "layer": null,
                  "id": "item-ee375ca3-6110-433e-ae7e-c4dbdaa8b0c8",
                  "characterId": "missy_sprite"
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day2_tea_choice == \"predator\""
            },
            {
              "id": "2f951e48-d66c-4ab9-be21-551bb73ba60a",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-62f903cf-6fd6-4afc-b4cc-3eb956805391",
                  "type": "dialogue",
                  "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
                  "text": "You stepped forward."
                },
                {
                  "id": "item-f9b2eac5-c9a2-4acf-a75e-67ddf550c479",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "Someone had to."
                },
                {
                  "id": "item-29172199-b8ba-41df-9d30-d271d825cbed",
                  "type": "dialogue",
                  "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
                  "text": "No one ever has to. That's what makes it something."
                },
                {
                  "id": "item-b29e0f35-958c-466a-9fe9-25090c0dc428",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She says it simply, which makes it unbearable."
                },
                {
                  "type": "hide",
                  "layer": null,
                  "id": "item-c3421483-a281-42e8-8dfa-5b15db291c66",
                  "characterId": "missy_sprite"
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-96498735-720d-4d64-a346-12b8a16d8260"
        },
        {
          "id": "item-9c604d12-5d6c-4dbe-979e-dc5eb31a47a7",
          "type": "dialogue",
          "characterId": null,
          "text": "I walk back down the narrow servants' corridor toward the quarters, the gas-lamp light casting long, uneasy shadows on the cold floorboards."
        },
        {
          "id": "item-6556d73f-e516-47cb-a075-59e05de1c5aa",
          "type": "dialogue",
          "characterId": null,
          "text": "As I pass the dark linen closet, a sliver of yellow light escapes the door, accompanied by the distinct clink of iron keys."
        },
        {
          "id": "item-667be883-2655-486e-b87a-fc4096100a19",
          "type": "dialogue",
          "characterId": null,
          "text": "I freeze, stepping back into the gloom. Through the half-inch gap in the heavy oak door, the air is thick with the scent of starch, cedar, and something warmer—lavender and pressed wool."
        },
        {
          "id": "item-fde12455-680a-407f-b93e-72e9e1b6a4fd",
          "type": "dialogue",
          "characterId": null,
          "text": "Inside, the space is cramped. Missy stands pinned against the high shelves, her back pressed flat against the stacked, pristine sheets."
        },
        {
          "id": "item-f961285f-bbff-44ab-81ea-3c4bbc7766f2",
          "type": "dialogue",
          "characterId": null,
          "text": "Ms. Stern stands directly in her path, blocking her escape. She is closer than I have ever seen her to any servant, her disciplinary mask cracked to reveal a low, burning intensity."
        },
        {
          "id": "item-be8672e5-e025-46b0-b244-b2e7025462c2",
          "type": "dialogue",
          "characterId": null,
          "text": "With a slow, deliberate movement, Stern raises her hand. Her keys dangle, chiming softly, as her fingers reach out to trace Missy's collarbone above the cotton collar."
        },
        {
          "id": "item-dc1825cf-00bc-4cd2-92ec-c8a977cf8228",
          "type": "dialogue",
          "characterId": null,
          "text": "Missy's breath catches, her chin rising as Stern's hand slides upward, her thumb pressing firmly against the rapid beat of Missy's pulse at her throat."
        },
        {
          "id": "item-1bbe8dec-2a66-49c6-a259-0dcc43970c9b",
          "type": "show",
          "characterId": "stern_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "moveinright",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "stern_sprite neutral"
        },
        {
          "id": "item-f6adfc4a-447a-4d64-82f3-117052f2b2e5",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "A girl with raw fingers has no business prying into the suites, Missy."
        },
        {
          "id": "item-5a5a6c73-e26e-4eed-a0ed-91d9d0f88eb3",
          "type": "dialogue",
          "characterId": null,
          "text": "Her voice is a low, husky vibration, her thumb slowly caressing the warm skin of Missy's neck."
        },
        {
          "id": "item-21ef7e3b-de9d-423b-bcad-1142e3dcfae4",
          "type": "dialogue",
          "characterId": null,
          "text": "The intimacy of the gesture is sharp, almost predatory, yet wrapped in a strange, fiercely protective heat."
        },
        {
          "id": "item-7b4ab8ec-2f45-438e-bc28-193e387c7f84",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "I can protect a quiet fool. I cannot protect a girl who lets the gentlemen see she has eyes. Do you understand me, child?"
        },
        {
          "id": "item-95f2cd8c-5129-4258-bbbb-e43b520ab81f",
          "type": "dialogue",
          "characterId": null,
          "text": "Missy does not pull away. Instead, she leans slightly into the pressure of Stern's thumb, her cheeks flushed, her dark eyes locking onto Stern's with a submissive yet fiercely observant focus."
        },
        {
          "id": "item-3211466b-9d60-4ec8-aaef-e69e5bb2528c",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "Yes, Ma'am. I only fold."
        },
        {
          "id": "item-36b22922-fce5-477f-bbbb-a5adac258512",
          "type": "dialogue",
          "characterId": null,
          "text": "Stern's gaze drops to Missy's parted lips, her thumb lingering for one long, silent heartbeat against the pulse before she draws her hand back, her iron-bound keys sliding back into the folds of her skirt."
        },
        {
          "id": "item-a58d6e0c-8fd5-460c-9c47-754964b89d0f",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "Then fold. And keep your eyes on the thread."
        },
        {
          "id": "item-40ef8a06-4196-483d-9cef-a72cf41ca3a2",
          "type": "dialogue",
          "characterId": null,
          "text": "I step back into the dark corridor, my chest tight."
        },
        {
          "id": "item-db949387-bf54-4002-8248-acfb18785920",
          "type": "dialogue",
          "characterId": null,
          "text": "The heavy atmosphere of the house seems to cling to my throat like soot."
        },
        {
          "id": "item-f000495f-e378-4953-88d1-709efa2c5f1f",
          "type": "dialogue",
          "characterId": null,
          "text": "There is a dark, heavy chapter in that—the invisible chains that bind the prey and the protector in this building."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "307598bd-e8ca-4574-87f5-17aa50a00e57",
              "type": "if",
              "conditionRaw": "not story.has_manuscript_chapter(\"day1_chapter\")",
              "dialogue": [
                {
                  "id": "item-16f7c3ce-b1a9-4466-b424-78756f0792f9",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Tonight I must write."
                },
                {
                  "id": "item-2e521163-5a44-4c5f-a201-1f04b40c7a4f",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Two days inside the machine and not a single finished chapter would be its own kind of defeat."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "not story.has_manuscript_chapter(\"day1_chapter\")"
            },
            {
              "id": "cfd65d98-5910-4bb7-a347-0a48ab36273a",
              "type": "elif",
              "conditionRaw": "not story.has_manuscript_chapter(\"day2_chapter\")",
              "dialogue": [
                {
                  "id": "item-143e1958-d588-442a-a2c8-e18879328756",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Tonight the fuel is finally high enough for something better than survival prose."
                },
                {
                  "id": "item-62b17e05-fae8-4183-a5d6-cab93a4f370a",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Chapter Two cannot wait for a braver version of me."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "not story.has_manuscript_chapter(\"day2_chapter\")"
            },
            {
              "id": "70e7b98a-ef9a-4a75-98fb-57be722b84bd",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-3cd4c08e-b502-417b-9ea3-6479fefe64c0",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Both opening chapters exist. Tonight I can afford to choose what the third will cost."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-09036af7-7a59-4158-bb73-f429dac50c64"
        },
        {
          "id": "item-67f4b0df-7ef4-4d7b-97f1-a50504cce7ab",
          "type": "jump",
          "destinationLabelId": "label-8f2e1297-6b8c-49a4-a9f6-ef74293cf9f4"
        }
      ]
    },
    {
      "id": "label-8f2e1297-6b8c-49a4-a9f6-ef74293cf9f4",
      "name": "day102_4_night",
      "x": 11700,
      "y": 11260,
      "dialogue": [
        {
          "type": "python_script",
          "code": "set_time_period(\"Night\")",
          "id": "item-499bfbc7-f1fb-4949-a8c3-e69529b2feb0"
        },
        {
          "id": "item-868c2a9c-f26c-42bc-9ffa-98279bcaf872",
          "type": "call",
          "destinationLabelId": "label-12a517e6-5fab-424b-94f0-a5e420578437"
        },
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-432a5411-012c-4710-a22d-9447be29b0a0",
          "backgroundId": "bg_cora_desk_night"
        },
        {
          "id": "item-401bd7b5-3857-4436-9826-a9acd00261b9",
          "type": "dialogue",
          "characterId": null,
          "text": "The candle takes reluctantly."
        },
        {
          "id": "item-ad06aa8a-149f-433e-ae75-c614bd3fd343",
          "type": "dialogue",
          "characterId": null,
          "text": "For a moment the room is only wick, breath, and the small circle of light I can afford."
        },
        {
          "id": "item-f0845d3f-88e1-4f50-8a83-316e53a093ac",
          "type": "dialogue",
          "characterId": null,
          "text": "My ledger lies open."
        },
        {
          "id": "item-844e36df-849a-4863-a72d-8ac29ab7a8a6",
          "type": "dialogue",
          "characterId": null,
          "text": "My page waits beside it."
        },
        {
          "id": "item-2337ce7d-0de4-45fa-9e05-a3c730e42097",
          "type": "dialogue",
          "characterId": null,
          "text": "One records appetite. The other pretends to tame it."
        },
        {
          "type": "python_script",
          "code": "show_ledger_ui()",
          "id": "item-a982f6a4-7a04-4f7f-87d2-ba13357786be"
        },
        {
          "type": "choice",
          "options": [
            {
              "id": "a8cb5f3f-1c49-402d-9e44-692986b91e38",
              "text": "Write. Turn the suite into fiction before it rots. [[Manuscript progress]]",
              "dialogue": [
                {
                  "id": "item-4fea8f6a-e2ff-4e4f-89a8-2f3fc0af2281",
                  "type": "jump",
                  "destinationLabelId": "label-d2cff8bb-fd00-4970-a018-a74bf7319e1a"
                }
              ]
            },
            {
              "id": "a4aa24da-72bd-4a58-ab57-b5aa6c22e65d",
              "text": "Do not write. Stay inside the feeling a little longer. [[Indulgence]]",
              "dialogue": [
                {
                  "id": "item-0a60351a-8ed4-4fbf-a201-ae617bec5b0e",
                  "type": "jump",
                  "destinationLabelId": "label-7c82a081-0d53-46d1-947b-af1a3846df9d"
                }
              ]
            }
          ],
          "id": "item-6da53f46-c79e-4523-a94d-dca3af65078e"
        },
        {
          "id": "item-59b78525-8384-48e8-800b-97aea3f80700",
          "type": "jump",
          "destinationLabelId": "label-12a517e6-5fab-424b-94f0-a5e420578437"
        }
      ]
    },
    {
      "id": "label-12a517e6-5fab-424b-94f0-a5e420578437",
      "name": "day102_night_consequence_window",
      "x": 22100,
      "y": 12382.5,
      "dialogue": [
        {
          "id": "item-0cb45cc8-239b-4ba4-8012-50762a5cf8c5",
          "type": "call",
          "destinationLabelId": "label-5f635f30-8ef3-4f17-80e7-4e5cde552ded"
        },
        {
          "id": "item-b69b0699-0481-43ec-925d-5d2d74d6d78a",
          "type": "call",
          "destinationLabelId": "label-7d0ab68c-82c3-423b-a677-a442c420ec43"
        }
      ]
    },
    {
      "id": "label-55af31a8-f543-4dc2-9964-64568d04da16",
      "name": "manuscript_slot_ch2_write",
      "x": 18100,
      "y": 11737.5,
      "dialogue": [
        {
          "type": "if_block",
          "branches": [
            {
              "id": "bfc3ca2a-5d72-4043-90e7-d4082eb1abf6",
              "type": "if",
              "conditionRaw": "has_story_fuel(*WRITE_GATE_CH2)",
              "dialogue": [
                {
                  "id": "item-8020a154-541b-4814-abbb-c5fb19477f1f",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Chapter Two begins with a hatbox."
                },
                {
                  "id": "item-41f03000-49e0-4747-a3b8-592199093557",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Not the object inside."
                },
                {
                  "id": "item-bfa790bb-9001-4540-8e06-dee854b7dfba",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The pause before it is opened."
                },
                {
                  "type": "if_block",
                  "branches": [
                    {
                      "id": "01c4f387-4e15-4dc4-8efc-62e58fa2118a",
                      "type": "if",
                      "conditionRaw": "story.day2_tea_choice == \"prey\"",
                      "dialogue": [
                        {
                          "id": "item-8db9bce4-bee7-41da-842e-f149e1e1fc9f",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "I write a woman who tells one clean portion of the truth and lets everyone mistake that portion for the whole."
                        },
                        {
                          "id": "item-27c00976-9b8e-4738-ab35-953cd01ded3f",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "Her honesty does not save her."
                        },
                        {
                          "id": "item-91e8729d-4a7e-4c0c-8d42-9c091eda5090",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "It places her exactly where the dangerous man can see her."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      },
                      "rawCondition": "story.day2_tea_choice == \"prey\""
                    },
                    {
                      "id": "461927fe-47c6-4cde-8edc-5084ab30b762",
                      "type": "elif",
                      "conditionRaw": "story.day2_tea_choice == \"predator\"",
                      "dialogue": [
                        {
                          "id": "item-92d90f45-b0d1-4dda-b0a5-6080c6fb7456",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "I write a woman who discovers that a lie told calmly can become furniture."
                        },
                        {
                          "id": "item-843ab130-b956-4d96-950f-6aa9917633a2",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "People walk around it. Lean on it. Arrange the room to suit it."
                        },
                        {
                          "id": "item-7234b0ec-36f7-4997-87a8-d15ff247246f",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "By the end of the chapter, even the gentleman is using her falsehood as if he ordered it built."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      },
                      "rawCondition": "story.day2_tea_choice == \"predator\""
                    },
                    {
                      "id": "7a0ec58b-4687-4321-aff3-ea6f2ad16f1c",
                      "type": "else",
                      "conditionRaw": null,
                      "dialogue": [
                        {
                          "id": "item-c6a50565-acfa-46f6-8068-89fa8314ba76",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "I write a woman who survives by leaving fingerprints on other people."
                        },
                        {
                          "id": "item-3a0b06fb-53ab-42d0-8275-98ccb727255d",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "No blood on her cuffs."
                        },
                        {
                          "id": "item-d8316524-8f2d-4dc0-9cf2-4bfadcebffa7",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "No proof in her pocket."
                        },
                        {
                          "id": "item-e3bae449-fa47-4776-9f07-4224d12286f3",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "Only a girl in the corridor learning what betrayal sounds like when it does not raise its voice."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      }
                    }
                  ],
                  "id": "item-f5758731-71fd-4775-b2d6-fb0c2565b974"
                },
                {
                  "type": "python_script",
                  "code": "story.complete_manuscript_chapter(\"day2_chapter\")",
                  "id": "item-97b312b8-df18-4ead-8f21-b0841c8e134a"
                },
                {
                  "id": "item-f92b9bd7-f268-4c0e-bdad-b40ef9351035",
                  "type": "call",
                  "destinationLabelId": "label-50c93452-a12f-49cf-9982-b6cc72b97648"
                },
                {
                  "type": "python_script",
                  "code": "apply_effects(insp=-15)",
                  "id": "item-58dbc707-373d-4597-8792-9ed88dbc6b83"
                },
                {
                  "id": "item-10e21cae-199e-44fa-ab15-9731099fe237",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "By the time the candle shortens, the second chapter exists."
                },
                {
                  "id": "item-d4452172-946b-45c8-8acf-d68a21b3adca",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "It is better than the first."
                },
                {
                  "id": "item-3959d9fd-b97c-48c1-8532-d26823fc579d",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "That is not comforting."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "has_story_fuel(*WRITE_GATE_CH2)"
            },
            {
              "id": "5425661b-8583-4318-a578-fca37a96a2c2",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-05c7fbaf-c07e-4134-84a2-90637b2bf075",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I write three sentences and cross them out."
                },
                {
                  "id": "item-fdf3006a-16f0-4792-af9f-1e5809e25874",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The scene is still too close to me."
                },
                {
                  "id": "item-a1bc3628-a844-4e4d-ad81-9cf528486503",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Vance's fury. Gideon's correction. Missy's face. The lace under cloth or hidden in the trunk."
                },
                {
                  "id": "item-bed0770b-5037-4583-8aa0-76ead0fa61fd",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "None of it has become art yet."
                },
                {
                  "id": "item-c32e75b4-037d-4a34-8c66-29f39fe32fcb",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "It remains appetite and consequence."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-557a1544-cbfd-4dd6-8954-44f0e14ecd7c"
        }
      ]
    },
    {
      "id": "label-d2cff8bb-fd00-4970-a018-a74bf7319e1a",
      "name": "day102_4_cora_writes_a_chapter",
      "x": 12100,
      "y": 11157.5,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-5dcc1e4f-187d-48c0-b687-d916e3521989",
          "backgroundId": "bg_cora_desk_night"
        },
        {
          "type": "python_script",
          "code": "story.set_day2_night_action(\"write\")",
          "id": "item-0ee58c46-68ee-4a6b-8429-001db2c05c52"
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "fb256771-5eba-4057-b68e-7a5dc75cd065",
              "type": "if",
              "conditionRaw": "not story.has_manuscript_chapter(\"day1_chapter\")",
              "dialogue": [
                {
                  "type": "if_block",
                  "branches": [
                    {
                      "id": "16845fd9-d839-4dc3-abb1-7591bc428d06",
                      "type": "if",
                      "conditionRaw": "has_story_fuel(*WRITE_GATE_CH1)",
                      "dialogue": [
                        {
                          "id": "item-f58cf135-6376-4dc2-979c-2249360af25d",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "Chapter One comes late, but it comes with teeth."
                        },
                        {
                          "type": "if_block",
                          "branches": [
                            {
                              "id": "19373e6f-2f36-4bb4-8044-a8f3955b3f67",
                              "type": "if",
                              "conditionRaw": "story.day1_corridor_state == \"predator\"",
                              "dialogue": [
                                {
                                  "id": "item-0416c5ec-586e-4482-a67d-7893f94f2217",
                                  "type": "dialogue",
                                  "characterId": null,
                                  "text": "I write a maid who learns that other people's innocence can open doors her own hands must not touch."
                                }
                              ],
                              "condition": {
                                "operator": "and",
                                "clauses": []
                              },
                              "rawCondition": "story.day1_corridor_state == \"predator\""
                            },
                            {
                              "id": "5db5d65e-a1d6-4a81-a8fa-96fb999be0af",
                              "type": "elif",
                              "conditionRaw": "story.day1_corridor_state == \"prey\"",
                              "dialogue": [
                                {
                                  "id": "item-60d90234-3298-45a3-bd90-13ef14a7148c",
                                  "type": "dialogue",
                                  "characterId": null,
                                  "text": "I write a maid caught at the threshold, exposed by the very hunger that brought her there."
                                }
                              ],
                              "condition": {
                                "operator": "and",
                                "clauses": []
                              },
                              "rawCondition": "story.day1_corridor_state == \"prey\""
                            },
                            {
                              "id": "142eead0-17e6-406b-bcbc-8aa4a660eea7",
                              "type": "else",
                              "conditionRaw": null,
                              "dialogue": [
                                {
                                  "id": "item-03b44e1a-c3ee-4201-84e0-3b085c5bd2c3",
                                  "type": "dialogue",
                                  "characterId": null,
                                  "text": "I write a maid who hears enough through walls to understand the architecture of power."
                                }
                              ],
                              "condition": {
                                "operator": "and",
                                "clauses": []
                              }
                            }
                          ],
                          "id": "item-439d808e-7c1b-4c26-a608-019835dd4726"
                        },
                        {
                          "id": "item-1c230201-3713-4234-a965-43ba2f5579be",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "The prose is raw."
                        },
                        {
                          "id": "item-4aeb491d-e340-4899-b257-898401a383af",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "Good. Raw things bleed honestly."
                        },
                        {
                          "type": "python_script",
                          "code": "story.complete_manuscript_chapter(\"day1_chapter\")",
                          "id": "item-cd4f3caf-1a5a-40df-9d8a-bfd55d1c76b5"
                        },
                        {
                          "id": "item-07aa8090-1c2b-43aa-9608-95ed31844f44",
                          "type": "call",
                          "destinationLabelId": "label-50c93452-a12f-49cf-9982-b6cc72b97648"
                        },
                        {
                          "type": "python_script",
                          "code": "apply_effects(insp=-10)",
                          "id": "item-91154eaa-6043-4652-ba98-992ab236f67f"
                        },
                        {
                          "id": "item-aff93dab-dc3f-45eb-a303-3ed2aa9f5ea3",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "Chapter One is done."
                        },
                        {
                          "id": "item-dd16d5d5-bebd-4501-9d1b-b60040dae9ff",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "Late is not failure."
                        },
                        {
                          "id": "item-13d1c1cb-4690-46ad-a0d9-8f17c9fa2d42",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "Blank is failure."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      },
                      "rawCondition": "has_story_fuel(*WRITE_GATE_CH1)"
                    },
                    {
                      "id": "566893ec-3a42-4257-8d83-887d8a0c1e43",
                      "type": "else",
                      "conditionRaw": null,
                      "dialogue": [
                        {
                          "id": "item-2db69489-5a14-4811-af2a-bc0e89baaea9",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "I try to begin with the corridor."
                        },
                        {
                          "id": "item-91275132-a4f2-43dc-b6d1-edc2027e2177",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "Then the suite."
                        },
                        {
                          "id": "item-7d3d697c-0810-45b7-8e96-7ca82bc9fc49",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "Then Missy's face."
                        },
                        {
                          "id": "item-e93c4bac-520c-4901-8e73-18ed8be1620d",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "Each beginning collapses into accusation."
                        },
                        {
                          "id": "item-e1e2be44-ed3d-44c4-b7e8-6c939442df57",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "I do not yet have enough material."
                        },
                        {
                          "id": "item-da55a3a6-6078-4414-a95a-cb16938b79c7",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "Or I have too much and no discipline."
                        },
                        {
                          "id": "item-edeadb7f-24b3-4739-9ac5-04328a8eec9b",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "The page does not care which excuse I prefer."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      }
                    }
                  ],
                  "id": "item-f4c57177-be4c-439c-a8d9-9b4d38059f01"
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "not story.has_manuscript_chapter(\"day1_chapter\")"
            }
          ],
          "id": "item-1caeb9d6-46e6-4263-b60d-7c5725b27bfd"
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "9cd41788-41aa-499e-8e50-13afc31cb0a3",
              "type": "if",
              "conditionRaw": "not story.has_manuscript_chapter(\"day2_chapter\")",
              "dialogue": [
                {
                  "id": "item-2955ca70-4d00-4b3c-8d7a-2428b4600f33",
                  "type": "call",
                  "destinationLabelId": "label-55af31a8-f543-4dc2-9964-64568d04da16"
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "not story.has_manuscript_chapter(\"day2_chapter\")"
            }
          ],
          "id": "item-995922f2-40ba-4e8e-8b49-914ea148b41f"
        },
        {
          "id": "item-a4319b87-d95a-41a0-892b-eaac1c8bca34",
          "type": "jump",
          "destinationLabelId": "label-d7e3d858-12f5-4c26-a43a-527505f43117"
        }
      ]
    },
    {
      "id": "label-7c82a081-0d53-46d1-947b-af1a3846df9d",
      "name": "day102_4_cora_sneaks_a_feel",
      "x": 12100,
      "y": 11007.5,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-d847a30a-37c1-4e1b-9a9e-d195b864df9a",
          "backgroundId": "bg_cora_desk_night"
        },
        {
          "type": "python_script",
          "code": "story.set_day2_night_action(\"indulge\")",
          "id": "item-65ace718-9231-4354-ae62-5423d6e33d89"
        },
        {
          "type": "python_script",
          "code": "apply_balanced_effect(\"transgressive\", intensity=\"standard\", witness=\"stern\")",
          "id": "item-d34e7cb8-c0da-416f-8807-960bc0557882"
        },
        {
          "id": "item-c84f21a2-0b07-46ab-80a0-d4fb5bc8ee18",
          "type": "dialogue",
          "characterId": null,
          "text": "I close the notebook."
        },
        {
          "id": "item-8d828b82-b07a-48b7-bbc8-07cd41f4b66d",
          "type": "dialogue",
          "characterId": null,
          "text": "The page has asked for discipline."
        },
        {
          "id": "item-ee9917c0-24b7-49f4-8785-702f3d957f78",
          "type": "dialogue",
          "characterId": null,
          "text": "I am tired of discipline."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "1b3536c3-d600-484a-8908-133c3a896a2a",
              "type": "if",
              "conditionRaw": "story.day2_contraband_state == \"stolen_wearing\"",
              "dialogue": [
                {
                  "id": "item-e9cb0e50-4fd7-49f9-bb22-aa25df295741",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I stand before the little mirror above the washstand."
                },
                {
                  "id": "item-50abc2af-07c4-4d87-b3f0-a21ed103ce08",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The uniform is plain. Severe. Designed to erase the body beneath it."
                },
                {
                  "id": "item-5aee477b-676c-4d9c-833f-e25f7aa4b12f",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I lift the hem only enough to confirm the secret is still mine."
                },
                {
                  "id": "item-1d1ea238-cf29-4b7b-ac31-334a57475b43",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The lace is ridiculous."
                },
                {
                  "id": "item-19d8985e-4dc6-4286-bfc8-fe8de8897700",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "That is part of its power."
                },
                {
                  "id": "item-7beca3b6-a69f-4563-8809-b4fb7e7fbffa",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The mirror gives back a maid."
                },
                {
                  "id": "item-37fb2875-38b9-4342-8aac-cb9bed85ce13",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The skin beneath disagrees."
                },
                {
                  "id": "item-cd9967a7-69bf-4e4a-94d6-a948f7b83643",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "A woman can scrub ash from a stranger's hearth while carrying a private scandal beneath her skirt."
                },
                {
                  "id": "item-4b3a0eeb-6b23-4010-a9f9-b5935873ac07",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "A woman can be unseen and still not be innocent."
                },
                {
                  "id": "item-45c7df42-33c3-40ed-bb05-95ac18134eff",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I lower the hem."
                },
                {
                  "id": "item-2f4718ac-ff74-4952-bf86-aa50ae66185b",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The maid returns."
                },
                {
                  "id": "item-090e230a-0d90-49c6-b642-8e94928e2810",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The witness remains."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day2_contraband_state == \"stolen_wearing\""
            },
            {
              "id": "fb92155f-8771-4cb8-90bd-2fbb31b8faf0",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-fe261956-7182-40b9-8560-daa161398c20",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "There is nothing in my hands tonight."
                },
                {
                  "id": "item-19714377-eaa2-4289-9f6a-6dd8ace06caf",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The dangerous thing is upstairs, hidden where I told Missy to hide it."
                },
                {
                  "id": "item-4d61ef1e-2df5-49ce-9ec2-23cc16500a50",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "That should make it less present."
                },
                {
                  "id": "item-d8c4f0c0-5fee-4fb9-975f-1cb00cb0e380",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "It does not."
                },
                {
                  "id": "item-95cc1ef4-b3e1-4a6c-ae15-5ee99aa01f0d",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I replay the afternoon until the room rearranges itself around Gideon's entrance."
                },
                {
                  "id": "item-00e25c2e-9488-431f-abb9-cee766084c64",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Vance's fury contained. Stern's authority paused. Missy's fear made useful."
                },
                {
                  "id": "item-ae0583cc-9b5e-4138-a542-49ebe3db75fe",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "And me, small enough to be overlooked until I was not."
                },
                {
                  "id": "item-8e43ba09-34b6-463b-9a47-8c95ac2d84dd",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "No chapter comes."
                },
                {
                  "id": "item-c5db2bce-9d0f-44f1-8ebc-55e459893fb0",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Only heat stored where ink should have gone."
                },
                {
                  "id": "item-4432e489-4aaf-4db5-a521-48d7a8293197",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Only the knowledge that I could have written and chose instead to keep feeling."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-28bb818e-4a67-44e7-a53d-05a3f10bfb9b"
        },
        {
          "id": "item-40818b51-fbf4-4e65-9b82-43611dadf2b5",
          "type": "dialogue",
          "characterId": null,
          "text": "When I finally sleep, the candle has burned lower than I meant to allow."
        },
        {
          "id": "item-9cddbf71-006f-4b02-935c-2b5c92eb969a",
          "type": "dialogue",
          "characterId": null,
          "text": "Waste has consequences."
        },
        {
          "id": "item-d015f610-d437-4396-b4a1-719281198ce1",
          "type": "jump",
          "destinationLabelId": "label-d7e3d858-12f5-4c26-a43a-527505f43117"
        }
      ]
    },
    {
      "id": "label-1bc4b5c8-8f78-49b3-bbd5-53b8b9afad8e",
      "name": "day103",
      "x": 12100,
      "y": 12307.5,
      "dialogue": [
        {
          "id": "item-8449cb7c-83c8-4cb3-8a18-5a816bf7841c",
          "type": "jump",
          "destinationLabelId": "label-d7e3d858-12f5-4c26-a43a-527505f43117"
        }
      ]
    },
    {
      "id": "label-d7e3d858-12f5-4c26-a43a-527505f43117",
      "name": "day103_morning",
      "x": 12500,
      "y": 11035,
      "dialogue": [
        {
          "type": "if_block",
          "branches": [
            {
              "id": "9161bb6b-2131-4e88-9bb9-205f607f7b44",
              "type": "if",
              "conditionRaw": "not story.has_manuscript_chapter(\"day1_chapter\")",
              "dialogue": [
                {
                  "id": "item-e272c3d5-251c-412b-8406-63c7298ef87b",
                  "type": "jump",
                  "destinationLabelId": "label-86bf649c-fdbf-4350-910e-a5ec2e9fd61c"
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "not story.has_manuscript_chapter(\"day1_chapter\")"
            }
          ],
          "id": "item-1397ca50-a752-4cbb-9bdd-9205344a0485"
        },
        {
          "type": "python_script",
          "code": "time_manager.set_current_day(3)",
          "id": "item-387c9da8-dbfb-4d65-b413-66dd3247160c"
        },
        {
          "type": "python_script",
          "code": "set_time_period(\"Morning\")",
          "id": "item-bf6375b7-ab8a-423b-945c-8d95e379f836"
        },
        {
          "id": "item-4f485f5d-4ba2-46cc-ac94-53caccaa3d94",
          "type": "call",
          "destinationLabelId": "label-db76af88-d5e1-4229-916f-381a3c1b4486"
        },
        {
          "id": "item-494aa35a-1144-4feb-8d87-4ccf744483cb",
          "type": "jump",
          "destinationLabelId": "label-4d4fcf8d-b631-4ab8-b08b-9b072cd32bf0"
        }
      ]
    },
    {
      "id": "label-db76af88-d5e1-4229-916f-381a3c1b4486",
      "name": "day103_morning_consequence_window",
      "x": 22100,
      "y": 12072.5,
      "dialogue": [
        {
          "id": "item-5813800b-d647-4747-a036-d6ce56c9f6eb",
          "type": "call",
          "destinationLabelId": "label-5f635f30-8ef3-4f17-80e7-4e5cde552ded"
        }
      ]
    },
    {
      "id": "label-4d4fcf8d-b631-4ab8-b08b-9b072cd32bf0",
      "name": "day103_1_servants_corridor",
      "x": 12900,
      "y": 10532.5,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "fade",
          "id": "item-bba2b6dc-6a49-4506-86e6-92d9a23d354c",
          "backgroundId": "bg_servants_corridor_morning"
        },
        {
          "id": "item-9b8000dd-8638-4062-ab9b-157ffd8a30f1",
          "type": "dialogue",
          "characterId": null,
          "text": "The bell rings before the sky has decided whether it means to become morning."
        },
        {
          "id": "item-beb2054d-26d1-4075-829d-e16bedd471ee",
          "type": "dialogue",
          "characterId": null,
          "text": "My body rises before my mind agrees."
        },
        {
          "id": "item-224cfc54-9698-4c2c-92a2-6d863d09a037",
          "type": "dialogue",
          "characterId": null,
          "text": "That is service, then: obedience practiced until it looks like instinct."
        },
        {
          "id": "item-d123edcd-4850-487e-84de-054e06f3b039",
          "type": "dialogue",
          "characterId": null,
          "text": "Yesterday has not ended."
        },
        {
          "id": "item-ab3461b4-a904-444b-a2ee-d3047545d666",
          "type": "dialogue",
          "characterId": null,
          "text": "It has merely put on a clean apron."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "40118e7c-9a24-41dd-884b-3e53fef3b6cd",
              "type": "if",
              "conditionRaw": "story.day2_tea_choice == \"predator\"",
              "dialogue": [
                {
                  "id": "item-bf994973-eb77-4e92-a789-5fbf77d7c210",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The hotel has found unpleasant work for me with suspicious efficiency."
                },
                {
                  "id": "item-0e3fe22c-4343-4874-a571-6f03dfca906b",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Crystal shattered in the Master Suite overnight. I spend the first hours on my knees, picking bright teeth from the rug."
                },
                {
                  "id": "item-019b165e-1b35-4ca8-8521-79448874f7ef",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Vance did not accuse me aloud."
                },
                {
                  "id": "item-5feae698-8601-425c-aeee-83a95db3ef89",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She did not need to."
                },
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"transgressive\", intensity=\"standard\", witness=\"vance\")",
                  "id": "item-0fed97b6-ece4-4cc8-ad91-147d0d17a4fb"
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day2_tea_choice == \"predator\""
            },
            {
              "id": "fa5c01f1-d53d-4f15-840e-f494b8ba154c",
              "type": "elif",
              "conditionRaw": "story.day2_tea_choice == \"prey\"",
              "dialogue": [
                {
                  "id": "item-2242b407-6670-4447-ac57-89694994eed3",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Stern performs a surprise inspection of the servants' quarters."
                },
                {
                  "id": "item-6f80412f-0666-47e8-b408-2e451a2372e3",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Drawers opened. Footlockers searched. Bedding turned back like bodies."
                },
                {
                  "type": "if_block",
                  "branches": [
                    {
                      "id": "8c5aca9a-6441-4e84-a6db-af705960ed20",
                      "type": "if",
                      "conditionRaw": "story.day2_contraband_state == \"stolen_wearing\"",
                      "dialogue": [
                        {
                          "id": "item-58c99c8a-0dbe-4071-afca-9b23bb398afd",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "The stolen lace is still beneath my uniform."
                        },
                        {
                          "id": "item-c3284e3d-84d0-4c36-b8d1-a56102fb9ea3",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "Stern's hands pass within inches of condemning me and find only folded cotton."
                        },
                        {
                          "id": "item-5e2b09e6-7bed-463b-8e87-9b35c63a3c77",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "I survive by the width of cloth."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      },
                      "rawCondition": "story.day2_contraband_state == \"stolen_wearing\""
                    },
                    {
                      "id": "a9923471-2db3-400b-9324-c7794f13296d",
                      "type": "else",
                      "conditionRaw": null,
                      "dialogue": [
                        {
                          "id": "item-681feb5c-647c-4e48-8784-0f0a8ffa6f7b",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "My belongings are too sparse to betray me."
                        },
                        {
                          "id": "item-b4430f3f-973f-4cf7-bc66-a30a5eba6b81",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "Stern finds nothing and resents the failure."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      }
                    }
                  ],
                  "id": "item-2b87e6c2-dc0a-4056-a44e-67ec6baecab5"
                },
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"transgressive\", intensity=\"standard\", witness=\"stern\")",
                  "id": "item-38f03e49-b4f6-4465-ad4c-5f0216f5425d"
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day2_tea_choice == \"prey\""
            },
            {
              "id": "9be0bfac-3d23-4596-bfac-25aa4f2024b6",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-7bfbdca4-3e49-462b-b116-4bd5f90c9d59",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Missy does not speak to me."
                },
                {
                  "id": "item-5c0736ea-b1ca-4cb0-988c-337b26f89828",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Not in the laundry. Not by the stair. Not when Stern sets us both to six hours of brass and silence."
                },
                {
                  "id": "item-b2bdd295-1c73-4855-b6e9-6befe3c46439",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Betrayal, I learn, is noisy only in plays. In life it polishes banisters until its wrists ache."
                },
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"observant\", intensity=\"standard\")",
                  "id": "item-482f3199-93b4-4c57-a661-193218e1dd37"
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-5e09ab4d-4ccc-4a14-8c62-ba61e685b911"
        },
        {
          "id": "item-65c3a8f2-163c-4dde-891b-1731787885df",
          "type": "dialogue",
          "characterId": null,
          "text": "By late morning, the corridor outside the guest wing feels less like architecture and more like a decision waiting to happen."
        },
        {
          "type": "choice",
          "options": [
            {
              "id": "1fa9f124-3766-4756-ad85-8b267e92ded6",
              "text": "Order. Safety in structure. [[Inspiration]]",
              "dialogue": [
                {
                  "id": "item-3e9420a6-328f-42b6-99e5-7e5b709e0073",
                  "type": "jump",
                  "destinationLabelId": "label-beb8150a-775f-4384-98d6-c18b1f11133c"
                }
              ]
            },
            {
              "id": "57efb16a-0979-4594-8a78-eb5ed5742b3d",
              "text": "Exposure. Safety in knowing the threat. [[Corruption]]",
              "dialogue": [
                {
                  "id": "item-e8c693cf-f18e-4a9b-9550-8fdc4e78c8e2",
                  "type": "jump",
                  "destinationLabelId": "label-a417f379-6852-4cbd-8adf-1ac7d356cb12"
                }
              ]
            }
          ],
          "id": "item-947a8d57-cc83-4d89-9d38-153132a5f584"
        },
        {
          "id": "item-901b291e-6d9b-4217-9dce-a1ac69e2bdf6",
          "type": "jump",
          "destinationLabelId": "label-beb8150a-775f-4384-98d6-c18b1f11133c"
        }
      ]
    },
    {
      "id": "label-beb8150a-775f-4384-98d6-c18b1f11133c",
      "name": "day103_1_corridor_insp_chain",
      "x": 13300,
      "y": 11820,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-cbf204d9-9b18-4069-8e49-f4f4a395f3fb",
          "backgroundId": "bg_servants_corridor_morning"
        },
        {
          "type": "python_script",
          "code": "story.set_day3_corridor_chain(\"inspiration\")",
          "id": "item-d83359d9-9c9a-40e7-97f3-90ebe4f1743c"
        },
        {
          "type": "python_script",
          "code": "apply_balanced_effect(\"creative\", intensity=\"standard\")",
          "id": "item-01354503-c287-41ae-8157-a3e0c1b022bb"
        },
        {
          "type": "python_script",
          "code": "apply_effects(stern_susp=-5)",
          "id": "item-a1658fa1-0748-43f7-8e56-ec3dbc448484"
        },
        {
          "id": "item-ea9ae6b4-7cb8-4d17-abd3-2abb191827e9",
          "type": "dialogue",
          "characterId": null,
          "text": "I count what can be counted."
        },
        {
          "id": "item-a006b109-6b40-4dc3-9bb8-7ddaf196d157",
          "type": "dialogue",
          "characterId": null,
          "text": "The bell-pull rhythm. The servant stair's turn. The distance between Stern's office and the Master Suite."
        },
        {
          "id": "item-c2814616-3e07-4d05-bf28-5afe32745929",
          "type": "dialogue",
          "characterId": null,
          "text": "A hotel is not a building. It is a machine for sorting bodies by permission."
        },
        {
          "id": "item-d879fc38-12e5-48dd-acb4-42c3beda0fe6",
          "type": "dialogue",
          "characterId": null,
          "text": "Guests move through carpet and light."
        },
        {
          "id": "item-367d392c-cb21-459d-86c4-a3c0e3fa1c7b",
          "type": "dialogue",
          "characterId": null,
          "text": "Servants move through steam and corners."
        },
        {
          "id": "item-cdc9516b-44d2-4949-b230-cb170e641566",
          "type": "dialogue",
          "characterId": null,
          "text": "Men like Mr. Locke move through both and call the passage natural."
        },
        {
          "id": "item-45e5e584-7cf9-402b-a348-9dd6a18964d5",
          "type": "dialogue",
          "characterId": null,
          "text": "That is the sentence I keep."
        },
        {
          "id": "item-b9db2267-93ac-4af6-8b1b-e553f0e69564",
          "type": "dialogue",
          "characterId": null,
          "text": "That is the one worth risking ink for."
        },
        {
          "id": "item-a01e4a57-98c6-461a-9f66-0f6ac44eacdf",
          "type": "dialogue",
          "characterId": null,
          "text": "A footman passes with a tea tray and nods toward the upper corridor."
        },
        {
          "id": "item-77a03ae1-acfa-4fc5-9655-e9b11c15e465",
          "type": "dialogue",
          "characterId": null,
          "text": "Mr. Locke has requested tea."
        },
        {
          "id": "item-5b537a4c-952b-47a9-a41d-cf50107350fb",
          "type": "dialogue",
          "characterId": null,
          "text": "Not from the kitchen."
        },
        {
          "id": "item-52e473be-4b64-4c56-b767-3e9a625f561c",
          "type": "dialogue",
          "characterId": null,
          "text": "From me."
        },
        {
          "id": "item-06718b27-9e0f-4dd8-8a6a-f1675f8e9c8a",
          "type": "call",
          "destinationLabelId": "label-3c8e33e7-7d1f-40eb-a088-bfc2554603f9"
        },
        {
          "id": "item-46c8d032-ff8d-4983-813c-e35d6479d0db",
          "type": "jump",
          "destinationLabelId": "label-5fc788d1-e522-49d4-84b4-07288a757257"
        }
      ]
    },
    {
      "id": "label-a417f379-6852-4cbd-8adf-1ac7d356cb12",
      "name": "day103_1_corridor_corr_chain",
      "x": 13300,
      "y": 10382.5,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-4f60f6f8-b1da-41e9-bb60-fc9707fb5a66",
          "backgroundId": "bg_servants_corridor_morning"
        },
        {
          "type": "python_script",
          "code": "story.set_day3_corridor_chain(\"corruption\")",
          "id": "item-de70052f-a076-40d7-a650-3b3d97867c33"
        },
        {
          "type": "python_script",
          "code": "apply_balanced_effect(\"transgressive\", intensity=\"standard\", witness=\"vance\")",
          "id": "item-70269a8d-1966-47f9-8baa-375dfbc12f89"
        },
        {
          "id": "item-12fabf8b-39e4-4785-a827-93f6a8c6c491",
          "type": "dialogue",
          "characterId": null,
          "text": "I should keep away from the guest wing."
        },
        {
          "id": "item-0e63da22-3f80-4bbe-945f-0d1fec91949e",
          "type": "dialogue",
          "characterId": null,
          "text": "Instead, I find errands."
        },
        {
          "id": "item-4545ae7e-aaeb-4a52-b87e-ee23527109ef",
          "type": "dialogue",
          "characterId": null,
          "text": "A towel that must be replaced. A coal scuttle that must be checked. A folded cloth that could be straighter if straightness mattered to anyone but me."
        },
        {
          "id": "item-5a8c26d8-b2ee-4bb3-8884-12ff4bda6e55",
          "type": "dialogue",
          "characterId": null,
          "text": "The truth is uglier: I want the door to open."
        },
        {
          "id": "item-4bab3a95-0153-4615-b8b7-3185495ee283",
          "type": "dialogue",
          "characterId": null,
          "text": "I want the room to notice me again."
        },
        {
          "id": "item-0b7d6ea4-cb23-4e47-8839-82aa0725a102",
          "type": "dialogue",
          "characterId": null,
          "text": "I want to know whether his silence yesterday was mercy, amusement, or appetite sharpened into manners."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "aef260ac-e8b8-4067-8970-80dbf62880c5",
              "type": "if",
              "conditionRaw": "story.day2_contraband_state == \"stolen_wearing\"",
              "dialogue": [
                {
                  "id": "item-a67aa2f3-5bfe-4a1c-b001-7cec691f52e9",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The stolen lace is no longer new against my skin."
                },
                {
                  "id": "item-2c7aa20c-78aa-4a98-8bd9-f6935ce9e7ac",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "That makes it worse."
                },
                {
                  "id": "item-e5ef24e1-9529-46ee-ab29-d1089690ab8b",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "A sin repeated starts pretending to be clothing."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day2_contraband_state == \"stolen_wearing\""
            }
          ],
          "id": "item-5c10697e-3f33-4bd2-be67-e843c48d36ef"
        },
        {
          "id": "item-d05ce881-e5c8-4005-a7a4-27cb6672d495",
          "type": "dialogue",
          "characterId": null,
          "text": "A footman appears at the bend of the corridor."
        },
        {
          "id": "item-52dd3630-42de-4887-aaaa-dfae524ec95a",
          "type": "dialogue",
          "characterId": null,
          "text": "He does not quite meet my eyes."
        },
        {
          "id": "item-728b4c12-0441-4b8e-aa73-8af285317f5e",
          "type": "dialogue",
          "characterId": null,
          "text": "That is how I know the order has travelled through more than one mouth."
        },
        {
          "id": "item-09464d28-814f-4853-93e3-458648e4a54b",
          "type": "dialogue",
          "characterId": null,
          "text": "Mr. Locke requests tea."
        },
        {
          "id": "item-7e756131-dc8a-48e7-bdcc-9a8c5048c32f",
          "type": "dialogue",
          "characterId": null,
          "text": "And he has asked that I bring it."
        },
        {
          "id": "item-442d1403-ba1d-485a-98be-550bd5bb4fc7",
          "type": "call",
          "destinationLabelId": "label-3c8e33e7-7d1f-40eb-a088-bfc2554603f9"
        },
        {
          "id": "item-403660a2-237e-4a3a-9148-a6ddca9c4e07",
          "type": "jump",
          "destinationLabelId": "label-5fc788d1-e522-49d4-84b4-07288a757257"
        }
      ]
    },
    {
      "id": "label-3c8e33e7-7d1f-40eb-a088-bfc2554603f9",
      "name": "day103_1_optional_character_chain",
      "x": 13700,
      "y": 11810,
      "dialogue": [
        {
          "id": "item-4acd4905-97ca-4575-bf78-80b8ba91aeb5",
          "type": "call",
          "destinationLabelId": "label-46e3ecc2-06e8-4066-9581-1bc3e9af5358"
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "43fb9762-3d30-4977-afd3-d25cc2df6b3c",
              "type": "if",
              "conditionRaw": "_penance_consumed",
              "dialogue": [],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "_penance_consumed"
            }
          ],
          "id": "item-2158b9fc-280c-4e4f-b461-b77c2b4bc573"
        },
        {
          "type": "choice",
          "options": [
            {
              "id": "2067be07-de3d-468a-8bc2-ae1d320a238b",
              "text": "Follow Stern's discipline before the guest wing wakes.",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "_chain_label = story.resolve_chain_label(\"stern\")",
                  "id": "item-f14b0eb4-7eb6-4fb9-86aa-0f4b3aa5c828"
                },
                {
                  "id": "item-89f1fc60-36ac-4886-935b-2ba20002b7b9",
                  "type": "call",
                  "destinationLabelId": ""
                }
              ]
            },
            {
              "id": "f81d1acd-2957-4259-9d5c-21a017a66c31",
              "text": "Find Missy while the house is still bruised from yesterday.",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "_chain_label = story.resolve_chain_label(\"missy\")",
                  "id": "item-66395b3c-4ea5-416a-baec-22679a9e3022"
                },
                {
                  "id": "item-88a143f2-347f-4b25-abfd-97fd9e1675b6",
                  "type": "call",
                  "destinationLabelId": ""
                }
              ]
            },
            {
              "id": "ba5df613-31ff-4096-acf2-989ca97275b8",
              "text": "Watch the Locke Suite door before the tea order becomes a summons.",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "_chain_label = story.resolve_chain_label(\"vance\")",
                  "id": "item-be1ebca0-8f70-4d52-ae03-7c59f378e686"
                },
                {
                  "id": "item-de3469f2-04a6-4804-a921-55e7c4a4f8e7",
                  "type": "call",
                  "destinationLabelId": ""
                }
              ]
            },
            {
              "id": "e7d9e8ec-331c-4fb0-ab88-b7f226784e43",
              "text": "Keep moving with the cart and give no one a reason.",
              "dialogue": [
                {
                  "type": "if_block",
                  "branches": [
                    {
                      "id": "cd762a32-da9e-4180-acb1-ca2c5f2dde22",
                      "type": "if",
                      "conditionRaw": "story.day3_corridor_chain == \"corruption\"",
                      "dialogue": [
                        {
                          "id": "item-f83fcfee-10f2-469d-b3db-a28a166ac4e4",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "Exposure promised safety."
                        },
                        {
                          "id": "item-e50f29c5-845c-4ebe-949e-3052e25871f1",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "Silence is cheaper until luncheon."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      },
                      "rawCondition": "story.day3_corridor_chain == \"corruption\""
                    },
                    {
                      "id": "b05668c1-e678-4e5c-9a59-593fcddfb3ab",
                      "type": "else",
                      "conditionRaw": null,
                      "dialogue": [
                        {
                          "id": "item-732118c2-29b4-4938-9ce2-6f1cdd96f1b6",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "Structure will not save me from Mr. Locke."
                        },
                        {
                          "id": "item-c8ce1927-cc7d-48b6-8025-84a8253cc8c1",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "It may keep my hands steady long enough to serve him tea without trembling."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      }
                    }
                  ],
                  "id": "item-8bb0164d-ef18-4c0c-8ca0-0f2ac64a8a73"
                },
                {
                  "id": "item-47263c13-ff7e-48b2-bc94-85fbd290daec",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I let the corridor pass without choosing a shadow."
                },
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"observant\", intensity=\"standard\")",
                  "id": "item-e1f44db2-0484-414a-94d7-f4fdf1ff1f9d"
                }
              ]
            }
          ],
          "id": "item-a2ad80da-27d1-484d-95a5-ec6812b6bc30"
        }
      ]
    },
    {
      "id": "label-5fc788d1-e522-49d4-84b4-07288a757257",
      "name": "day103_afternoon",
      "x": 13700,
      "y": 10402.5,
      "dialogue": [
        {
          "id": "item-b1402a17-f29b-4d25-97f9-a6fe202eab1c",
          "type": "jump",
          "destinationLabelId": "label-13151fdf-3820-4b60-ba6d-1718ec15a84e"
        }
      ]
    },
    {
      "id": "label-13151fdf-3820-4b60-ba6d-1718ec15a84e",
      "name": "day103_2_suite_gideon_tea",
      "x": 14100,
      "y": 10402.5,
      "dialogue": [
        {
          "type": "python_script",
          "code": "set_time_period(\"Afternoon\")",
          "id": "item-25a1ada8-bc37-47a0-9903-0a4f7b7ca9ab"
        },
        {
          "type": "scene",
          "layer": null,
          "transition": "fade",
          "id": "item-4c92e195-0845-4dbe-8492-d2c74d0ff508",
          "backgroundId": "bg_master_suite_day"
        },
        {
          "id": "item-d46c9cce-2477-4983-92a7-4e446d4a70de",
          "type": "show",
          "characterId": "gideon_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "gideon_sprite neutral"
        },
        {
          "id": "item-dc2a4d2c-b86f-42a5-96e2-edeb71647336",
          "type": "show",
          "characterId": "vance_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "vance_sprite kneeling_cowed_dressing_gown"
        },
        {
          "id": "item-8c9f7c82-648b-4904-a35c-3529b29471ad",
          "type": "dialogue",
          "characterId": null,
          "text": "The Master Suite receives me with the politeness of a trap."
        },
        {
          "id": "item-92edacbb-37d8-420d-9cda-92e658fbb35f",
          "type": "dialogue",
          "characterId": null,
          "text": "Vance sits at the vanity. Her hands are folded in her lap, but the pale curve of her shoulders trembles slightly as the heavy aroma of warm silk and French powder rises between us."
        },
        {
          "id": "item-d3a3d35a-6d4b-4bee-a2ee-c56d73322029",
          "type": "dialogue",
          "characterId": null,
          "text": "Mr. Locke stands behind her, not touching her, which somehow makes the whole room more aware of his hands."
        },
        {
          "id": "item-d58a6ed9-fc00-4847-97c0-f454ce5fd63b",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "You."
        },
        {
          "id": "item-d0e4bb6a-1b2c-4bd2-a0b7-7e2b012c6464",
          "type": "show",
          "characterId": "vance_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "vance_sprite kneeling_cowed_dressing_gown"
        },
        {
          "id": "item-060d3a9f-6e0a-484c-a247-41f8fd5f5831",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base"
        },
        {
          "id": "item-c6c2e3e5-dec8-4909-8dbc-d53b3858d031",
          "type": "show",
          "characterId": "vance_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "move",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "vance_sprite kneeling_cowed_dressing_gown"
        },
        {
          "id": "item-09777084-c5d3-4def-ac30-df4c476b32f3",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Sir."
        },
        {
          "id": "item-896dd701-15c6-4c70-8483-ded897f29523",
          "type": "dialogue",
          "characterId": null,
          "text": "I set the tea tray down."
        },
        {
          "id": "item-7f2cd832-f2e1-4302-9005-20a86b2358cc",
          "type": "dialogue",
          "characterId": null,
          "text": "The cups make a small sound against the table. Too loud, sharp in the afternoon quiet."
        },
        {
          "id": "item-50a0b049-4e02-42fb-9e68-ed9d6aa8fff2",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Ms. Vance's maid is indisposed. You will assist her."
        },
        {
          "id": "item-0bf7512b-9aee-484a-ae7f-8a4cf40155e2",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "That is not necessary."
        },
        {
          "id": "item-8621195a-50f2-49b1-9547-ba2c3c7677ac",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "It is not a negotiation."
        },
        {
          "id": "item-2c840fa7-4db1-4124-a7b5-6af3660f239b",
          "type": "dialogue",
          "characterId": null,
          "text": "Vance goes quiet."
        },
        {
          "id": "item-7680f21a-3880-4f13-8906-ffd329cce88e",
          "type": "dialogue",
          "characterId": null,
          "text": "Not defeated. Not exactly."
        },
        {
          "id": "item-57be1c37-d3bf-4e57-b2c6-3676cda3f9d4",
          "type": "dialogue",
          "characterId": null,
          "text": "Contained, her chest rising and falling beneath the fine lace of her collar."
        },
        {
          "id": "item-984e052b-56e5-40d3-9213-89feb994fefa",
          "type": "dialogue",
          "characterId": null,
          "text": "Mr. Locke lifts a silver-backed brush from the vanity and offers it to me, his fingers lingering briefly near mine as he releases it."
        },
        {
          "id": "item-27d07cc3-cec4-40e0-9d61-48b700bf6cc3",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Her hair. Carefully."
        },
        {
          "id": "item-d840a3aa-1f01-48d4-a775-0d78c2d49886",
          "type": "dialogue",
          "characterId": null,
          "text": "The mirror catches all three of us."
        },
        {
          "id": "item-77c00933-3aea-4ba4-bb8e-f7a82eb4ab02",
          "type": "dialogue",
          "characterId": null,
          "text": "Vance seated. Mr. Locke standing. Me behind her with a servant's hands and a writer's eyes mapping out the hot, silent geometry of the dressing room."
        },
        {
          "id": "item-0a7c8754-63af-4940-9dda-a6d8446132c2",
          "type": "jump",
          "destinationLabelId": "label-3fe3901f-5df2-40da-96bd-f835be73ea04"
        }
      ]
    },
    {
      "id": "label-3fe3901f-5df2-40da-96bd-f835be73ea04",
      "name": "day103_2_suite_cora_vs_gideon",
      "x": 14500,
      "y": 10402.5,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-ddbf9004-e400-4765-b6cb-f2428fc0d3d7",
          "backgroundId": "bg_master_suite_day"
        },
        {
          "id": "item-7e6070c9-1e14-4831-a58b-5154616b6044",
          "type": "show",
          "characterId": "gideon_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "gideon_sprite neutral"
        },
        {
          "id": "item-b6b9b508-9d19-4b09-99e4-19eeae737d47",
          "type": "show",
          "characterId": "vance_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "vance_sprite kneeling_cowed_dressing_gown"
        },
        {
          "id": "item-6c65066d-351c-4caa-9278-10f9e3fe31b9",
          "type": "dialogue",
          "characterId": null,
          "text": "I draw the brush through Vance's hair."
        },
        {
          "id": "item-740cf108-9655-43f3-b4f7-c4001a6db377",
          "type": "dialogue",
          "characterId": null,
          "text": "It is heavier than it looks. Softer than she is, sliding through my fingertips like warm copper wire."
        },
        {
          "id": "item-7f4f2b10-14fe-4661-a7df-7c9b423aba2a",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Tell me. Do you find Ms. Vance beautiful?"
        },
        {
          "id": "item-f41a78e1-a2ac-4ed9-b8aa-20768ccca57c",
          "type": "dialogue",
          "characterId": null,
          "text": "The brush pauses for less than a second."
        },
        {
          "id": "item-94b285aa-65e7-40f0-9929-c2537afd1e2d",
          "type": "dialogue",
          "characterId": null,
          "text": "Still enough for him to notice, his dark eyes meeting mine in the vanity glass."
        },
        {
          "id": "item-82370153-e359-4488-88c7-5ac4e3c3210f",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "Gideon."
        },
        {
          "id": "item-460cafe6-cea8-4f5f-b930-e9f3737b3162",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "I asked the girl."
        },
        {
          "id": "item-b3efef31-aa44-4203-99c6-175962cb8d00",
          "type": "dialogue",
          "characterId": null,
          "text": "The room tightens around the question, heavy and thick with a sudden, physical charge."
        },
        {
          "id": "item-2a58742b-e490-444e-a523-6383c9628e0b",
          "type": "dialogue",
          "characterId": null,
          "text": "He has not summoned me for tea."
        },
        {
          "id": "item-195c9604-3e5c-4445-ae53-34f1adfa9d83",
          "type": "dialogue",
          "characterId": null,
          "text": "He has summoned me for position."
        },
        {
          "type": "choice",
          "options": [
            {
              "id": "e1f66d4d-770b-43ee-ac16-40c52e856436",
              "text": "Answer like a craftsman. Describe what is visible, not what is wanted. [[Inspiration]]",
              "dialogue": [
                {
                  "id": "item-f2c11f35-4f3c-4862-baab-c935e33adea4",
                  "type": "jump",
                  "destinationLabelId": "label-58d8c722-1829-404d-aa5c-c63eca1fac8d"
                }
              ]
            },
            {
              "id": "777e41d3-2bf7-42e6-bc28-54b25b279544",
              "text": "Let him see that I understand the charge in the room. [[Corruption]]",
              "dialogue": [
                {
                  "id": "item-b8bf5bc8-70e3-4cad-bacd-ade5f80793b8",
                  "type": "jump",
                  "destinationLabelId": "label-c3038985-fcd3-4486-90b0-561f798ed27c"
                }
              ]
            },
            {
              "id": "82ce19b9-2efc-4362-ae76-51b2c40cb9b0",
              "text": "Retreat into the maid's mask. Drop the brush. [[Suspicion + Inspiration]]",
              "dialogue": [
                {
                  "id": "item-c201ecc2-d117-4d86-b266-6d7ed2309fcd",
                  "type": "jump",
                  "destinationLabelId": "label-567c5d9d-77ba-4836-ab8c-62edbc223c8b"
                }
              ]
            }
          ],
          "id": "item-b83eab8b-3f3b-4b93-8372-e10ea5490e30"
        },
        {
          "id": "item-34baae38-ac74-4dc1-a749-5cad62242d8c",
          "type": "jump",
          "destinationLabelId": "label-58d8c722-1829-404d-aa5c-c63eca1fac8d"
        }
      ]
    },
    {
      "id": "label-58d8c722-1829-404d-aa5c-c63eca1fac8d",
      "name": "day103_2_cora_vs_gideon_insp",
      "x": 14900,
      "y": 11755,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-737fe926-f722-4ea5-bbe7-6e894558c3c2",
          "backgroundId": "bg_master_suite_day"
        },
        {
          "id": "item-22c397ee-3551-432b-89af-ab0799bd1906",
          "type": "show",
          "characterId": "gideon_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "gideon_sprite neutral"
        },
        {
          "id": "item-b1df2e08-33cb-4079-a2b2-0528e8d6e6d7",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base"
        },
        {
          "id": "item-a2a57dee-334c-415c-8868-970526904359",
          "type": "show",
          "characterId": "vance_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "vance_sprite kneeling_cowed_dressing_gown"
        },
        {
          "type": "python_script",
          "code": "story.set_day3_brush_choice(\"predator\")",
          "id": "item-c4f54529-5591-4ffa-a867-07bcfc09f2aa"
        },
        {
          "type": "python_script",
          "code": "apply_archetype_edge(\"predator\", 1)",
          "id": "item-ed8cc63e-a250-4ca8-9e49-e144deae14b4"
        },
        {
          "type": "python_script",
          "code": "apply_balanced_effect(\"creative\", intensity=\"standard\")",
          "id": "item-b4f14957-62fb-45a0-bfb1-8855a08ec8ed"
        },
        {
          "id": "item-f9f99f67-7538-445d-88ee-f52153fdd512",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Yes, Sir."
        },
        {
          "id": "item-31cc72d4-0f0b-4155-b950-b53f061d523d",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "That is not an answer."
        },
        {
          "id": "item-d650f111-82e1-4353-a1d6-510b8eb7683e",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Her face holds anger better than softness. It gives the bones more purpose."
        },
        {
          "id": "item-5dc68eed-7007-4827-8510-8f0f260c159f",
          "type": "dialogue",
          "characterId": null,
          "text": "Vance inhales, her throat flushing a deep pink under the glass."
        },
        {
          "id": "item-384ee671-a183-4ad2-a3ce-c79f65d3e861",
          "type": "dialogue",
          "characterId": null,
          "text": "The brush keeps moving, rhythmic, precise."
        },
        {
          "id": "item-11f78d35-df46-42b3-868e-b9d3607d030d",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "And her weakness?"
        },
        {
          "id": "item-376529f0-448b-4cb3-9a49-5dd9a05e8932",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "She lets other people see when they have wounded her."
        },
        {
          "id": "item-f3af90df-91f5-4cd9-a6c0-9221817c3ec4",
          "type": "dialogue",
          "characterId": null,
          "text": "The sentence leaves my mouth dressed as observation."
        },
        {
          "id": "item-8253d3cb-5ef2-4315-bf88-c04fe2b9ed7e",
          "type": "dialogue",
          "characterId": null,
          "text": "It lands as cruelty."
        },
        {
          "id": "item-f2a409dd-bd45-4b2f-a5eb-65402f3494ca",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "You insolent—"
        },
        {
          "id": "item-92531f04-e668-4e43-957e-18d4369cd424",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "No."
        },
        {
          "id": "item-dc6c315b-4003-41e0-8f29-a11995c74f09",
          "type": "dialogue",
          "characterId": null,
          "text": "Vance stops, her chest heaving as she clutches the vanity edge."
        },
        {
          "id": "item-10a3b5a3-bf62-4a4f-b1ec-377801c92228",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "She answered well."
        },
        {
          "id": "item-5b84cb16-aab4-4885-867b-b8c55cb68ebd",
          "type": "dialogue",
          "characterId": null,
          "text": "In the mirror, his eyes lock onto mine with a cold, sharp interest."
        },
        {
          "id": "item-377cd650-b492-4336-bf6f-966700a148ee",
          "type": "dialogue",
          "characterId": null,
          "text": "Approval should not feel like a hand at the back of the neck, warm and heavy."
        },
        {
          "id": "item-76a0d009-5fd6-4d7e-b4fe-e29b6dbc7591",
          "type": "jump",
          "destinationLabelId": "label-a27e7291-2fa8-4149-966a-bbe24926e584"
        }
      ]
    },
    {
      "id": "label-c3038985-fcd3-4486-90b0-561f798ed27c",
      "name": "day103_2_cora_vs_gideon_corr",
      "x": 14900,
      "y": 10310,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-fe2ddb5c-02a7-43f3-94e3-4a7e9a209a84",
          "backgroundId": "bg_master_suite_day"
        },
        {
          "id": "item-5b523ed0-5b89-4ae4-978e-acf72597d95c",
          "type": "show",
          "characterId": "gideon_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "gideon_sprite neutral"
        },
        {
          "id": "item-984dff58-7866-40e6-865b-aab6392d1fdd",
          "type": "show",
          "characterId": "vance_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "vance_sprite submissive"
        },
        {
          "type": "python_script",
          "code": "story.set_day3_brush_choice(\"prey\")",
          "id": "item-5bb868e0-bbae-49d6-a003-be86d8417bbd"
        },
        {
          "type": "python_script",
          "code": "apply_archetype_edge(\"prey\", 1)",
          "id": "item-351c221d-546f-482e-99b0-44f2a1e3f0a2"
        },
        {
          "type": "python_script",
          "code": "apply_balanced_effect(\"transgressive\", intensity=\"standard\", witness=\"vance\")",
          "id": "item-ac70441a-11ec-40b2-b12d-127cec1c867d"
        },
        {
          "id": "item-b9d536d4-4c9b-49d0-b2fb-4409a8a6dd10",
          "type": "dialogue",
          "characterId": null,
          "text": "I look up into the mirror."
        },
        {
          "id": "item-08265c08-e910-446d-a761-682bb56d4bbc",
          "type": "dialogue",
          "characterId": null,
          "text": "Not at Vance."
        },
        {
          "id": "item-dd4af07d-0c88-4edb-997f-edb63e2a30ad",
          "type": "dialogue",
          "characterId": null,
          "text": "At him."
        },
        {
          "id": "item-be6ccb79-f520-49f0-849a-d47dcd83d78e",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base"
        },
        {
          "id": "item-d6a88a5a-7dcd-421a-a2b2-0c858d3829c0",
          "type": "show",
          "characterId": "vance_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "move",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "vance_sprite submissive"
        },
        {
          "id": "item-6f4c5246-6eb1-4085-b908-bb84ced65c20",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Yes, Sir."
        },
        {
          "id": "item-c9f2bc9c-c6f0-4fe0-870a-30ec478acef1",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Why?"
        },
        {
          "id": "item-991c3db5-6544-4170-913c-cd8c688bcfb6",
          "type": "dialogue",
          "characterId": null,
          "text": "The question is too close to the thing beneath the thing, the physical weight in the air."
        },
        {
          "id": "item-89cdbcf6-88eb-4d48-b69d-1123d2a21878",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Because she is trying not to feel what everyone in the room can see."
        },
        {
          "id": "item-f6dbf6d3-aed0-4dd7-9afe-8d02a636def8",
          "type": "dialogue",
          "characterId": null,
          "text": "Vance goes completely rigid beneath the brush, her red hair pooling over my knuckles."
        },
        {
          "id": "item-58d1766b-c357-44c7-b593-44c822f14d3c",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "And what can everyone see?"
        },
        {
          "id": "item-dfc3c25b-3141-48e2-96e4-0cbdfc61f6cb",
          "type": "dialogue",
          "characterId": null,
          "text": "My face warms, the heat spreading under the collar of my uniform."
        },
        {
          "id": "item-3dfe7a41-2f86-4e7b-8b8a-cac50d49a502",
          "type": "dialogue",
          "characterId": null,
          "text": "I let it."
        },
        {
          "id": "item-6fd4723b-d792-4e4b-9959-9055df5db542",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "That she has been corrected."
        },
        {
          "id": "item-b4c4ef67-eeda-46b7-9222-93f2692bfa3c",
          "type": "dialogue",
          "characterId": null,
          "text": "The word stays in the mirror between us, heavy, silent, and thick with implication."
        },
        {
          "id": "item-0f26cf95-58f1-444d-9f3a-8f2ce207842a",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Corrected."
        },
        {
          "id": "item-925a06c0-e3a8-4659-bc74-d98b478fa822",
          "type": "dialogue",
          "characterId": null,
          "text": "He tastes it, then smiles without showing his teeth, his gaze dropping slowly to my hands."
        },
        {
          "id": "item-99f4882b-bf15-4a14-a372-e3d2b0a908af",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "A precise servant is a rare thing."
        },
        {
          "id": "item-92683020-cebc-4b02-b758-7492dd7e0c11",
          "type": "dialogue",
          "characterId": null,
          "text": "I have shown too much."
        },
        {
          "id": "item-2fc51954-d8f8-43ea-bb1a-eb71f556b8b7",
          "type": "dialogue",
          "characterId": null,
          "text": "Worse: he knows I meant to, and he enjoys the transgression."
        },
        {
          "id": "item-3c07657a-8aad-49a3-a1b9-b07a5dd22c14",
          "type": "jump",
          "destinationLabelId": "label-a27e7291-2fa8-4149-966a-bbe24926e584"
        }
      ]
    },
    {
      "id": "label-567c5d9d-77ba-4836-ab8c-62edbc223c8b",
      "name": "day103_2_cora_vs_gideon_ghost",
      "x": 14900,
      "y": 10180,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-4e813ae2-89b9-46dd-8bd1-2396893dc112",
          "backgroundId": "bg_master_suite_day"
        },
        {
          "id": "item-24d2fcc7-f1bc-4a69-8424-239517f00e83",
          "type": "show",
          "characterId": "gideon_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "gideon_sprite neutral"
        },
        {
          "id": "item-bd9a2a76-160a-4dfe-bc18-92579ca508d3",
          "type": "show",
          "characterId": "vance_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "vance_sprite submissive"
        },
        {
          "type": "python_script",
          "code": "story.set_day3_brush_choice(\"ghost\")",
          "id": "item-ed31a46b-de0c-441e-b934-c49ba9a4c5ab"
        },
        {
          "type": "python_script",
          "code": "apply_archetype_edge(\"ghost\", 1)",
          "id": "item-d0ffaa4c-3510-44a2-aacf-7754e96aaf61"
        },
        {
          "type": "python_script",
          "code": "apply_balanced_effect(\"transgressive\", intensity=\"standard\", witness=\"vance\")",
          "id": "item-6bdde744-53b1-4fc3-b6ff-c2e542d87a17"
        },
        {
          "id": "item-a3ba5c98-87e3-41fe-8f58-5b0dbfa4d2b2",
          "type": "dialogue",
          "characterId": null,
          "text": "The brush catches in a knot."
        },
        {
          "id": "item-fd8ce32a-79c7-4f5a-a8ca-bf471eac5f74",
          "type": "dialogue",
          "characterId": null,
          "text": "Vance flinches."
        },
        {
          "id": "item-b95b18d1-4a57-4eb1-acbd-7e62bb4e83a2",
          "type": "dialogue",
          "characterId": null,
          "text": "His eyes lift to the mirror, sharp and commanding."
        },
        {
          "id": "item-9f9a22bb-7676-4443-8c1b-78e7b578c088",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Carefully, I said."
        },
        {
          "id": "item-82f528a4-6116-4ff8-a099-7835ac93df98",
          "type": "dialogue",
          "characterId": null,
          "text": "My fingers fail me on command."
        },
        {
          "id": "item-2b2bd1d1-1743-4f32-87b7-07e2908fd540",
          "type": "dialogue",
          "characterId": null,
          "text": "The brush slips and strikes the floor with a bright, silver crack."
        },
        {
          "id": "item-978d45ba-9d30-487a-95f8-8a4e7ef36371",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base"
        },
        {
          "id": "item-50fef3bd-5259-42b4-a907-e27693c53c1e",
          "type": "show",
          "characterId": "vance_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "move",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "vance_sprite submissive"
        },
        {
          "id": "item-1c7b9784-36dd-4a52-8afd-9d1f9fca3a06",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Forgive me, Sir."
        },
        {
          "id": "item-aab4046b-d7fa-4837-89c5-72667defd203",
          "type": "dialogue",
          "characterId": null,
          "text": "I drop immediately to retrieve it, my uniform skirt catching against the leather of Gideon's boots."
        },
        {
          "id": "item-19f15809-e928-4ef1-b6dc-20f51740bc95",
          "type": "dialogue",
          "characterId": null,
          "text": "A terrified maid. Nothing more."
        },
        {
          "id": "item-81186075-363a-430f-b0d5-91111b7b3b94",
          "type": "dialogue",
          "characterId": null,
          "text": "From the floor, I see the room differently, the proximity making my breath shallow: Vance's clenched slipper, Mr. Locke's polished boot inches from my knee, the hem of my own uniform trembling."
        },
        {
          "id": "item-e9a79bc6-2a28-4ab3-bcc4-f2bdc420d85c",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Clumsy."
        },
        {
          "id": "item-a1d860ef-bfa7-4bfe-89f0-2cfa64427bc8",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Yes, Sir."
        },
        {
          "id": "item-b98b6baa-8c5f-4488-9eec-a473aaf901c1",
          "type": "dialogue",
          "characterId": null,
          "text": "Let him have the word."
        },
        {
          "id": "item-f5a61503-cee4-422a-8c3c-41c14bdeafea",
          "type": "dialogue",
          "characterId": null,
          "text": "I take the angle and store the details."
        },
        {
          "id": "item-7276ecf9-fa9e-47e3-9e88-189346766d3f",
          "type": "jump",
          "destinationLabelId": "label-a27e7291-2fa8-4149-966a-bbe24926e584"
        }
      ]
    },
    {
      "id": "label-a27e7291-2fa8-4149-966a-bbe24926e584",
      "name": "day103_2_suite_gideon_beat",
      "x": 15300,
      "y": 10375,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-a6975cd1-e1a5-4f73-8bd0-2f1219e96c90",
          "backgroundId": "bg_master_suite_day"
        },
        {
          "id": "item-70c9dba0-ad10-4ceb-b8da-7f6318214b31",
          "type": "show",
          "characterId": "gideon_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "gideon_sprite dominant"
        },
        {
          "id": "item-2182dea9-20c9-48dd-9425-b6266bf6f181",
          "type": "show",
          "characterId": "vance_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "vance_sprite neutral_dressing_gown"
        },
        {
          "id": "item-71d3ef7e-4a98-4949-aac2-92d84b6c9d7a",
          "type": "dialogue",
          "characterId": null,
          "text": "Vance is dismissed behind the dressing screen before the brushing is properly finished."
        },
        {
          "id": "item-6851e49a-2084-4da3-8e71-2eb23a5102f5",
          "type": "dialogue",
          "characterId": null,
          "text": "She goes because he expects her to go, her silk rustling in the dark corner."
        },
        {
          "id": "item-7839334c-b1e4-4820-b890-fb44eb5772e8",
          "type": "dialogue",
          "characterId": null,
          "text": "The screen closes with a sound softer than a door and somehow less merciful."
        },
        {
          "id": "item-20991f95-bdc6-4e71-a38e-0d5440a42e7d",
          "type": "dialogue",
          "characterId": null,
          "text": "I reach for the tea tray."
        },
        {
          "id": "item-32a36201-5118-4f90-bda3-4da4d50ab765",
          "type": "dialogue",
          "characterId": null,
          "text": "Mr. Locke steps into my path, his chest almost touching mine."
        },
        {
          "id": "item-8af0a5a2-6b43-4b04-8c22-105df67385b6",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "No. Leave it."
        },
        {
          "id": "item-983ebc36-e6ee-4f9c-a924-715060a62198",
          "type": "dialogue",
          "characterId": null,
          "text": "He is close enough now that I can see the faint mark where his collar presses his throat. I can smell his tobacco and clean linen."
        },
        {
          "id": "item-87128d8d-700d-4e58-8d3d-d1fd9517a492",
          "type": "dialogue",
          "characterId": null,
          "text": "Human, then."
        },
        {
          "id": "item-b6c04ec1-8557-489b-becf-db15272d7476",
          "type": "dialogue",
          "characterId": null,
          "text": "Inconvenient."
        },
        {
          "id": "item-5a548315-7bf9-4f49-99fa-301b56cea884",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "You observe too much."
        },
        {
          "id": "item-45d4da19-1cad-400a-8794-53401c78ece6",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base"
        },
        {
          "id": "item-0bf6dc18-a65f-4e26-8652-64d5aedd1129",
          "type": "show",
          "characterId": "gideon_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "move",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "gideon_sprite dominant"
        },
        {
          "id": "item-4491e208-67b4-4901-8186-51fd697b9723",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "I try to be useful, Sir."
        },
        {
          "id": "item-e12a913d-7519-4ca7-9853-1e37134012e1",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Useful girls do not stare through keyholes."
        },
        {
          "id": "item-deafdb32-37b3-4f2d-8690-4ba16985e997",
          "type": "dialogue",
          "characterId": null,
          "text": "There it is."
        },
        {
          "id": "item-30381f74-ea5a-43b1-9f4e-b94523626bef",
          "type": "dialogue",
          "characterId": null,
          "text": "Not accusation. Confirmation."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "8da2d2f0-2795-4617-b5eb-2d788cfa8dcc",
              "type": "if",
              "conditionRaw": "story.day1_corridor_state == \"prey\"",
              "dialogue": [
                {
                  "id": "item-fd5b78f7-2dfa-45f6-b3a6-723395880158",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "My stomach drops. Yesterday's floorboard. His eyes at the door. Not nearly. Not almost. He knew."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day1_corridor_state == \"prey\""
            },
            {
              "id": "a6a0fced-a9c4-434c-96aa-3aec5cdc9171",
              "type": "elif",
              "conditionRaw": "story.day1_corridor_state == \"predator\"",
              "dialogue": [
                {
                  "id": "item-39b35bed-bffe-4eba-a182-b4b07794a179",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Missy opened the door. I stood back. It did not matter. Mr. Locke is the sort of man who notices the person who benefits."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day1_corridor_state == \"predator\""
            },
            {
              "id": "4b5f85e6-2531-414b-ad90-179a77561cc8",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-71fa24fe-5bed-4769-9423-559354ed5f91",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I walked away. I did. But perhaps listening leaves a shape of its own, a silent tension."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-ecb56210-66f3-4af3-abe6-4dccf6dd130a"
        },
        {
          "id": "item-c82bb876-0867-4a40-8aca-6b24d645aef1",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "You also lie better than your references suggest."
        },
        {
          "id": "item-dd615085-106b-4bef-85df-b7d6b20ae92c",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Sir?"
        },
        {
          "id": "item-57cb6197-e477-4068-87a8-d046bcd554dc",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Do not spoil this by pretending stupidity."
        },
        {
          "id": "item-d10f6fdf-2958-418c-8b1e-d7de0fa35105",
          "type": "dialogue",
          "characterId": null,
          "text": "The words should frighten me."
        },
        {
          "id": "item-a1c419ac-d08a-432c-90eb-1ad1833f6928",
          "type": "dialogue",
          "characterId": null,
          "text": "They do. My heart hammer-strokes against my ribs."
        },
        {
          "id": "item-dd176b7f-f7e6-44e8-8018-54ea598a6b8e",
          "type": "dialogue",
          "characterId": null,
          "text": "They also unlock something warm."
        },
        {
          "id": "item-06b79504-02e1-46fe-9e2a-f7ed130b822f",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Tonight. Nine o'clock. You will bring tea. Alone."
        },
        {
          "id": "item-0c568618-0494-48bb-a19a-075cfe78401c",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Miss Stern assigns the evening duties, Sir."
        },
        {
          "id": "item-bed5b78b-33ee-4eb8-842c-1452dad1594f",
          "type": "dialogue",
          "characterId": null,
          "text": "The rebellion is microscopic, a small intake of breath."
        },
        {
          "id": "item-6d5639fc-a947-459f-94d8-08431a026fa4",
          "type": "dialogue",
          "characterId": null,
          "text": "His attention sharpens anyway, his dark eyes narrowing with intense amusement."
        },
        {
          "id": "item-933079be-c513-4aa2-aa9a-0d3647196feb",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Then Miss Stern will have assigned correctly."
        },
        {
          "id": "item-17ceba04-6391-455b-b8cc-eedcf20e1511",
          "type": "dialogue",
          "characterId": null,
          "text": "He opens the door behind me."
        },
        {
          "id": "item-4e98aa77-199c-4a71-97d8-a4c1214c7ddb",
          "type": "dialogue",
          "characterId": null,
          "text": "Dismissal. Invitation. Threat."
        },
        {
          "id": "item-7dfca164-3d58-4a15-ac9f-747a233c634b",
          "type": "dialogue",
          "characterId": null,
          "text": "All the same movement."
        },
        {
          "id": "item-c12621be-830d-4f93-a908-f59c6519b25c",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Go."
        },
        {
          "id": "item-655188d1-9340-4cea-b0b6-d2c583b7decb",
          "type": "jump",
          "destinationLabelId": "label-79aafb64-e9b7-41d2-8058-76b446b28569"
        }
      ]
    },
    {
      "id": "label-7e7c17eb-2bb1-4612-b5d1-3f2ddb0aa6e0",
      "name": "day103_evening",
      "x": 15300,
      "y": 11727.5,
      "dialogue": [
        {
          "id": "item-3f67b130-ed0c-4651-943a-88de099c76dd",
          "type": "jump",
          "destinationLabelId": "label-79aafb64-e9b7-41d2-8058-76b446b28569"
        }
      ]
    },
    {
      "id": "label-ec5b76d5-c78e-469d-b78d-8b973cba1669",
      "name": "day103_evening_consequence_window",
      "x": 22100,
      "y": 11812.5,
      "dialogue": [
        {
          "id": "item-53fa37ad-fe2e-4d91-a94f-647f796f545b",
          "type": "call",
          "destinationLabelId": "label-5f635f30-8ef3-4f17-80e7-4e5cde552ded"
        },
        {
          "id": "item-ddcd3121-10f3-4210-8fcd-64ba0233b6a0",
          "type": "call",
          "destinationLabelId": "label-7d0ab68c-82c3-423b-a677-a442c420ec43"
        }
      ]
    },
    {
      "id": "label-79aafb64-e9b7-41d2-8058-76b446b28569",
      "name": "day103_3_bedroom_cora_frantic_writing_event",
      "x": 15700,
      "y": 10505,
      "dialogue": [
        {
          "type": "python_script",
          "code": "set_time_period(\"Evening\")",
          "id": "item-ca3462cc-d978-4779-abf9-83a70a29ad23"
        },
        {
          "id": "item-83cce11d-f568-4456-bd3d-fe175a3680c6",
          "type": "call",
          "destinationLabelId": "label-ec5b76d5-c78e-469d-b78d-8b973cba1669"
        },
        {
          "type": "scene",
          "layer": null,
          "transition": "fade",
          "id": "item-e507e67a-1b66-4a6b-9bec-731e7ff9d392",
          "backgroundId": "bg_servants_quarters_dusk"
        },
        {
          "id": "item-bf119ea9-c117-42ae-b461-284b3561d087",
          "type": "dialogue",
          "characterId": null,
          "text": "I make it back to my room without dropping the tray."
        },
        {
          "id": "item-5b17ce2c-ebfe-49df-849b-12d92245a989",
          "type": "dialogue",
          "characterId": null,
          "text": "I do not remember the corridor. I remember only his voice, low and physical."
        },
        {
          "id": "item-e0ab9c97-37ac-4b7d-88ed-20ce7fd286de",
          "type": "dialogue",
          "characterId": null,
          "text": "I remember his sentence."
        },
        {
          "id": "item-8962974b-5f6c-4c33-8a09-e70e7154efb6",
          "type": "dialogue",
          "characterId": null,
          "text": "Do not spoil this by pretending stupidity."
        },
        {
          "id": "item-c37a98ca-bd14-4305-a76f-8770a35789d5",
          "type": "dialogue",
          "characterId": null,
          "text": "The words crawl under the door with me."
        },
        {
          "type": "python_script",
          "code": "show_ledger_ui()",
          "id": "item-a6c15782-45a7-420a-9d33-43daed720ff1"
        },
        {
          "id": "item-8e70bc55-7d47-4183-93ce-94d3aeb60af8",
          "type": "dialogue",
          "characterId": null,
          "text": "I have less than an hour before nine."
        },
        {
          "id": "item-fc8fa468-9277-42b8-91c7-00c82b0a0125",
          "type": "dialogue",
          "characterId": null,
          "text": "Enough time to prepare."
        },
        {
          "id": "item-a3bf5485-2b31-41c8-95e4-310c867abf95",
          "type": "dialogue",
          "characterId": null,
          "text": "Enough time to write."
        },
        {
          "id": "item-870926f0-a7a6-4a63-8288-f9d69ea292a1",
          "type": "dialogue",
          "characterId": null,
          "text": "Not enough time to be sane about either."
        },
        {
          "type": "choice",
          "options": [
            {
              "id": "302ed12b-5bfb-422d-b419-82cf1296c8a7",
              "text": "Write with whatever time is left. [[Frantic Write]]",
              "dialogue": [
                {
                  "id": "item-b04762cf-aa99-45ab-9b4d-f3f9510365ba",
                  "type": "jump",
                  "destinationLabelId": "label-e1e21088-d4a9-4907-86d9-5c7178c78af1"
                }
              ]
            },
            {
              "id": "cf08756f-f38e-46f2-8355-edc1f3277559",
              "text": "Prepare my uniform and mask. [[Prepare Mask]]",
              "dialogue": [
                {
                  "id": "item-2d7c6a8f-23ba-4833-a38e-82e2eeff8ed8",
                  "type": "jump",
                  "destinationLabelId": "label-11bf99b7-d47e-4f9b-8de6-9f4100cf1839"
                }
              ]
            },
            {
              "id": "63dde29b-6eac-43f5-a8a6-c60cfb77aa64",
              "text": "Re-read the dangerous words. [[Indulge Words]]",
              "dialogue": [
                {
                  "id": "item-16b4f88c-c332-4c7e-93c9-2b7c4332521b",
                  "type": "jump",
                  "destinationLabelId": "label-60c90402-5a99-49f9-9b6c-bed885a16fbd"
                }
              ]
            }
          ],
          "id": "item-fd44e85e-569b-4e76-9d77-e3acbf9dbe54"
        },
        {
          "id": "item-69ee9831-23de-4e5c-b672-e32e6d0db388",
          "type": "jump",
          "destinationLabelId": "label-e1e21088-d4a9-4907-86d9-5c7178c78af1"
        }
      ]
    },
    {
      "id": "label-e1e21088-d4a9-4907-86d9-5c7178c78af1",
      "name": "day103_3_frantic_write",
      "x": 16100,
      "y": 11560,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-ce0c72c6-057e-4bb3-8c55-49d4335596c1",
          "backgroundId": "bg_cora_desk_night"
        },
        {
          "type": "python_script",
          "code": "story.set_day3_twilight_action(\"frantic_write\")",
          "id": "item-439a30ec-ca39-493f-9655-35340383608b"
        },
        {
          "type": "python_script",
          "code": "apply_balanced_effect(\"creative\", intensity=\"standard\")",
          "id": "item-487d5e94-3442-42c5-a07c-078dd2ba7d6f"
        },
        {
          "id": "item-dae09093-3804-48ee-9e36-90d47311b2b3",
          "type": "dialogue",
          "characterId": null,
          "text": "I light the candle too early and waste wax with both hands."
        },
        {
          "id": "item-81806679-c548-492f-80a2-398caaded903",
          "type": "dialogue",
          "characterId": null,
          "text": "No time for neatness. No time for the ledger's polite categories."
        },
        {
          "id": "item-5082b416-a033-491e-934e-4fcc1879e28b",
          "type": "dialogue",
          "characterId": null,
          "text": "I write as if the door is already opening."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "fb95f733-0a56-4b9c-81ae-e13abe7f6e42",
              "type": "if",
              "conditionRaw": "story.day3_brush_choice == \"predator\"",
              "dialogue": [
                {
                  "id": "item-41017c54-d7fe-4f33-9e34-c10a2ea1c25f",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "A maid stands behind a lady with a brush in her hand and discovers that service can be a weapon if the room is arranged correctly."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day3_brush_choice == \"predator\""
            },
            {
              "id": "22c0cf35-4365-4cdb-96bd-23a51c976268",
              "type": "elif",
              "conditionRaw": "story.day3_brush_choice == \"prey\"",
              "dialogue": [
                {
                  "id": "item-cb78f82a-d153-4fc3-9578-7a9d7b323854",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "A maid looks into a mirror and lets the dangerous man see the exact place where fear becomes want."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day3_brush_choice == \"prey\""
            },
            {
              "id": "f214fb25-787c-450d-93e8-b42afb5fd3ff",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-bd52bc14-2d6f-49e1-b1c4-188214598ad5",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "A maid drops a silver brush and learns that the floor has its own witness box."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-63a5e7be-8628-4ac3-9ac0-482712238ace"
        },
        {
          "id": "item-5be96469-d5b6-4efd-8cb4-c1cc55499154",
          "type": "dialogue",
          "characterId": null,
          "text": "The sentences are too fast, too hot, too honest."
        },
        {
          "id": "item-5a08fa0d-c47c-42b5-b550-ccd1563da31d",
          "type": "dialogue",
          "characterId": null,
          "text": "Good."
        },
        {
          "id": "item-4adfc873-22e2-4a54-99f3-b1723ae1484c",
          "type": "dialogue",
          "characterId": null,
          "text": "There will be time to make them respectable later."
        },
        {
          "type": "python_script",
          "code": "story.set_day3_frantic_pages_written(True)",
          "id": "item-c87a6e3e-9e85-4386-bbc9-24f82d0c5006"
        },
        {
          "id": "item-6bb0ed80-80d0-48e2-b3ee-eb62ac9dffa4",
          "type": "jump",
          "destinationLabelId": "label-d30ec3a3-9bda-4b86-8eff-d9acf8864678"
        }
      ]
    },
    {
      "id": "label-11bf99b7-d47e-4f9b-8de6-9f4100cf1839",
      "name": "day103_3_prepare_mask",
      "x": 16100,
      "y": 10337.5,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-c4b66888-e740-451a-884e-0e16228820c4",
          "backgroundId": "bg_servants_quarters_dusk"
        },
        {
          "type": "python_script",
          "code": "story.set_day3_twilight_action(\"prepare_mask\")",
          "id": "item-6afb483f-faec-4a75-9917-02e4ff13126d"
        },
        {
          "type": "python_script",
          "code": "apply_effects(stern_susp=-20)",
          "id": "item-47c98207-db7d-42c5-a179-cf4f94b1b539"
        },
        {
          "id": "item-20a402bf-9d9c-4c8d-b9a0-33802051f44e",
          "type": "dialogue",
          "characterId": null,
          "text": "I force my hands into useful work."
        },
        {
          "id": "item-ad81418a-251b-402d-a43e-e9c7a1c96421",
          "type": "dialogue",
          "characterId": null,
          "text": "Collar pressed. Cuffs scrubbed. Apron inspected for ink, ash, and evidence of having a mind."
        },
        {
          "id": "item-2073fd92-28cc-46f3-ae31-bab90ed02648",
          "type": "dialogue",
          "characterId": null,
          "text": "A perfect uniform is a kind of locked door."
        },
        {
          "id": "item-fa3cc7c4-aecb-4f75-8528-771aa8823a62",
          "type": "dialogue",
          "characterId": null,
          "text": "Stern trusts what looks maintained."
        },
        {
          "id": "item-41fbf0bd-48c4-4ebc-bc0d-de4d039821c4",
          "type": "dialogue",
          "characterId": null,
          "text": "Men trust what looks available."
        },
        {
          "id": "item-7d230f5e-943c-4fbc-a614-d833321b11ef",
          "type": "dialogue",
          "characterId": null,
          "text": "Both are wrong often enough to be useful."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "e5943aa2-1a2e-4ab6-b084-4b22f0bc03b2",
              "type": "if",
              "conditionRaw": "story.day2_contraband_state == \"stolen_wearing\"",
              "dialogue": [
                {
                  "id": "item-19c923e7-791a-4325-8262-4c4471da2d75",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I consider removing the stolen lace."
                },
                {
                  "id": "item-30c8bba9-05b1-4a92-a67c-2ac4a87ad1cd",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I do not."
                },
                {
                  "id": "item-b65cdc15-37e2-430f-9ca1-7890fd2e90cb",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The uniform lies better with a secret under it, warm against my ribs."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day2_contraband_state == \"stolen_wearing\""
            }
          ],
          "id": "item-be68e363-7c08-46c0-be11-901557bf95b0"
        },
        {
          "id": "item-fd1c1610-6145-466f-b79f-a1d40dc6f66e",
          "type": "jump",
          "destinationLabelId": "label-d30ec3a3-9bda-4b86-8eff-d9acf8864678"
        }
      ]
    },
    {
      "id": "label-60c90402-5a99-49f9-9b6c-bed885a16fbd",
      "name": "day103_3_indulge_words",
      "x": 16100,
      "y": 10207.5,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-cbd5c25a-d1bc-4bbd-817d-3d3a6af24011",
          "backgroundId": "bg_servants_quarters_dusk"
        },
        {
          "type": "python_script",
          "code": "story.set_day3_twilight_action(\"indulge_words\")",
          "id": "item-c9f86755-a98b-47f8-85b7-46ff2d541c6d"
        },
        {
          "type": "python_script",
          "code": "apply_balanced_effect(\"transgressive\", intensity=\"standard\", witness=\"stern\")",
          "id": "item-9243a45e-36db-4427-96db-f5997f40119c"
        },
        {
          "id": "item-fceee877-1f40-4b17-b5bc-6000708fbf47",
          "type": "dialogue",
          "characterId": null,
          "text": "I do not write the chapter."
        },
        {
          "id": "item-e004d254-69f5-4ac6-92d8-270ef821734e",
          "type": "dialogue",
          "characterId": null,
          "text": "I write only what he said."
        },
        {
          "id": "item-6e1fe066-01a3-425b-9bae-28907cea4a93",
          "type": "dialogue",
          "characterId": null,
          "text": "You observe too much."
        },
        {
          "id": "item-7b61639f-3299-42e7-88c2-011a4dfb76ba",
          "type": "dialogue",
          "characterId": null,
          "text": "You lie better than your references suggest."
        },
        {
          "id": "item-82d81e5f-da84-42ac-8281-f17c72d496be",
          "type": "dialogue",
          "characterId": null,
          "text": "Do not spoil this by pretending stupidity."
        },
        {
          "id": "item-883f942d-44ab-477e-9972-3c3464c27a19",
          "type": "dialogue",
          "characterId": null,
          "text": "Each sentence is a hook."
        },
        {
          "id": "item-c16e25dd-a8d7-4a06-a8f0-29066547bf77",
          "type": "dialogue",
          "characterId": null,
          "text": "I hang myself on them willingly, feeling the slow, physical heat they stir."
        },
        {
          "id": "item-45ac9d5b-7074-41f6-a511-5dbafa91a726",
          "type": "dialogue",
          "characterId": null,
          "text": "This is not craft yet."
        },
        {
          "id": "item-80bf4f5c-554e-4062-b8c6-80b6f5d8a965",
          "type": "dialogue",
          "characterId": null,
          "text": "It is the thing before craft."
        },
        {
          "id": "item-c91f573c-8561-4203-8737-b7e5657496e8",
          "type": "dialogue",
          "characterId": null,
          "text": "The private damage that later pretends it was research all along."
        },
        {
          "id": "item-da220a5d-db37-431f-a695-496886b8c056",
          "type": "jump",
          "destinationLabelId": "label-d30ec3a3-9bda-4b86-8eff-d9acf8864678"
        }
      ]
    },
    {
      "id": "label-d30ec3a3-9bda-4b86-8eff-d9acf8864678",
      "name": "day103_4_room_stern_suspicion",
      "x": 16500,
      "y": 10402.5,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "fade",
          "id": "item-ef74baf3-a09e-4aac-a86a-65f4e69a6d5d",
          "backgroundId": "bg_servants_quarters_dusk"
        },
        {
          "id": "item-bd0d3401-d89f-426a-8770-7c085f3ad51e",
          "type": "dialogue",
          "characterId": null,
          "text": "A knock comes at my door."
        },
        {
          "id": "item-3fa3b5f8-6e5b-408f-a16a-eaa551e79de4",
          "type": "dialogue",
          "characterId": null,
          "text": "Not Mr. Locke's."
        },
        {
          "id": "item-6cd12222-5ed8-426f-9810-ea7c6a72ddfd",
          "type": "dialogue",
          "characterId": null,
          "text": "Worse."
        },
        {
          "id": "item-17a2f71c-1c8d-4c28-977c-151c59a636ba",
          "type": "show",
          "characterId": "stern_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "stern_sprite stern"
        },
        {
          "id": "item-da6b6d26-8a32-4252-849e-643776c98923",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "Open."
        },
        {
          "id": "item-c9eb60c0-7730-4b05-a476-c107d2b29404",
          "type": "dialogue",
          "characterId": null,
          "text": "I open."
        },
        {
          "id": "item-357f74fd-9e7d-45a9-aa5d-4e9f7274a789",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "You have been called upstairs this evening."
        },
        {
          "id": "item-cea98250-268e-4a4c-993c-4f1046190172",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base"
        },
        {
          "id": "item-1125ef87-4897-438c-904b-f278947e5730",
          "type": "show",
          "characterId": "stern_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "move",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "stern_sprite stern"
        },
        {
          "id": "item-ccbcab3c-4838-411e-8b74-898df2386336",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Yes, Ma'am."
        },
        {
          "id": "item-3f070a85-bf06-4490-9806-2706906275ac",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "Do you know why?"
        },
        {
          "id": "item-bc1188bc-767b-4052-bdab-58139234b65b",
          "type": "dialogue",
          "characterId": null,
          "text": "A trap with no clever answer."
        },
        {
          "type": "choice",
          "options": [
            {
              "id": "dae60701-0fa0-4984-85b9-b53b000e531c",
              "text": "Be boring. Make the summons sound like ordinary service. [[-Suspicion]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "story.set_day3_stern_response(\"boring\")",
                  "id": "item-665ef906-1cec-4536-9cd1-59c2a099ad56"
                },
                {
                  "type": "python_script",
                  "code": "apply_effects(stern_susp=-10)",
                  "id": "item-013b80d8-6293-45dc-ad1f-31748f2c506d"
                },
                {
                  "id": "item-782adef8-b781-4ca9-8a92-253df817139e",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "Mr. Locke requested tea, Ma'am. I assumed the kitchen was short-handed."
                },
                {
                  "id": "item-ff4579b6-c4e0-4463-8a0e-ab8c5cb14f09",
                  "type": "dialogue",
                  "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
                  "text": "You assumed."
                },
                {
                  "id": "item-8625eb83-246b-47ed-a72c-0d9d21a79542",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "Poorly, Ma'am. I should have asked you first."
                },
                {
                  "id": "item-154aa36c-71d5-46a7-aa7c-79d47c9fa6b4",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Stern studies the apology for hooks."
                },
                {
                  "id": "item-9bef8a36-9722-4322-8cec-5578fa774d25",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Finding none, she dislikes it."
                },
                {
                  "id": "item-4bddab89-e285-4094-93fd-8487244a8860",
                  "type": "dialogue",
                  "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
                  "text": "You will carry the tray, set it down, and return immediately. No conversation. No wandering. No delay."
                },
                {
                  "id": "item-93f53c8c-c049-4b1d-8fa3-17ae1836ffa3",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "Yes, Ma'am."
                }
              ]
            },
            {
              "id": "4be25a4b-1bd9-4ca7-a106-aa57a29625f6",
              "text": "Tell a partial truth. Admit he unsettles me. [[+Inspiration, mixed risk]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "story.set_day3_stern_response(\"partial_truth\")",
                  "id": "item-f2bd1e83-d90d-4fc3-b62f-d6b9777a7607"
                },
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"observant\", intensity=\"standard\")",
                  "id": "item-2064cb94-05b8-48a5-b887-4f286c0dd343"
                },
                {
                  "id": "item-a6dab22c-1aa1-4531-91d9-a17d6b905715",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "I don't know, Ma'am. He asks questions in a way that makes answers feel unsafe."
                },
                {
                  "id": "item-7604c664-6914-40f5-93d6-b619f29bff7c",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Stern's face changes by almost nothing."
                },
                {
                  "id": "item-5113eadf-d9f0-4b21-9384-af301c61ae50",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Almost nothing is not nothing."
                },
                {
                  "id": "item-af4e192f-1dd3-4bfb-be12-2c74a7e46bdd",
                  "type": "dialogue",
                  "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
                  "text": "Then remember that silence is also an answer. Often the better one."
                },
                {
                  "id": "item-5188ddc3-5d04-4d7e-b108-1dfc3835c400",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Advice. Warning. Confession."
                },
                {
                  "id": "item-202a647d-e83b-425b-80f1-7551e2883ffd",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Stern packages all three as discipline."
                },
                {
                  "id": "item-157a9639-70d4-4594-a827-77accf62e609",
                  "type": "dialogue",
                  "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
                  "text": "You will return directly after delivering the tray. If you are delayed, I will know."
                },
                {
                  "id": "item-74699b36-0022-4f4a-bbff-ff1f9af0fb2e",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "Yes, Ma'am."
                }
              ]
            },
            {
              "id": "6bd501c7-d315-4649-b77c-8c73a6e638a0",
              "text": "Play stupid. Make her underestimate me. [[+Suspicion if she sees through it]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "story.set_day3_stern_response(\"stupid\")",
                  "id": "item-cc39c4bf-3e11-4dec-a985-b4ad124fce65"
                },
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"transgressive\", intensity=\"standard\", witness=\"stern\")",
                  "id": "item-4e559c6b-9271-49bc-808d-26b3108ef6a9"
                },
                {
                  "id": "item-45b76b5b-8734-49b5-ae47-cbe47df230ed",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "I thought gentlemen often wanted tea, Ma'am."
                },
                {
                  "id": "item-2462d887-8161-41e2-a71e-3fb14d26b906",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The stupidity hangs there, shiny and false."
                },
                {
                  "id": "item-9cfe9a39-77d8-45a9-b9e6-b28fef2da3ec",
                  "type": "dialogue",
                  "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
                  "text": "Do not insult me with innocence you cannot afford."
                },
                {
                  "id": "item-1d5a9ca2-db49-4bec-9747-eb3dc093fecc",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "My stomach tightens."
                },
                {
                  "id": "item-5dd2d157-f0e8-456c-ba8b-7804c59561e5",
                  "type": "dialogue",
                  "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
                  "text": "You are new, not empty. Learn the difference before someone else teaches it cruelly."
                },
                {
                  "id": "item-9ea71084-dbb7-43d9-ab6c-427c12726f38",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "Yes, Ma'am."
                }
              ]
            }
          ],
          "id": "item-6e8716fb-1ebb-4a1e-8804-aeb1f405a365"
        },
        {
          "id": "item-5bf8cf33-debd-4015-99e2-823146c1a644",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "And Cora."
        },
        {
          "id": "item-35610430-1260-4ac1-98f4-8c51acca8ad7",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Ma'am?"
        },
        {
          "id": "item-e8913f0e-6b1e-42b2-986e-0acbef24314b",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "A guest's attention is not a promotion."
        },
        {
          "type": "hide",
          "layer": null,
          "id": "item-3b6566b4-1717-4d63-8f9a-8f0aa7856c84",
          "characterId": "stern_sprite"
        },
        {
          "id": "item-644d4f01-e1ac-4e81-9dc2-a61d8ec03c3e",
          "type": "dialogue",
          "characterId": null,
          "text": "She leaves before I can answer."
        },
        {
          "id": "item-d2934916-a6a7-4b42-bb55-59e327b056d4",
          "type": "dialogue",
          "characterId": null,
          "text": "Which is mercy, because I had none."
        },
        {
          "id": "item-16b9f651-969d-46a5-8cbf-0ff220b71afc",
          "type": "jump",
          "destinationLabelId": "label-c1a0ddd6-b519-42b6-8c2e-89eb07898ab0"
        }
      ]
    },
    {
      "id": "label-45163c26-5054-41a7-9f26-a223bd84a300",
      "name": "day103_night",
      "x": 16500,
      "y": 11607.5,
      "dialogue": [
        {
          "id": "item-c95a1b10-263a-4d92-9691-a21123e390b7",
          "type": "jump",
          "destinationLabelId": "label-c1a0ddd6-b519-42b6-8c2e-89eb07898ab0"
        }
      ]
    },
    {
      "id": "label-c8ea3118-302e-49b1-b35a-f73857007d7d",
      "name": "day103_night_consequence_window",
      "x": 22100,
      "y": 11662.5,
      "dialogue": [
        {
          "id": "item-4558e399-545a-4568-b79e-595254cbb4cf",
          "type": "call",
          "destinationLabelId": "label-5f635f30-8ef3-4f17-80e7-4e5cde552ded"
        },
        {
          "id": "item-eb1247e2-702e-4017-be63-95b22fe5bd4f",
          "type": "call",
          "destinationLabelId": "label-7d0ab68c-82c3-423b-a677-a442c420ec43"
        }
      ]
    },
    {
      "id": "label-c1a0ddd6-b519-42b6-8c2e-89eb07898ab0",
      "name": "day103_2_suite_night_tea",
      "x": 16900,
      "y": 10532.5,
      "dialogue": [
        {
          "type": "python_script",
          "code": "set_time_period(\"Night\")",
          "id": "item-23471f2e-f64b-4d87-8301-fc5e2ceea06f"
        },
        {
          "type": "scene",
          "layer": null,
          "transition": "fade",
          "id": "item-5f71d354-bcae-4cd5-bec5-d9867083f2e5",
          "backgroundId": "bg_master_suite_night"
        },
        {
          "id": "item-3662b3ad-411a-4ac4-aea0-8f38d59bf3e3",
          "type": "dialogue",
          "characterId": null,
          "text": "At nine, I carry tea through a hotel that has gone quiet enough to hear itself lying."
        },
        {
          "id": "item-e6c7d237-59a1-430c-b0ea-6e2202406ca7",
          "type": "dialogue",
          "characterId": null,
          "text": "The tray is heavier than it should be."
        },
        {
          "id": "item-c03bf836-3cc5-457b-a862-0d7b36104d57",
          "type": "dialogue",
          "characterId": null,
          "text": "That is because it contains a choice."
        },
        {
          "id": "item-1661a15b-6775-4501-a541-750246b13c7b",
          "type": "show",
          "characterId": "gideon_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "gideon_sprite dominant"
        },
        {
          "id": "item-ae1ce594-2470-425d-b0ed-242dbc183576",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "You came."
        },
        {
          "id": "item-0872629d-77c2-46d7-b90d-036b60616664",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base"
        },
        {
          "id": "item-1cdfbd4f-e14a-4f2a-ad11-1458885f4c47",
          "type": "show",
          "characterId": "gideon_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "move",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "gideon_sprite dominant"
        },
        {
          "id": "item-1db6c6a7-92a7-426d-a930-3df350e0189d",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "I was instructed to bring tea, Sir."
        },
        {
          "id": "item-9e050422-1a2f-49c1-858b-f11cbd47d258",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "By whom?"
        },
        {
          "id": "item-41d823cc-d213-41fb-8f50-2cfe3230bc88",
          "type": "dialogue",
          "characterId": null,
          "text": "A smile without warmth."
        },
        {
          "id": "item-193e81b2-c2df-433c-92ca-97a7038bb65e",
          "type": "dialogue",
          "characterId": null,
          "text": "He knows exactly what he is asking."
        },
        {
          "id": "item-06abccc3-a389-472f-b7a6-f331d92748d8",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "By the needs of the house."
        },
        {
          "id": "item-935f95bd-06b6-4a02-83fd-0338b645cdba",
          "type": "dialogue",
          "characterId": null,
          "text": "He laughs once."
        },
        {
          "id": "item-c7ce7272-d190-49c9-983e-98d2327e4a5d",
          "type": "dialogue",
          "characterId": null,
          "text": "Quietly."
        },
        {
          "id": "item-dba7b2ca-d558-409c-a4e7-1767cf57cbb6",
          "type": "dialogue",
          "characterId": null,
          "text": "It is worse than approval, sending a small spike of heat down my spine."
        },
        {
          "id": "item-d51d9b22-02d5-4d0e-8763-dc2ec186fecd",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Set it down."
        },
        {
          "id": "item-581410e6-2e50-4832-98c8-508ab09e2e9b",
          "type": "dialogue",
          "characterId": null,
          "text": "I do."
        },
        {
          "id": "item-84789a04-651c-4df6-8c75-4c9f3c784906",
          "type": "dialogue",
          "characterId": null,
          "text": "He does not drink. He circles the table slowly, his cuffs clicking, his collar undone to expose the strong, pale column of his neck."
        },
        {
          "id": "item-f5cc2b48-43f2-466b-b015-6a422500e7e8",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "You write."
        },
        {
          "id": "item-da9822a8-eef3-44a1-a276-02a0148a746d",
          "type": "dialogue",
          "characterId": null,
          "text": "The room falls out from under me, leaving only the sound of my shallow breathing."
        },
        {
          "id": "item-939d84e9-92bc-4046-8367-8541217ddf81",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Sir?"
        },
        {
          "id": "item-226f5e59-1bfc-4aaa-a8d5-d38f225eb461",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Again. Do not spoil this."
        },
        {
          "id": "item-ae56dd5d-789f-4917-a473-c4051f14c4a6",
          "type": "dialogue",
          "characterId": null,
          "text": "My hands remain at my sides."
        },
        {
          "id": "item-9273a04b-5eaf-4e68-b4c7-8f2cd578a084",
          "type": "dialogue",
          "characterId": null,
          "text": "I am proud of that, in the distant way one might admire a burning building for standing upright under pressure."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "30ed2acc-f33d-4883-a875-7401c41c4494",
              "type": "if",
              "conditionRaw": "story.day3_twilight_action == \"frantic_write\"",
              "dialogue": [
                {
                  "id": "item-da55881e-e245-4d20-bb60-66b95e2e07f4",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The fresh pages are hidden beneath my ledger downstairs."
                },
                {
                  "id": "item-0bac1fe5-de63-463e-b1c7-09cf476ccb75",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The ink may still be wet."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day3_twilight_action == \"frantic_write\""
            },
            {
              "id": "111cacb5-9fec-42d2-97ed-1335f18b5948",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-dc5158f5-24a4-4793-b15e-37d638ed40ec",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The unwritten pages accuse me from my room."
                },
                {
                  "id": "item-4310821a-1d7d-42d2-8c03-2df42f9494ea",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Somehow that feels no safer."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-b17ccdc3-c82d-477a-9bb1-1457504e3e98"
        },
        {
          "id": "item-28a7fad9-5eb9-483f-a8db-16346dc20156",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "A servant who watches is irritating. A servant who records is dangerous."
        },
        {
          "id": "item-918a9abd-da91-4fb8-b8bf-e8366565c5f3",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "I record nothing of consequence."
        },
        {
          "id": "item-ccabce99-8bbf-49c9-a648-85e87c9bd716",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Then you are wasting both ink and opportunity."
        },
        {
          "id": "item-368fc497-d72e-438f-809c-6842c1fc466d",
          "type": "dialogue",
          "characterId": null,
          "text": "There is no clean category for this."
        },
        {
          "id": "item-ba60bb1c-0af6-473e-934c-2e3c99069827",
          "type": "dialogue",
          "characterId": null,
          "text": "Not threat. Not flirtation. Not patronage."
        },
        {
          "id": "item-831cebc2-56b3-4b53-8c3c-5abce88a823e",
          "type": "dialogue",
          "characterId": null,
          "text": "A man with power has discovered a locked cabinet and is deciding whether to force it open or purchase the key, his physical presence crowding the small space between us."
        },
        {
          "type": "choice",
          "options": [
            {
              "id": "14dddb1c-22d3-4b44-9004-392f5704ca99",
              "text": "Deny him access. Keep the book mine. [[Defiance]]",
              "dialogue": [
                {
                  "id": "item-6a758f52-faef-4b69-bace-06adbe35bb59",
                  "type": "jump",
                  "destinationLabelId": "label-e387385d-db19-4f6f-b546-35016989e83f"
                }
              ]
            },
            {
              "id": "5f182a77-aa38-4bd4-a973-df7d1bc5780c",
              "text": "Offer him a controlled fragment. Make curiosity serve me. [[Bargain]]",
              "dialogue": [
                {
                  "id": "item-280e82f3-0663-41b3-97d0-c155b5a38c7f",
                  "type": "jump",
                  "destinationLabelId": "label-03bb5fb2-8d9e-4199-9f30-33092752780a"
                }
              ]
            },
            {
              "id": "1bd4a397-ec3a-4711-8fee-b1ff82e93348",
              "text": "Let him frighten me. Gather every detail. [[Surrender]]",
              "dialogue": [
                {
                  "id": "item-763fd860-2286-4556-a9d1-489d57d6348b",
                  "type": "jump",
                  "destinationLabelId": "label-7f0bfa45-dd21-44c9-bfb3-24f6a097b0d5"
                }
              ]
            }
          ],
          "id": "item-fe594c30-70fb-4775-9e31-f826d5ef5f38"
        },
        {
          "id": "item-a9d3be48-9418-492b-9364-fb5ddcf217d4",
          "type": "jump",
          "destinationLabelId": "label-e387385d-db19-4f6f-b546-35016989e83f"
        }
      ]
    },
    {
      "id": "label-e387385d-db19-4f6f-b546-35016989e83f",
      "name": "day103_2_night_defy_gideon",
      "x": 17300,
      "y": 11672.5,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-e1bebf3d-8685-466e-be29-d59874de192c",
          "backgroundId": "bg_master_suite_night"
        },
        {
          "id": "item-23a3c61c-04a2-4299-b9d8-214eae0f4637",
          "type": "show",
          "characterId": "gideon_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "gideon_sprite dominant"
        },
        {
          "type": "python_script",
          "code": "story.set_day3_ultimatum(\"defied\")",
          "id": "item-4603eb24-4688-45aa-8629-c3a692fa73fa"
        },
        {
          "type": "python_script",
          "code": "apply_balanced_effect(\"transgressive\", intensity=\"standard\", witness=\"vance\")",
          "id": "item-2385d8b3-05be-41c5-a817-55b029c15149"
        },
        {
          "id": "item-6df0eed3-1a6c-41cb-985a-d6ef256b7f9b",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base"
        },
        {
          "id": "item-5678dc2e-48c5-4900-81d6-7f7b0aabbd3b",
          "type": "show",
          "characterId": "gideon_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "move",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "gideon_sprite dominant"
        },
        {
          "id": "item-164dcfed-9515-48f6-bdbf-2d44d9064096",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "My writing is not part of my service, Sir."
        },
        {
          "id": "item-0fca1c12-402a-4058-bc7a-f03171a9fce5",
          "type": "dialogue",
          "characterId": null,
          "text": "There."
        },
        {
          "id": "item-f09b10dc-ebaa-416c-a5e4-0eed7967a30d",
          "type": "dialogue",
          "characterId": null,
          "text": "A sentence that can get me dismissed."
        },
        {
          "id": "item-2cc0671b-f796-46ed-bb77-a2a5bca58996",
          "type": "dialogue",
          "characterId": null,
          "text": "Or worse, retained."
        },
        {
          "id": "item-1cb1ea45-328e-4aff-a3dc-b920858ef0b3",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Everything in this house becomes service if a guest is sufficiently interested."
        },
        {
          "id": "item-f41c5e6c-268f-4009-ac65-515307bb86cd",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Then the house is mistaken."
        },
        {
          "id": "item-fb238bcb-6ac2-41ee-9796-64ba46875e1d",
          "type": "dialogue",
          "characterId": null,
          "text": "Silence."
        },
        {
          "id": "item-68ff991b-218a-4d63-8f0d-0d88b72f9473",
          "type": "dialogue",
          "characterId": null,
          "text": "Not empty silence. Selected silence. The kind a man uses when deciding how much force a door requires."
        },
        {
          "id": "item-ed06dead-d628-4d82-9abf-51d63653858b",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "You are either brave or poorly educated in consequences."
        },
        {
          "id": "item-ba598f72-6698-487a-8a4e-0877b86598e8",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "I expect those often look similar from above, Sir."
        },
        {
          "id": "item-e04b11c1-1e9e-4f56-9cb5-b20539ed0153",
          "type": "dialogue",
          "characterId": null,
          "text": "His face changes."
        },
        {
          "id": "item-f3bfa64c-3379-4098-b675-59dab68f7b74",
          "type": "dialogue",
          "characterId": null,
          "text": "Only slightly."
        },
        {
          "id": "item-034173fd-6bfc-4587-9c18-a5686f5cbbc7",
          "type": "dialogue",
          "characterId": null,
          "text": "Enough, his eyes flashing with a sudden, dark appreciation."
        },
        {
          "id": "item-e0fad1e0-6866-4591-88ca-e0a41f0b01b2",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Go. Before you become less amusing."
        },
        {
          "id": "item-2013c7a2-41a4-4253-af1f-9b0389f4abc4",
          "type": "dialogue",
          "characterId": null,
          "text": "I leave with the tray untouched."
        },
        {
          "id": "item-69b55fef-ab47-4fb2-ae58-955982f5e9dd",
          "type": "dialogue",
          "characterId": null,
          "text": "My knees nearly fail in the corridor, trembling violently."
        },
        {
          "id": "item-5e7698a5-d3d4-47ef-a5e1-861fac596c2c",
          "type": "dialogue",
          "characterId": null,
          "text": "They wait until he cannot see."
        },
        {
          "id": "item-ab5a14f5-bc15-4806-9b35-62c366abcf9a",
          "type": "jump",
          "destinationLabelId": "label-d19f3540-3325-4283-9d50-38ac74fa78e0"
        }
      ]
    },
    {
      "id": "label-03bb5fb2-8d9e-4199-9f30-33092752780a",
      "name": "day103_2_night_bargain_gideon",
      "x": 17300,
      "y": 10467.5,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-99f22073-133f-4a60-b446-29996052145f",
          "backgroundId": "bg_master_suite_night"
        },
        {
          "id": "item-c80d3b6d-c5bd-4345-ae7e-172a0d845530",
          "type": "show",
          "characterId": "gideon_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "gideon_sprite dominant"
        },
        {
          "type": "python_script",
          "code": "story.set_day3_ultimatum(\"bargained\")",
          "id": "item-195629c1-d6a7-4628-af4a-e0ef128d704d"
        },
        {
          "type": "python_script",
          "code": "apply_balanced_effect(\"transgressive\", intensity=\"standard\", witness=\"vance\")",
          "id": "item-877dc00a-e5c9-4ae9-a0a7-4f7ce2550073"
        },
        {
          "id": "item-682219aa-1a72-4d81-a771-c290381976b7",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base"
        },
        {
          "id": "item-f85f240e-e855-45bc-bb28-1a56ca009be0",
          "type": "show",
          "characterId": "gideon_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "move",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "gideon_sprite dominant"
        },
        {
          "id": "item-8493e048-710b-4eb2-8d5e-2e18ee8e8926",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "A fragment, perhaps. If it keeps you from imagining worse."
        },
        {
          "id": "item-b8bc938a-008b-411c-ad0d-08fd148d53c4",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "You negotiate quickly."
        },
        {
          "id": "item-9ca14a26-e776-4db7-b6ab-5001192f8f28",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Servants learn prices, Sir. Usually by paying them."
        },
        {
          "id": "item-178e153a-586c-410b-b1ef-61a64ab49a2f",
          "type": "dialogue",
          "characterId": null,
          "text": "That earns a pause, his fingers tapping the silver tray."
        },
        {
          "id": "item-88c9e6b4-f902-4ba3-b723-dbebe0c84240",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Recite it."
        },
        {
          "id": "item-94abceec-b20a-4786-8482-bb9768d72504",
          "type": "dialogue",
          "characterId": null,
          "text": "So I give him three sentences."
        },
        {
          "id": "item-78752863-0495-40e9-9a6f-d2a9674ed144",
          "type": "dialogue",
          "characterId": null,
          "text": "Not the true ones."
        },
        {
          "id": "item-0d69b13c-4f38-4111-81d1-71f80943200c",
          "type": "dialogue",
          "characterId": null,
          "text": "Not the safest ones either."
        },
        {
          "id": "item-07a2b20d-0a2b-4f10-8152-b7d8e9324f4e",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "A house teaches silence as if silence were virtue. But silence is only obedience with its throat cut. A girl who listens long enough may mistake the wound for a mouth."
        },
        {
          "id": "item-f795ddda-f492-4ee5-b394-f56e90d68093",
          "type": "dialogue",
          "characterId": null,
          "text": "Mr. Locke watches me through all of it, his eyes fixed on my lips."
        },
        {
          "id": "item-b4f1a184-b065-442c-bed9-0e5b53e2e6d7",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "You are wasted below stairs."
        },
        {
          "id": "item-26c2c7fe-5d0a-4e59-b654-4f8df57c15bc",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Many things are, Sir."
        },
        {
          "id": "item-4a436ef6-b181-4a1a-8a1f-d72ed02dfa1f",
          "type": "dialogue",
          "characterId": null,
          "text": "The answer comes too fast."
        },
        {
          "id": "item-394c9f3d-93fc-4839-94b2-24958071844e",
          "type": "dialogue",
          "characterId": null,
          "text": "He notices, his breathing slowing."
        },
        {
          "id": "item-6c697e30-b2db-42a4-a0c9-87af61f88648",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Careful. I enjoy cleverness most when it knows it is trapped."
        },
        {
          "id": "item-c274ed7a-3e9e-43d7-b77a-6e1f6f80bd4c",
          "type": "dialogue",
          "characterId": null,
          "text": "I lower my eyes."
        },
        {
          "id": "item-767291d2-cf8c-4897-8f38-464c50201cfc",
          "type": "dialogue",
          "characterId": null,
          "text": "Not in surrender."
        },
        {
          "id": "item-cea3e7b6-dc60-464a-a137-adc5277858b9",
          "type": "dialogue",
          "characterId": null,
          "text": "In bookkeeping."
        },
        {
          "id": "item-8f39705d-60a3-4da8-b663-bc3542376ab3",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Go. Bring better tea tomorrow."
        },
        {
          "id": "item-a53033ac-e258-46a2-9c5c-3c9fe3e3b827",
          "type": "dialogue",
          "characterId": null,
          "text": "Tomorrow."
        },
        {
          "id": "item-3c5cff1d-168b-4dcf-9aa4-69b4829e266a",
          "type": "dialogue",
          "characterId": null,
          "text": "So the door has not closed."
        },
        {
          "id": "item-c3a06569-e47d-40b3-828c-597f0c1307d1",
          "type": "dialogue",
          "characterId": null,
          "text": "It has learned my name."
        },
        {
          "id": "item-931f84ef-18ba-4805-a9f6-96e9767ae2cb",
          "type": "jump",
          "destinationLabelId": "label-d19f3540-3325-4283-9d50-38ac74fa78e0"
        }
      ]
    },
    {
      "id": "label-7f0bfa45-dd21-44c9-bfb3-24f6a097b0d5",
      "name": "day103_2_night_surrender_gideon",
      "x": 17300,
      "y": 8665,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-5deb28a4-fbf9-448b-9498-515a4e697b13",
          "backgroundId": "bg_master_suite_night"
        },
        {
          "id": "item-94c8afbd-ba60-4fcf-a5ad-541ba0a55009",
          "type": "show",
          "characterId": "gideon_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "gideon_sprite dominant"
        },
        {
          "type": "python_script",
          "code": "story.set_day3_ultimatum(\"surrendered\")",
          "id": "item-361a5d24-2538-4c78-92b4-68ee711dca39"
        },
        {
          "type": "python_script",
          "code": "apply_balanced_effect(\"transgressive\", intensity=\"standard\", witness=\"vance\")",
          "id": "item-769bd729-3915-4d6e-8b6a-d511673c5b27"
        },
        {
          "id": "item-a993ce52-06ab-405f-bde5-b6a3baa823d1",
          "type": "dialogue",
          "characterId": null,
          "text": "I could deny him."
        },
        {
          "id": "item-19dec904-a0f2-4b14-97f8-df0de898ba0b",
          "type": "dialogue",
          "characterId": null,
          "text": "I could lie better."
        },
        {
          "id": "item-e414b2d4-a693-4cdf-96aa-f4497c5d0781",
          "type": "dialogue",
          "characterId": null,
          "text": "Instead, I let the fear and the heavy physical heat show."
        },
        {
          "id": "item-83da0e50-1778-4b3c-a190-7428a0f6789c",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base"
        },
        {
          "id": "item-9b2c1ef2-58a3-4247-b9a0-8bf76aaf883a",
          "type": "show",
          "characterId": "gideon_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "move",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "gideon_sprite dominant"
        },
        {
          "id": "item-197313a5-0965-4e98-a7df-4040c7aa3c41",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "What do you want from me, Sir?"
        },
        {
          "id": "item-0abb6cfc-4cd7-4c4b-ab4d-102807cd6d75",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "That is the first honest question you have asked."
        },
        {
          "id": "item-7fcc944e-c5bc-4c9d-9530-7f6739823727",
          "type": "dialogue",
          "characterId": null,
          "text": "He circles the tea table slowly, closing the distance until I can feel the warmth of his chest."
        },
        {
          "id": "item-f505cb95-f474-4c41-872c-79fd9f226fd9",
          "type": "dialogue",
          "characterId": null,
          "text": "No touch."
        },
        {
          "id": "item-eb381208-532a-47e4-aee0-cbd2594210bb",
          "type": "dialogue",
          "characterId": null,
          "text": "No raised voice."
        },
        {
          "id": "item-12919e63-0472-466f-ac0f-84fa1ecb76bd",
          "type": "dialogue",
          "characterId": null,
          "text": "Only proximity, which rich men use as if space itself were another servant to be manipulated."
        },
        {
          "id": "item-decd2518-3673-4716-be86-fd65084b1dbe",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "I want to know whether you are merely curious, or whether you have the discipline to become dangerous."
        },
        {
          "id": "item-03f55668-ed35-4503-a5e1-ec005e66da2d",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "And if I don't?"
        },
        {
          "id": "item-fb963a75-b793-42aa-9ab3-dae4e31fa87b",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Then you will make an instructive failure."
        },
        {
          "id": "item-df1a48ab-f562-4808-aba3-fde5b1175dfa",
          "type": "dialogue",
          "characterId": null,
          "text": "The words should close something in me."
        },
        {
          "id": "item-ca9c3fbe-a031-4ad4-a409-e449f7c54733",
          "type": "dialogue",
          "characterId": null,
          "text": "They open it instead, a delicious tremor running down my spine."
        },
        {
          "id": "item-0ce967c0-3e2a-4e50-8324-ec4e71df9e07",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Go. Write whatever frightened thing you are trying not to write."
        },
        {
          "id": "item-6a9bcace-54a8-4d16-9448-c16747dc230c",
          "type": "dialogue",
          "characterId": null,
          "text": "Dismissed."
        },
        {
          "id": "item-3b77104f-58d8-483c-a21d-5c1315a27369",
          "type": "dialogue",
          "characterId": null,
          "text": "Not spared."
        },
        {
          "id": "item-09097982-c9de-49c0-b0a4-8ec6366a6b20",
          "type": "dialogue",
          "characterId": null,
          "text": "Sent back to my quarters sharpened, flushed, and ashamed."
        },
        {
          "id": "item-0614c9f5-a50b-4835-b606-77d6f19e84b9",
          "type": "jump",
          "destinationLabelId": "label-d19f3540-3325-4283-9d50-38ac74fa78e0"
        }
      ]
    },
    {
      "id": "label-d19f3540-3325-4283-9d50-38ac74fa78e0",
      "name": "day103_3_bedroom_final_write",
      "x": 17700,
      "y": 8730,
      "dialogue": [
        {
          "id": "item-46616338-b228-44a3-aad5-ebdfa8ccce18",
          "type": "call",
          "destinationLabelId": "label-c8ea3118-302e-49b1-b35a-f73857007d7d"
        },
        {
          "type": "scene",
          "layer": null,
          "transition": "fade",
          "id": "item-35863ee2-a697-41c6-925e-98e51c72cb26",
          "backgroundId": "bg_cora_desk_night"
        },
        {
          "id": "item-c247210d-6204-48e9-a745-fb9a4da0163e",
          "type": "dialogue",
          "characterId": null,
          "text": "I reach my room and close the door with both hands."
        },
        {
          "id": "item-72c3baa8-fe6a-40d3-8816-be853176d788",
          "type": "dialogue",
          "characterId": null,
          "text": "The candle is still low."
        },
        {
          "id": "item-a1da7ecf-b926-4e31-8341-278053f85a39",
          "type": "dialogue",
          "characterId": null,
          "text": "The page is still there."
        },
        {
          "id": "item-83aaec7b-eba6-4079-bb33-63f2c8692f1d",
          "type": "dialogue",
          "characterId": null,
          "text": "So am I, apparently."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "91cdf91f-6b55-4dc2-962d-9ed8958b174c",
              "type": "if",
              "conditionRaw": "story.day3_ultimatum == \"defied\"",
              "dialogue": [
                {
                  "id": "item-5167f1bf-101e-434f-b71d-8a284c4a8792",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Defiance leaves a clean taste for approximately three breaths."
                },
                {
                  "id": "item-5bc32467-580d-4343-b436-0291264f86a8",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Then terror returns with its ledger open."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day3_ultimatum == \"defied\""
            },
            {
              "id": "8983883b-ed3f-45b0-85a9-d1f9c5550db1",
              "type": "elif",
              "conditionRaw": "story.day3_ultimatum == \"bargained\"",
              "dialogue": [
                {
                  "id": "item-92e2dfbb-3222-47d5-963d-8c4ce8cfb534",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I gave him three sentences and kept the rest."
                },
                {
                  "id": "item-2cc5e02c-171e-4403-b5a1-848198189674",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "This feels like victory only if I ignore the fact that he now knows there is a rest."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day3_ultimatum == \"bargained\""
            },
            {
              "id": "ef20503e-1785-44b6-9109-54ec081dad42",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-18e4c4eb-1e07-4227-9ae4-053296ef36c1",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "He sent me back to write."
                },
                {
                  "id": "item-0bdee42a-5a42-412f-9beb-a2ea5e197825",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The command is poisonous because I wanted the same thing, my skin still tingling from his proximity."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-70cefb4b-9dda-4d04-bede-0a735d82cb89"
        },
        {
          "type": "choice",
          "options": [
            {
              "id": "0707289f-57ea-4fbd-b123-c47a78321937",
              "text": "Write until the candle dies. [[Chapter gate]]",
              "dialogue": [
                {
                  "type": "if_block",
                  "branches": [
                    {
                      "id": "f6d6007f-526d-477b-a769-7c587e5ab150",
                      "type": "if",
                      "conditionRaw": "not story.has_manuscript_chapter(\"day2_chapter\")",
                      "dialogue": [
                        {
                          "id": "item-65407800-8482-4f6d-a722-0ae9e670b8f8",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "Chapter Two never left the hatbox."
                        },
                        {
                          "id": "item-c539ae34-3cf1-4fd0-a3f1-81c14fd4b9fc",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "I cannot leap to the mirror scene while the second chapter is still only appetite."
                        },
                        {
                          "id": "item-7356040b-7396-425f-88cb-185f8887fa3d",
                          "type": "call",
                          "destinationLabelId": "label-55af31a8-f543-4dc2-9964-64568d04da16"
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      },
                      "rawCondition": "not story.has_manuscript_chapter(\"day2_chapter\")"
                    }
                  ],
                  "id": "item-783400d7-c752-4365-baeb-0f9b6cb9a511"
                },
                {
                  "type": "if_block",
                  "branches": [
                    {
                      "id": "191ab971-f70d-42e1-9864-e34e0ca5b437",
                      "type": "if",
                      "conditionRaw": "can_write_ch3_manuscript()",
                      "dialogue": [
                        {
                          "id": "item-1e1cfcf5-2cc2-4f35-a31b-b9277f72ca73",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "I write as if the lock is already failing, my fingers hot and quick."
                        },
                        {
                          "id": "item-5613e33b-430e-4b03-b2fc-776e4950e6ba",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "The pen becomes a tool of intense reinterpretation, converting parlor constraint into raw physical heat."
                        },
                        {
                          "type": "if_block",
                          "branches": [
                            {
                              "id": "d9a33791-8b16-48b8-8082-09a59601f0d9",
                              "type": "if",
                              "conditionRaw": "story.day3_ultimatum == \"defied\"",
                              "dialogue": [
                                {
                                  "id": "item-fb937995-4770-4717-a911-1b2b30e319dc",
                                  "type": "dialogue",
                                  "characterId": null,
                                  "text": "The chapter becomes a trap refused. A lord sets the snare beautifully, his fingers unhooking the lady's laces only for her to slip away into the cold, beautiful woods instead."
                                }
                              ],
                              "condition": {
                                "operator": "and",
                                "clauses": []
                              },
                              "rawCondition": "story.day3_ultimatum == \"defied\""
                            },
                            {
                              "id": "cc05fb93-1c17-4a39-ae98-7e0fa213e3d2",
                              "type": "elif",
                              "conditionRaw": "story.day3_ultimatum == \"bargained\"",
                              "dialogue": [
                                {
                                  "id": "item-2db03144-55e0-4035-8de3-2d638e4a8e7a",
                                  "type": "dialogue",
                                  "characterId": null,
                                  "text": "The chapter becomes a negotiation conducted with a knife under the table. The master slides his palm over the maid's thigh to check her pulse, while every offered truth hides a hotter one behind it."
                                }
                              ],
                              "condition": {
                                "operator": "and",
                                "clauses": []
                              },
                              "rawCondition": "story.day3_ultimatum == \"bargained\""
                            },
                            {
                              "id": "7ebd5321-c5fc-44ef-8f19-7a8a171d1aec",
                              "type": "else",
                              "conditionRaw": null,
                              "dialogue": [
                                {
                                  "id": "item-c40c5df1-bd13-40a8-88d9-813bac149490",
                                  "type": "dialogue",
                                  "characterId": null,
                                  "text": "The chapter becomes a summons. A girl walks toward the dark hearth and discovers that physical surrender can feel like authorship when the master's hand unbuttons her collar in the gold firelight."
                                }
                              ],
                              "condition": {
                                "operator": "and",
                                "clauses": []
                              }
                            }
                          ],
                          "id": "item-c36683a9-4eb1-476c-9265-3f734269a850"
                        },
                        {
                          "type": "if_block",
                          "branches": [
                            {
                              "id": "5fb02c34-d48e-42b5-9e9b-7a714ff4d082",
                              "type": "if",
                              "conditionRaw": "story.day3_brush_choice == \"predator\"",
                              "dialogue": [
                                {
                                  "id": "item-1bce78e8-7d40-4d28-97ca-87cb026eb456",
                                  "type": "dialogue",
                                  "characterId": null,
                                  "text": "The mirror scene gives it teeth."
                                },
                                {
                                  "id": "item-c5f1a914-725b-4cbd-a572-161f3f46a03b",
                                  "type": "dialogue",
                                  "characterId": null,
                                  "text": "She answered his question like a craftsman: Vance's beauty was in her bones, not her obedience, and her weakness was letting wounds show."
                                },
                                {
                                  "id": "item-a1476c50-9726-4db2-b0be-cae17d589623",
                                  "type": "dialogue",
                                  "characterId": null,
                                  "text": "On the page, that answer is the chapter's real edge. The maid already understood the room before the gentleman arranged it."
                                }
                              ],
                              "condition": {
                                "operator": "and",
                                "clauses": []
                              },
                              "rawCondition": "story.day3_brush_choice == \"predator\""
                            },
                            {
                              "id": "f2fa5ccd-dedf-4e11-8590-c4e37c6a98f6",
                              "type": "elif",
                              "conditionRaw": "story.day3_brush_choice == \"prey\"",
                              "dialogue": [
                                {
                                  "id": "item-990b40dd-4b6a-4c3d-860c-cec3e1275d4e",
                                  "type": "dialogue",
                                  "characterId": null,
                                  "text": "The mirror scene gives it heat and a specific peril."
                                },
                                {
                                  "id": "item-bb6ed200-f894-40c3-b782-aa4a0d7ef867",
                                  "type": "dialogue",
                                  "characterId": null,
                                  "text": "She looked at him when she should have looked at the lady. He saw her looking."
                                },
                                {
                                  "id": "item-4b677ab7-ae39-4fdd-b014-852e2a5d6b7b",
                                  "type": "dialogue",
                                  "characterId": null,
                                  "text": "On the page, that visibility is the chapter's fulcrum: the maid is most dangerous precisely when she is most readable, because readability assumes the reader knows what to do with her."
                                }
                              ],
                              "condition": {
                                "operator": "and",
                                "clauses": []
                              },
                              "rawCondition": "story.day3_brush_choice == \"prey\""
                            },
                            {
                              "id": "a409c53f-ea4e-4ff4-8cde-4b1b0a55d51d",
                              "type": "else",
                              "conditionRaw": null,
                              "dialogue": [
                                {
                                  "id": "item-8b409936-8403-456f-9e0a-483baeeecdf6",
                                  "type": "dialogue",
                                  "characterId": null,
                                  "text": "The fallen brush gives it the angle no gentleman thinks to check."
                                },
                                {
                                  "id": "item-194f88fe-34fc-4b47-891d-383d683ef67f",
                                  "type": "dialogue",
                                  "characterId": null,
                                  "text": "From the floor she saw the polished boot, the clenched slipper, the hem of her own uniform trembling against the carpet."
                                },
                                {
                                  "id": "item-cd9c6fb2-a9bb-4f98-a437-003ab31d3a00",
                                  "type": "dialogue",
                                  "characterId": null,
                                  "text": "On the page, the maid's clumsiness is her method. The view from below has its own authority and he never looked down long enough to claim it."
                                }
                              ],
                              "condition": {
                                "operator": "and",
                                "clauses": []
                              }
                            }
                          ],
                          "id": "item-85d50e8d-59bb-4d7d-acb9-26d2fc15336e"
                        },
                        {
                          "type": "python_script",
                          "code": "story.complete_manuscript_chapter(\"day3_chapter\")",
                          "id": "item-7ec08d95-b7f9-4eef-9f11-b641fc0a9b7a"
                        },
                        {
                          "id": "item-feacf998-52bd-4166-9a20-a02015705834",
                          "type": "call",
                          "destinationLabelId": "label-50c93452-a12f-49cf-9982-b6cc72b97648"
                        },
                        {
                          "type": "python_script",
                          "code": "apply_effects(insp=-20)",
                          "id": "item-f4c16853-def2-4dc2-97bd-16e8e8f37876"
                        },
                        {
                          "type": "python_script",
                          "code": "apply_effects(stern_susp=5)",
                          "id": "item-ded8817b-e907-4406-b7e5-d2e63264b2c9"
                        },
                        {
                          "id": "item-c552dbd1-4a62-476a-a30d-8b192c70ac17",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "Chapter Three is complete."
                        },
                        {
                          "id": "item-ac665f36-8f20-4d6c-bcbe-c1fc38fe6272",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "I do not feel safer."
                        },
                        {
                          "id": "item-a5bd8cf6-8c62-4145-ab96-951419d1a156",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "I feel more legible, exposed on my own pages."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      },
                      "rawCondition": "can_write_ch3_manuscript()"
                    },
                    {
                      "id": "2f610593-e997-4bc5-8334-eb944ddfd4ee",
                      "type": "elif",
                      "conditionRaw": "story.has_manuscript_chapter(\"day2_chapter\")",
                      "dialogue": [
                        {
                          "id": "item-3f4de7ee-dffb-4f8e-9ba6-f83b77d458d9",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "I try."
                        },
                        {
                          "id": "item-cc9040ea-630f-4c85-9441-e22f15230787",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "That is the most humiliating phrase in the English language."
                        },
                        {
                          "id": "item-bf51e1dc-aa37-40da-8817-29ed2dace3f3",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "The pen moves, stops, scratches, fails."
                        },
                        {
                          "id": "item-b38d0bb4-79ed-415c-8afc-5958c090b4d4",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "The material is too close. Mr. Locke is too close. My own want is too close behind him."
                        },
                        {
                          "id": "item-3bdf2d06-8021-4660-b4c7-0876dd6a3f32",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "No chapter comes."
                        },
                        {
                          "id": "item-e8d9d98e-9aa1-4862-a6e4-f9a26bda19d2",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "Only fragments, warm and useless."
                        },
                        {
                          "type": "python_script",
                          "code": "story.set_day3_failed_write(True)",
                          "id": "item-fee9036d-e01a-456b-9847-ce3b13992714"
                        },
                        {
                          "type": "python_script",
                          "code": "apply_balanced_effect(\"curious\", intensity=\"standard\", witness=\"stern\")",
                          "id": "item-e75e6cd7-2330-488f-b110-534295befd80"
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      },
                      "rawCondition": "story.has_manuscript_chapter(\"day2_chapter\")"
                    }
                  ],
                  "id": "item-6f1d0ab1-dfe7-4977-ab21-b4619c3ce506"
                }
              ]
            },
            {
              "id": "b37e556c-156d-459c-b9f9-0be934d6a6fd",
              "text": "Do not write. Barricade the door and wait for morning. [[Safety over progress]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "story.set_day3_night_action(\"barricade\")",
                  "id": "item-2689b167-95e8-4e40-9873-45c5f1768ee9"
                },
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"transgressive\", intensity=\"standard\", witness=\"stern\")",
                  "id": "item-0312d14c-c585-4784-a07e-85d0ed89e047"
                },
                {
                  "id": "item-521cc388-75e8-4cdc-aa7e-90c7bdb1c363",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I push the washstand against the door."
                },
                {
                  "id": "item-8446e8dd-616a-4f14-a82a-65052200d4dc",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "It is not heavy enough to stop a determined man."
                },
                {
                  "id": "item-a7b32114-bf29-495c-a0f3-e55ab1f1903c",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "It is heavy enough to let me pretend there is a difference between fear and strategy."
                },
                {
                  "id": "item-9dc23674-ae43-4987-aa30-8270e328ea5d",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "At half past nine, footsteps pause outside."
                },
                {
                  "id": "item-b54512e1-2b38-479e-9e30-f44b47f22de1",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The handle does not move."
                },
                {
                  "id": "item-83554d9f-2871-41bf-b567-6d3dfbb37d3d",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "That is worse, somehow, the silent proximity humming through the wood."
                },
                {
                  "id": "item-382a8629-f24c-4f51-803c-93e01d88d236",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "In the morning, the page is still blank."
                },
                {
                  "id": "item-a1325c1f-9388-4deb-b124-6ea9c5626683",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "But so is the doorway."
                }
              ]
            }
          ],
          "id": "item-1891be1a-6c9c-4587-9e10-a1fdb75b90f0"
        },
        {
          "type": "python_script",
          "code": "resolve_turn()",
          "id": "item-9ecf1fa1-e93a-45e8-b2e9-4161d464df81"
        },
        {
          "id": "item-e5a00158-c5d7-4926-bc4b-f5e54db5752b",
          "type": "jump",
          "destinationLabelId": "label-fdbb3f86-a9f2-4011-937c-a66925b7ac87"
        }
      ]
    },
    {
      "id": "label-5763213a-0f5a-4a7d-8491-907899a4d999",
      "name": "day104",
      "x": 17700,
      "y": 11737.5,
      "dialogue": [
        {
          "id": "item-3b0dcfb6-6c98-4dc0-a7a8-3f0e35af0d6b",
          "type": "jump",
          "destinationLabelId": "label-fdbb3f86-a9f2-4011-937c-a66925b7ac87"
        }
      ]
    },
    {
      "id": "label-fdbb3f86-a9f2-4011-937c-a66925b7ac87",
      "name": "day104_morning",
      "x": 18100,
      "y": 10890,
      "dialogue": [
        {
          "type": "python_script",
          "code": "time_manager.set_current_day(4)",
          "id": "item-4c857cd1-7a94-4542-803d-02c3c6c958d5"
        },
        {
          "type": "python_script",
          "code": "set_time_period(\"Morning\")",
          "id": "item-50111089-0674-4fb8-a2bc-808e63e9fed4"
        },
        {
          "id": "item-2194f593-8e4c-4a1c-b047-8ff89e9f8e91",
          "type": "jump",
          "destinationLabelId": "label-2eb64572-53ac-4f98-bf44-d1ba9fbcbe55"
        }
      ]
    },
    {
      "id": "label-2eb64572-53ac-4f98-bf44-d1ba9fbcbe55",
      "name": "day104_1_false_dawn_suite_window",
      "x": 18500,
      "y": 10890,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "fade",
          "id": "item-3227e168-8d1a-4ba6-9171-2a303a25c07b",
          "backgroundId": "bg_master_suite_day"
        },
        {
          "id": "item-fc446590-dc44-4566-87d3-92a210751fd5",
          "type": "dialogue",
          "characterId": null,
          "text": "Morning enters the Master Suite as if nothing terrible has ever happened there."
        },
        {
          "id": "item-2e897409-db3d-4476-b29f-c9f1d0aec95e",
          "type": "dialogue",
          "characterId": null,
          "text": "That is the talent of expensive rooms."
        },
        {
          "id": "item-6e60f3e1-4f0f-4fad-866c-ffcb3a4c9e69",
          "type": "dialogue",
          "characterId": null,
          "text": "They reset themselves."
        },
        {
          "id": "item-f8eb230f-5410-4d04-a1f1-4674a47e316e",
          "type": "dialogue",
          "characterId": null,
          "text": "Gideon and Vance have gone to a matinee in the West End."
        },
        {
          "id": "item-6c8024f3-07e7-49a4-86f2-a83b99eead29",
          "type": "dialogue",
          "characterId": null,
          "text": "Stern believes I am polishing silver on the ground floor."
        },
        {
          "id": "item-a3ff0b2e-340d-4ccb-a112-0c407b33b552",
          "type": "dialogue",
          "characterId": null,
          "text": "Missy believes I am avoiding her because guilt has finally made me decent."
        },
        {
          "id": "item-c1ce0c2c-9c89-400b-8058-c7082fafafd4",
          "type": "dialogue",
          "characterId": null,
          "text": "Everyone is wrong in a useful direction."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "13852217-15b5-403f-8415-956dd212a04a",
              "type": "if",
              "conditionRaw": "story.day3_ultimatum == \"defied\"",
              "dialogue": [
                {
                  "id": "item-90b624ec-5074-4d0b-8f00-812dce385eb1",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Last night I told Gideon that my writing was not part of my service."
                },
                {
                  "id": "item-d5ef1508-793f-4cc4-8356-194bd740ee18",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Today I prove it by committing a crime in his room."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day3_ultimatum == \"defied\""
            },
            {
              "id": "7584d79f-7c0f-4d63-900d-739e547296d6",
              "type": "elif",
              "conditionRaw": "story.day3_ultimatum == \"bargained\"",
              "dialogue": [
                {
                  "id": "item-c709dfd4-7efe-437f-911d-234c2c702c10",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Last night I gave Gideon three sentences and kept the rest."
                },
                {
                  "id": "item-205d343e-ef19-4ef7-8cbc-cdc52b000c29",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Today I need something of his to balance the exchange."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day3_ultimatum == \"bargained\""
            },
            {
              "id": "514170fb-7c00-46eb-a041-0f5336b6c347",
              "type": "elif",
              "conditionRaw": "story.day3_ultimatum == \"surrendered\"",
              "dialogue": [
                {
                  "id": "item-34b1e7a6-bf50-4168-996a-a590a9ea2961",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Last night he sent me back sharpened and ashamed."
                },
                {
                  "id": "item-86cf0478-1064-43e8-812b-2214e8dd629d",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Today I come looking for a blade that is not made of appetite."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day3_ultimatum == \"surrendered\""
            },
            {
              "id": "3b792411-afac-4760-813f-7753ddb68b58",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-0689658c-870c-4144-b719-738993cb8799",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Last night left me with too many questions and not enough power."
                },
                {
                  "id": "item-597bb29d-6941-421d-a6a4-932f5131425a",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Today I come looking for the thing powerful men hide from one another."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-0534fc94-37e9-448b-8e32-97cb311fa1c5"
        },
        {
          "id": "item-e4950f0b-3f04-49ef-96a1-481e79e6e9a4",
          "type": "dialogue",
          "characterId": null,
          "text": "The manuscript needs an ending."
        },
        {
          "id": "item-67296d4f-31f9-426f-9782-79ff37a6919b",
          "type": "dialogue",
          "characterId": null,
          "text": "Not a pretty one. Not a moral one."
        },
        {
          "id": "item-0231c7f1-fdcf-43db-8a43-1648ce65b30b",
          "type": "dialogue",
          "characterId": null,
          "text": "An ending with enough truth inside it to bite."
        },
        {
          "id": "item-2d707422-94fb-42a7-b27e-fd8edd3d73aa",
          "type": "dialogue",
          "characterId": null,
          "text": "I cross to the heavy oak writing desk."
        },
        {
          "id": "item-864b8ea8-8048-4531-8e77-dd6b144e454d",
          "type": "dialogue",
          "characterId": null,
          "text": "The lockbox waits beneath a stack of correspondence, exactly where a careless man would not hide it and a confident man would."
        },
        {
          "id": "item-f83dcdad-99c8-4d50-a24a-f23a3c5be32e",
          "type": "jump",
          "destinationLabelId": "label-ed37cf44-44c6-42aa-95f7-8b0dc3c751fa"
        }
      ]
    },
    {
      "id": "label-ed37cf44-44c6-42aa-95f7-8b0dc3c751fa",
      "name": "day104_1_lockbox_evidence",
      "x": 18900,
      "y": 10890,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-fd4c03a6-0914-407d-87aa-548211675960",
          "backgroundId": "bg_master_suite_day"
        },
        {
          "id": "item-073d40c5-1c87-442c-ad24-b3a75a170a0c",
          "type": "dialogue",
          "characterId": null,
          "text": "The hairpin bends before the lock does."
        },
        {
          "id": "item-08ad1075-2661-4092-afff-f00695f7a7aa",
          "type": "dialogue",
          "characterId": null,
          "text": "My hands are slick. My breath is too loud."
        },
        {
          "id": "item-792dc8b0-a9c8-4b79-aa9c-faa506402cd9",
          "type": "dialogue",
          "characterId": null,
          "text": "Every sound in the room becomes Stern's footstep, Gideon's voice, Vance's laugh returning early down the hall."
        },
        {
          "id": "item-7d517846-f662-438f-aa2c-ee0b6efc8343",
          "type": "dialogue",
          "characterId": null,
          "text": "Then the lock gives."
        },
        {
          "id": "item-ca1bf3b2-9cf9-43ed-9c95-138cd1d1df83",
          "type": "dialogue",
          "characterId": null,
          "text": "Inside: bank notes, a theatre programme, two folded letters, and an envelope stiff with photographic paper."
        },
        {
          "id": "item-72eabe43-daa1-467b-ab45-beb771560396",
          "type": "dialogue",
          "characterId": null,
          "text": "The photograph is not large."
        },
        {
          "id": "item-c9831c4f-3a4a-4acc-9850-ac54cf1f26e9",
          "type": "dialogue",
          "characterId": null,
          "text": "That feels obscene somehow."
        },
        {
          "id": "item-14fb3ab0-87ac-4658-a3d7-3e44f5785a67",
          "type": "dialogue",
          "characterId": null,
          "text": "A life can fit on paper smaller than a prayer book."
        },
        {
          "id": "item-55fe7aa7-4980-4bb1-95da-1144632e3210",
          "type": "dialogue",
          "characterId": null,
          "text": "Gideon. Another gentleman."
        },
        {
          "id": "item-20549a55-2b02-4d67-ab87-4f0f3a7faf3d",
          "type": "dialogue",
          "characterId": null,
          "text": "Not merely friendly. Not deniable in any honest room."
        },
        {
          "id": "item-93175022-a1e3-4dca-ac06-0d672d55aaaf",
          "type": "dialogue",
          "characterId": null,
          "text": "My first feeling is triumph."
        },
        {
          "id": "item-1893e6c1-a4ef-4a21-9c1f-269a1c8e968f",
          "type": "dialogue",
          "characterId": null,
          "text": "My second is fear."
        },
        {
          "id": "item-c6c72f40-2652-42eb-bb32-2d593ec27abf",
          "type": "dialogue",
          "characterId": null,
          "text": "My third is the writer's monstrous little gratitude."
        },
        {
          "id": "item-3b11e756-608e-4428-91f4-fa710fa9c41e",
          "type": "dialogue",
          "characterId": null,
          "text": "Here is the ending."
        },
        {
          "id": "item-cd599bdf-2f26-4948-8152-50b27304134e",
          "type": "dialogue",
          "characterId": null,
          "text": "Here is the proof."
        },
        {
          "id": "item-9486a958-b8f5-4f34-ab11-06b90c80fc3c",
          "type": "dialogue",
          "characterId": null,
          "text": "Here is the thing even Gideon Locke cannot smooth over with a quiet voice and a better coat."
        },
        {
          "type": "python_script",
          "code": "story.set_day4_evidence_discovered(True)",
          "id": "item-bfed510f-7e40-4851-aa73-f266d6a6ada0"
        },
        {
          "type": "python_script",
          "code": "apply_balanced_effect(\"creative\", intensity=\"standard\")",
          "id": "item-9da8ab0a-5de6-45f1-a2ec-12c9313b0374"
        },
        {
          "id": "item-ae655098-c989-4906-964a-63ac4a42180c",
          "type": "dialogue",
          "characterId": null,
          "text": "I slide the photograph beneath my bodice."
        },
        {
          "id": "item-d682b885-d38e-4016-a7e0-ed2b635c05ce",
          "type": "dialogue",
          "characterId": null,
          "text": "It scratches once against my skin and becomes real."
        },
        {
          "id": "item-9a203d41-5cc4-4ea5-9588-70e6ef80cece",
          "type": "jump",
          "destinationLabelId": "label-6a529dbf-2eff-4d61-991e-6634316e32f2"
        }
      ]
    },
    {
      "id": "label-6a529dbf-2eff-4d61-991e-6634316e32f2",
      "name": "day104_2_return_early",
      "x": 19300,
      "y": 10890,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-f83d34ed-501b-4a34-b81b-e35e83787421",
          "backgroundId": "bg_master_suite_day"
        },
        {
          "id": "item-5034e068-7771-4bec-a260-66b28175aa89",
          "type": "dialogue",
          "characterId": null,
          "text": "A key turns in the outer door."
        },
        {
          "id": "item-2f06b0af-8096-4803-a8ec-96891c8a1f39",
          "type": "show",
          "characterId": "vance_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "moveinright",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "vance_sprite neutral"
        },
        {
          "id": "item-c4a38316-01ea-473c-87eb-659f174582ad",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "—and I will not tolerate that tone from her again. Not from a dresser, not from a maid, not from anyone."
        },
        {
          "id": "item-ec650a5e-21ac-4662-8225-f89a5ad50de1",
          "type": "dialogue",
          "characterId": null,
          "text": "They are early."
        },
        {
          "id": "item-ecd674ac-b8f0-490b-a1a4-e16bb5858df7",
          "type": "dialogue",
          "characterId": null,
          "text": "Of course they are early."
        },
        {
          "id": "item-617a0919-d055-4fab-8cfb-52abc95a6a93",
          "type": "dialogue",
          "characterId": null,
          "text": "False dawns do not announce the trap. They simply let the sun in first."
        },
        {
          "id": "item-c6f352ee-2f51-4908-b41b-97612dae40f5",
          "type": "dialogue",
          "characterId": null,
          "text": "I am standing beside Gideon's desk with his lockbox open and his ruin pressed against my ribs."
        },
        {
          "type": "choice",
          "options": [
            {
              "id": "5f2c67be-d257-46d2-9a63-aba2a1f1ba25",
              "text": "Hide in the cold hearth. Keep the evidence. [[Ghost escape: high suspicion]]",
              "dialogue": [
                {
                  "id": "item-b6f92a4b-a0b7-491a-9dd7-35839f6ec456",
                  "type": "jump",
                  "destinationLabelId": "label-f6ca0cf9-5ba3-476a-9cd7-8f375fd1ebf3"
                }
              ]
            },
            {
              "id": "034da07e-d2c3-4846-bd1a-15c83aa8eca8",
              "text": "Stand in the room and lie cleanly. Keep the evidence. [[Prey escape: high visibility]]",
              "dialogue": [
                {
                  "id": "item-395dc721-f015-49ea-80ef-3a1aa10bf75e",
                  "type": "jump",
                  "destinationLabelId": "label-4b7ce8ca-ffa4-4754-9d82-9ab41734ba25"
                }
              ]
            },
            {
              "id": "1eeec43b-f485-43e9-9c9c-ead9636ab48d",
              "text": "Use Missy as cover. Lose the evidence, preserve the alibi. [[Predator escape: low suspicion, moral cost]]",
              "dialogue": [
                {
                  "id": "item-ba00b5c4-d534-49d4-bf8a-76f2b20a4fbe",
                  "type": "jump",
                  "destinationLabelId": "label-cf221f9a-19e5-4517-b237-8587e00df7d2"
                }
              ]
            }
          ],
          "id": "item-24d80e9f-fc7f-4735-85f8-1f1e79e3b88e"
        },
        {
          "id": "item-cf1ef5f3-bdde-405b-8572-9348f736ce95",
          "type": "jump",
          "destinationLabelId": "label-f6ca0cf9-5ba3-476a-9cd7-8f375fd1ebf3"
        }
      ]
    },
    {
      "id": "label-f6ca0cf9-5ba3-476a-9cd7-8f375fd1ebf3",
      "name": "day104_2_escape_fireplace",
      "x": 19700,
      "y": 11522.5,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-3a3fd759-f4d9-4372-b6d3-ddc88ac0c533",
          "backgroundId": "bg_master_suite_day"
        },
        {
          "type": "python_script",
          "code": "story.set_day4_escape_state(\"fireplace\")",
          "id": "item-4fb85d0e-4244-4c75-a38e-f10dcf678037"
        },
        {
          "type": "python_script",
          "code": "story.set_has_photograph(True)",
          "id": "item-ed497b30-2a32-4788-9a72-ef6cead33abd"
        },
        {
          "type": "python_script",
          "code": "apply_balanced_effect(\"transgressive\", intensity=\"standard\", witness=\"stern\")",
          "id": "item-bfe0dfaa-ec04-4f21-971d-5d185e70a84e"
        },
        {
          "id": "item-874507a7-7e5a-457a-9dac-c4d8b50852c9",
          "type": "dialogue",
          "characterId": null,
          "text": "The hearth is enormous, black, and unlit."
        },
        {
          "id": "item-832d6332-2e05-4690-b7e9-92d867e197a4",
          "type": "dialogue",
          "characterId": null,
          "text": "A servant could disappear there."
        },
        {
          "id": "item-042c31ff-9a2a-47b1-a5c0-7973ce32258b",
          "type": "dialogue",
          "characterId": null,
          "text": "A desperate one does."
        },
        {
          "id": "item-5b4a42e1-41ac-4c56-b2b2-8c4dd80c62fc",
          "type": "dialogue",
          "characterId": null,
          "text": "I close the lockbox, shove it beneath the correspondence, and crawl into the cold soot with the photograph against my chest."
        },
        {
          "id": "item-751215a8-82a9-4b48-98cc-3534a8732764",
          "type": "show",
          "characterId": "gideon_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "gideon_sprite angry"
        },
        {
          "id": "item-4f5970be-35a4-4858-b956-7b4bccd20921",
          "type": "show",
          "characterId": "vance_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "vance_sprite angry"
        },
        {
          "id": "item-444fa390-2e80-48e3-a8d3-6de6873e480b",
          "type": "dialogue",
          "characterId": null,
          "text": "They enter arguing."
        },
        {
          "id": "item-09d1151e-0053-4eb1-9e21-a8668896f4f4",
          "type": "dialogue",
          "characterId": null,
          "text": "Vance first, bright with grievance. Gideon behind her, quiet enough to make the silence arrange itself around him."
        },
        {
          "id": "item-ad3bc817-ddb3-4473-bae2-e03bca0b83fa",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "You let her smirk at me."
        },
        {
          "id": "item-772068bb-0a91-4208-b615-c44c1e63d06c",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "I let many people do many things when their errors are instructive."
        },
        {
          "id": "item-b952c1cf-a24b-45d5-8b8b-4ed11d60dfe3",
          "type": "dialogue",
          "characterId": null,
          "text": "From the hearth, I can see only shoes, hems, the polished legs of furniture."
        },
        {
          "id": "item-de83db84-3d73-4a4d-a7dc-63f6f3c5519f",
          "type": "dialogue",
          "characterId": null,
          "text": "It is the brush scene again, but lower. Dirtier."
        },
        {
          "id": "item-a1addba9-58e0-4376-bdaf-f115cf7049f7",
          "type": "dialogue",
          "characterId": null,
          "text": "The room has angles gentlemen never check because they cannot imagine needing them."
        },
        {
          "id": "item-7f61524f-42a0-4550-84da-f3d468a343c5",
          "type": "dialogue",
          "characterId": null,
          "text": "Soot enters my nose."
        },
        {
          "id": "item-479a4f14-0a34-402e-8478-9b526e1b195c",
          "type": "dialogue",
          "characterId": null,
          "text": "I breathe through my apron and do not cough."
        },
        {
          "id": "item-b53f1b87-837d-4d53-ae61-7290594b55e0",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "You are not listening to me."
        },
        {
          "id": "item-3fb5665b-16a4-4bf6-93c9-d1cbf09ab370",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "I am listening precisely as much as required."
        },
        {
          "id": "item-55d558cd-a48e-4178-98c0-137553068b39",
          "type": "dialogue",
          "characterId": null,
          "text": "An hour passes in pieces."
        },
        {
          "id": "item-d2ad75e0-1177-4330-a2a7-51112d01993b",
          "type": "dialogue",
          "characterId": null,
          "text": "At last they move into the bedchamber."
        },
        {
          "id": "item-ceaa7f73-c0ab-4728-a4e7-86f0ed7777d4",
          "type": "dialogue",
          "characterId": null,
          "text": "At last the sitting room is empty."
        },
        {
          "type": "hide",
          "layer": null,
          "id": "item-bbd62434-4a58-4ab1-85c5-56347ae9dd35",
          "characterId": "gideon_sprite"
        },
        {
          "type": "hide",
          "layer": null,
          "id": "item-b9b8c1c2-7d5a-40c6-afd3-8425b6a264f3",
          "characterId": "vance_sprite"
        },
        {
          "id": "item-de45ed47-2915-4146-9594-b5d2dc22a5af",
          "type": "dialogue",
          "characterId": null,
          "text": "I slide out of the hearth blackened, shaking, alive."
        },
        {
          "id": "item-edef3bd0-8ee9-4657-a27c-fcdc0fe0b590",
          "type": "dialogue",
          "characterId": null,
          "text": "The photograph is still mine."
        },
        {
          "id": "item-7573d9b6-d757-461b-9472-4e4f8d035683",
          "type": "dialogue",
          "characterId": null,
          "text": "So is the soot."
        },
        {
          "id": "item-8f5bf8d5-bd9c-4168-9d56-04f59a20edba",
          "type": "jump",
          "destinationLabelId": "label-6eb01ae9-d4e8-47d8-b211-27d8c55b780e"
        }
      ]
    },
    {
      "id": "label-4b7ce8ca-ffa4-4754-9d82-9ab41734ba25",
      "name": "day104_2_escape_bold_lie",
      "x": 19700,
      "y": 10890,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-e53ef643-cf0a-458d-8af5-1af2ab553dc8",
          "backgroundId": "bg_master_suite_day"
        },
        {
          "type": "python_script",
          "code": "story.set_day4_escape_state(\"bold_lie\")",
          "id": "item-ea131b3b-8122-4a9c-85bc-c3cf587b5105"
        },
        {
          "type": "python_script",
          "code": "story.set_has_photograph(True)",
          "id": "item-03dc6863-8d59-4c8f-80c9-b90d764d9260"
        },
        {
          "type": "python_script",
          "code": "apply_balanced_effect(\"transgressive\", intensity=\"standard\", witness=\"vance\")",
          "id": "item-3fffd4dc-31d8-4d2a-bc3d-b6d108a97789"
        },
        {
          "id": "item-ed407b02-9130-4834-9c18-3b0c95300516",
          "type": "dialogue",
          "characterId": null,
          "text": "I close the lockbox with one hand and seize the dust cloth with the other."
        },
        {
          "id": "item-295de43c-6b28-410b-ad12-1d11eef2cfa8",
          "type": "dialogue",
          "characterId": null,
          "text": "By the time the door opens, I am wiping the desk as if mahogany has personally insulted Miss Stern."
        },
        {
          "id": "item-1b2e5b65-b7de-47b0-9a7e-555cb1a2a677",
          "type": "show",
          "characterId": "vance_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "vance_sprite angry"
        },
        {
          "id": "item-39c6c935-74a4-411c-a249-59f303da2e0e",
          "type": "show",
          "characterId": "gideon_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "gideon_sprite angry"
        },
        {
          "id": "item-0aa010ed-d6a1-4299-91e2-f6937b1f8ffe",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "What is she doing here?"
        },
        {
          "id": "item-86a8669c-750b-4b66-bbd7-c668e9151616",
          "type": "dialogue",
          "characterId": null,
          "text": "Gideon's eyes move from my face to the desk."
        },
        {
          "id": "item-ce8952e5-08c7-4a49-b1cf-e05f86cc68a5",
          "type": "dialogue",
          "characterId": null,
          "text": "Then to my hands."
        },
        {
          "id": "item-f16b55da-170f-44e7-a83e-aee5f5ae67ca",
          "type": "dialogue",
          "characterId": null,
          "text": "Then back to my face."
        },
        {
          "id": "item-71180bd0-731f-4a8d-ad13-5f82946be14a",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "That is my question."
        },
        {
          "id": "item-fa5daa5b-eac7-446b-9ee5-5c4033656f96",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base"
        },
        {
          "id": "item-caf42fec-19f5-4177-a921-2ba7a0e5bbbc",
          "type": "show",
          "characterId": "vance_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "move",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "vance_sprite angry"
        },
        {
          "id": "item-a7f047c8-af2e-4bd1-82a4-0f6a34f55f7a",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Checking the desk for dust, Sir. Miss Stern's orders."
        },
        {
          "id": "item-5d205738-d06b-461a-8cf6-77b0e13fdd46",
          "type": "dialogue",
          "characterId": null,
          "text": "The lie stands up."
        },
        {
          "id": "item-431763da-53fc-46f5-b4ce-9b2355e3b637",
          "type": "dialogue",
          "characterId": null,
          "text": "Badly."
        },
        {
          "id": "item-dc5fed5b-68de-42d1-a54a-533d3be50ae5",
          "type": "dialogue",
          "characterId": null,
          "text": "But standing is sometimes enough if everyone in the room prefers not to touch it."
        },
        {
          "id": "item-af51928a-7c4e-4cda-a171-69fb70ff0f6f",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "This suite was cleaned at dawn."
        },
        {
          "id": "item-976df7ce-cdfb-4058-a3cb-3e715edde2f1",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Yes, Madam. Miss Stern is particular after complaints."
        },
        {
          "id": "item-1f08708f-8e2e-40ae-bffa-de7fd52a0803",
          "type": "dialogue",
          "characterId": null,
          "text": "A small cruelty."
        },
        {
          "id": "item-c8c5f3d8-ac2f-4d75-8215-f9f89db72764",
          "type": "dialogue",
          "characterId": null,
          "text": "Not safe."
        },
        {
          "id": "item-4a6b922e-a120-486c-b73b-d28bf1667b37",
          "type": "dialogue",
          "characterId": null,
          "text": "Useful."
        },
        {
          "id": "item-433ea6a2-a437-41d9-9bd5-840358c7deea",
          "type": "dialogue",
          "characterId": "char-3879d838-4e67-46b4-b6c9-636ab5fcef38",
          "text": "Complaints?"
        },
        {
          "id": "item-4c7ad025-5808-47cc-a371-bafa64111ac8",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Leave us."
        },
        {
          "id": "item-35588f66-9332-4afe-9ceb-d732d74c3fc1",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Yes, Sir."
        },
        {
          "id": "item-868cf201-133e-4efd-ae67-40a9a10b2174",
          "type": "dialogue",
          "characterId": null,
          "text": "As I pass him, Gideon does not move aside until the last possible second."
        },
        {
          "id": "item-d604726b-fd76-4544-8792-b2570ab33138",
          "type": "dialogue",
          "characterId": null,
          "text": "The photograph scratches my skin like a second pulse."
        },
        {
          "id": "item-7d19adaa-c55f-4e8d-a6f6-eae70a0c8a5b",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Cora."
        },
        {
          "id": "item-cbb3b945-79ca-4f57-9c7a-1ba60febecb3",
          "type": "dialogue",
          "characterId": null,
          "text": "I stop."
        },
        {
          "id": "item-5b0c4d79-09d2-4f10-96d4-ada0ff9194f0",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "You are developing a troubling habit of being where you ought not be."
        },
        {
          "id": "item-b58f7758-f577-4045-a910-f0fe765e1ff3",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Then I am grateful the house has so many rooms, Sir."
        },
        {
          "id": "item-333a24e7-ce96-483b-b87d-5e4fe688d6c7",
          "type": "dialogue",
          "characterId": null,
          "text": "A foolish answer."
        },
        {
          "id": "item-31518d9d-2831-4afc-96b6-97447e47c1e2",
          "type": "dialogue",
          "characterId": null,
          "text": "A glorious one."
        },
        {
          "id": "item-03b9bd23-f6e9-4ae1-bce0-dfa759129afd",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Go."
        },
        {
          "type": "hide",
          "layer": null,
          "id": "item-ee83ad27-ab74-4d01-b47a-26221947f090",
          "characterId": "gideon_sprite"
        },
        {
          "type": "hide",
          "layer": null,
          "id": "item-158b2cb6-407f-47ce-8d4b-df59e87fd119",
          "characterId": "vance_sprite"
        },
        {
          "id": "item-dcba8084-0196-4d87-8355-c1ca6207099c",
          "type": "dialogue",
          "characterId": null,
          "text": "I go before my courage notices what it has done."
        },
        {
          "id": "item-5e696458-1dd9-4b64-bb85-0e949a21fb7f",
          "type": "jump",
          "destinationLabelId": "label-6eb01ae9-d4e8-47d8-b211-27d8c55b780e"
        }
      ]
    },
    {
      "id": "label-cf221f9a-19e5-4517-b237-8587e00df7d2",
      "name": "day104_2_escape_missy_cover",
      "x": 19700,
      "y": 8067.5,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-9fc142a0-19b5-4e99-82e6-db2853c20408",
          "backgroundId": "bg_master_suite_day"
        },
        {
          "type": "python_script",
          "code": "story.set_day4_escape_state(\"missy_cover\")",
          "id": "item-1c22e93d-b7bb-4713-a3fe-4f9b501f9da4"
        },
        {
          "type": "python_script",
          "code": "story.set_has_photograph(True)",
          "id": "item-192f906e-5ecf-45a7-8075-9744111c13d5"
        },
        {
          "type": "python_script",
          "code": "story.set_missy_day4_used_as_cover(True)",
          "id": "item-7a7fbdfe-3c6d-4be8-940d-94c231f07c36"
        },
        {
          "type": "python_script",
          "code": "apply_effects(vance_susp=-15, missy_susp=20, insp=5, corr=20)",
          "id": "item-c66126f1-11c4-418a-ac99-cd4ed641f2ce"
        },
        {
          "id": "item-68191619-cee0-4293-8c36-1cd5c366bcc8",
          "type": "dialogue",
          "characterId": null,
          "text": "Panic makes the first decision."
        },
        {
          "id": "item-5296485d-e700-4784-8aaa-050dc9ab6ed9",
          "type": "dialogue",
          "characterId": null,
          "text": "Ambition improves it."
        },
        {
          "id": "item-6ec41393-63a4-4850-81be-416eef562e05",
          "type": "dialogue",
          "characterId": null,
          "text": "I slide the photograph into my bodice and close the lockbox, leaving everything else exactly as I found it."
        },
        {
          "id": "item-7759e756-cea5-42cd-aba1-c2177ab3d239",
          "type": "dialogue",
          "characterId": null,
          "text": "I have the proof."
        },
        {
          "id": "item-bde6edfb-0293-44c9-b02c-1c4c67b0a460",
          "type": "dialogue",
          "characterId": null,
          "text": "I slip through the servants' door as the outer door opens."
        },
        {
          "type": "scene",
          "layer": null,
          "transition": "fade",
          "id": "item-51e29d3c-63d9-4674-9456-2977212495e2",
          "backgroundId": "bg_servants_corridor_day"
        },
        {
          "id": "item-0a337d7f-4d6f-43fe-8308-e3eb02b2c1e0",
          "type": "show",
          "characterId": "missy_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "missy_sprite shocked"
        },
        {
          "id": "item-86d3cb81-6004-4447-83fa-b41bfaff5b78",
          "type": "dialogue",
          "characterId": null,
          "text": "Missy is in the corridor with a stack of towels."
        },
        {
          "id": "item-386a1448-90e1-4cb5-b3b0-8fe0eb1f98b9",
          "type": "dialogue",
          "characterId": null,
          "text": "Wrong place. Right time."
        },
        {
          "id": "item-d219a3a3-bfc4-4465-ba73-ccae5a74f1d5",
          "type": "dialogue",
          "characterId": null,
          "text": "For me."
        },
        {
          "id": "item-bd310718-a99f-42a2-bcf3-f024807e1e84",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base"
        },
        {
          "id": "item-eea1b7e3-f92d-4b1a-b9af-ddbc3e147c4c",
          "type": "show",
          "characterId": "missy_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "move",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "missy_sprite shocked"
        },
        {
          "id": "item-80ca7834-e627-4422-8a25-269820a6a71f",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "They need you in the suite. Now. Take this."
        },
        {
          "id": "item-998f7d1e-1508-47da-a09a-673a5c9189fe",
          "type": "dialogue",
          "characterId": null,
          "text": "I push the dust cloth into her hands."
        },
        {
          "id": "item-f94a37bd-ee79-4926-a60c-9cf4509ba5b3",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "What? Cora... why are you so pale? Is there..."
        },
        {
          "id": "item-ea9d5186-830a-4fab-bc19-b79e487f9262",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Vance is asking for the room to be checked again. Hurry before she comes looking and Miss Stern hears the noise."
        },
        {
          "id": "item-d218cd9c-4ee5-4846-bc9d-81191625ea94",
          "type": "dialogue",
          "characterId": null,
          "text": "Missy's eyes flick to my hands, then to the heavy master suite door. Her sharp observancy senses the transgressive panic in my chest."
        },
        {
          "id": "item-818e9e14-978c-447d-a0f6-c67860719529",
          "type": "dialogue",
          "characterId": null,
          "text": "She hesitates, her defensive moral guard up, but the threat of Stern and the sheer habit of class-duty make her step forward."
        },
        {
          "id": "item-672786b7-fadc-49d2-a669-7fdb77c3b6d5",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "All right. But don't you wander off, Cora. It isn't proper."
        },
        {
          "id": "item-419e97f4-2bc1-400c-b8d0-2520c2456e03",
          "type": "dialogue",
          "characterId": null,
          "text": "She goes in, her shoulders squared against the impending storm."
        },
        {
          "id": "item-edf3b9e0-294b-4226-b7a5-2eebcd5b6824",
          "type": "dialogue",
          "characterId": null,
          "text": "The door closes."
        },
        {
          "id": "item-10cd84b1-1160-421e-9bd4-812a618626e1",
          "type": "dialogue",
          "characterId": null,
          "text": "Instead of running, I find myself frozen against the mahogany paneling."
        },
        {
          "id": "item-7db709c5-e024-448a-a435-b920bfcd85ec",
          "type": "dialogue",
          "characterId": null,
          "text": "The wood is cold, but the keyhole is a hot eye, a direct conduit to the danger inside."
        },
        {
          "id": "item-20365721-6b91-4d51-b4cc-5b2c8e149534",
          "type": "dialogue",
          "characterId": null,
          "text": "I press my ear to the crack of the service door, holding my breath."
        },
        {
          "id": "item-9db1e44a-dc38-4865-8fb5-7fed4959deef",
          "type": "dialogue",
          "characterId": null,
          "text": "Within the Master Suite, the air is thick and heavy. I hear the slow, rhythmic click of Mr. Locke's walking stick against the polished floorboards."
        },
        {
          "id": "item-5a08410f-4b53-4bb6-85aa-444b27a385c2",
          "type": "dialogue",
          "characterId": null,
          "text": "He is circling her."
        },
        {
          "id": "item-6959ee5c-f348-45d4-9bd1-17c2d7638add",
          "type": "show",
          "characterId": "missy_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "missy_sprite shocked"
        },
        {
          "id": "item-6615c0f4-04d4-4412-b44c-65f36b6f93c7",
          "type": "show",
          "characterId": "gideon_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "moveinright",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "gideon_sprite neutral"
        },
        {
          "id": "item-e0cb7b0a-6a76-474f-83c9-aac42f3c8e84",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "And what, pray tell, are you doing in my quarters, girl? Miss Stern was quite specific about who was to clear these rooms."
        },
        {
          "id": "item-def632e0-6289-4f3c-a16d-298bbe725a61",
          "type": "dialogue",
          "characterId": null,
          "text": "His voice is a low, silk-wrapped growl, vibrating through the wood. Missy's reply is barely a whisper, yet steady, carrying that active, unyielding moral shield."
        },
        {
          "id": "item-f2775e99-d5db-4a08-8d85-4516bd3cc0b7",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "The towels, Mr. Locke. They were reported damp. I was sent to change them."
        },
        {
          "id": "item-27d3a3aa-46bb-45c2-8bda-7b200a85a231",
          "type": "dialogue",
          "characterId": null,
          "text": "The click of the walking stick stops. Through the gap, I can see Gideon step directly into her space, his towering frame casting a shadow that completely swallows her."
        },
        {
          "id": "item-bee8d127-74d3-4435-b0f6-7b4d27bd2932",
          "type": "dialogue",
          "characterId": null,
          "text": "He raises his silver-headed walking stick, the polished wood gliding slowly, suggestively up the front of her uniform. The tip rests beneath her chin, tilting it upward, forcing her head back."
        },
        {
          "id": "item-083ae89a-9c76-4bb0-8d91-1e3fd6900417",
          "type": "dialogue",
          "characterId": null,
          "text": "Missy's breath catches. Her hands clench the damp towels against her chest as if they are a shield."
        },
        {
          "id": "item-e931386d-ca27-4097-a43d-fa2b1be090e0",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Damp, you say? And who, Missy, gave you that report? A maid does not walk into a gentleman's study without a very specific command."
        },
        {
          "id": "item-71cc876b-313a-4c67-b06b-bf61fd30dabf",
          "type": "dialogue",
          "characterId": null,
          "text": "He steps closer, his boots almost touching the hem of her skirt. He leans down, his face inches from hers, his free hand rising to trail the starched edge of her collar, his fingers brushing the sensitive skin of her jaw. The class terror is absolute, yet the physical proximity burns with a dark, forbidden heat."
        },
        {
          "id": "item-24a32f0c-8db1-455e-9512-54b04bcdecc9",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Is there someone else here? Someone who sent you to find what does not belong to you?"
        },
        {
          "id": "item-ab3d4e4b-b234-4d06-91c4-9f937369cb10",
          "type": "dialogue",
          "characterId": null,
          "text": "For a terrible second, I am sure she will speak my name. My pulse beats like a trapped bird in my ears."
        },
        {
          "id": "item-f1711cd9-6504-4fe9-b94f-6dd669aef008",
          "type": "dialogue",
          "characterId": null,
          "text": "But Missy does not flinch from his touch. Her chin remains high against the silver tip of his cane, her dark eyes locking onto his with a quiet, sovereign courage that defies the terror of his touch."
        },
        {
          "id": "item-d6ed82c7-d75b-4d23-8f80-68bdc9f9404d",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "I was sent by the service board, Sir. No one else."
        },
        {
          "id": "item-1804ef7b-45c9-4247-9913-65312e579bcc",
          "type": "dialogue",
          "characterId": null,
          "text": "Gideon's thumb traces the edge of her jaw, his eyes narrowing as he studies her flushed face, her parted lips. The silence between them is taut, charged with a heavy, dangerous intimacy."
        },
        {
          "id": "item-970b1264-48b7-4917-88c2-b0d00e7da9ba",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "You are either very loyal, or very foolish, Missy. Both are expensive qualities in this house."
        },
        {
          "id": "item-ab70005a-1e38-4b14-90ff-a68a5398f804",
          "type": "dialogue",
          "characterId": null,
          "text": "He slowly lowers the cane, his fingers sliding off her jaw with a lingering touch that leaves Missy trembling yet unbowed."
        },
        {
          "id": "item-4d500ef8-4a16-4165-b66b-90065e9884e3",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Change the towels. Then leave. Before I decide to charge you for the privilege of your presence."
        },
        {
          "id": "item-57bbc464-a8fd-490f-82de-429f282f1785",
          "type": "dialogue",
          "characterId": null,
          "text": "I step back from the door, my hands trembling, my chest tight with a sudden, devastating wave of shame."
        },
        {
          "id": "item-3267fd7b-68b2-4bc6-9cbc-f23d6457f474",
          "type": "dialogue",
          "characterId": null,
          "text": "I have survived."
        },
        {
          "id": "item-046b5e86-8e93-4c7c-8614-770d32814ef4",
          "type": "dialogue",
          "characterId": null,
          "text": "But Missy has paid for my survival in currency I did not have the courage to spend."
        },
        {
          "id": "item-745f7d60-d380-4fe5-bfb4-f5be7ca3a0aa",
          "type": "jump",
          "destinationLabelId": "label-6eb01ae9-d4e8-47d8-b211-27d8c55b780e"
        }
      ]
    },
    {
      "id": "label-6eb01ae9-d4e8-47d8-b211-27d8c55b780e",
      "name": "day104_evening",
      "x": 20100,
      "y": 11095,
      "dialogue": [
        {
          "id": "item-4d65292a-4ed6-4b10-b899-f29c57e80129",
          "type": "jump",
          "destinationLabelId": "label-f8ca5477-5db4-4481-aeb3-c2e8e122eeeb"
        }
      ]
    },
    {
      "id": "label-f8ca5477-5db4-4481-aeb3-c2e8e122eeeb",
      "name": "day104_3_stern_pressure",
      "x": 20500,
      "y": 11095,
      "dialogue": [
        {
          "type": "python_script",
          "code": "set_time_period(\"Evening\")",
          "id": "item-3872461d-323c-422d-a312-b6b3293eb8a4"
        },
        {
          "type": "scene",
          "layer": null,
          "transition": "fade",
          "id": "item-d7b8c68a-464c-4ea5-9b96-4f2afb53c064",
          "backgroundId": "bg_servants_quarters_dusk"
        },
        {
          "id": "item-b4f79951-dc7d-4c9c-96e6-eb50e94088c7",
          "type": "dialogue",
          "characterId": null,
          "text": "By twilight, survival has begun charging interest."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "8c2f57b1-051d-42f6-b538-c6dd870af224",
              "type": "if",
              "conditionRaw": "story.day4_escape_state == \"fireplace\"",
              "dialogue": [
                {
                  "id": "item-1adf8fe5-84b3-47d4-bf42-cb5db6dee72e",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Soot sits beneath my nails, in the seams of my cuffs, along the hem where the apron should be clean."
                },
                {
                  "id": "item-69832cec-85b3-4098-b1b5-8a7d7678b23a",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Every black mark is a witness with no loyalty."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day4_escape_state == \"fireplace\""
            },
            {
              "id": "143d23c5-c90e-46ee-86f3-ef6e84854189",
              "type": "elif",
              "conditionRaw": "story.day4_escape_state == \"bold_lie\"",
              "dialogue": [
                {
                  "id": "item-ed378567-fa51-4b3e-914e-5394bf95ed34",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Gideon saw me near the desk."
                },
                {
                  "id": "item-a8378af1-2471-44d5-b84f-ef7c65b11351",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "He may not know what I took."
                },
                {
                  "id": "item-1afa602f-bf7f-4002-a7f3-5fca03a2a1c1",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "He knows I took the right kind of risk."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day4_escape_state == \"bold_lie\""
            },
            {
              "id": "f23cb9d0-36bc-48ae-ac54-ee5558a4562f",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-74f88812-db31-4fdc-bf90-e5a73177005d",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Missy returned from the suite with red eyes and a voice pressed flat."
                },
                {
                  "id": "item-afe5ac8e-48b7-4e6a-8af4-ee6f58edbf74",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Vance had found fault. Of course Vance had found fault."
                },
                {
                  "id": "item-89ce98d7-fc5d-4efb-a2b2-a0e1077603db",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I had handed her a target and called it haste."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-15632b68-ca45-4591-bcdd-7e785b1937d6"
        },
        {
          "id": "item-cfe0a862-dd38-48b3-b17f-cd3410db2be9",
          "type": "show",
          "characterId": "stern_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "stern_sprite stern"
        },
        {
          "id": "item-ae72cbe4-9cf8-47f0-9d92-20db6b5abfcf",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "Cora."
        },
        {
          "id": "item-9123d162-e68f-4608-9c98-36b1dc121857",
          "type": "dialogue",
          "characterId": null,
          "text": "Stern does not need evidence to suspect disorder."
        },
        {
          "id": "item-11f76525-239f-4935-9353-28608dbe3443",
          "type": "dialogue",
          "characterId": null,
          "text": "She smells it the way laundresses smell mildew."
        },
        {
          "id": "item-f07e0ed8-6c92-4aa9-a440-02f3c7a47d4a",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "You were difficult to locate this afternoon."
        },
        {
          "type": "choice",
          "options": [
            {
              "id": "a608e6a0-c361-4e72-a11d-d5b8801fe295",
              "text": "Give her the boring servant answer. [[-Suspicion]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "story.set_day4_stern_response(\"boring\")",
                  "id": "item-fa20267f-6361-4e33-bdb4-a5cd4cbd241c"
                },
                {
                  "type": "python_script",
                  "code": "apply_effects(stern_susp=-15)",
                  "id": "item-bca85060-cf11-451a-b5a1-710f5cfed584"
                },
                {
                  "id": "item-995c9855-42df-492f-b47f-9a47c1eb7801",
                  "type": "show",
                  "characterId": "cora_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "None",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "cora_sprite base"
                },
                {
                  "id": "item-410f112a-2af0-4f62-9b80-d9db491948bc",
                  "type": "show",
                  "characterId": "stern_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "move",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "stern_sprite stern"
                },
                {
                  "id": "item-06a14eb4-2ed1-4715-a49e-b336b87f423d",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "Ground-floor silver, Ma'am. Then linens. Then back stairs. I should have reported each change."
                },
                {
                  "id": "item-5d69b21e-049c-49b2-a83f-ad73cf63f489",
                  "type": "dialogue",
                  "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
                  "text": "Yes. You should have."
                },
                {
                  "id": "item-afa9a092-a29c-4fbc-8b94-59eccdadb4a5",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She dislikes the answer because it gives her nothing but negligence."
                },
                {
                  "id": "item-4d2f8e4c-9289-49a6-8913-9b232c35578f",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Negligence is punishable."
                },
                {
                  "id": "item-4a0787a4-28e1-430c-bde5-1b247f48e3fd",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "It is also ordinary."
                }
              ]
            },
            {
              "id": "54283c55-f8f9-43de-bd07-01a9587131b0",
              "text": "Let her see I am frightened, not guilty. [[+Inspiration, small suspicion]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "story.set_day4_stern_response(\"frightened\")",
                  "id": "item-e732a5a5-52af-40c8-919b-a8b14b49875e"
                },
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"observant\", intensity=\"standard\")",
                  "id": "item-9022ff08-c6d6-45cf-9b62-6c1a49054ca5"
                },
                {
                  "id": "item-a76f1de6-26b2-47e5-9013-db625c93a083",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "I am trying not to make mistakes, Ma'am. That is making me slower."
                },
                {
                  "id": "item-4f051bb8-e9cc-46b5-90c0-6bf267c07917",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Stern studies me."
                },
                {
                  "id": "item-5f5c64c6-d1f3-4560-bec5-194f29306d8b",
                  "type": "dialogue",
                  "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
                  "text": "Fear is useful only when it sharpens. Yours is beginning to spill."
                },
                {
                  "id": "item-f482e222-a2d5-4901-8e77-3e8b9e774f75",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "Yes, Ma'am."
                },
                {
                  "id": "item-0ac09d6f-ce3f-4ec2-9be6-c62c6a356f59",
                  "type": "dialogue",
                  "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
                  "text": "Clean it up."
                }
              ]
            },
            {
              "id": "c2e6e80c-59de-49ce-8f77-1cc0cfc7f01a",
              "text": "Hide behind Missy if she was used. [[Conditional moral cost]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "story.set_day4_stern_response(\"missy_cover\")",
                  "id": "item-f3a96e45-891c-4bff-8ef7-f8836ce3d606"
                },
                {
                  "type": "python_script",
                  "code": "apply_effects(stern_susp=-10, missy_susp=10, corr=10)",
                  "id": "item-e79eb829-b7d8-4fc1-a6b1-899838eb2723"
                },
                {
                  "id": "item-ecc884bb-8b9b-4c11-9cbe-db7d7af68647",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "Missy was with the suite, Ma'am. I was sent back down after delivering cloth."
                },
                {
                  "id": "item-2d9fd7b6-020f-47c1-b03c-d6e5540ea307",
                  "type": "dialogue",
                  "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
                  "text": "I asked where you were."
                },
                {
                  "id": "item-8825aa52-44bc-4ed0-85eb-019adb668031",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "Yes, Ma'am. Below stairs."
                },
                {
                  "id": "item-794d55d9-0f5a-4290-8394-75e317eabfe2",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The answer is shaped to be true from a distance."
                },
                {
                  "id": "item-1536e935-fa8a-4758-b409-893597b82439",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Stern hears the distance."
                },
                {
                  "id": "item-78fafbb2-c430-4aaf-a218-46f515349c11",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She cannot yet cross it."
                }
              ]
            }
          ],
          "id": "item-1c1843da-ed8c-4ab6-848c-07ec56cbdc76"
        },
        {
          "id": "item-153023e1-6114-4941-8e3f-3cf23d746748",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "Whatever has caught the attention of that room, remove yourself from it."
        },
        {
          "id": "item-94f3e852-4659-48a3-8640-d0d5a9669d83",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Yes, Ma'am."
        },
        {
          "id": "item-802c5b64-d769-442e-92ac-1bc021378184",
          "type": "dialogue",
          "characterId": "char-73fd1dc9-64b4-4025-9914-bd03daa1de46",
          "text": "Do not mistake a guest's notice for fortune. That lesson ruins girls."
        },
        {
          "type": "hide",
          "layer": null,
          "id": "item-b0c6b612-093e-4027-bdda-6bad99f444b6",
          "characterId": "stern_sprite"
        },
        {
          "id": "item-333f91b7-11de-4d02-8bd6-ccb3cfa927a4",
          "type": "dialogue",
          "characterId": null,
          "text": "She leaves me with the warning and no proof."
        },
        {
          "id": "item-76b0d25c-5840-4644-a162-5382d0c0bb04",
          "type": "dialogue",
          "characterId": null,
          "text": "Tonight, no proof is beginning to feel like grace."
        },
        {
          "id": "item-38620b58-74e6-4ef8-832c-aaff160d9ff9",
          "type": "jump",
          "destinationLabelId": "label-8ba6b0bd-ce7b-4bbd-9587-755d98ab403b"
        }
      ]
    },
    {
      "id": "label-8ba6b0bd-ce7b-4bbd-9587-755d98ab403b",
      "name": "day104_4_twilight_ledger_false_dawn",
      "x": 20900,
      "y": 11095,
      "dialogue": [
        {
          "id": "item-00f1a84a-6874-4276-b652-9da4cd5a57b6",
          "type": "call",
          "destinationLabelId": "label-618fe0c3-adcd-4ffa-925f-194ecff37842"
        },
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-31eb7975-c101-4714-ba67-d4fa5b5946f9",
          "backgroundId": "bg_servants_quarters_dusk"
        },
        {
          "type": "python_script",
          "code": "show_ledger_ui()",
          "id": "item-4b4e40ab-2f3f-4e3a-a355-b7996b2b569d"
        },
        {
          "id": "item-92400038-ac75-44ea-9edb-2ade19f00d2c",
          "type": "dialogue",
          "characterId": null,
          "text": "The ledger sits open on my desk."
        },
        {
          "id": "item-81b1f729-8908-490a-9d90-c475c437265a",
          "type": "dialogue",
          "characterId": null,
          "text": "My hands have stopped shaking."
        },
        {
          "id": "item-44e5c252-9e92-4d46-ab59-b84e9c40b069",
          "type": "dialogue",
          "characterId": null,
          "text": "This feels like improvement until I realise they have only gone numb."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "0cd53ebe-af6c-4ca8-aada-f6812154840c",
              "type": "if",
              "conditionRaw": "story.has_photograph",
              "dialogue": [
                {
                  "id": "item-8e5806bd-4284-4103-8630-55e283eb2ff7",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The photograph is hidden beneath the loose board under my bed."
                },
                {
                  "id": "item-c1a2c84b-710a-4081-8e08-4fd4a76a8a96",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Not safe."
                },
                {
                  "id": "item-12506592-980a-41f0-8729-89c362e1be0c",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Safer than my skin."
                },
                {
                  "id": "item-2e64a38a-9fa6-4e4e-a055-04f8ba3283ea",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I have evidence."
                },
                {
                  "id": "item-e641108b-3aca-4dbf-91b9-56a86ccd4ec1",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I have leverage."
                },
                {
                  "id": "item-1ce2cc60-4193-42be-ba47-8ea82321a7ac",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I have, for the first time since arriving, something Gideon Locke does not want me to have."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.has_photograph"
            },
            {
              "id": "1e7d5420-b3cc-4ba6-96ec-c3464b1f780b",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-be8acc5a-e234-41e3-af74-b81828832cd4",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The lockbox still holds what I could not carry."
                },
                {
                  "id": "item-de5fecb7-4cd4-4b69-9daf-f37ce7aa26f4",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I have memory, appetite, and a manuscript — not yet a weapon."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-e0e9bf45-12d2-4851-8234-374b8c1dc4e1"
        },
        {
          "id": "item-f89d1322-fbad-41d9-a55c-3e1d3bab970f",
          "type": "dialogue",
          "characterId": null,
          "text": "The manuscript waits."
        },
        {
          "id": "item-8d69af43-89c1-4ed5-9b48-14ddfeb06205",
          "type": "dialogue",
          "characterId": null,
          "text": "Not for more material."
        },
        {
          "id": "item-d08ec0a3-1791-4716-8c73-6091210516ab",
          "type": "dialogue",
          "characterId": null,
          "text": "For courage."
        },
        {
          "type": "choice",
          "options": [
            {
              "id": "d51b0679-10c2-4555-b5b2-3e30f2806bef",
              "text": "Perform visible penance to lower their guard. [[Atonement]]",
              "dialogue": [
                {
                  "id": "item-c968ad7a-b38f-4f00-a63b-9098bca4a1ef",
                  "type": "jump",
                  "destinationLabelId": "label-1e4151cc-5fa9-4caf-8f4c-aff64b7dafc6"
                }
              ]
            },
            {
              "id": "d3a0ec97-971a-47b9-8206-b43b1f021b4f",
              "text": "Risk the dark room to write the triumphant chapter. [[Triumphant Write]]",
              "dialogue": [
                {
                  "type": "if_block",
                  "branches": [
                    {
                      "id": "4537d44c-4c1b-4fc5-a1fd-b14a611fd3fb",
                      "type": "if",
                      "conditionRaw": "player.anxiety >= ANXIETY_WRITE_PARALYSIS",
                      "dialogue": [
                        {
                          "id": "item-9e21f6f7-1da9-4329-8881-8e88682ea1b6",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "My hand shakes too violently to hold the pen. The hotel feels alive, every creaking floorboard a footstep, every shadow a reaching hand."
                        },
                        {
                          "id": "item-f6c35852-5393-4ebf-aa7d-b66d2b0c9125",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "At this level of anxiety, my panic blocks the pen."
                        },
                        {
                          "id": "item-345e07b8-9697-43b9-ab59-cfdbedde7fe1",
                          "type": "jump",
                          "destinationLabelId": "label-8ba6b0bd-ce7b-4bbd-9587-755d98ab403b"
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      },
                      "rawCondition": "player.anxiety >= ANXIETY_WRITE_PARALYSIS"
                    }
                  ],
                  "id": "item-a4a641cb-4aa4-4b75-a5fc-068ca14dec8c"
                },
                {
                  "id": "item-2764b3c1-49c5-4c20-a82e-39fb5f78ff1a",
                  "type": "jump",
                  "destinationLabelId": "label-b1462b72-ef0c-4ba7-85fd-c9544bb7b866"
                }
              ]
            },
            {
              "id": "6ed81921-c1b2-491d-9602-58a71a6df15f",
              "text": "Find Missy and salvage what remains of her trust. [[Missy Repair]]",
              "dialogue": [
                {
                  "id": "item-41f08069-5051-47c4-9965-463ef4b83d5a",
                  "type": "jump",
                  "destinationLabelId": "label-0564942f-a1cd-4a2a-9945-8b05d4b2c7a1"
                }
              ]
            }
          ],
          "id": "item-495eab33-a15c-4fd5-9c6c-3908e62e9361"
        },
        {
          "id": "item-6c22497b-379f-4202-8a5a-d43ec936831b",
          "type": "jump",
          "destinationLabelId": "label-618fe0c3-adcd-4ffa-925f-194ecff37842"
        }
      ]
    },
    {
      "id": "label-618fe0c3-adcd-4ffa-925f-194ecff37842",
      "name": "day104_evening_consequence_window",
      "x": 22100,
      "y": 11532.5,
      "dialogue": [
        {
          "id": "item-67e416b5-7ab1-4359-a44c-a44559dd7768",
          "type": "call",
          "destinationLabelId": "label-5f635f30-8ef3-4f17-80e7-4e5cde552ded"
        },
        {
          "id": "item-e02a47ee-ace6-4612-9ad1-cbd8e14e50eb",
          "type": "call",
          "destinationLabelId": "label-7d0ab68c-82c3-423b-a677-a442c420ec43"
        }
      ]
    },
    {
      "id": "label-1e4151cc-5fa9-4caf-8f4c-aff64b7dafc6",
      "name": "day104_4_atonement",
      "x": 21700,
      "y": 11457.5,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-688a480d-da4f-4f81-8d29-1ecd08394967",
          "backgroundId": "bg_servants_quarters_dusk"
        },
        {
          "type": "python_script",
          "code": "story.set_day4_twilight_action(\"atonement\")",
          "id": "item-a2671d12-1d31-483d-8ed0-3bd60a374521"
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "04d3b60c-4348-457b-89e8-4ce76c55d61d",
              "type": "if",
              "conditionRaw": "story.day4_escape_state == \"fireplace\"",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_effects(stern_susp=-30)",
                  "id": "item-f9c418bb-e13d-4d0b-8f24-3f2d8608a163"
                },
                {
                  "id": "item-fa2fce7b-9f5a-4826-9894-1392763cb227",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I scrub soot from my apron until the water turns grey, then black, then grey again."
                },
                {
                  "id": "item-455ac166-830b-44be-8b26-e457bf42b6db",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "My knuckles split."
                },
                {
                  "id": "item-616a0860-fd10-4943-ae1e-9a3c491e2cf8",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Good. Blood is easier to explain than chimney dust."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day4_escape_state == \"fireplace\""
            },
            {
              "id": "f858de3d-d42d-45fe-92fe-f99905cc5159",
              "type": "elif",
              "conditionRaw": "story.day4_escape_state == \"bold_lie\"",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_effects(stern_susp=-25)",
                  "id": "item-18696e20-e978-4d8b-965e-372f935373cf"
                },
                {
                  "id": "item-63ce19cd-1a42-4274-8b04-4b0b2e1369fd",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I sit in the laundry corner and mend cuffs with saintly dullness."
                },
                {
                  "id": "item-3c3497bd-9c6c-4e8b-ac5c-a2d8485f8ddc",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Anyone watching sees a maid trying very hard to become furniture."
                },
                {
                  "id": "item-003c4333-947c-4704-a6f6-5b2f1abc8bbe",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "That is the point."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day4_escape_state == \"bold_lie\""
            },
            {
              "id": "a668ee51-2bea-4c8f-aee5-a7c00bdf6561",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "apply_effects(stern_susp=-10)",
                  "id": "item-d6f2367c-c284-4203-85f6-155940f93758"
                },
                {
                  "id": "item-0cde9591-9c81-4ed6-99fd-77019806f711",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I fold linens."
                },
                {
                  "id": "item-21c1d5d8-20c1-4a76-971e-fd406ee7cad9",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I carry water."
                },
                {
                  "id": "item-29b5371c-3644-4be6-9658-57397e416569",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I become useful in every visible way, which is not the same as becoming good."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-1f91121c-4c33-4a16-9ad6-37d090d97d8c"
        },
        {
          "id": "item-3a9ee69b-ff1f-49de-b232-573b88c93321",
          "type": "dialogue",
          "characterId": null,
          "text": "The hour does what it can."
        },
        {
          "id": "item-4b81a0fb-c173-4506-bdd9-77d418a45433",
          "type": "dialogue",
          "characterId": null,
          "text": "It lowers the heat on my neck."
        },
        {
          "id": "item-e757f230-8490-47ba-a5fd-570ebb731bee",
          "type": "dialogue",
          "characterId": null,
          "text": "But the manuscript remains untouched. I am too exhausted to write."
        },
        {
          "id": "item-62838663-1193-48c5-af36-df53bb5196da",
          "type": "jump",
          "destinationLabelId": "label-8d9600ae-280d-46fe-a57b-0886ab86aae9"
        }
      ]
    },
    {
      "id": "label-0564942f-a1cd-4a2a-9945-8b05d4b2c7a1",
      "name": "day104_4_missy_repair",
      "x": 21700,
      "y": 8132.5,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-7efd6073-a3e5-4e41-97be-987c15caf237",
          "backgroundId": "bg_servants_quarters_dusk"
        },
        {
          "id": "item-0da1bc07-c1cb-474a-b9eb-d194134ff7d6",
          "type": "show",
          "characterId": "missy_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "missy_sprite shocked"
        },
        {
          "type": "python_script",
          "code": "story.set_day4_twilight_action(\"missy_repair\")",
          "id": "item-0c5fe4b3-fd4b-4873-8b58-805d0a343dd0"
        },
        {
          "type": "python_script",
          "code": "apply_balanced_effect(\"creative\", intensity=\"standard\")",
          "id": "item-2e44e8ad-c7d9-42a9-b966-3efa69319e27"
        },
        {
          "type": "python_script",
          "code": "apply_effects(missy_susp=-15)",
          "id": "item-0f1f2e36-ece0-48b1-a3c7-55a409f88970"
        },
        {
          "id": "item-3fd05b96-18f0-4c3e-9a0f-b2e5a3c44fbf",
          "type": "dialogue",
          "characterId": null,
          "text": "Missy sits on the edge of her narrow iron bed, twisting her linen handkerchief until her knuckles are as white as the cloth."
        },
        {
          "id": "item-058b6014-af00-4ddd-9ed1-45f2d4153754",
          "type": "dialogue",
          "characterId": null,
          "text": "She doesn't look like a simple country girl caught in a mistake tonight. Her eyes are quiet, exceptionally focused, and dangerous with what they have resolved."
        },
        {
          "id": "item-32977ebb-94b9-4212-aa10-5a645fb904c6",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "You sent me in there, Cora Vale."
        },
        {
          "id": "item-4b5031b1-ba1b-40f0-9c31-8fb537e4c1d9",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base"
        },
        {
          "id": "item-e2d3c98f-0065-4098-8255-269e2bd66944",
          "type": "show",
          "characterId": "missy_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "move",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "missy_sprite shocked"
        },
        {
          "id": "item-9197b840-d494-44c3-a9b5-c9b7ec1dcb23",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "I did."
        },
        {
          "id": "item-331d09bc-250c-4030-ac64-ea426d487eb8",
          "type": "dialogue",
          "characterId": null,
          "text": "The word is smaller than the betrayal. It hangs in the narrow space between us, smelling of cedar oil and grey twilight."
        },
        {
          "id": "item-a322e752-d584-4efc-b2c1-1fea4fe85bc1",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "You knew they were returning. You knew Mr. Locke was angry. You were standing by his open desk, your hands clean, while I was sent into the suite to take the blow."
        },
        {
          "id": "item-64d33314-ce52-4523-bb59-65187897e999",
          "type": "dialogue",
          "characterId": null,
          "text": "She rises, her posture rigid, her voice losing every trace of its deferential junior maid register."
        },
        {
          "id": "item-4b827526-d789-4d3f-baec-9c17e8988a40",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "You're a spy, aren't you? Prying into the suites, stealing Mr. Locke's letters... and you used me as a shield because you thought I was too stupid to see the joints in your performance."
        },
        {
          "id": "item-2bf88d61-46d0-4d33-ae49-863aafb4bb21",
          "type": "dialogue",
          "characterId": null,
          "text": "She has decoded it. Not with empty-headed curiosity, but with a sharp, sovereign intellect."
        },
        {
          "id": "item-ecd8884e-d225-47be-bacc-684521aadb89",
          "type": "dialogue",
          "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
          "text": "Why, Cora? I trusted you. I thought... I thought you were the only righteous thing in this terrible hotel."
        },
        {
          "type": "choice",
          "options": [
            {
              "id": "52233985-7926-494c-9f3a-acca686c6cab",
              "text": "Give her the raw, romantic truth. Offer my vulnerability. [[Tender Romance / Path B Intimacy]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "story.set_missy_day4_repair_state(\"partial_truth\")",
                  "id": "item-ed45d473-efff-42b0-a771-c17203aa3809"
                },
                {
                  "type": "python_script",
                  "code": "apply_effects(missy_susp=-25, vance_susp=5, insp=15, corr=10)",
                  "id": "item-89b62e69-fda6-44c6-8317-3c10285672c1"
                },
                {
                  "id": "item-e26d4fe8-a139-4134-959d-1cf82efc17d3",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "Because I was cornered, and I was terrified of losing the only thing that keeps me alive in this place. My writing. My book."
                },
                {
                  "id": "item-fd0662f4-536d-4183-addf-fcac8d8ca7d2",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "And because when I am terrified, I am a monster. But I would rather be dismissed a hundred times than see you look at me with that wall between us."
                },
                {
                  "id": "item-4a9c8653-de38-44a7-8aec-b138bfb875d8",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I step closer, crossing the narrow floorboards, my hands reaching out to cover her raw, trembling fingers."
                },
                {
                  "id": "item-bfeb927f-d453-4dc5-98f9-7c221777ece5",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Missy flinches, her breath catching, but she does not step back. The proximity between us is suffocating, thick with lye-steam and the scent of cedar."
                },
                {
                  "id": "item-53569767-3414-45a1-bcf9-a178d6a3b558",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "I do not see you as a shield, Missy. I see you as the only beautiful thing in this hotel that isn't a lie."
                },
                {
                  "id": "item-c689e228-b1fc-452a-8682-7f857628b6da",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I raise my hand, my thumb tracing the damp, flushed skin of her cheek, my voice dropping the maid's mask entirely. It is a quiet, sovereign register of deep romantic tenderness."
                },
                {
                  "id": "item-41bc842d-1ee5-49b2-a4de-795827a51f03",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Missy's eyes widen, her breathing turning shallow, her chest rising against my hands."
                },
                {
                  "id": "item-3a22e33d-3ed9-46e6-858b-a1034af7ddfa",
                  "type": "dialogue",
                  "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
                  "text": "Cora... your touch is like... it's like a sin I want to keep."
                },
                {
                  "id": "item-cbf2e0cd-0e33-4814-b27b-556064d4757c",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "Then let us keep it together. No more shields, Missy. Only this."
                },
                {
                  "id": "item-b9000c11-a744-48f4-9de2-1e93cd32fc86",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She leans her forehead against my shoulder, her body trembling with a self-possessed, deliberate yielding."
                },
                {
                  "id": "item-a9cb63b7-cc13-439c-988f-f795824fd574",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The physical heat between us is a dramatic middle ground—restrained, dangerous, but born of absolute romantic trust."
                }
              ]
            },
            {
              "id": "18b054fd-078b-4cf0-af1e-56d3ee700de5",
              "text": "Keep the truth. Offer a coward's comfort. [[Guarded Distance]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "story.set_missy_day4_repair_state(\"comfort_lie\")",
                  "id": "item-7e2b14dc-07f4-43a5-816d-d843bdb21c0c"
                },
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"creative\", intensity=\"standard\")",
                  "id": "item-894dd3f0-36ce-4fbd-8f46-2fd4ec7db03a"
                },
                {
                  "type": "python_script",
                  "code": "apply_effects(missy_susp=-10)",
                  "id": "item-7c2cdc8a-8020-4a8e-bacc-500d4ac5f40b"
                },
                {
                  "id": "item-69dcfe36-4e14-480f-b651-e10c9adc4486",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "Because I am a coward when cornered, Missy. I saw the door, I saw the threat, and I used what was closest. It was cruel, and I cannot justify it."
                },
                {
                  "id": "item-ef7385c8-68b8-4b3f-95c0-98a974c63fae",
                  "type": "dialogue",
                  "characterId": "char-40a69e0d-a385-4733-9af7-8bdb85f4582a",
                  "text": "That is a confession, Cora. It is not an apology."
                },
                {
                  "id": "item-66772e22-6d6e-48d9-96cd-ef596eefb278",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "No. But it is the only honest thing I have left to give you."
                },
                {
                  "id": "item-3cb09dc2-06e2-4545-9539-2fa610820d8c",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I sit on the edge of the bed, leaving a cold foot of cedar wood between us."
                },
                {
                  "id": "item-d14f62b0-ed51-4e07-b277-ae2acf5c472f",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She does not ask me to leave, but her defensive moral shield is up, her posture guarded."
                },
                {
                  "id": "item-ffe32f25-a4d8-4fb0-b17e-4eed213ce2ee",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "We are safe from Miss Stern tonight, but the book has lost its partner."
                }
              ]
            }
          ],
          "id": "item-3293531d-41b1-42da-a04a-b130cf2ad2a2"
        },
        {
          "type": "hide",
          "layer": null,
          "id": "item-e71de694-cce3-4421-b37b-89f211fd1ee7",
          "characterId": "missy_sprite"
        },
        {
          "id": "item-4d9e3c94-f834-4fed-a365-3e53ef1a6c85",
          "type": "dialogue",
          "characterId": null,
          "text": "When I return to my room, the emotional toll weighs heavier than the fear."
        },
        {
          "id": "item-2b3ec743-70cd-4a3d-a057-1ef527e29d1a",
          "type": "dialogue",
          "characterId": null,
          "text": "I am safe, but the pen refuses to move. I cannot write tonight."
        },
        {
          "id": "item-156e0c05-f972-4c6d-9409-1e298c44cf76",
          "type": "jump",
          "destinationLabelId": "label-8d9600ae-280d-46fe-a57b-0886ab86aae9"
        }
      ]
    },
    {
      "id": "label-b1462b72-ef0c-4ba7-85fd-c9544bb7b866",
      "name": "day104_night",
      "x": 21300,
      "y": 11095,
      "dialogue": [
        {
          "type": "python_script",
          "code": "set_time_period(\"Night\")",
          "id": "item-a9d26452-5ce9-4be7-9948-827462ec7c91"
        },
        {
          "id": "item-28009a21-f387-4277-9b16-4c21ee022f21",
          "type": "jump",
          "destinationLabelId": "label-419a8dfe-1ad6-49d4-a322-6f31cec87dea"
        }
      ]
    },
    {
      "id": "label-419a8dfe-1ad6-49d4-a322-6f31cec87dea",
      "name": "day104_5_triumphant_chapter",
      "x": 21700,
      "y": 11095,
      "dialogue": [
        {
          "id": "item-58717737-e59c-4a7f-b2d9-48a6f002d102",
          "type": "call",
          "destinationLabelId": "label-ba7a08ab-ac6f-4455-b259-ce04ddf14339"
        },
        {
          "type": "scene",
          "layer": null,
          "transition": "fade",
          "id": "item-3efc82f2-5d60-4673-bc8a-365cdf6c5354",
          "backgroundId": "bg_cora_desk_night"
        },
        {
          "type": "python_script",
          "code": "story.set_day4_night_action(\"finish_manuscript\")",
          "id": "item-5b5b7f5c-bd5e-4cf1-94fa-8f429123a853"
        },
        {
          "id": "item-c631bcdc-cd0d-4ee3-8a8e-f6e6f07b95ac",
          "type": "dialogue",
          "characterId": null,
          "text": "Night arrives gently."
        },
        {
          "id": "item-e9d82349-26ac-4d78-a5c2-0fe133be9abf",
          "type": "dialogue",
          "characterId": null,
          "text": "Suspiciously gently."
        },
        {
          "id": "item-c47adb02-91dc-498d-afbe-1d1f6175b63e",
          "type": "dialogue",
          "characterId": null,
          "text": "No summons."
        },
        {
          "id": "item-9eed0d3a-5d2f-46fc-be29-6368725297f2",
          "type": "dialogue",
          "characterId": null,
          "text": "No knock."
        },
        {
          "id": "item-224eac01-815e-42d9-a928-fe97380371c7",
          "type": "dialogue",
          "characterId": null,
          "text": "No key turning in a room where I should not be."
        },
        {
          "id": "item-54a324ac-acbd-4392-8d50-a207b9f38a4a",
          "type": "dialogue",
          "characterId": null,
          "text": "Only the candle, the page, and everything I have stolen without permission."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "83ffaa8e-b5e1-4b7c-98d2-8590c4197329",
              "type": "if",
              "conditionRaw": "story.day4_escape_state == \"fireplace\"",
              "dialogue": [
                {
                  "id": "item-cf28295b-ed77-4b06-91da-9db170928af4",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I still feel the grate. Cold stone. Soot. The particular humiliation of pressing myself smaller than a flue."
                },
                {
                  "id": "item-1f0b191c-8a34-40d9-840c-1970b4f4ca6b",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I made myself nothing and emerged on the far side of the corridor with charcoal on my apron and the chapter already complete in my head."
                },
                {
                  "id": "item-880bfe7c-e33f-4335-adbf-d3ce54aeb6a0",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The book was always going to come out of that contraction."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day4_escape_state == \"fireplace\""
            },
            {
              "id": "d35ff2b1-e34c-4b3b-88c9-d7df8b38726e",
              "type": "elif",
              "conditionRaw": "story.day4_escape_state == \"bold_lie\"",
              "dialogue": [
                {
                  "id": "item-6ca99129-3038-4453-9fb1-5b20a336420e",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I said something outrageous and watched it land."
                },
                {
                  "id": "item-5b49cf41-c414-4c77-8470-ba39c1070ce7",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Not because they believed me. Because challenging it required effort, and men in that room reserved effort for things that mattered."
                },
                {
                  "id": "item-07822697-35a0-4d9a-9bcb-a4c104eaea51",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I was not yet a thing that mattered enough to disprove. That is the armour this chapter writes itself inside."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day4_escape_state == \"bold_lie\""
            },
            {
              "id": "cfdc6f92-605a-4e10-a0d8-d932634ac972",
              "type": "elif",
              "conditionRaw": "story.day4_escape_state == \"missy_cover\"",
              "dialogue": [
                {
                  "id": "item-ab6e936c-c4a0-426c-970c-eb8293fb6e6a",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I sent her in first."
                },
                {
                  "id": "item-98f240a3-21d2-429f-96f2-bc87ff77f671",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The corridor, the door, the timing."
                },
                {
                  "id": "item-c645d7c6-6757-490d-ae3f-a58936d2dcb8",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The manuscript gets the chapter it demanded. Missy got the corridor she did not ask for."
                },
                {
                  "id": "item-871d16ea-0549-4f58-ace5-d1b77bbbeb9d",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "That sentence must go somewhere. Here, in this chapter, it becomes a flaw with a purpose. Whether that is craft or rationalisation the page has not yet decided."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day4_escape_state == \"missy_cover\""
            },
            {
              "id": "f4253262-3b8e-4201-bb29-3ed3c2618926",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-4802647a-e1d9-48ad-abba-8b5bd6f811a6",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The escape has already become story."
                },
                {
                  "id": "item-f8e95632-9168-4864-a0c1-8c66ddc0687f",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The fear is still here. But the shape of it is cleaner now."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-170f6e22-031e-4276-813a-21235f4cde72"
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "40dd8377-4dcf-4a28-ad32-148a6cf78908",
              "type": "if",
              "conditionRaw": "story.has_photograph",
              "dialogue": [
                {
                  "id": "item-38dbee1e-3b30-47fc-ba3e-93ea31bf0f98",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The photograph is under the loose board beneath my bed."
                },
                {
                  "id": "item-8b3b48a8-90d7-42aa-8463-f7a7f255ec96",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Physical evidence. Something that can be held, shown, placed on a table and left to do its own harm."
                },
                {
                  "id": "item-a70d0a40-1bba-4735-a569-4a22f152e498",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I have a knife. Tonight I write what it looks like when a maid who has a knife is not afraid of it."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.has_photograph"
            },
            {
              "id": "23bf8315-c6ea-49bf-891f-752b45b8d4ad",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-1685db97-f11b-47e4-9b9f-86218fc13c97",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I have no paper to place between us. Only the image I carried out in my head instead of my apron pocket."
                },
                {
                  "id": "item-69abbae0-44db-4540-9ce9-78076c063293",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Memory without documentation. The chapter must convince itself that this is enough."
                },
                {
                  "id": "item-c11b6223-01b6-410e-8d47-92f1c9f37df6",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Tonight it will manage. Tomorrow Gideon will explain otherwise."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-e173d504-415e-42de-8f9f-222e3134c9d3"
        },
        {
          "id": "item-d2aa6e1c-b137-48ff-9d04-b98e57f2909a",
          "type": "dialogue",
          "characterId": null,
          "text": "The chapter comes all at once."
        },
        {
          "id": "item-a683461c-bef6-4eb3-8366-4c82d452d94f",
          "type": "dialogue",
          "characterId": null,
          "text": "Not because it is easy."
        },
        {
          "id": "item-549f9a72-deb1-4473-be3f-286580c2f89d",
          "type": "dialogue",
          "characterId": null,
          "text": "Because I finally understand the shape of the threat, and understanding is a kind of violence."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "46ffe2bf-3f43-4f8f-93f0-1e4667efa6a3",
              "type": "if",
              "conditionRaw": "story.day2_tea_choice == \"predator\"",
              "dialogue": [
                {
                  "id": "item-948c77f1-5a6f-46d0-8555-6303021d115b",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "In this chapter, the maid's composed lie becomes the only true sentence in the room."
                },
                {
                  "id": "item-1e7ccca7-6b44-4e7a-b19b-729798462adc",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She placed the dangerous thing where the dangerous man could find it and be grateful to her for finding it."
                },
                {
                  "id": "item-64960242-a3cc-49b5-9825-b49f6015e483",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She said servant ways in a voice that meant something else, and he heard both meanings and chose the useful one."
                },
                {
                  "type": "if_block",
                  "branches": [
                    {
                      "id": "93791cba-3138-45b3-8d4a-bb8a2e7104f1",
                      "type": "if",
                      "conditionRaw": "story.day3_brush_choice == \"predator\"",
                      "dialogue": [
                        {
                          "id": "item-b0ae2eda-e38b-41e4-b0b9-3d0c5a5c0231",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "In the mirror she named the seated woman's weakness with the precision of a naturalist."
                        },
                        {
                          "id": "item-24aca590-9480-4456-85a7-03b90e2901a3",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "On the page, that answer is her origin: the maid already understood the room before the gentleman finished furnishing it."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      },
                      "rawCondition": "story.day3_brush_choice == \"predator\""
                    },
                    {
                      "id": "9455f26a-7177-4294-8193-43c2e64d3272",
                      "type": "elif",
                      "conditionRaw": "story.day3_brush_choice == \"prey\"",
                      "dialogue": [
                        {
                          "id": "item-b03308cf-40c9-4c41-b20b-6c9dc243ecfd",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "She looked at him in the mirror when she should have looked at the lady, and the chapter decides this was strategy too."
                        },
                        {
                          "id": "item-7ce1ecc0-d1a1-407d-8c8a-68a18a9a991e",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "The chapter is not entirely honest with itself here. Neither is she."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      },
                      "rawCondition": "story.day3_brush_choice == \"prey\""
                    },
                    {
                      "id": "26a1a8a4-53d3-4ed6-b752-d03e1a18c58e",
                      "type": "else",
                      "conditionRaw": null,
                      "dialogue": [
                        {
                          "id": "item-fc5a4fd8-5599-4611-b19e-4a00af8d972c",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "She dropped the brush and saw the room from the floor, and the chapter finds this consistent: she collects views that polished boots cannot reach."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      }
                    }
                  ],
                  "id": "item-89bc2994-c0c5-45e9-91dc-b5ebfd3ddeac"
                },
                {
                  "id": "item-3f49ef8e-8894-4ed3-98aa-39b6a9c11c82",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The heroine in this chapter wins by being too useful to destroy and too observant to lie to without cost."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day2_tea_choice == \"predator\""
            },
            {
              "id": "646ad978-0802-4cb4-8e2c-5a46e75567ad",
              "type": "elif",
              "conditionRaw": "story.day2_tea_choice == \"prey\"",
              "dialogue": [
                {
                  "id": "item-2e119843-8dac-46a8-8029-7f10731d0f0b",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "In this chapter, the maid's partial truth becomes the sharper weapon."
                },
                {
                  "id": "item-66f2bf07-28af-4e0a-85fb-e77d2947a60a",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She admitted what she saw and did not admit where she had stood to see it."
                },
                {
                  "id": "item-f391e9af-5ae6-4085-a39e-db4efa927cf3",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The gentleman recognised the gap and called it interesting. The chapter calls the gap the entire point."
                },
                {
                  "type": "if_block",
                  "branches": [
                    {
                      "id": "495fc5e9-ddb4-4fc7-9855-a1315223ee24",
                      "type": "if",
                      "conditionRaw": "story.day3_brush_choice == \"predator\"",
                      "dialogue": [
                        {
                          "id": "item-3e08de94-c4fd-411f-a2cf-217a09701d8c",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "In the mirror she answered clinically and he called it well. The heroine in this chapter wins through accuracy: her eye is better than his secrets."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      },
                      "rawCondition": "story.day3_brush_choice == \"predator\""
                    },
                    {
                      "id": "d5493714-7dfd-4c30-ac1a-1bc4617441ea",
                      "type": "elif",
                      "conditionRaw": "story.day3_brush_choice == \"prey\"",
                      "dialogue": [
                        {
                          "id": "item-990d164c-6847-48e5-a332-d16579963edd",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "She was seen and let herself be seen, and this chapter insists that visibility chosen is different from visibility imposed."
                        },
                        {
                          "id": "item-c52320a9-348a-4c07-b27e-317deb769c41",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "That may even be true. The chapter believes it with more conviction than Cora does, tonight, writing it."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      },
                      "rawCondition": "story.day3_brush_choice == \"prey\""
                    },
                    {
                      "id": "a25fef89-dc9e-45fc-855b-7f536b38ad9c",
                      "type": "else",
                      "conditionRaw": null,
                      "dialogue": [
                        {
                          "id": "item-42bd1ab7-c16f-4f9c-84e9-ed3e8fa7b0ea",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "She retrieved the brush and called herself clumsy and kept the low angle. The chapter calls her restraint precision."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      }
                    }
                  ],
                  "id": "item-91f89c5f-8004-4b77-bb4d-7ed9484ec70d"
                },
                {
                  "id": "item-57bb6da8-2eff-4bb0-92c0-e8f115d4a4cf",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The heroine in this chapter wins because her honesty is more carefully edited than his lies."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day2_tea_choice == \"prey\""
            },
            {
              "id": "b8a4a0e8-c6d4-41fc-98e4-984b3dc704f3",
              "type": "elif",
              "conditionRaw": "story.day2_tea_choice == \"ghost\"",
              "dialogue": [
                {
                  "id": "item-9d58bec5-8d05-4545-8a13-cafc82ae5b39",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "In this chapter, the maid disappears between the accusation and the conviction."
                },
                {
                  "id": "item-388d7089-53a2-4873-be2e-b569058df883",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Her hands are empty. Another girl's hands are where the blame landed."
                },
                {
                  "id": "item-8450e972-637d-4283-ad1d-51ec40823f64",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She moved through the room like weather and the room forgot she had a shape."
                },
                {
                  "type": "if_block",
                  "branches": [
                    {
                      "id": "59e68a26-a96c-457a-9089-8ef3748a4e9b",
                      "type": "if",
                      "conditionRaw": "story.day3_brush_choice == \"predator\"",
                      "dialogue": [
                        {
                          "id": "item-4885899c-96f3-446d-bffb-fe5bd6a2c21b",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "In the mirror she was composed and direct, and in the corridor she was nowhere."
                        },
                        {
                          "id": "item-99354f04-bcfd-4c47-8b49-9574eba2d058",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "The chapter finds no contradiction in this. It may be wrong."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      },
                      "rawCondition": "story.day3_brush_choice == \"predator\""
                    },
                    {
                      "id": "82d82c45-8375-4685-82c4-3ba274af5e4a",
                      "type": "elif",
                      "conditionRaw": "story.day3_brush_choice == \"prey\"",
                      "dialogue": [
                        {
                          "id": "item-1e632daa-080f-44ca-bcaf-268440eb77b7",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "She was too visible in the mirror and too absent in the corridor. The chapter says this is her range: she can be whatever the room requires."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      },
                      "rawCondition": "story.day3_brush_choice == \"prey\""
                    },
                    {
                      "id": "93573dd2-b5c7-4817-a2c9-1b14e28991dc",
                      "type": "else",
                      "conditionRaw": null,
                      "dialogue": [
                        {
                          "id": "item-d657469c-77f6-40c3-b0b0-cf05fa7b9983",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "She dropped the brush and vanished below the line of sight. The chapter calls both moments the same technique at different scales."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      }
                    }
                  ],
                  "id": "item-70f91fc6-572b-4dc1-8794-384d97322f7b"
                },
                {
                  "id": "item-ac8b5161-e3e7-419b-8f0f-36b28ead29d2",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The heroine in this chapter wins because she is never precisely where the accusation points."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day2_tea_choice == \"ghost\""
            },
            {
              "id": "562882d0-4462-4624-87a3-7863dabc5d89",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-42edd9a2-9b92-4d6c-9593-4cd63a74787d",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "In this chapter, the maid uses what she found."
                },
                {
                  "id": "item-9ac1d97e-99b2-4f5d-a7d5-6a4a9de2d38f",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "She gathered it, kept it, brought it out into the light, and named it correctly."
                },
                {
                  "id": "item-c41a41f1-8a45-4c30-9329-71207ba9c838",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The chapter calls this sufficient."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-26a1f42d-fd99-4830-80d7-5457816a99aa"
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "97da6d1b-4d02-4102-9ec2-fddca44a3ead",
              "type": "if",
              "conditionRaw": "story.has_photograph",
              "dialogue": [
                {
                  "id": "item-2ed99e26-2504-46cd-9ac1-59a9e4d05b88",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The lord's sealed secret. The maid carrying it out in an apron pocket."
                },
                {
                  "id": "item-0e0dda79-5e05-4389-8c6e-5a4cb3dd5909",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "In this chapter, this is enough. The evidence is categorical. His denial would require an audience willing to call it perjury."
                },
                {
                  "id": "item-1dace216-06ed-488e-9560-10b88a6a1896",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The chapter does not yet know that the audience must also be willing to hear the maid."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.has_photograph"
            },
            {
              "id": "87c0d003-b8ea-4686-bcb8-474974420d0f",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-22625274-c9f9-4ded-ae52-42c53904906b",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The lord's secret is real. The maid knows it, remembers it, has written it in clean declarative sentences."
                },
                {
                  "id": "item-218bc396-b26c-4c54-a8b9-d65cf793c2be",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "In this chapter, memory is the same as evidence."
                },
                {
                  "id": "item-f0a1e4ca-33c3-4bc3-85e4-2a5a61e54c29",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The chapter believes this completely. Tomorrow will be the first test of whether the world agrees."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-5f88d43f-1543-48b2-b002-6fb1af7b0de6"
        },
        {
          "id": "item-0570dc7a-8901-4558-a99f-05c83cfd3484",
          "type": "dialogue",
          "characterId": null,
          "text": "The heroine defeats him completely. She is untouchable. She has won."
        },
        {
          "type": "python_script",
          "code": "story.complete_manuscript_chapter(\"day4_triumphant_chapter\")",
          "id": "item-65ae7574-e0b4-4178-ac82-e785ca83ae93"
        },
        {
          "id": "item-58d1e775-934d-4071-9451-93c93bcd612d",
          "type": "call",
          "destinationLabelId": "label-50c93452-a12f-49cf-9982-b6cc72b97648"
        },
        {
          "type": "python_script",
          "code": "apply_effects(insp=-15)",
          "id": "item-766b3fa3-3a54-4ddd-a849-e2f34b69f52d"
        },
        {
          "type": "python_script",
          "code": "apply_effects(stern_susp=15)",
          "id": "item-5fbdb568-bf6c-4fb8-a22e-e6a4b3007188"
        },
        {
          "id": "item-5d2e133e-88fd-4929-b229-80084b3bf609",
          "type": "dialogue",
          "characterId": null,
          "text": "The final sentence lands just before the candle dies."
        },
        {
          "id": "item-3c21f0a3-3ede-4f02-a9af-ea9d5eda8882",
          "type": "dialogue",
          "characterId": null,
          "text": "For a while, I do not move."
        },
        {
          "id": "item-ddba45ff-09b6-48b9-b558-e8eb367e94f1",
          "type": "dialogue",
          "characterId": null,
          "text": "It feels triumphant. It feels like an ending."
        },
        {
          "id": "item-1114fa54-781e-47b8-ace8-7a6002e5e037",
          "type": "dialogue",
          "characterId": null,
          "text": "I mistake fiction for reality, believing that writing the victory makes it absolute."
        },
        {
          "id": "item-6c6fef22-8552-4ed1-914f-d94842c2a932",
          "type": "jump",
          "destinationLabelId": "label-8d9600ae-280d-46fe-a57b-0886ab86aae9"
        }
      ]
    },
    {
      "id": "label-ba7a08ab-ac6f-4455-b259-ce04ddf14339",
      "name": "day104_night_consequence_window",
      "x": 22100,
      "y": 11402.5,
      "dialogue": [
        {
          "id": "item-6fa6a8bf-0ca9-48b0-884c-edafce54e06c",
          "type": "call",
          "destinationLabelId": "label-5f635f30-8ef3-4f17-80e7-4e5cde552ded"
        },
        {
          "id": "item-98786dfb-8fda-430b-bd88-8e9375626ef6",
          "type": "call",
          "destinationLabelId": "label-7d0ab68c-82c3-423b-a677-a442c420ec43"
        }
      ]
    },
    {
      "id": "label-8d9600ae-280d-46fe-a57b-0886ab86aae9",
      "name": "day104_6_false_dawn_ending",
      "x": 22100,
      "y": 11057.5,
      "dialogue": [
        {
          "type": "python_script",
          "code": "set_time_period(\"Night\")",
          "id": "item-824b93e2-1403-4e55-a4fa-b52feb6a9926"
        },
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-22b710cd-9bab-4bf3-aaf3-760f49aa1114",
          "backgroundId": "bg_cora_desk_night"
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "ef78acc0-6992-45ab-8e76-2f525bbe9e4a",
              "type": "if",
              "conditionRaw": "story.day4_night_action == \"finish_manuscript\"",
              "dialogue": [
                {
                  "id": "item-e2f4a02a-5903-4f04-974e-3197cdcf043a",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The chapter is complete."
                },
                {
                  "id": "item-1bd5ea0d-33df-4ce5-af86-c9c0ed46ad81",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I have told the story where the maid outwits the master."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day4_night_action == \"finish_manuscript\""
            },
            {
              "id": "341af182-ab2d-4726-8fcb-cd21acd66e6f",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-79611d83-343d-4b2a-9e5f-9b777e52ef1c",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The manuscript remains untouched."
                },
                {
                  "id": "item-cd714561-1391-487f-b09b-4d6f18d5158e",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "But the danger has passed. I am still here. I have survived the day."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-55e2de7b-081b-4b51-8c10-0581f5894f6f"
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "68732f99-17eb-42bd-9661-44743c977a14",
              "type": "if",
              "conditionRaw": "story.has_photograph",
              "dialogue": [
                {
                  "id": "item-baab9efe-41fd-4438-a354-dee4ae8955b9",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Beneath the loose floorboard, Gideon's photograph waits in the dark."
                },
                {
                  "id": "item-66ddef26-922c-4e7b-a83f-693ed8dfdd38",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "My leverage. My absolute proof."
                },
                {
                  "id": "item-57c0cf50-358b-48e7-966b-5fac109255f2",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Tomorrow I will decide how to use it."
                },
                {
                  "id": "item-bc166375-707e-4b47-8335-4cf584d07be5",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Tomorrow Gideon Locke will learn that servants can keep evidence."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.has_photograph"
            },
            {
              "id": "b6b0e9c1-909d-4490-a425-a8e9a22a7ff9",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-1b9a44a7-98a8-47f0-932a-1cda2c41ed26",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Tomorrow I will decide what survives of today's theft."
                },
                {
                  "id": "item-4e302950-0af6-4b09-86b5-9ccd07814eb0",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Tomorrow Gideon Locke will still own the rooms I cleaned."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-1e3221e4-6a50-4baa-88e1-d22d026e1153"
        },
        {
          "id": "item-56f4ce92-19c8-4722-8e64-3d6a88448d26",
          "type": "dialogue",
          "characterId": null,
          "text": "Tomorrow the balance changes."
        },
        {
          "id": "item-b6a015ec-d416-42f2-9e9a-e2916915e79e",
          "type": "dialogue",
          "characterId": null,
          "text": "For the first time since I arrived, sleep comes without asking permission."
        },
        {
          "id": "item-cc2474e7-1c36-4f34-8a15-ed2b4078830e",
          "type": "dialogue",
          "characterId": null,
          "text": "Outside my room, the hotel breathes around me."
        },
        {
          "id": "item-05d5af63-6c40-438c-a60a-ab3f08550674",
          "type": "dialogue",
          "characterId": null,
          "text": "Not beaten."
        },
        {
          "id": "item-fc074b98-82e3-4047-948e-004910fa1b70",
          "type": "dialogue",
          "characterId": null,
          "text": "Only sleeping."
        },
        {
          "id": "item-0467e377-56b3-4856-bc58-d78fc8269ff3",
          "type": "dialogue",
          "characterId": null,
          "text": "I mistake the difference for victory."
        },
        {
          "type": "python_script",
          "code": "resolve_turn()",
          "id": "item-29b79715-5087-41a9-af3e-1e326b8e9f80"
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "b4e84901-d01b-4007-a6a3-f5d0b2c0ded5",
              "type": "if",
              "conditionRaw": "not story.has_manuscript_chapter(\"day2_chapter\")",
              "dialogue": [
                {
                  "id": "item-471f0c5d-7f3c-415e-a936-8c5ada2726e7",
                  "type": "jump",
                  "destinationLabelId": "label-8cfac59a-d4f9-4532-82a9-c0ca8c0e7ee8"
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "not story.has_manuscript_chapter(\"day2_chapter\")"
            }
          ],
          "id": "item-9b1bba19-d211-467f-a6f2-d59c5973ce66"
        },
        {
          "id": "item-f00eeb21-48dc-45dc-8527-fafe674dda80",
          "type": "jump",
          "destinationLabelId": "label-e005b712-ec55-42bd-a555-eab6fa2de6e0"
        }
      ]
    },
    {
      "id": "label-e005b712-ec55-42bd-a555-eab6fa2de6e0",
      "name": "day105_1_monster_reemerges",
      "x": 22500,
      "y": 10992.5,
      "dialogue": [
        {
          "type": "python_script",
          "code": "time_manager.set_current_day(5)",
          "id": "item-c0a23901-c1e3-4f8a-b3ee-483f0716d250"
        },
        {
          "type": "python_script",
          "code": "set_time_period(\"Morning\")",
          "id": "item-78b7f752-124a-4a01-8481-274e6566452b"
        },
        {
          "type": "scene",
          "layer": null,
          "transition": "fade",
          "id": "item-4f0f246a-6e0f-40ec-aad1-719d21180e13",
          "backgroundId": "bg_master_suite_day"
        },
        {
          "id": "item-1870ce5f-dc4f-4a2b-a559-6cdb68600ad7",
          "type": "dialogue",
          "characterId": null,
          "text": "Morning arrives too cleanly."
        },
        {
          "id": "item-6a8ba6a6-ec75-4198-b2aa-bc6ee03f2ecb",
          "type": "dialogue",
          "characterId": null,
          "text": "The room simply becomes visible again, as if the hotel turned a key in me."
        },
        {
          "id": "item-d035344e-e780-4874-a5f0-810478038961",
          "type": "dialogue",
          "characterId": null,
          "text": "That should have warned me."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "3d037f06-7009-4aaf-b7ae-14a6c4d56173",
              "type": "if",
              "conditionRaw": "story.day4_night_action == \"finish_manuscript\"",
              "dialogue": [
                {
                  "id": "item-25909b20-365c-448a-b4ac-f8de4cc94a53",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The chapter is finished."
                },
                {
                  "id": "item-4b30ad56-14b7-41ec-9f6c-a965e66bfc46",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "For a few hours, I believed that meant the story was."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day4_night_action == \"finish_manuscript\""
            },
            {
              "id": "e57ad6ed-341e-4a08-a5eb-239daed8bd5e",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-ef8bfc29-baef-4378-9d30-0176ce9c2b36",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The manuscript remains unfinished."
                },
                {
                  "id": "item-62958bf7-1112-4e64-8043-894e77ee6c36",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Still, I woke with the stupid animal relief of someone who survived the night."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-bc2d8a38-0395-4bdf-93c6-6cd9403a33b4"
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "efca20d9-61ca-45e2-add6-ee98f3c7a11a",
              "type": "if",
              "conditionRaw": "story.has_photograph",
              "dialogue": [
                {
                  "id": "item-a57a49d3-8178-4fe3-a2d8-8d2cba5a6fa9",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The photograph is no longer under the floorboard."
                },
                {
                  "id": "item-7f66f6ea-732b-4fa6-83e5-6f8bd0f63815",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The plank is level."
                },
                {
                  "id": "item-dec66014-5025-4871-a9e2-03778729e985",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "That is how I know something has been taken: the house prefers surfaces without secrets."
                },
                {
                  "id": "item-8f7d0419-2214-4c05-9c14-e60ffa85379d",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The room has the wrong silence."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.has_photograph"
            },
            {
              "id": "65735c1a-371f-4b7d-b296-2416f65524b4",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-7ed25c5d-b215-4755-af58-276662994601",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The photograph remains where I left it: in Gideon's lockbox, where powerful men keep the things they trust the world to protect."
                },
                {
                  "id": "item-efab52bd-8e74-4043-8ce2-abe09cb22c78",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "But memory has weight."
                },
                {
                  "id": "item-9306d77c-5b3e-45b0-bd65-7a295f0049d2",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "At least, I believed it did."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-4c982d42-5fb9-44e1-a264-b60d62874dbc"
        },
        {
          "id": "item-bbff3700-6e90-4e10-9602-302ebc4845c5",
          "type": "dialogue",
          "characterId": null,
          "text": "A message comes before breakfast."
        },
        {
          "id": "item-2366b219-0482-4291-a303-733d81b8cedf",
          "type": "dialogue",
          "characterId": null,
          "text": "The paper on the tray is folded too crisply for a servant's hand."
        },
        {
          "id": "item-6d847835-b28b-4f20-9baf-5ff57f94e2e2",
          "type": "dialogue",
          "characterId": null,
          "text": "Mr. Locke requires me in the Master Suite."
        },
        {
          "id": "item-291f55c7-fd18-4a36-bfdd-f788e1c1aba0",
          "type": "dialogue",
          "characterId": null,
          "text": "Alone."
        },
        {
          "id": "item-fa4a0304-0da0-4b93-92e2-047c4ecb495b",
          "type": "dialogue",
          "characterId": null,
          "text": "The summons is not a threat."
        },
        {
          "id": "item-7b96f274-22b1-4391-aad2-55fe4f525832",
          "type": "dialogue",
          "characterId": null,
          "text": "It is an appointment with the machinery."
        },
        {
          "id": "item-1424ef13-ce3a-41e9-ba4e-c3acf3b4a7a7",
          "type": "dialogue",
          "characterId": null,
          "text": "The false dawn ends without thunder."
        },
        {
          "id": "item-3a01d669-545e-4bfd-84c2-f2fe5e4ec004",
          "type": "jump",
          "destinationLabelId": "label-7ac78516-dd79-4eee-b807-e480491b374c"
        }
      ]
    },
    {
      "id": "label-7ac78516-dd79-4eee-b807-e480491b374c",
      "name": "day105_2_the_summons",
      "x": 22900,
      "y": 10992.5,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-f46d8db7-e2a1-415f-b909-cf80d01af29c",
          "backgroundId": "bg_master_suite_day"
        },
        {
          "id": "item-dc2b506f-47d9-423f-a927-33611e712575",
          "type": "show",
          "characterId": "gideon_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "gideon_sprite dominant"
        },
        {
          "id": "item-def2e07a-56cf-4c0f-9b6c-6609c68b3be3",
          "type": "dialogue",
          "characterId": null,
          "text": "The clock on the mantel has stopped."
        },
        {
          "id": "item-e0673497-4099-42f4-bbaf-5f7701248d16",
          "type": "dialogue",
          "characterId": null,
          "text": "Or I have."
        },
        {
          "id": "item-9399b0f0-c4a6-4e04-b518-fa335590228f",
          "type": "dialogue",
          "characterId": null,
          "text": "I cannot tell which is worse."
        },
        {
          "id": "item-f8d0f3a7-d7e1-4af1-98b9-ef6827fdc9b5",
          "type": "dialogue",
          "characterId": null,
          "text": "Gideon sits in the leather armchair with one ankle crossed over the other."
        },
        {
          "id": "item-936f972c-4a9a-4111-99cc-cf36a1f20016",
          "type": "dialogue",
          "characterId": null,
          "text": "He is not pacing."
        },
        {
          "id": "item-dc8cb2e2-14c1-4a98-bb1b-67c484a534b0",
          "type": "dialogue",
          "characterId": null,
          "text": "He is not furious."
        },
        {
          "id": "item-3e88e1f9-2f06-4673-a5ea-7444213a2cc8",
          "type": "dialogue",
          "characterId": null,
          "text": "He reads the Morning Post as though the headlines owe him money."
        },
        {
          "id": "item-6a77951c-db3e-4a4f-8be7-2bde52f35be7",
          "type": "dialogue",
          "characterId": null,
          "text": "That is the first cruelty."
        },
        {
          "id": "item-2e752b19-1b30-4528-aca4-5308b6069e89",
          "type": "dialogue",
          "characterId": null,
          "text": "I wait on the threshold until he looks up."
        },
        {
          "id": "item-ccdb6ea0-2312-427b-aa9b-a0cdc8d07554",
          "type": "dialogue",
          "characterId": null,
          "text": "Guests are not kept waiting. Servants are."
        },
        {
          "id": "item-c39c9eae-2f11-435e-ab2f-cbb9603d3c93",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Close the door, Cora."
        },
        {
          "id": "item-9bb03960-c3cc-4ec9-bdb0-8ded6f0460ae",
          "type": "dialogue",
          "characterId": null,
          "text": "I close it."
        },
        {
          "id": "item-e11b0f1a-0dd2-4853-8103-c2b4eac25d84",
          "type": "dialogue",
          "characterId": null,
          "text": "I do not lean on it."
        },
        {
          "id": "item-3da32526-b156-4472-a08b-f8743b2d0181",
          "type": "dialogue",
          "characterId": null,
          "text": "Footsteps pause in the corridor."
        },
        {
          "id": "item-43d9d147-4503-4b99-a047-7b52c85555fa",
          "type": "dialogue",
          "characterId": null,
          "text": "Someone is listening who will report whether I flinch."
        },
        {
          "id": "item-9643d807-f581-4e80-a70c-4c2a61db4cb2",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Not for privacy. For theatre. You have a taste for theatre, I think."
        },
        {
          "id": "item-394641a0-60db-423c-9c41-a50b83ee4314",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base"
        },
        {
          "id": "item-e964f4cf-2a5a-46f8-a43c-b032596a4fab",
          "type": "show",
          "characterId": "gideon_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "move",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "gideon_sprite dominant"
        },
        {
          "id": "item-4acd8456-5f16-4f39-95bf-0f027aac10ad",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "I have a taste for employment, sir."
        },
        {
          "id": "item-9a92f8ed-f202-48aa-89f0-3c34ed7cffac",
          "type": "dialogue",
          "characterId": null,
          "text": "He folds the paper once, neatly."
        },
        {
          "id": "item-5be7620e-d726-43a2-b2ae-e2fa3cfe818b",
          "type": "dialogue",
          "characterId": null,
          "text": "The paper was open to departures."
        },
        {
          "id": "item-80635f60-7442-4a88-9d1f-f7508fdcd9d0",
          "type": "dialogue",
          "characterId": null,
          "text": "He wanted me to see it without asking."
        },
        {
          "id": "item-41166ea4-196c-4bbe-895f-4564761c24e1",
          "type": "dialogue",
          "characterId": null,
          "text": "He sets it aside."
        },
        {
          "id": "item-965f0882-6a17-4b9f-b827-8713ea7e46cf",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Someone forced the lock on my private box yesterday."
        },
        {
          "id": "item-7ba722b0-97ba-47e1-b811-33e3bbb333c3",
          "type": "dialogue",
          "characterId": null,
          "text": "The sentence does not accuse."
        },
        {
          "id": "item-a60ee18b-ac2b-421b-a6c8-9e281b69e868",
          "type": "dialogue",
          "characterId": null,
          "text": "It merely places a fact on the table and waits to see what shape I take around it."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "d237517c-4f55-4444-b3c7-f3af5611895f",
              "type": "if",
              "conditionRaw": "story.day4_escape_state == \"bold_lie\"",
              "dialogue": [
                {
                  "id": "item-7d4abc56-aa38-4162-8a89-1844eb991ef5",
                  "type": "dialogue",
                  "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
                  "text": "A girl dusting a locked desk in an already-clean room. Admirably stupid, if it had been stupid."
                },
                {
                  "id": "item-e8d70b5e-2f6b-4b11-b321-b3103de734c2",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "The dust was aspirational, sir."
                },
                {
                  "id": "item-356755ce-cedf-4fcd-8ea4-f2b72c4ff28d",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "His mouth twitches."
                },
                {
                  "id": "item-44558b5b-fc8c-4b1c-87ba-9aac19791aaf",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Not amusement."
                },
                {
                  "id": "item-0a53ea61-89b0-4a5d-a117-fd3c1484d317",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Appraisal."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day4_escape_state == \"bold_lie\""
            },
            {
              "id": "0bcfca13-9814-4bd8-8fcb-9fcad8606638",
              "type": "elif",
              "conditionRaw": "story.day4_escape_state == \"fireplace\"",
              "dialogue": [
                {
                  "id": "item-9819e3dc-df3c-4c30-958d-0b8034a26115",
                  "type": "dialogue",
                  "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
                  "text": "There was soot where no soot belonged. You left time on the wall."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day4_escape_state == \"fireplace\""
            },
            {
              "id": "3c7bff02-2853-4412-a741-33a3b6588952",
              "type": "elif",
              "conditionRaw": "story.day4_escape_state == \"missy_cover\"",
              "dialogue": [
                {
                  "id": "item-571e67c1-f367-4cc0-b42f-a21d84cee21a",
                  "type": "dialogue",
                  "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
                  "text": "And poor Missy appeared at precisely the moment she was useful to someone else. A coincidence with your fingerprints on it."
                },
                {
                  "id": "item-150ddd68-ea6f-44c6-ac03-a3ef1d068f75",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I file the detail."
                },
                {
                  "id": "item-ea546439-dc2a-4e9c-9007-37f614b05cfa",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Someone assigned her route."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day4_escape_state == \"missy_cover\""
            },
            {
              "id": "6ba1f5db-29e6-4d95-97fb-1440cd969376",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-b8cee71b-0164-4852-87ea-d04052068738",
                  "type": "dialogue",
                  "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
                  "text": "Do not trouble yourself with denial. We are past the inexpensive parts of the conversation."
                },
                {
                  "id": "item-655f08dc-f102-4204-a6b7-a88b0d8aaf93",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "Then we are past my favourite part of the interview, sir."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-ac069261-50e7-44ad-b996-2d0cff1aecbc"
        },
        {
          "id": "item-b093be49-b9d1-481d-b86b-e089e41a787f",
          "type": "dialogue",
          "characterId": null,
          "text": "I count my breaths."
        },
        {
          "id": "item-9d08239e-c24d-4bb9-b71b-64a0591e839d",
          "type": "dialogue",
          "characterId": null,
          "text": "Four before he speaks again."
        },
        {
          "id": "item-3ec68f3f-5a75-447b-94be-0ab238f504a8",
          "type": "dialogue",
          "characterId": null,
          "text": "He waits for five."
        },
        {
          "id": "item-82d36e21-38be-4fcd-8884-4804263055d8",
          "type": "dialogue",
          "characterId": null,
          "text": "My mouth has gone dry."
        },
        {
          "id": "item-6f38b80e-18cd-4c22-830c-4351b3a8c02e",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Where is it?"
        },
        {
          "id": "item-86c61552-b197-427b-8f44-c6f40ac672d1",
          "type": "jump",
          "destinationLabelId": "label-89f58718-b3de-4b18-9dce-8617fe6c6942"
        }
      ]
    },
    {
      "id": "label-89f58718-b3de-4b18-9dce-8617fe6c6942",
      "name": "day105_3_leverage_collapses",
      "x": 23300,
      "y": 10992.5,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-9384e2ad-9f99-48a8-8351-a005dc580720",
          "backgroundId": "bg_master_suite_day"
        },
        {
          "id": "item-39d8d763-46ac-4d9e-8376-e87fb9557a38",
          "type": "show",
          "characterId": "gideon_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "gideon_sprite dominant"
        },
        {
          "id": "item-5390ebdb-2ac7-412f-a90e-a8dfca04ac42",
          "type": "dialogue",
          "characterId": null,
          "text": "He remains seated."
        },
        {
          "id": "item-d0bc8577-0ed6-4101-ae57-a2f21aaf9785",
          "type": "dialogue",
          "characterId": null,
          "text": "I remain standing."
        },
        {
          "id": "item-7e372895-3484-44bc-95e1-7417809affab",
          "type": "dialogue",
          "characterId": null,
          "text": "The geometry is the argument."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "63196b2e-c305-4115-9ad4-7aed88bdb508",
              "type": "if",
              "conditionRaw": "story.has_photograph",
              "dialogue": [
                {
                  "id": "item-8a847fe8-cb00-4838-97f0-8d7400ac9c55",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I reach into my apron."
                },
                {
                  "id": "item-760f60fb-d637-4a3e-9f0b-55eb03d55b43",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Not because I want to."
                },
                {
                  "id": "item-1123a5a8-8e39-466f-81e3-280a9b648333",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Because keeping it hidden has already failed."
                },
                {
                  "id": "item-a4c90323-db48-4ca3-ab6f-1627bfb6501b",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I should not place anything on his table without permission."
                },
                {
                  "id": "item-e68d956d-f1e3-425a-8c8d-90e24f7fa84b",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I place the photograph face up on the polished table between us."
                },
                {
                  "id": "item-1dbc78db-3aec-4d41-8275-5f61dbf853aa",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The way one lays a scalpel: carefully, knowing the cut goes both ways."
                },
                {
                  "id": "item-0117571a-1444-466a-ad0a-23b379dcf022",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The paper is warm from my body."
                },
                {
                  "id": "item-5225d234-af49-40a2-ae08-242e71aabb68",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Gideon looks at it."
                },
                {
                  "id": "item-9c66549b-c23c-44bd-a6c0-2be9c52948e7",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "At himself."
                },
                {
                  "id": "item-b76253d6-e887-4e37-926c-453806b5c001",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "At his supposed ruin."
                },
                {
                  "id": "item-773c1b09-9fca-4c5d-8574-de82639b78e4",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "His eyes move over the image, then over me."
                },
                {
                  "id": "item-e52b799c-fe66-4ed0-8380-eade68500e94",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Something in his face shifts."
                },
                {
                  "id": "item-e14eba69-f9a6-4edb-8369-0d42278d8b24",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I do not have a word for it that does not sound like surrender."
                },
                {
                  "id": "item-c619161f-95ae-4305-8c64-e35df0d22e03",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "It is genuine. That is the worst of it."
                },
                {
                  "id": "item-4637346d-f163-45f5-8ce2-280e45b54af8",
                  "type": "show",
                  "characterId": "cora_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "None",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "cora_sprite base"
                },
                {
                  "id": "item-6799bf3b-e15f-4688-86fd-51fbcf068702",
                  "type": "show",
                  "characterId": "gideon_sprite",
                  "isFlipped": false,
                  "xpos": 0.5,
                  "ypos": 1,
                  "zoom": 1,
                  "alpha": 1,
                  "transition": "move",
                  "layer": null,
                  "atlBlocks": [],
                  "spriteId": "gideon_sprite dominant"
                },
                {
                  "id": "item-84aff2a1-5d05-4f9a-a3bc-44f309af5c5e",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "You think this is funny?"
                },
                {
                  "id": "item-1c43fc04-9886-4f7b-ae7f-d43f745bbaf5",
                  "type": "dialogue",
                  "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
                  "text": "No. I think you are."
                },
                {
                  "id": "item-3244f329-3cdc-4d5e-994e-25093b34207b",
                  "type": "dialogue",
                  "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
                  "text": "You are not funny."
                },
                {
                  "id": "item-bcb11d1c-7efa-4daa-b0a8-e5fd78505c0a",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "No, sir. I am inconvenient."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.has_photograph"
            },
            {
              "id": "4d49593b-9097-415a-8657-b5ff40f649f5",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-c9b009d8-711d-4add-beb5-2cffd003b1f7",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I have no paper to place between us."
                },
                {
                  "id": "item-9db2ccb0-7b15-47ba-9753-746514d757d6",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Only memory, fear, and the absurd hope that truth remains truth when a servant speaks it."
                },
                {
                  "id": "item-9dec73d1-9b4c-41ef-9bbc-fc0a08eb34f6",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "I saw what was in the envelope."
                },
                {
                  "id": "item-7d9e65a2-0d13-4117-a94f-081246d4b4ca",
                  "type": "dialogue",
                  "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
                  "text": "Did you?"
                },
                {
                  "id": "item-cbc4eaf2-4dca-4594-8b80-2dc7fe554b27",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "He sounds almost kind."
                },
                {
                  "id": "item-e819b1f0-0f6c-4930-b45c-8b9d1acc0742",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "That is how I know the blow is coming."
                },
                {
                  "id": "item-07796ba7-6f03-4e5d-a34d-0f883c053e1b",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "I know what you are hiding."
                },
                {
                  "id": "item-0222fc13-7793-4868-8f8f-263390cbfc67",
                  "type": "dialogue",
                  "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
                  "text": "No. You know what you believe you saw while committing theft."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-19a22731-b202-4a5e-9df6-85284ec45573"
        },
        {
          "id": "item-8817c452-dae8-4ac9-a77c-8e418a4246bb",
          "type": "dialogue",
          "characterId": null,
          "text": "He stands."
        },
        {
          "id": "item-f7476e16-1aa1-436b-96e5-adb60aff6110",
          "type": "dialogue",
          "characterId": null,
          "text": "Only then do I understand that the room has been arranged to make standing matter."
        },
        {
          "id": "item-c5c5700e-0c5b-44ba-ad57-2ab12f924e94",
          "type": "dialogue",
          "characterId": null,
          "text": "He steps closer."
        },
        {
          "id": "item-7c7c39d5-35e4-41e4-a7e7-13c73d65bb25",
          "type": "dialogue",
          "characterId": null,
          "text": "Not touching."
        },
        {
          "id": "item-8e842ce2-8651-47b2-a54e-794c6b2f7e96",
          "type": "dialogue",
          "characterId": null,
          "text": "Worse."
        },
        {
          "id": "item-ab202812-bd38-4038-8bef-2311fdec8187",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Shall I teach you the arithmetic of reputation?"
        },
        {
          "id": "item-78f5d76f-087f-4289-aba8-51e2f1f54fe8",
          "type": "dialogue",
          "characterId": null,
          "text": "He does not raise his voice."
        },
        {
          "id": "item-94cec23b-1abc-4b69-800f-2d027c91d880",
          "type": "dialogue",
          "characterId": null,
          "text": "He does not need to."
        },
        {
          "id": "item-309365d3-259e-479c-beb7-43eb5b7c3cd3",
          "type": "dialogue",
          "characterId": null,
          "text": "The room is already full of men who are not here."
        },
        {
          "id": "item-f4183d7b-bc33-40fa-99f9-2390d4093605",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Let us imagine you walk out of this hotel and tell your story."
        },
        {
          "id": "item-daedc74f-3256-469e-b4f3-2a9059ec956e",
          "type": "dialogue",
          "characterId": null,
          "text": "He begins counting on his fingers."
        },
        {
          "id": "item-ce7e18c6-f320-47fe-b609-d81e577a8cc1",
          "type": "dialogue",
          "characterId": null,
          "text": "Not hurriedly."
        },
        {
          "id": "item-d2f1617b-74e4-42a6-a0f9-1a9bd18a6c43",
          "type": "dialogue",
          "characterId": null,
          "text": "Like a tutor with a dull but promising pupil."
        },
        {
          "id": "item-c95f0b15-b651-45dd-a518-0a4d0ea6ee4d",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "The police will ask why you were in my private rooms."
        },
        {
          "id": "item-7034d667-bb68-452b-a258-aa4106ece20f",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "They will ask you first, sir."
        },
        {
          "id": "item-4e97d49d-87d3-4e5b-9dcf-dd8857057254",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "They will ask me last."
        },
        {
          "id": "item-a776265a-bb2b-486b-b019-4cd0f4f127c0",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "My solicitor will ask who paid you."
        },
        {
          "id": "item-7c6c5996-4164-4570-b6de-ae7710091c84",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Your employer will ask why she should keep a thief."
        },
        {
          "id": "item-35c14db3-3a2c-47af-9b6b-60aa2ccea812",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "A publisher will ask whether a maid's scandal is worth a libel suit."
        },
        {
          "id": "item-10825e53-6585-4b4a-8122-813bbb7e7cc7",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Every decent woman in London will pretend she does not understand the accusation."
        },
        {
          "id": "item-e067663b-95a5-44c9-ac91-4cd074163834",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "And every indecent man will understand it perfectly and still dine with me."
        },
        {
          "id": "item-b16bc3fb-f4c6-4973-960e-09af1b9a34c0",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "A crowded social calendar, sir."
        },
        {
          "id": "item-b0846638-53fb-4f03-90ac-08d31c82447e",
          "type": "dialogue",
          "characterId": null,
          "text": "There it is."
        },
        {
          "id": "item-deaf25ca-ec15-4743-99c4-41a503c16e5d",
          "type": "dialogue",
          "characterId": null,
          "text": "Not his power."
        },
        {
          "id": "item-83863697-83a5-4c8c-b25a-81dcc6f05549",
          "type": "dialogue",
          "characterId": null,
          "text": "The power around him."
        },
        {
          "id": "item-0914ab5b-b97f-4908-86ba-2b589fbd34ba",
          "type": "dialogue",
          "characterId": null,
          "text": "None of them need to enter to vote."
        },
        {
          "id": "item-d779788d-cdf9-4db9-af31-c94fe2bc90c8",
          "type": "dialogue",
          "characterId": null,
          "text": "The hands I cannot see because they have never needed to enter the room."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "791b8bee-66fc-4ff3-875d-de80a4e5ab29",
              "type": "if",
              "conditionRaw": "story.has_photograph",
              "dialogue": [
                {
                  "id": "item-d90d00fb-5764-4d32-ba9d-5bdc8152d1d2",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "He picks up the photograph."
                },
                {
                  "id": "item-0581f170-0e0a-4bdf-87f4-5c72e55eb594",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I do not stop him."
                },
                {
                  "id": "item-a7672779-2b0e-4c37-b288-3f198585e72e",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "That is the second defeat."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.has_photograph"
            },
            {
              "id": "8c251fee-e053-41d2-b2f1-a4f38c79c027",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-3160f05d-688b-43a4-8be3-423dae05b49c",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "He does not need to take anything from me."
                },
                {
                  "id": "item-4f7c4fa3-2032-4471-a76e-c2660eabe1a1",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "That is the second defeat."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-6114b2d5-64d0-4dc5-9142-79498b708f48"
        },
        {
          "id": "item-3122caad-572b-493b-848d-739c1e1eb0c2",
          "type": "dialogue",
          "characterId": null,
          "text": "I thought I had found a knife."
        },
        {
          "id": "item-463e6f2e-de11-4596-a0ff-8374ee772280",
          "type": "dialogue",
          "characterId": null,
          "text": "I had found a handle attached to a door that opens only from his side."
        },
        {
          "id": "item-2795979e-1059-4e16-8d96-3421efb1af66",
          "type": "jump",
          "destinationLabelId": "label-018e5c6e-4921-4946-bf7f-3a7e85febd81"
        }
      ]
    },
    {
      "id": "label-018e5c6e-4921-4946-bf7f-3a7e85febd81",
      "name": "day105_4_why_did_you_do_it",
      "x": 23700,
      "y": 10992.5,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-9162df64-22d5-45c2-a684-b7a0ce974ca0",
          "backgroundId": "bg_master_suite_day"
        },
        {
          "id": "item-09c2e694-70d2-4594-9e91-937143f29ade",
          "type": "show",
          "characterId": "gideon_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "gideon_sprite dominant"
        },
        {
          "id": "item-58d00f43-14dc-4be1-ac40-6561d450753a",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Still."
        },
        {
          "id": "item-ce0de120-3178-4ab2-a3d4-f1b5f4756bd5",
          "type": "dialogue",
          "characterId": null,
          "text": "The word changes the room."
        },
        {
          "id": "item-ffaac8e9-1cb7-4877-8814-03181bff78c4",
          "type": "dialogue",
          "characterId": null,
          "text": "He is finished explaining why I cannot hurt him."
        },
        {
          "id": "item-936d42b8-95b3-4d48-997c-9ba48dd2edd1",
          "type": "dialogue",
          "characterId": null,
          "text": "Now he is deciding why I tried."
        },
        {
          "id": "item-7aef4c51-7e03-4d98-9655-0e32a4214f05",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "It took nerve to pick the lock."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "dc4b06d3-9548-49a3-96a2-2c5b62f04748",
              "type": "if",
              "conditionRaw": "story.has_photograph",
              "dialogue": [
                {
                  "id": "item-bc2f7b8b-78ff-4400-8880-58c12a474830",
                  "type": "dialogue",
                  "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
                  "text": "More nerve to keep the photograph overnight."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.has_photograph"
            },
            {
              "id": "d2a11b76-e73b-4968-8343-97fac440bf36",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-2270d92b-4144-47a5-84f9-9557fa359078",
                  "type": "dialogue",
                  "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
                  "text": "Less nerve to abandon it, perhaps. But enough to look. Enough to remember."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-83c7bbcf-357c-449d-8f06-750cf0526c58"
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "c75fd64e-d63d-49d2-9c62-537640de96a0",
              "type": "if",
              "conditionRaw": "story.day4_escape_state == \"missy_cover\" or story.missy_day4_used_as_cover",
              "dialogue": [
                {
                  "id": "item-71db2562-a646-4795-a66e-1b6a9ca5443a",
                  "type": "dialogue",
                  "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
                  "text": "And enough appetite to spend another girl when the corridor narrowed."
                },
                {
                  "id": "item-2b422cf2-4e1b-4d31-9f3a-befb0e43921f",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Missy's name is not spoken."
                },
                {
                  "id": "item-20fc5261-726c-4481-a6bb-6f2e7f43148f",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "It does not need to be."
                },
                {
                  "id": "item-b7b5a331-9cbd-4e44-af60-c498948df8ab",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Some debts do not require witnesses to become permanent."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day4_escape_state == \"missy_cover\" or story.missy_day4_used_as_cover"
            }
          ],
          "id": "item-1ce31941-56fa-4dcc-8f40-5395d4cd418a"
        },
        {
          "id": "item-5ad400a8-a7d3-4e23-b697-6ae6458d3672",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Why?"
        },
        {
          "type": "choice",
          "options": [
            {
              "id": "ed58b7ae-6d0d-4176-af38-cf52ab247864",
              "text": "To finish the book. [[Observer / Muse]]",
              "dialogue": [
                {
                  "id": "item-50be7b00-871d-42d1-b532-b1bde4432efd",
                  "type": "jump",
                  "destinationLabelId": "label-0b4d4c38-847f-4eff-b84c-e70ccec05258"
                }
              ]
            },
            {
              "id": "1dcb51f7-da61-4620-905a-ac1545ac2ecd",
              "text": "To stand where you stand. [[Predator / Protégé]]",
              "dialogue": [
                {
                  "id": "item-4cf8ce01-ae37-4062-ac8a-8d9b886c8502",
                  "type": "jump",
                  "destinationLabelId": "label-004b30eb-cee2-489a-91d1-87d7afb36857"
                }
              ]
            },
            {
              "id": "e3062d2f-064a-49a6-8a2f-06a04243ea3a",
              "text": "Because you frightened me, and I needed something that frightened you back. [[Prey / Adversary]]",
              "dialogue": [
                {
                  "id": "item-e9bd0b99-e95b-4638-9c45-0f845dad168d",
                  "type": "jump",
                  "destinationLabelId": "label-dc2ffde7-89d0-4c3b-86e1-f7f114a306c2"
                }
              ]
            },
            {
              "id": "36a75889-6ac7-4d8e-b159-77b338241721",
              "text": "Because people like you survive by not being seen. [[Ghost / Witness]]",
              "dialogue": [
                {
                  "id": "item-014f78dc-e2f0-4aa5-a435-99a6ddba2fa5",
                  "type": "jump",
                  "destinationLabelId": "label-529f38a6-bf69-4da6-9cc6-8e284e08260d"
                }
              ]
            }
          ],
          "id": "item-13b20968-afe3-4ac7-bda4-e16cf1be846f"
        },
        {
          "id": "item-529d1aa3-7190-495f-acc5-dd217fcdf5a3",
          "type": "jump",
          "destinationLabelId": "label-0b4d4c38-847f-4eff-b84c-e70ccec05258"
        }
      ]
    },
    {
      "id": "label-0b4d4c38-847f-4eff-b84c-e70ccec05258",
      "name": "day105_4_motivation_observer",
      "x": 24100,
      "y": 11252.5,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-60f34954-75f2-4b7d-a40e-419e74a4ab72",
          "backgroundId": "bg_master_suite_day"
        },
        {
          "id": "item-93499437-2f85-4735-b5d8-b0d633738d39",
          "type": "show",
          "characterId": "gideon_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "gideon_sprite dominant"
        },
        {
          "type": "python_script",
          "code": "story.set_day5_dynamic(\"muse\")",
          "id": "item-f009d9db-4e3e-45b2-a644-cff59dfeba32"
        },
        {
          "type": "python_script",
          "code": "story.set_cora_release1_flavour(\"observer\")",
          "id": "item-3f7045d7-5b8e-4d73-8e17-827fd2d55dbc"
        },
        {
          "type": "python_script",
          "code": "apply_balanced_effect(\"creative\", intensity=\"standard\")",
          "id": "item-424c66ed-7187-414d-8a8d-12179bfa12fd"
        },
        {
          "id": "item-ccad8c54-4e44-44da-b5b3-af742d8117e2",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base"
        },
        {
          "id": "item-b8e23e54-81be-4921-854b-3a3e8d0fb2b5",
          "type": "show",
          "characterId": "gideon_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "move",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "gideon_sprite dominant"
        },
        {
          "id": "item-93e07661-6dfe-4be8-8022-26963d73312b",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "To finish my book."
        },
        {
          "id": "item-26f1b29e-1e22-4033-8a1b-710ad6240413",
          "type": "dialogue",
          "characterId": null,
          "text": "For the first time, Gideon does not answer immediately."
        },
        {
          "id": "item-0de1e316-e7cb-4672-a3ea-0329f62c6511",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "I needed the truth of the ending. Not gossip. Not fear. Something absolute."
        },
        {
          "id": "item-ad6bcf4b-6533-4492-b58c-c48c665df7f1",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "And you thought I would provide it."
        },
        {
          "id": "item-59db1bf4-8de6-45f2-902b-6847d61d767c",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "You did."
        },
        {
          "id": "item-406755b4-6e77-4c81-873a-27b0ae082c52",
          "type": "dialogue",
          "characterId": null,
          "text": "He studies me with new attention."
        },
        {
          "id": "item-b3d01b56-71b4-4a35-8e72-b85d66ef7643",
          "type": "dialogue",
          "characterId": null,
          "text": "Not respect."
        },
        {
          "id": "item-57f4a899-5df6-4ede-94fc-f77d706020e8",
          "type": "dialogue",
          "characterId": null,
          "text": "Respect would require equality."
        },
        {
          "id": "item-ce112e59-6cd7-41a6-8391-b5ffc5708438",
          "type": "dialogue",
          "characterId": null,
          "text": "This is curiosity. Colder. Safer for him. More dangerous for me."
        },
        {
          "id": "item-1882c1ac-27dc-46fd-9979-85a2a3d11b6a",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "A little anatomist below stairs. Cutting open her betters for art."
        },
        {
          "id": "item-f091984f-14c1-4f70-9307-795289d1f794",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Not my betters."
        },
        {
          "id": "item-7f69e12a-c725-4b1e-adef-f398f7141506",
          "type": "dialogue",
          "characterId": null,
          "text": "The correction slips out."
        },
        {
          "id": "item-b6b12474-b85a-4bdf-a039-7f8b1361b19b",
          "type": "dialogue",
          "characterId": null,
          "text": "His smile arrives slowly."
        },
        {
          "id": "item-0c9106ea-0549-4fb7-953d-777446309bb2",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "There she is."
        },
        {
          "id": "item-9517c2ea-05fd-42fd-9aa0-001bba6365bf",
          "type": "jump",
          "destinationLabelId": "label-55546062-5bc8-4a1b-85ea-b056414a4283"
        }
      ]
    },
    {
      "id": "label-004b30eb-cee2-489a-91d1-87d7afb36857",
      "name": "day105_4_motivation_predator",
      "x": 24100,
      "y": 11122.5,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-49600c75-49f2-4574-b980-dd44143eb166",
          "backgroundId": "bg_master_suite_day"
        },
        {
          "id": "item-8da60ddf-2ac3-4c1a-bedc-5bd0bf39dc89",
          "type": "show",
          "characterId": "gideon_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "gideon_sprite dominant"
        },
        {
          "type": "python_script",
          "code": "story.set_day5_dynamic(\"protege\")",
          "id": "item-983d5ed6-e883-4c78-9bdd-5b35f31737c6"
        },
        {
          "type": "python_script",
          "code": "story.set_cora_release1_flavour(\"predator\")",
          "id": "item-fe72eead-0598-4abc-817d-e264597ae96b"
        },
        {
          "type": "python_script",
          "code": "apply_archetype_edge(\"predator\", 1)",
          "id": "item-e0a32584-673a-458e-884b-3a105dcd54a3"
        },
        {
          "type": "python_script",
          "code": "apply_balanced_effect(\"transgressive\", intensity=\"standard\", witness=\"gideon\")",
          "id": "item-83e89836-78bd-4590-99aa-96fc9dfc9b87"
        },
        {
          "id": "item-02322f44-48b3-495a-a9c9-e2ab1097ab5a",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base"
        },
        {
          "id": "item-e45e0a5c-ed1e-41f1-9b46-9a4433b49d98",
          "type": "show",
          "characterId": "gideon_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "move",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "gideon_sprite dominant"
        },
        {
          "id": "item-2fbbcd4b-1c4f-49b1-8b91-a9b75f03ed19",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Because I wanted to know what it felt like."
        },
        {
          "id": "item-22805880-78be-48f3-919c-0fe240166682",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "What?"
        },
        {
          "id": "item-036854b3-d909-474e-a960-1a75b0e91c86",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "To hold something over someone. To have the room change because I entered it with power hidden on me."
        },
        {
          "id": "item-b5cd33b7-6b90-4973-9827-9deacc39b394",
          "type": "dialogue",
          "characterId": null,
          "text": "The confession should shame me."
        },
        {
          "id": "item-8c2ac0e0-b1e2-452a-9b49-8c11fcf08e5b",
          "type": "dialogue",
          "characterId": null,
          "text": "It does."
        },
        {
          "id": "item-e3d90f2b-be33-4043-b405-eed862e754a0",
          "type": "dialogue",
          "characterId": null,
          "text": "Not enough."
        },
        {
          "id": "item-9cb41d55-6928-4db4-bef9-7e14bfdf3779",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "And did you enjoy it?"
        },
        {
          "id": "item-4745907a-3e1d-4dbf-9b3b-6ba8624d487a",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Before it failed, yes."
        },
        {
          "id": "item-e8920664-9a8f-4dca-ac35-f49d84f7cbd5",
          "type": "dialogue",
          "characterId": null,
          "text": "His eyes darken with recognition."
        },
        {
          "id": "item-30b04037-7970-4d4e-a69c-6d15549006f3",
          "type": "dialogue",
          "characterId": null,
          "text": "Not affection."
        },
        {
          "id": "item-f9e025cf-2ca6-4487-a42e-0a9ae4628022",
          "type": "dialogue",
          "characterId": null,
          "text": "Recognition is not soft."
        },
        {
          "id": "item-dae8448d-718d-4288-b045-5606380ef087",
          "type": "dialogue",
          "characterId": null,
          "text": "It is a mirror deciding whether to cut."
        },
        {
          "id": "item-32639111-e3aa-4851-8d23-5b002d2653e3",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "A wolf does not become dangerous because it finds teeth. It becomes dangerous when it stops apologising for hunger."
        },
        {
          "id": "item-555999f8-f3a0-47cf-a88d-8cf3020b3bed",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Is that advice?"
        },
        {
          "id": "item-c9afa2c6-b6d7-4526-a4be-ec23f877bc31",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "No. An inventory."
        },
        {
          "id": "item-a3575ab9-c245-479d-b917-ec4cf203a37e",
          "type": "jump",
          "destinationLabelId": "label-55546062-5bc8-4a1b-85ea-b056414a4283"
        }
      ]
    },
    {
      "id": "label-dc2ffde7-89d0-4c3b-86e1-f7f114a306c2",
      "name": "day105_4_motivation_prey",
      "x": 24100,
      "y": 10992.5,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-b7371540-7d51-4a50-9e74-39b1762debca",
          "backgroundId": "bg_master_suite_day"
        },
        {
          "id": "item-c73ecef7-1ffb-4fd8-805b-019f2758ca6f",
          "type": "show",
          "characterId": "gideon_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "gideon_sprite dominant"
        },
        {
          "type": "python_script",
          "code": "story.set_day5_dynamic(\"adversary\")",
          "id": "item-635acc1e-b5dc-42a6-b721-1c3d5aee9810"
        },
        {
          "type": "python_script",
          "code": "story.set_cora_release1_flavour(\"prey\")",
          "id": "item-229b1520-b411-4ae3-895f-3f3c57e2478c"
        },
        {
          "type": "python_script",
          "code": "apply_archetype_edge(\"prey\", 1)",
          "id": "item-9ce52d61-9af8-41a0-949d-a4f166a1b6e9"
        },
        {
          "type": "python_script",
          "code": "apply_balanced_effect(\"transgressive\", intensity=\"standard\", witness=\"vance\")",
          "id": "item-e8eb7047-56a2-45ec-8f28-f83059f272b2"
        },
        {
          "id": "item-86f7d3b7-2d23-455a-859c-bee30c9cbc10",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base"
        },
        {
          "id": "item-6c8488d0-772d-4ea5-9334-0c4922d64914",
          "type": "show",
          "characterId": "gideon_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "move",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "gideon_sprite dominant"
        },
        {
          "id": "item-518a4e9b-0cc0-40a6-b24a-2b3f7b00824d",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Because you frightened me."
        },
        {
          "id": "item-912ad5cf-c751-4db8-b4cb-421ce7b55310",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Sensible."
        },
        {
          "id": "item-0bd6d1d5-c9a0-4a63-81f6-05bbe8f2d3e9",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "And I wanted something that frightened you back."
        },
        {
          "id": "item-38e71369-549f-4d7b-975f-0c3f408a55ac",
          "type": "dialogue",
          "characterId": null,
          "text": "That pleases him more than it should."
        },
        {
          "id": "item-e8be10c4-2bec-43ff-9638-742162c081e3",
          "type": "dialogue",
          "characterId": null,
          "text": "Or perhaps not pleasure."
        },
        {
          "id": "item-bbdc1246-bee7-4490-8a4e-95fe1b07fc5b",
          "type": "dialogue",
          "characterId": null,
          "text": "Interest. The predator noticing that the animal in the snare has bitten the wire."
        },
        {
          "id": "item-45018a23-9624-4c03-b49b-6d27c0788784",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Did it?"
        },
        {
          "id": "item-66884067-2c7a-4429-8869-9b57b6ed11c0",
          "type": "dialogue",
          "characterId": null,
          "text": "The question is gentle enough to be cruel."
        },
        {
          "id": "item-f8c54786-fb53-411c-a45e-ef1167ee8586",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "No."
        },
        {
          "id": "item-2b349494-538a-4ac1-b819-7849a09487b5",
          "type": "dialogue",
          "characterId": null,
          "text": "The truth tastes like blood."
        },
        {
          "id": "item-87e59fde-1b45-4651-a644-baaf6eebd610",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Not yet."
        },
        {
          "id": "item-1551804a-c3e7-4f6c-9da7-6e5fd57f9ca6",
          "type": "dialogue",
          "characterId": null,
          "text": "He says it lightly."
        },
        {
          "id": "item-043f001e-04f6-42ed-9b93-1bd4b3b2503a",
          "type": "dialogue",
          "characterId": null,
          "text": "He should not have said it at all."
        },
        {
          "id": "item-42c3fafd-8e0d-4e09-b661-9313dabfdb5c",
          "type": "jump",
          "destinationLabelId": "label-55546062-5bc8-4a1b-85ea-b056414a4283"
        }
      ]
    },
    {
      "id": "label-529f38a6-bf69-4da6-9cc6-8e284e08260d",
      "name": "day105_4_motivation_ghost",
      "x": 24100,
      "y": 10862.5,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-b820e19f-068f-4867-92e6-eaae4f200543",
          "backgroundId": "bg_master_suite_day"
        },
        {
          "id": "item-87e7940e-efd5-4032-bfb2-1a9fdfefce78",
          "type": "show",
          "characterId": "gideon_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "gideon_sprite dominant"
        },
        {
          "type": "python_script",
          "code": "story.set_day5_dynamic(\"witness\")",
          "id": "item-882ee59c-59d2-4dee-9561-03bb2af5ac71"
        },
        {
          "type": "python_script",
          "code": "story.set_cora_release1_flavour(\"ghost\")",
          "id": "item-92e90a0c-50c2-4efb-a745-751041397564"
        },
        {
          "type": "python_script",
          "code": "apply_archetype_edge(\"ghost\", 1)",
          "id": "item-998a52ab-4f65-47e6-857d-3b623835330e"
        },
        {
          "type": "python_script",
          "code": "apply_balanced_effect(\"creative\", intensity=\"standard\")",
          "id": "item-622292e7-c36c-4e44-87c1-7223b4b394ac"
        },
        {
          "type": "python_script",
          "code": "apply_effects(vance_susp=-5)",
          "id": "item-f3e4316a-d723-43e4-823c-2494f990f38e"
        },
        {
          "id": "item-96fa1539-172c-438a-a2ad-807667b9471a",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base"
        },
        {
          "id": "item-b8f6e445-4cca-41ca-aa74-d242435f536a",
          "type": "show",
          "characterId": "gideon_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "move",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "gideon_sprite dominant"
        },
        {
          "id": "item-c834621a-931f-467c-98d5-e36b6021313e",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Because people like you survive by not being seen, sir."
        },
        {
          "id": "item-8a7431bd-443f-427f-bfd4-6780113a73c0",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "People like me are seen constantly."
        },
        {
          "id": "item-a83abe00-f107-4257-8aae-0a25d2bd0f4b",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "No. You are looked at, sir. That is not the same."
        },
        {
          "id": "item-0d363e25-dd48-4068-a9f5-779fc10ad942",
          "type": "dialogue",
          "characterId": null,
          "text": "The room goes still."
        },
        {
          "id": "item-730b2f03-c979-4b5b-9881-97e0a35d7648",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Everyone sees the coat. The money. The table manners. The names that answer your letters."
        },
        {
          "id": "item-3ab8d691-46b0-4cf4-b627-134d7af01019",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "No one sees the machinery unless they are small enough to be crushed by it."
        },
        {
          "id": "item-0598cfc8-3143-4c6f-b587-87760f5b0082",
          "type": "dialogue",
          "characterId": null,
          "text": "For one second, I think I have reached him."
        },
        {
          "id": "item-207bffb4-25ae-481c-9d18-d152863bded4",
          "type": "dialogue",
          "characterId": null,
          "text": "Then I realise that reaching him is not victory."
        },
        {
          "id": "item-22078df2-f08e-4aa2-9eb7-30897179f45b",
          "type": "dialogue",
          "characterId": null,
          "text": "It is only proximity."
        },
        {
          "id": "item-62979a9c-ad05-4aa8-a5d7-f023559a9e79",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "A witness, then."
        },
        {
          "id": "item-538f2166-08a5-4ed4-8d22-df5647cbc16c",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Yes."
        },
        {
          "id": "item-c54b3342-15a0-40f4-b2ff-25cf83807909",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "How unfortunate for you. Witnesses are useful only when someone with authority calls them."
        },
        {
          "id": "item-c443e7c8-aeaf-410e-a63f-cf741d2f869a",
          "type": "jump",
          "destinationLabelId": "label-55546062-5bc8-4a1b-85ea-b056414a4283"
        }
      ]
    },
    {
      "id": "label-55546062-5bc8-4a1b-85ea-b056414a4283",
      "name": "day105_5_gideon_marks_cora",
      "x": 24500,
      "y": 11122.5,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-56628859-62a7-4343-9081-acee4e6e80b1",
          "backgroundId": "bg_master_suite_day"
        },
        {
          "id": "item-9805adcb-b697-49a4-960a-a4cdd571a4fe",
          "type": "show",
          "characterId": "gideon_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "gideon_sprite dominant"
        },
        {
          "id": "item-1404340a-2079-4801-9341-64296b74425e",
          "type": "dialogue",
          "characterId": null,
          "text": "Gideon turns away first."
        },
        {
          "id": "item-71106411-f7b8-48ed-81c5-1a6292aa34d5",
          "type": "dialogue",
          "characterId": null,
          "text": "Not because he is finished with me."
        },
        {
          "id": "item-f8695122-1780-4118-98e5-d97ba923b057",
          "type": "dialogue",
          "characterId": null,
          "text": "Because he wants me to understand that turning away is still safe for him."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "ee6e0ded-8696-4df0-be9e-b8ea473281bb",
              "type": "if",
              "conditionRaw": "story.has_photograph",
              "dialogue": [
                {
                  "id": "item-5242d2f1-51d2-4e10-b9e0-12e80cdf78d0",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "He carries the photograph to the fireplace."
                },
                {
                  "id": "item-86fdfa92-348f-4a03-8269-6fdac6201f2e",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "He holds the match near my face before he strikes it."
                },
                {
                  "id": "item-d1d06bfc-663f-404b-911f-f2f6d4d3096c",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I feel the heat on my cheek before the paper curls."
                },
                {
                  "id": "item-6de80427-6165-4e71-ae92-5239cce5c815",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The flame is small."
                },
                {
                  "id": "item-bf887b04-3d9d-423e-a7ff-410fbfd61dca",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "It eats the face first."
                },
                {
                  "id": "item-2b2cece2-82cd-46ad-ba3c-3348b6db04d3",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I expect panic."
                },
                {
                  "id": "item-f7c8edbd-5aad-4894-8a09-c0bdda8d8dd1",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Instead, I feel the strangest grief."
                },
                {
                  "id": "item-948d2322-44d3-48fd-984c-ef724ebb54e0",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Not for the image."
                },
                {
                  "id": "item-83b76daf-5239-416c-888f-81b8d03fdff1",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "For the version of myself who believed the image was enough."
                },
                {
                  "id": "item-d4d3faeb-8595-4736-95b7-7fc3290ca009",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Absurdly, I mourn my belief that evidence was the same as sight."
                },
                {
                  "type": "python_script",
                  "code": "story.set_has_photograph(False)",
                  "id": "item-f97e8f02-b13c-4f3e-a55e-81c625e258ac"
                },
                {
                  "type": "python_script",
                  "code": "story.set_day5_evidence_destroyed(True)",
                  "id": "item-014e3372-5859-4d54-aeda-671d01875faa"
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.has_photograph"
            },
            {
              "id": "15da46d0-1727-4963-ba0f-e589ec45e6d2",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-abf8fa31-867d-47e8-a097-79f478d9944e",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "He opens the lockbox and removes the envelope I failed to keep."
                },
                {
                  "id": "item-3b5ee51b-1c63-40a8-a8fb-ceec814fcd37",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "He does not burn it."
                },
                {
                  "id": "item-1482bdcb-90ec-490d-9515-ea7e34c1e541",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "That is worse."
                },
                {
                  "id": "item-1176c333-38a1-4478-be31-4005a33af5bd",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "He simply places it back inside and turns the key."
                },
                {
                  "type": "python_script",
                  "code": "story.set_day5_evidence_destroyed(False)",
                  "id": "item-5b62f991-d4f0-4614-b2a9-fa74744c8b5b"
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-8062d15d-5507-4fde-a7f7-22d949f443f9"
        },
        {
          "id": "item-52798f0a-768c-4601-a7b9-c233e7abfb4d",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "There."
        },
        {
          "id": "item-d1bd62ad-7767-43c1-b239-63a0cbf8f96e",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base"
        },
        {
          "id": "item-17eb3dca-a22d-4a95-a775-6f24fd34b213",
          "type": "show",
          "characterId": "gideon_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "move",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "gideon_sprite dominant"
        },
        {
          "id": "item-5838c683-5f7c-4a67-a66e-def972219622",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "You could dismiss me."
        },
        {
          "id": "item-1a4a80cf-3083-4413-9d54-2dc381f4be70",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Yes."
        },
        {
          "id": "item-5f442668-0955-41f4-b021-ef21587178be",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Have me arrested."
        },
        {
          "id": "item-488b84c9-40e0-4f0d-882c-210d2bb644ac",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Also yes."
        },
        {
          "id": "item-7251b085-c3b3-46aa-8b22-27d9802fb49d",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Then why not?"
        },
        {
          "id": "item-2363f013-81bd-4bf7-b806-b26607a925c0",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Because ending a thing too early teaches one nothing."
        },
        {
          "id": "item-0e3cfc84-ea95-4895-940c-14d5954226c1",
          "type": "dialogue",
          "characterId": null,
          "text": "He returns to the table and picks up his newspaper."
        },
        {
          "id": "item-98a8506d-290e-49bc-8b50-043151a82dc7",
          "type": "dialogue",
          "characterId": null,
          "text": "The crease is perfect."
        },
        {
          "id": "item-0ce34255-4702-47da-8045-ed53e7f84be7",
          "type": "dialogue",
          "characterId": null,
          "text": "He has done this before to someone."
        },
        {
          "id": "item-0c291aad-a19e-4bc3-bd76-76302568d693",
          "type": "dialogue",
          "characterId": null,
          "text": "The conversation, to him, has become light enough to read beside."
        },
        {
          "id": "item-7c36af56-29d1-4a33-8363-793fa88c9444",
          "type": "dialogue",
          "characterId": null,
          "text": "There it is."
        },
        {
          "id": "item-c24196db-4b37-4f4e-89da-8a3519bd617c",
          "type": "dialogue",
          "characterId": null,
          "text": "The mistake."
        },
        {
          "id": "item-0f880e46-5b86-4092-863d-a70f2651f59b",
          "type": "dialogue",
          "characterId": null,
          "text": "Not mine."
        },
        {
          "id": "item-64cb52ad-1715-4430-b41d-b7c03a9d1de6",
          "type": "dialogue",
          "characterId": null,
          "text": "His."
        },
        {
          "id": "item-bfbb6227-8f2c-4a90-95f8-4adc44256f84",
          "type": "dialogue",
          "characterId": null,
          "text": "He can end this."
        },
        {
          "id": "item-361f09ca-8895-4607-aa7e-9382bee9a476",
          "type": "dialogue",
          "characterId": null,
          "text": "He does not."
        },
        {
          "id": "item-58ed6e18-f817-44c7-b66c-a615fc3aa63b",
          "type": "dialogue",
          "characterId": null,
          "text": "Not from mercy."
        },
        {
          "id": "item-728234ed-3837-4973-a476-69cb386518cb",
          "type": "dialogue",
          "characterId": null,
          "text": "From the obscene confidence of a man who has never needed to imagine consequence arriving late."
        },
        {
          "id": "item-1377a206-c784-4606-820f-a812543027dd",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "You are not powerful, Cora. You are interesting. Do not confuse the two."
        },
        {
          "id": "item-d3a8c621-b14c-4154-a4f8-606eff68c7fc",
          "type": "dialogue",
          "characterId": null,
          "text": "The sentence lands harder than anger would have."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "5348fc5b-2936-4095-8501-07ee0394063d",
              "type": "if",
              "conditionRaw": "story.day5_dynamic == \"muse\"",
              "dialogue": [
                {
                  "id": "item-084849da-264d-41f6-bd1b-1257245f39f7",
                  "type": "dialogue",
                  "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
                  "text": "Finish your little book. Send it somewhere vulgar. I should like to see whether ink can do what theft could not."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day5_dynamic == \"muse\""
            },
            {
              "id": "a83c4ce7-e035-4ac2-a3f3-625295e69cc0",
              "type": "elif",
              "conditionRaw": "story.day5_dynamic == \"protege\"",
              "dialogue": [
                {
                  "id": "item-703934d6-db62-4401-81ba-4b5f55b45391",
                  "type": "dialogue",
                  "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
                  "text": "Learn the difference between hunger and leverage. One embarrasses you. The other moves rooms."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day5_dynamic == \"protege\""
            },
            {
              "id": "d54bf3f9-2b39-4ef2-a6d8-188b88d5ba02",
              "type": "elif",
              "conditionRaw": "story.day5_dynamic == \"adversary\"",
              "dialogue": [
                {
                  "id": "item-f69e8472-0043-43f7-a60e-1c2408af31e0",
                  "type": "dialogue",
                  "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
                  "text": "Keep your fear. It has made you less dull than most brave people."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day5_dynamic == \"adversary\""
            },
            {
              "id": "8a06e6e3-5ffd-4743-a605-0e0d12ae7fae",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-36087d5a-34a8-47b6-8d28-ae2f2331e54b",
                  "type": "dialogue",
                  "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
                  "text": "Keep watching, if you must. But understand that witnesses also become exhibits."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-2ad8e7f1-6995-4da5-bf47-9089fd9f4d57"
        },
        {
          "id": "item-1033abb6-1450-408f-bd78-1f09364e719e",
          "type": "dialogue",
          "characterId": null,
          "text": "He opens a drawer and removes an envelope."
        },
        {
          "id": "item-6855f5e8-17af-4405-8ac8-1632c9a522d8",
          "type": "dialogue",
          "characterId": null,
          "text": "Money."
        },
        {
          "id": "item-12c8deb9-d6ae-4624-8a00-8cc8d6eb2d6f",
          "type": "dialogue",
          "characterId": null,
          "text": "Of course money."
        },
        {
          "id": "item-29993f09-5cd4-43ee-a93b-9e4b9d0258db",
          "type": "dialogue",
          "characterId": null,
          "text": "The envelope is heavier than travel money should be."
        },
        {
          "id": "item-930b3559-db93-4ea2-8b4f-f823bc35cbe6",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "For printing. Or passage. Or a better pair of lies. Spend it as your genre requires."
        },
        {
          "id": "item-ff3ba24b-3203-4949-b863-2ed01a45e2d6",
          "type": "dialogue",
          "characterId": null,
          "text": "He places it on the table."
        },
        {
          "id": "item-ffc489b2-8dc8-4321-b3b5-1e9df189853d",
          "type": "dialogue",
          "characterId": null,
          "text": "Not into my hand."
        },
        {
          "id": "item-1c5956bc-3719-48ab-911f-66edffcee9ce",
          "type": "dialogue",
          "characterId": null,
          "text": "He will not allow the gesture to look like payment unless I choose to take it that way."
        },
        {
          "id": "item-8303257b-7033-4596-8b30-0b8e18897cee",
          "type": "dialogue",
          "characterId": null,
          "text": "I do not touch it until he turns away."
        },
        {
          "id": "item-416eaae5-d4e4-466d-ad69-6d1b11b789bc",
          "type": "dialogue",
          "characterId": null,
          "text": "Even then, I wait one breath."
        },
        {
          "id": "item-1c5f61d3-bc8e-456a-95d6-da22a2ad6c25",
          "type": "dialogue",
          "characterId": null,
          "text": "Servants who reach too quickly are thieves twice."
        },
        {
          "type": "choice",
          "options": [
            {
              "id": "d281823a-8f5c-480e-bcfe-640ca42aad82",
              "text": "Take it. Survival first. [[Pragmatic entanglement]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "story.set_day5_money_choice(\"taken\")",
                  "id": "item-c5a6e7d8-5e28-4c7a-907d-03ef61993c15"
                },
                {
                  "type": "python_script",
                  "code": "story.set_gideon_entanglement_level(\"accepted_money\")",
                  "id": "item-a17b11d9-6638-40e5-993d-b03e1760f76a"
                },
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"transgressive\", intensity=\"standard\", witness=\"gideon\")",
                  "id": "item-510a6341-ec4c-40be-8c3b-a0faadc96fba"
                },
                {
                  "id": "item-fd3f7aa1-b574-4383-a289-1e3ff0bfff93",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I take the envelope."
                },
                {
                  "id": "item-4ca10700-e86a-498a-a95a-05e0fb2bfa67",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "My hand does not shake."
                },
                {
                  "id": "item-2c2b45bd-bc64-449c-b823-597ffe0bccf0",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Our skin touches once."
                },
                {
                  "id": "item-48bdcef9-d907-497e-9be6-364e4867651f",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "He notes whether I look at the denomination."
                },
                {
                  "id": "item-f542a3bd-b2d4-4809-92d8-34c8aeeddc07",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "That may be growth."
                },
                {
                  "id": "item-c4aea3c1-0cfd-4ea5-bd20-b8fdfc1541d4",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "It may be damage."
                },
                {
                  "id": "item-edbb9d69-4f15-45ef-b9fe-b8f67f0c3025",
                  "type": "dialogue",
                  "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
                  "text": "Good. Pride is most useful after one has eaten."
                }
              ]
            },
            {
              "id": "fbd18004-5c95-4a03-8f0e-282e6391fa98",
              "text": "Refuse it. Keep one clean line. [[Defiant poverty]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "story.set_day5_money_choice(\"refused\")",
                  "id": "item-adbea14d-792e-4f4b-b2e9-0d05eb5e2119"
                },
                {
                  "type": "python_script",
                  "code": "story.set_gideon_entanglement_level(\"refused_money\")",
                  "id": "item-a5f466fa-ec43-4430-94e0-2a4836910da4"
                },
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"observant\", intensity=\"standard\")",
                  "id": "item-e38a6545-2033-40bb-b9db-c6fe299a0f60"
                },
                {
                  "id": "item-01481f47-dc94-4ce8-9341-abbaf8c9d542",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "I will not take your money, sir."
                },
                {
                  "id": "item-97d4e927-94b1-4fd6-a69e-c873eacfa724",
                  "type": "dialogue",
                  "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
                  "text": "You already took my photograph."
                },
                {
                  "id": "item-171e9c97-d7e1-4252-a8af-06989a8a1ddd",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "That was different."
                },
                {
                  "id": "item-f3540a08-ab53-427a-83e6-bd5b6ed38bb1",
                  "type": "dialogue",
                  "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
                  "text": "Yes. Less useful."
                },
                {
                  "id": "item-d3e85bb9-1bdb-40a9-bace-6723f8184f17",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The envelope remains on the table between us."
                },
                {
                  "id": "item-609fb624-0851-49e7-a6b8-b8b59bb04599",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "A third object I cannot make mean only one thing."
                }
              ]
            },
            {
              "id": "49ffd8d6-5501-4ed2-88b0-45a0f59905f9",
              "text": "Leave it untouched, but remember where he placed it. [[Ghost option]]",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "story.set_day5_money_choice(\"deferred\")",
                  "id": "item-1d163b66-ac30-4e00-8001-b8c568c787ff"
                },
                {
                  "type": "python_script",
                  "code": "story.set_gideon_entanglement_level(\"deferred_money\")",
                  "id": "item-ebe712eb-b1d5-40ba-b6de-848070964bd8"
                },
                {
                  "type": "python_script",
                  "code": "apply_balanced_effect(\"creative\", intensity=\"standard\")",
                  "id": "item-34583d4b-4e26-488e-9c50-292f8cc8e511"
                },
                {
                  "type": "python_script",
                  "code": "apply_effects(vance_susp=-5)",
                  "id": "item-17d49109-35e5-469c-ad59-c56e4568f30c"
                },
                {
                  "id": "item-0f44903f-0d98-418a-9704-5d395e8268a3",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I do not touch the envelope."
                },
                {
                  "id": "item-6c2314ac-77bf-4a1a-82c6-72c1628aff22",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I step back three paces."
                },
                {
                  "id": "item-1e0a0e49-28e3-4c19-b983-2c1f972871f6",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I also do not refuse it."
                },
                {
                  "id": "item-3a1c61d6-bd03-4596-9f30-675f2e93605c",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I do not look away."
                },
                {
                  "id": "item-76770800-3008-4843-b0b6-5b7decddf6f2",
                  "type": "dialogue",
                  "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
                  "text": "Careful. That almost resembles strategy."
                },
                {
                  "id": "item-9e3d2343-0aa0-4ba7-a88a-64d065bdfb64",
                  "type": "dialogue",
                  "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
                  "text": "Almost is sometimes enough, sir."
                },
                {
                  "id": "item-f3d22dc9-08a3-43eb-8f23-aa36d5685a07",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "He smiles at that."
                },
                {
                  "id": "item-0faebdd3-ad71-4443-876f-810d05c6485d",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I wish he had not."
                }
              ]
            }
          ],
          "id": "item-d86dd30b-be1e-433a-8809-2cf3be7533e5"
        },
        {
          "id": "item-95e350de-1a85-4be0-af3c-af848f952684",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Go back downstairs."
        },
        {
          "id": "item-e3983183-f3c6-456d-985a-4c18ae537df3",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "And tomorrow, sir?"
        },
        {
          "id": "item-67e65254-f099-4679-994f-3ac9c7909d31",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Tomorrow, I leave the Savoy."
        },
        {
          "id": "item-cb4b1c06-ecd3-48c8-bcd0-54c625a60e77",
          "type": "dialogue",
          "characterId": null,
          "text": "The answer is a door I did not expect."
        },
        {
          "id": "item-a547299e-1663-40af-83c7-7062ca5bc58a",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Did you imagine I lived here? Monsters are rarely so convenient."
        },
        {
          "id": "item-14468b73-82ad-4317-8854-c8f02d34ecd6",
          "type": "dialogue",
          "characterId": null,
          "text": "I hate that he says monsters."
        },
        {
          "id": "item-bd0dcdee-e98a-4596-86a3-2fd24cf92e03",
          "type": "dialogue",
          "characterId": null,
          "text": "I hate more that he says it accurately."
        },
        {
          "id": "item-a6ff43d9-f854-4263-a43e-04dbb785c602",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "We will meet again when it is interesting to do so. In the meantime, write. It seems to make you troublesome."
        },
        {
          "id": "item-65af7008-1c5c-4045-97d2-98a7205b94df",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "I shall inform the dust, sir."
        },
        {
          "id": "item-e68e30a3-26a8-4d40-a1ad-f9c17bbfcd8d",
          "type": "dialogue",
          "characterId": null,
          "text": "He almost smiles."
        },
        {
          "id": "item-3e9b5727-8991-4dbd-b90e-a10c1e55f945",
          "type": "dialogue",
          "characterId": null,
          "text": "Almost is a wage increase in this hotel."
        },
        {
          "id": "item-47259f8c-0fde-4210-8d49-0a14da258468",
          "type": "dialogue",
          "characterId": null,
          "text": "He picks up the paper."
        },
        {
          "id": "item-a01dddf8-1e43-4d26-b40f-ba28b94ee286",
          "type": "dialogue",
          "characterId": null,
          "text": "Dismissed."
        },
        {
          "id": "item-e974000a-2a36-445f-a9d7-5ff2a39e06c4",
          "type": "dialogue",
          "characterId": null,
          "text": "Not defeated."
        },
        {
          "id": "item-8b60b599-b4cb-4e5b-b2a6-8213932477b6",
          "type": "dialogue",
          "characterId": null,
          "text": "Not spared."
        },
        {
          "id": "item-968ba38e-19d6-43a2-aecb-16c0fb9255ea",
          "type": "dialogue",
          "characterId": null,
          "text": "Marked and released."
        },
        {
          "id": "item-4b0f0890-6a05-43a8-812b-2157d6c64518",
          "type": "jump",
          "destinationLabelId": "label-37f59cc9-8e5a-49a0-a4d1-c36d7374821a"
        }
      ]
    },
    {
      "id": "label-37f59cc9-8e5a-49a0-a4d1-c36d7374821a",
      "name": "day105_6_manuscript_reckoning",
      "x": 24900,
      "y": 11122.5,
      "dialogue": [
        {
          "type": "if_block",
          "branches": [
            {
              "id": "8b8cccb1-6698-4ebf-bb80-6698a3f8ded9",
              "type": "if",
              "conditionRaw": "player.corruption_level < WRITE_GATE_CH2[1]",
              "dialogue": [
                {
                  "id": "item-d1019c28-a149-4864-8858-40aa0cd566bd",
                  "type": "jump",
                  "destinationLabelId": "label-1776c6e9-dbce-4e73-855b-df61bbd09d45"
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "player.corruption_level < WRITE_GATE_CH2[1]"
            }
          ],
          "id": "item-36d58ceb-8a63-47fe-b044-45f701a3b210"
        },
        {
          "type": "scene",
          "layer": null,
          "transition": "fade",
          "id": "item-d079e832-d8cc-4825-b673-fa8e9a38188a",
          "backgroundId": "bg_cora_desk_night"
        },
        {
          "id": "item-c850ae3f-0e70-458c-ac72-ed7032c68cd6",
          "type": "dialogue",
          "characterId": null,
          "text": "The room is exactly as I left it."
        },
        {
          "id": "item-5fa0437a-582b-4d18-941d-6a002f1564ca",
          "type": "dialogue",
          "characterId": null,
          "text": "That feels impossible."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "fc151fee-f997-415b-aa9f-279f6031dc6a",
              "type": "if",
              "conditionRaw": "story.day4_night_action == \"finish_manuscript\"",
              "dialogue": [
                {
                  "id": "item-6e2ff615-73b0-44e4-8bb9-c82fd4be2f09",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The triumphant chapter waits on the desk."
                },
                {
                  "id": "item-03437765-9bb1-4bd1-a5f6-937fa3b4fb1e",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The maid outwits the master."
                },
                {
                  "id": "item-3c6b8e69-f65d-4f10-aeec-664647e26ffc",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The lord is trapped by his own secret."
                },
                {
                  "id": "item-0875b46d-4c55-4d03-8247-5ff4d58982be",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The ending is beautiful."
                },
                {
                  "id": "item-4e268d62-9907-4397-b5b6-f9b641573e2d",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "It is also wrong."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day4_night_action == \"finish_manuscript\""
            },
            {
              "id": "ad120bf4-c914-4628-9f78-b7d5ebb33a99",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-1d77dc10-a908-4322-83af-a2e6403e7604",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The unfinished pages wait on the desk."
                },
                {
                  "id": "item-08377f1e-aecf-4a06-84ea-cbdb516b1f60",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Yesterday I thought survival might be enough."
                },
                {
                  "id": "item-e0a935bc-d896-4440-abb2-fd190ecbb5ec",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Today survival feels like a room with the lock on the outside."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-0b685d2d-4ba9-4d84-9d80-1c7f1ebe10a3"
        },
        {
          "id": "item-29fb6927-bbae-40fc-9cb0-f904e8ff5d37",
          "type": "dialogue",
          "characterId": null,
          "text": "The desk is an altar I built for a god who does not answer."
        },
        {
          "id": "item-f5b9510f-666e-440f-94a5-6733653279b4",
          "type": "dialogue",
          "characterId": null,
          "text": "I open the manuscript."
        },
        {
          "id": "item-92bc394e-c0f8-476f-89d7-c8c78470faad",
          "type": "dialogue",
          "characterId": null,
          "text": "I do not know whether I am correcting art or confessing defeat."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "001cd4ac-5acf-42de-9c13-21a275145fcb",
              "type": "if",
              "conditionRaw": "story.day5_dynamic == \"muse\"",
              "dialogue": [
                {
                  "id": "item-2c7d9473-3560-43f6-85b1-bb328a3cb844",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I write the machine around the man."
                },
                {
                  "id": "item-2f4bf7f0-c7f5-4fb9-876f-5c1610d8baea",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The carriage waiting outside. The solicitor's letterhead. The policeman's lowered eyes. The publisher's careful refusal dressed as taste."
                },
                {
                  "id": "item-6e72de8d-2ca2-4d07-94e6-998a471151a8",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Gideon becomes smaller on the page because the world behind him becomes vast."
                },
                {
                  "type": "if_block",
                  "branches": [
                    {
                      "id": "a93647ea-4978-438e-88e9-550200ae0e7b",
                      "type": "if",
                      "conditionRaw": "story.day1_interview_state == \"competent\"",
                      "dialogue": [
                        {
                          "id": "item-1b914eb2-1f01-402e-a591-254029fc9f6f",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "Stern called precision a dangerous word from a girl in a borrowed apron."
                        },
                        {
                          "id": "item-67ee33a2-fb9a-44e5-93bb-7373214436c1",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "She was not wrong. She was describing the machine's logic: exactness belongs to the people the machine was built to serve."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      },
                      "rawCondition": "story.day1_interview_state == \"competent\""
                    }
                  ],
                  "id": "item-5fc6b998-9b92-4cc6-9453-9049efd7c4cb"
                },
                {
                  "type": "if_block",
                  "branches": [
                    {
                      "id": "f3c1af72-4a4e-4e51-b341-98c28dae193a",
                      "type": "if",
                      "conditionRaw": "story.day3_brush_choice == \"predator\"",
                      "dialogue": [
                        {
                          "id": "item-1303f722-5a87-4479-98c9-8cf1e25a14b8",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "In the suite I named Vance's weakness with the accuracy of someone who has been watching rooms too long."
                        },
                        {
                          "id": "item-8b416313-12fd-41ce-a2e2-60ec0e8bc31c",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "He called me a little anatomist. Even his compliments describe the altitude of the shelf where he keeps me."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      },
                      "rawCondition": "story.day3_brush_choice == \"predator\""
                    }
                  ],
                  "id": "item-fcc2178b-f65e-4075-9fdc-b814643aa3e1"
                },
                {
                  "type": "if_block",
                  "branches": [
                    {
                      "id": "4c8294d0-7ba1-49fc-b840-99b4c7acd29a",
                      "type": "if",
                      "conditionRaw": "story.day3_corridor_chain == \"inspiration\"",
                      "dialogue": [
                        {
                          "id": "item-5009262e-8322-402c-a6d3-b4c6be74d271",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "That morning I counted it: bell-pull rhythm, servants' stair, the distance from Stern's office to the Master Suite."
                        },
                        {
                          "id": "item-ebabbccd-93fe-458e-ab7f-c891fdb73d6c",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "A hotel is a machine for sorting bodies by permission. Men like Gideon move through both halves and call the passage natural."
                        },
                        {
                          "id": "item-7d61c7e0-9ba8-4149-9181-8982d3cfa682",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "That sentence was already in the book. I only had to let the page be large enough to hold what I had seen."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      },
                      "rawCondition": "story.day3_corridor_chain == \"inspiration\""
                    }
                  ],
                  "id": "item-9c1d740c-e6f5-4f00-8309-ef202b1c9756"
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day5_dynamic == \"muse\""
            },
            {
              "id": "c81a545f-529a-4138-8dab-231ee332847a",
              "type": "elif",
              "conditionRaw": "story.day5_dynamic == \"protege\"",
              "dialogue": [
                {
                  "id": "item-1db39573-0764-42be-8525-bbe13585da1f",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I write the hunger honestly."
                },
                {
                  "id": "item-28e87e9d-b5f0-4fe1-9eae-746444e7b8d4",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Not as triumph. Not as corruption alone."
                },
                {
                  "id": "item-cc7fca20-b43d-4fa8-bc65-dbf43630036e",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "As a tool I do not yet know how to hold without cutting someone poorer than me."
                },
                {
                  "type": "if_block",
                  "branches": [
                    {
                      "id": "020c8dd9-97be-49e4-b013-de31429e4f7d",
                      "type": "if",
                      "conditionRaw": "story.day1_corridor_state == \"predator\"",
                      "dialogue": [
                        {
                          "id": "item-c996bb32-4dbf-4656-b946-092d4b8ecbf0",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "I sent Missy to the service door first."
                        },
                        {
                          "id": "item-788a5678-d97f-4ad3-a282-901cb982d3c1",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "The corridor, the half-open door, the sound through plaster. I placed another girl's innocence between my hunger and the possible consequence."
                        },
                        {
                          "id": "item-552ecc05-536a-4ae8-8c21-42d49f23bda9",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "That is what the hunger looks like before the page makes it interesting. The chapter must say so."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      },
                      "rawCondition": "story.day1_corridor_state == \"predator\""
                    }
                  ],
                  "id": "item-ea11c915-a1ee-488a-9d00-f9da9a4c7dc5"
                },
                {
                  "type": "if_block",
                  "branches": [
                    {
                      "id": "454b40da-173b-4bae-8984-302fe64b9af3",
                      "type": "if",
                      "conditionRaw": "story.day2_tea_choice == \"predator\"",
                      "dialogue": [
                        {
                          "id": "item-1ec4c6a4-f21b-4ab1-b116-c0d4b88b5667",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "In the suite I crossed to the trunk and produced the missing thing with composed hands."
                        },
                        {
                          "id": "item-f638d1da-f272-459a-b4e9-559cbc6d7972",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "I said servant ways in a voice that meant something else, and he thanked me."
                        },
                        {
                          "id": "item-7b18d3bc-84cf-40ce-9b2d-90b9c1767a81",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "The chapter must ask what I gave him in exchange for that thanks. It must answer honestly."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      },
                      "rawCondition": "story.day2_tea_choice == \"predator\""
                    }
                  ],
                  "id": "item-f0721d67-7637-457c-844b-5f41b8facc9f"
                },
                {
                  "type": "if_block",
                  "branches": [
                    {
                      "id": "0619c29b-cf03-4876-899d-9ba58d6d9e82",
                      "type": "if",
                      "conditionRaw": "story.day3_brush_choice == \"predator\"",
                      "dialogue": [
                        {
                          "id": "item-89db2eff-0c31-44ba-a0c8-9016e1e4b1d6",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "I stood behind the seated woman with a brush in my hand and described her weakness with the precision of a naturalist."
                        },
                        {
                          "id": "item-4231628a-551c-4bc5-a9eb-d79d63d864d6",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "On the page, the hunger that moves the maid is not cruelty. It is appetite: for the room, the view, the position, the precision."
                        },
                        {
                          "id": "item-63a00219-2b22-48fd-9613-1af4d543cfe8",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "The chapter must learn to hold that without apologising for it and without pretending it comes free."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      },
                      "rawCondition": "story.day3_brush_choice == \"predator\""
                    }
                  ],
                  "id": "item-038701c1-5021-4e89-8e58-ab26cf97246b"
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day5_dynamic == \"protege\""
            },
            {
              "id": "c39b5bd0-01a7-43b4-a49c-14adea89fd01",
              "type": "elif",
              "conditionRaw": "story.day5_dynamic == \"adversary\"",
              "dialogue": [
                {
                  "id": "item-4b799fab-8229-470f-8db8-43093a4d45bf",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I write fear as evidence."
                },
                {
                  "id": "item-44b6e91b-8929-49ee-a5a5-d0a6e3a07b99",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Not weakness. Evidence."
                },
                {
                  "id": "item-e14011c9-d1af-4a85-9b2d-3f5f2388c57a",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The body knows power before the mind builds theories to survive it."
                },
                {
                  "type": "if_block",
                  "branches": [
                    {
                      "id": "48c2e162-fab6-494b-bcef-28852a7d0c31",
                      "type": "if",
                      "conditionRaw": "story.day1_corridor_state == \"prey\"",
                      "dialogue": [
                        {
                          "id": "item-104bded0-ff5a-4f6e-bb7a-0a219bf38409",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "The third board announced me. His eyes moved to the door."
                        },
                        {
                          "id": "item-0913f85e-d9ce-441d-a800-d6500207d5c6",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "I felt the fear and kept moving toward it. The body was already inside the danger before I had decided to enter."
                        },
                        {
                          "id": "item-5f119e68-60ce-4fcd-aafe-b0c07c7697f9",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "That is the chapter's first evidence: fear and motion are not opposites."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      },
                      "rawCondition": "story.day1_corridor_state == \"prey\""
                    }
                  ],
                  "id": "item-ea06d860-4960-4791-8812-074cdd15287b"
                },
                {
                  "type": "if_block",
                  "branches": [
                    {
                      "id": "a5f9e2fd-d08b-480c-a761-032dc0ca88d1",
                      "type": "if",
                      "conditionRaw": "story.day3_brush_choice == \"prey\"",
                      "dialogue": [
                        {
                          "id": "item-a5a1a3f3-de8b-4668-841f-f25c59a27c96",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "I looked at him in the mirror when I should have looked at the floor. He saw me looking."
                        },
                        {
                          "id": "item-f0338bdd-15df-4fcc-b3b7-80d983c0ef5d",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "The chapter calls this the body's deposition: the face that showed too much was not failure."
                        },
                        {
                          "id": "item-4455fe20-3c9f-429e-a783-e2dd639f8180",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "It was the one moment in five days where I produced exactly what I felt without the maid's costume over it."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      },
                      "rawCondition": "story.day3_brush_choice == \"prey\""
                    }
                  ],
                  "id": "item-a5de5f13-3b6e-4fd8-b533-5962cfd94f1d"
                },
                {
                  "type": "if_block",
                  "branches": [
                    {
                      "id": "1d076030-5493-4d49-8fb5-ad311075b725",
                      "type": "if",
                      "conditionRaw": "story.day3_ultimatum == \"defied\"",
                      "dialogue": [
                        {
                          "id": "item-e18c26fe-522a-4357-81be-31d82b278d47",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "I said no to the nine o'clock room and the fear arrived correctly: sharp, specific, and located in the chest."
                        },
                        {
                          "id": "item-d0e35aca-1133-47ac-a15e-743d5a6a5c43",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "That is what the chapter calls evidence. Not proof against him. Proof of the pressure's shape."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      },
                      "rawCondition": "story.day3_ultimatum == \"defied\""
                    }
                  ],
                  "id": "item-2d9cdc73-0276-4469-a951-67d74a358ac3"
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day5_dynamic == \"adversary\""
            },
            {
              "id": "d1469804-dbbf-43f4-8d5d-7a76a5f82390",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-69495066-9407-46fe-a7e2-f77baf8c5267",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I write what witnesses cost."
                },
                {
                  "id": "item-4028c2ab-af9f-4eba-bea4-3f62b9695791",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Who is believed. Who is displayed. Who is corrected for naming the room too accurately."
                },
                {
                  "type": "if_block",
                  "branches": [
                    {
                      "id": "d44b9f2b-7fb4-4c8e-8017-487e0430493a",
                      "type": "if",
                      "conditionRaw": "story.day2_tea_choice == \"ghost\"",
                      "dialogue": [
                        {
                          "id": "item-d90262db-0d4a-46f4-a767-a2023b668fbb",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "Missy said: I only did what you said."
                        },
                        {
                          "id": "item-364f0c73-5214-4e17-a76f-aadfa3ef48b6",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "Stern said: quiet."
                        },
                        {
                          "id": "item-9b2e2c95-2b61-4f3b-bfdb-3bd6dfe9073f",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "The room agreed. Truth without rank is noise, and I was the one who arranged for Missy to be the noise."
                        },
                        {
                          "id": "item-c3e9cebc-9599-48f7-973e-3d64d32340fb",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "The chapter must name this. A witness who engineers another person's exposure is not a witness. She is a user of testimony."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      },
                      "rawCondition": "story.day2_tea_choice == \"ghost\""
                    }
                  ],
                  "id": "item-eb837dcd-e31f-4216-8d14-092057440a9a"
                },
                {
                  "type": "if_block",
                  "branches": [
                    {
                      "id": "d0782004-3a3c-40b8-9227-94af6811c402",
                      "type": "if",
                      "conditionRaw": "story.day1_corridor_state == \"ghost\"",
                      "dialogue": [
                        {
                          "id": "item-a7971fb9-02ae-46f7-a76c-93b8c0efc24d",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "I pulled her away from the service door. I said we were not the cure."
                        },
                        {
                          "id": "item-35ced340-bc25-4dc0-98ec-0c21c5735c19",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "The chapter faces the other sentence: we were also not witnesses. We were bystanders who collected material and called the distance craft."
                        },
                        {
                          "id": "item-a4e821e7-1d2a-4b18-9050-3c5812e18c4d",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "The manuscript must decide whether those are different things."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      },
                      "rawCondition": "story.day1_corridor_state == \"ghost\""
                    }
                  ],
                  "id": "item-abd1ee6b-3971-4dc6-abf3-015058dbde72"
                },
                {
                  "type": "if_block",
                  "branches": [
                    {
                      "id": "a03ea680-329f-4a40-8d48-6fe95231ca02",
                      "type": "if",
                      "conditionRaw": "story.day3_brush_choice == \"ghost\"",
                      "dialogue": [
                        {
                          "id": "item-eb0da75d-638e-4c10-a370-5e7abac33cee",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "I dropped the brush and saw the room from the floor and kept the angle."
                        },
                        {
                          "id": "item-12898aa5-be46-4cf1-99f7-7a6fd309362f",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "From below: a polished boot, a clenched slipper, the hem of my own uniform trembling."
                        },
                        {
                          "id": "item-6b50b8dd-6ed5-4275-8992-cf15bd586054",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "A witness that low in the room is also a witness who can be stepped on."
                        },
                        {
                          "id": "item-214ea227-3d3a-4c81-bd27-fbd9bab61ded",
                          "type": "dialogue",
                          "characterId": null,
                          "text": "The chapter must say what that costs. Not only what it sees."
                        }
                      ],
                      "condition": {
                        "operator": "and",
                        "clauses": []
                      },
                      "rawCondition": "story.day3_brush_choice == \"ghost\""
                    }
                  ],
                  "id": "item-c88f8b73-2c56-41de-b664-d1bc91363fb3"
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-37802cd3-9435-4fdc-ada5-d7795e1a5230"
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "55e52720-c46d-4558-8e0a-b47d01f7d21e",
              "type": "if",
              "conditionRaw": "story.day2_tea_choice == \"ghost\" or story.day4_escape_state == \"missy_cover\" or story.missy_day4_used_as_cover",
              "dialogue": [
                {
                  "id": "item-33cbbd5c-369f-49a7-b8c4-be591ad77745",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Then Missy enters the page."
                },
                {
                  "id": "item-c918d014-3d65-437f-aee6-2b87a5a0928b",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Not as symbol."
                },
                {
                  "id": "item-075750a7-54a0-4032-be96-e196f81e9ce8",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "As debt."
                },
                {
                  "id": "item-e5b864da-778b-4aa0-ae08-097e16ff5c47",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "There are things I did to survive that the book cannot turn noble."
                },
                {
                  "type": "python_script",
                  "code": "story.set_missy_debt_carried_forward(True)",
                  "id": "item-4c8a2671-bcf5-4ae2-89a1-b2ac9ebfe4e5"
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day2_tea_choice == \"ghost\" or story.day4_escape_state == \"missy_cover\" or story.missy_day4_used_as_cover"
            }
          ],
          "id": "item-38a9eae7-3d76-40d3-bab2-9212a33053bb"
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "59ddad39-27f5-4719-a817-a505eac8c9cb",
              "type": "if",
              "conditionRaw": "story.day4_night_action == \"finish_manuscript\"",
              "dialogue": [
                {
                  "id": "item-02e5ddae-dd3b-42d7-862a-0840694f0d97",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I do not destroy yesterday's ending."
                },
                {
                  "id": "item-c899f156-b2bb-46c4-89f3-ebcbf152cab1",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I draw a line beneath it and write another."
                },
                {
                  "id": "item-f7e13757-9613-46a9-b50f-d50e46e05777",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The first ending is the lie I needed."
                },
                {
                  "id": "item-9befdf6e-fba9-4c91-b369-8cdc6f72be4b",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The second is the truth I can bear."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day4_night_action == \"finish_manuscript\""
            },
            {
              "id": "b500fc37-41c5-4d04-9c88-173c382fb508",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-b3d66e34-04da-4f98-9600-ff9073d346a4",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The ending comes now, stripped of victory."
                },
                {
                  "id": "item-be3db08b-9314-4b9a-ba4a-5ed20fe28fa3",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Not triumphant."
                },
                {
                  "id": "item-4abfc331-561a-492a-b325-13714306694f",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Useful."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-7d6b7042-912d-47b5-ba5a-46f96dfe1a8a"
        },
        {
          "type": "python_script",
          "code": "story.complete_manuscript_chapter(\"day5_reckoning_chapter\")",
          "id": "item-3c86e1e3-e8f0-4b63-aac6-79c0a28f63a1"
        },
        {
          "type": "python_script",
          "code": "story.complete_release1_manuscript(True)",
          "id": "item-54159520-0678-4dd9-91c0-4a89aaf7f97b"
        },
        {
          "type": "python_script",
          "code": "story.set_release1_completed(True)",
          "id": "item-5afb5b67-d417-4363-8a41-fc574d53e8c6"
        },
        {
          "id": "item-34b11764-f338-4fc0-8422-06a81c169f97",
          "type": "call",
          "destinationLabelId": "label-50c93452-a12f-49cf-9982-b6cc72b97648"
        },
        {
          "id": "item-1794db26-5785-4f54-81d0-fcb8b12f44da",
          "type": "dialogue",
          "characterId": null,
          "text": "When the candle dies, the manuscript is complete."
        },
        {
          "id": "item-70a36e10-f8e5-43ee-b1ae-81bacd04a112",
          "type": "dialogue",
          "characterId": null,
          "text": "Not because I won."
        },
        {
          "id": "item-1290edcb-3b9a-4851-b85a-bf8786a55c63",
          "type": "dialogue",
          "characterId": null,
          "text": "Because I finally understand the shape of the thing I lost to."
        },
        {
          "id": "item-a1aa4486-a85c-4f3b-8efe-8488b8e98e3d",
          "type": "dialogue",
          "characterId": null,
          "text": "The ending is not victory."
        },
        {
          "id": "item-c61b1c57-3243-44fc-a6e8-b1fad5afada5",
          "type": "dialogue",
          "characterId": null,
          "text": "It is diagnosis."
        },
        {
          "id": "item-3708498d-10c6-49e0-9d23-eebabdefa819",
          "type": "jump",
          "destinationLabelId": "label-8c1ec897-29d6-4e70-99be-8aaf2e7cc5bf"
        }
      ]
    },
    {
      "id": "label-8c1ec897-29d6-4e70-99be-8aaf2e7cc5bf",
      "name": "day105_7_release_one_ending",
      "x": 25300,
      "y": 10937.5,
      "dialogue": [
        {
          "type": "scene",
          "layer": null,
          "transition": "fade",
          "id": "item-9fff7e5d-ce59-4e7d-9668-9d446f40646d",
          "backgroundId": "bg_master_suite_day"
        },
        {
          "id": "item-f17bcfc7-9ccf-487c-b97a-82307349f572",
          "type": "dialogue",
          "characterId": null,
          "text": "The next morning, Gideon Locke leaves the Savoy."
        },
        {
          "id": "item-a64fd5dd-cca6-4052-8af7-b698df8dc9e3",
          "type": "show",
          "characterId": "vance_sprite",
          "isFlipped": false,
          "xpos": 0.1,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "vance_sprite confused"
        },
        {
          "id": "item-62c0c251-2f12-4fe1-a6f5-292697ee5e32",
          "type": "dialogue",
          "characterId": null,
          "text": "Vance travels with him, dressed beautifully enough to convince strangers of almost anything."
        },
        {
          "id": "item-3a5b7bed-1340-49bb-b1a2-21d8062bfc38",
          "type": "dialogue",
          "characterId": null,
          "text": "She does not look at me until the footman carries down the last of the luggage."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "95aa6c00-509b-489d-877f-251918750896",
              "type": "if",
              "conditionRaw": "story.day2_tea_choice == \"ghost\" or story.day4_escape_state == \"missy_cover\"",
              "dialogue": [
                {
                  "id": "item-00847648-865d-4ea2-8728-493267ab6811",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Missy stands on the opposite side of the corridor."
                },
                {
                  "id": "item-562a38f4-bee0-4236-a059-20450d8662e6",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Not beside me."
                },
                {
                  "id": "item-a2948726-2a1a-4903-babb-9de0b867824a",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "That distance is one of the few honest things in the hotel."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day2_tea_choice == \"ghost\" or story.day4_escape_state == \"missy_cover\""
            },
            {
              "id": "78e18bbd-43a2-40f3-8e49-9d1da096b982",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-c0eee191-eb2e-4530-8368-5b30b6316345",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Missy stands beside me, close enough that our sleeves almost touch."
                },
                {
                  "id": "item-94633920-862b-4e57-a30f-9c225ff11ad4",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Almost."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-15ed43d4-4d0a-482f-9118-11c4ea52e71d"
        },
        {
          "id": "item-23c25eaa-bc17-4de0-bb15-acbc92981079",
          "type": "show",
          "characterId": "gideon_sprite",
          "isFlipped": false,
          "xpos": 0.9,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "gideon_sprite dominant"
        },
        {
          "id": "item-067e30af-e0b5-40d1-8e3e-d714a2b7bb4b",
          "type": "dialogue",
          "characterId": null,
          "text": "Gideon pauses at the foot of the stairs."
        },
        {
          "id": "item-8bc56952-bf10-4497-84da-b4be6b80cb66",
          "type": "dialogue",
          "characterId": null,
          "text": "Not long enough for anyone important to notice."
        },
        {
          "id": "item-083b2453-a0bd-493c-85f0-070ea9a99de6",
          "type": "dialogue",
          "characterId": null,
          "text": "Long enough for me."
        },
        {
          "type": "if_block",
          "branches": [
            {
              "id": "70562d6a-00d2-4d36-96b6-da66c149d386",
              "type": "if",
              "conditionRaw": "story.day5_money_choice == \"taken\"",
              "dialogue": [
                {
                  "id": "item-563a606c-bf68-455f-baa5-9888419792ac",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The envelope is hidden beneath my mattress."
                },
                {
                  "id": "item-b438b050-2918-409e-a5d8-7d46b6c42617",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I can feel the weight of it from here, absurd as that is."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day5_money_choice == \"taken\""
            },
            {
              "id": "53893d9c-4a39-463e-b07c-6d25b81c27d9",
              "type": "elif",
              "conditionRaw": "story.day5_money_choice == \"refused\"",
              "dialogue": [
                {
                  "id": "item-54e8794c-cacd-4d13-a15f-c4ace2dcfc4b",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The envelope remained on his table."
                },
                {
                  "id": "item-28a8d400-2ba6-42f8-a6ad-c7de412e7520",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "I have kept my pride and solved nothing."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "story.day5_money_choice == \"refused\""
            },
            {
              "id": "97b1c00d-aaa3-445c-a8b4-86e361c846f5",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "id": "item-b1502beb-8f29-4d68-94f2-3265e1bc4845",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "The envelope remained where he placed it."
                },
                {
                  "id": "item-95c1b3f4-778f-47bf-8495-ef6fe9114968",
                  "type": "dialogue",
                  "characterId": null,
                  "text": "Which means, inconveniently, that it may still become a choice later."
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-c7ba12fc-a126-4840-a5b7-975870a02bd4"
        },
        {
          "id": "item-40fccb70-982d-4075-8750-f875887abcf0",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Cora."
        },
        {
          "id": "item-76357814-488c-4fd3-8a26-5ac258bd5c34",
          "type": "dialogue",
          "characterId": null,
          "text": "Vance's eyes move sharply to me."
        },
        {
          "id": "item-0110af5b-d388-4cdd-a919-db3ac518015f",
          "type": "dialogue",
          "characterId": null,
          "text": "There is calculation there. Fear too."
        },
        {
          "id": "item-2c8ab51c-dd85-41a2-9cb7-657913938284",
          "type": "dialogue",
          "characterId": null,
          "text": "For once, she and I understand the same danger from different sides of the carpet."
        },
        {
          "id": "item-c7e7ee37-ae5b-45b1-ac5e-18b1aba373b0",
          "type": "show",
          "characterId": "cora_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "cora_sprite base"
        },
        {
          "id": "item-7e2b9ed9-a1b9-4df8-9ac6-8c04dc21aaba",
          "type": "show",
          "characterId": "vance_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "None",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "vance_sprite confused"
        },
        {
          "id": "item-1e2d222a-341c-401c-9a02-9bf43ecf8c28",
          "type": "show",
          "characterId": "gideon_sprite",
          "isFlipped": false,
          "xpos": 0.5,
          "ypos": 1,
          "zoom": 1,
          "alpha": 1,
          "transition": "move",
          "layer": null,
          "atlBlocks": [],
          "spriteId": "gideon_sprite dominant"
        },
        {
          "id": "item-b5c76e0c-5140-448f-9d3e-5a426249a4d2",
          "type": "dialogue",
          "characterId": "char-46d27e95-f9db-4406-aabf-f20f0316869c",
          "text": "Sir."
        },
        {
          "id": "item-3008e28d-83d4-4697-ae46-73f0b350ba44",
          "type": "dialogue",
          "characterId": "char-db095816-da0e-4dbd-81f1-96fa08045728",
          "text": "Do not become dull."
        },
        {
          "id": "item-4ff50887-caff-44d1-a57e-53d83ef15e81",
          "type": "dialogue",
          "characterId": null,
          "text": "That is all."
        },
        {
          "id": "item-fc667cd7-1932-4d08-b066-fce6e4d54e3b",
          "type": "dialogue",
          "characterId": null,
          "text": "No threat. No promise."
        },
        {
          "id": "item-27a6e904-4709-4f23-a049-37b1ef74ff44",
          "type": "dialogue",
          "characterId": null,
          "text": "Only a man with every exit open marking a servant as a future amusement, problem, instrument, or wound."
        },
        {
          "type": "hide",
          "layer": null,
          "id": "item-db4df19a-dcee-43e8-a558-dd16eabe5266",
          "characterId": "gideon_sprite"
        },
        {
          "type": "hide",
          "layer": null,
          "id": "item-ebeb2f01-4ef6-4d01-a35f-4c07beb6eb3d",
          "characterId": "vance_sprite"
        },
        {
          "id": "item-58c7be94-e136-412d-89cc-6c8e6716c451",
          "type": "dialogue",
          "characterId": null,
          "text": "He leaves."
        },
        {
          "type": "scene",
          "layer": null,
          "transition": "dissolve",
          "id": "item-07afbcf8-a885-4565-8d13-c7dbc9c8787b",
          "backgroundId": "bg_servants_quarters_dusk"
        },
        {
          "id": "item-50da2aef-9e3d-421a-9b8e-df557be06705",
          "type": "dialogue",
          "characterId": null,
          "text": "By evening, the Savoy has already made space for new guests."
        },
        {
          "id": "item-461d58ab-ed82-412c-b416-75e20ed05d92",
          "type": "dialogue",
          "characterId": null,
          "text": "Fresh trunks. Fresh flowers. Fresh lies."
        },
        {
          "id": "item-059e4369-4bae-4632-99a3-d1b33fe2fd35",
          "type": "dialogue",
          "characterId": null,
          "text": "The room resets."
        },
        {
          "id": "item-5100b996-04c6-4e73-b546-e2d599179303",
          "type": "dialogue",
          "characterId": null,
          "text": "The machine continues."
        },
        {
          "id": "item-ae27b694-49db-4af6-a8d2-6e9e5ecaf91b",
          "type": "dialogue",
          "characterId": null,
          "text": "My manuscript lies beneath my folded apron."
        },
        {
          "id": "item-5cc17710-a6b1-429a-9c41-61329493e703",
          "type": "dialogue",
          "characterId": null,
          "text": "It is not a victory."
        },
        {
          "id": "item-314a433b-81a0-421f-92d0-9ba138e73ffb",
          "type": "dialogue",
          "characterId": null,
          "text": "It is a beginning with teeth."
        },
        {
          "type": "python_script",
          "code": "story.set_gideon_recurring_pressure(True)",
          "id": "item-7a5f02d3-b93e-4089-b1ec-3a5d3e9093b0"
        },
        {
          "type": "python_script",
          "code": "story.set_release2_gideon_status(\"marked_cora\")",
