        },
        {
          "type": "python_script",
          "code": "line = get_suspicion_monologue(character, tier, anxiety, reason, scene_context)",
          "id": "item-6b70e793-8808-4bfe-af36-6bf403041a8b"
        },
        {
          "type": "python_script",
          "code": "suspicion_focus = character",
          "id": "item-6d3ffc2f-c6dd-4d0f-b7f3-6891a8acd052"
        },
        {
          "type": "python_script",
          "code": "suspicion_focus_intensity = 2",
          "id": "item-8ee92aff-3bdc-4a36-a74e-4a26fdbd7fbb"
        },
        {
          "id": "item-a592e353-801c-42ac-a604-077c7f6f24e2",
          "type": "dialogue",
          "characterId": null,
          "text": "[line]"
        },
        {
          "type": "python_script",
          "code": "suspicion_focus_intensity = 0",
          "id": "item-2fcbcd58-7059-488b-94c7-8cf3b7e47e11"
