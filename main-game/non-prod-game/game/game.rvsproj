        },
        {
          "type": "scene",
          "layer": null,
          "transition": "fade",
          "id": "item-a232b901-e937-407d-9971-16ddcf668867",
          "backgroundId": "black"
        },
        {
          "id": "item-1396ca34-8338-4e8d-bbac-f7bbc57201d7",
          "type": "dialogue",
          "characterId": null,
          "text": "END OF RELEASE 1."
        },
        {
          "id": "item-3e90a76e-1052-4677-8e03-1e710981b522",
          "type": "dialogue",
          "characterId": null,
          "text": "THE BOOK IS WRITTEN."
        },
        {
          "id": "item-43614d25-01f9-43d6-9089-e1d4df3cd005",
          "type": "dialogue",
          "characterId": null,
          "text": "THE HOUSE REMAINS."
        }
      ]
    },
