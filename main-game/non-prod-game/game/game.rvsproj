                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "chapter_key == \"day1_chapter\" or chapter_key == \"day1_slop_chapter\""
            },
            {
              "id": "cd7d018c-b2a0-47ff-b2d3-fae04c71f190",
              "type": "elif",
              "conditionRaw": "chapter_key == \"day2_chapter\"",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "_theme = story.day2_tea_choice",
                  "id": "item-cd5de613-2c26-438b-bece-eb476767f031"
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "chapter_key == \"day2_chapter\""
            },
            {
              "id": "60f8b5b1-875e-4ff8-9a33-ecbe214c6cbf",
              "type": "elif",
              "conditionRaw": "chapter_key == \"day3_chapter\"",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "_theme = story.day3_brush_choice",
                  "id": "item-b7fa7011-8382-41f5-a79a-c8f79d441c1d"
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "chapter_key == \"day3_chapter\""
            },
            {
              "id": "d0667838-a7da-4a0c-8cd6-bebf159780df",
              "type": "elif",
              "conditionRaw": "chapter_key == \"day4_triumphant_chapter\"",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "_theme = story.day2_tea_choice",
                  "id": "item-f40ff858-7ddd-47a5-9af8-6b1a63269db6"
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "chapter_key == \"day4_triumphant_chapter\""
            },
            {
              "id": "73cc16ea-7a68-4312-9140-f0be3207b434",
              "type": "elif",
              "conditionRaw": "chapter_key == \"day5_reckoning_chapter\"",
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "_theme = story.day5_dynamic",
                  "id": "item-c6b40dac-561a-48f7-bcda-6dbdd7b9c3ab"
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              },
              "rawCondition": "chapter_key == \"day5_reckoning_chapter\""
            },
            {
              "id": "0f0ba1e2-e0e7-44ac-ab6f-01010196822c",
              "type": "else",
              "conditionRaw": null,
              "dialogue": [
                {
                  "type": "python_script",
                  "code": "_theme = \"default\"",
                  "id": "item-78443c63-7cc5-4775-a888-5a10f301bdec"
                }
              ],
              "condition": {
                "operator": "and",
                "clauses": []
              }
            }
          ],
          "id": "item-e5c0e9a8-a73c-4ac4-84ce-b5c6be20acda"
        },
        {
          "type": "python_script",
          "code": "_chapter_map = book1.CHAPTER_BLOCKS.get(chapter_key, {})",
          "id": "item-b556edf6-14d2-4477-a1b5-b8ef1c72b63d"
        },
        {
          "type": "python_script",
          "code": "_label       = _chapter_map.get(_theme, _chapter_map.get(\"default\", \"NO_ROUTE\"))",
          "id": "item-578b5b3d-f9de-422c-b9ad-66b2b377a73a"
        },
        {
          "id": "item-55874bef-1514-402b-a091-783fbe87ab0a",
