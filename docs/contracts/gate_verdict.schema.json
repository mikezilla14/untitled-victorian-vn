{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/untitled-victorian-vn/contracts/gate_verdict.schema.json",
  "title": "GateVerdict",
  "type": "object",
  "required": [
    "contract_version",
    "day_id",
    "release",
    "gate",
    "verdict",
    "blocking",
    "reviewed_files"
  ],
  "additionalProperties": false,
  "properties": {
    "contract_version": { "type": "string", "const": "1" },
    "day_id": {
      "type": "string",
      "pattern": "^day[0-9]{3}$",
      "description": "e.g. day105"
    },
    "release": { "type": "string", "minLength": 1 },
    "gate": {
      "type": "string",
      "enum": ["lead_narrative", "forensic_psychology", "victorian"]
    },
    "verdict": { "type": "string", "minLength": 1 },
    "blocking": { "type": "boolean" },
    "reviewed_at": { "type": "string", "format": "date" },
    "reviewed_files": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "markdown_verdict_path": { "type": "string" },
    "follow_up": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "writers_room": { "type": "boolean" },
        "lead_narrative_editor": { "type": "boolean" },
        "forensic_psychology_consultant": { "type": "boolean" },
        "victorian_consultant": { "type": "boolean" },
        "profile_update": { "type": "boolean" }
      }
    },
    "notes": { "type": "string" }
  }
}
